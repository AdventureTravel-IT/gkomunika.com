{% style %}
  #iccid {
    padding: 15px;
    border-radius: 15px;
    outline: none;
    width: 100%;
    border: 1px solid var(--color-primary);
    background-color: var(--color-neutral);
    color: var(--color-primary);
    font-size: var(--font-large);
  }
  #check-iccid {
    padding: 15px;
    border-radius: 15px;
    outline: none;
    width: 100%;
    border: 1px solid var(--color-primary);
    background-color: var(--color-primary);
    color: var(--color-neutral);
    font-size: var(--font-large);
    font-weight: bold;
    margin-top: 20px;
  }
  .check-data-usage__container {
    margin: 0 auto;
    max-width: 1920px;
  }
  .check-data-usage__wrapper {
    padding: 20px 20%;
  }
  .check-data-usage__esim-information {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-primary);
    background-color: var(--color-neutral);
    border-radius: 15px;
    padding: 15px;
    margin-top: 20px;
    font-size: var(--font-large);
  }
  .check-data-usage__esim-information h3 {
    color: var(--color-primary);
    font-size: var(--font-supper-large);
    margin: 10px;
  }
{% endstyle %}

<div class="check-data-usage__container">
  <div class="check-data-usage__wrapper">
    <div class="check-data-usage__header">
      <p>TOP UP</p>
      <span>Enter your iccid</span>
    </div>
    <div class="check-data-usage__input">
      <input
        type="number"
        id="iccid"
        placeholder="Input ICCID Number"
        required
      >
      <button id="check-iccid" onclick="checkICCID()">Next</button>
    </div>

    <div class="check-data-usage__result">
      <div id="result"></div>
    </div>
  </div>
</div>

<script>
  let lastSubmit = 0;

  const prefixVendorMap = [
    { prefix: '89859', vendor: 'fmf' },
    { prefix: '89862', vendor: 'fmf' },
    { prefix: '89810', vendor: 'atgt' },
    { prefix: '2210', vendor: 'abc' },
    { prefix: '8981200', vendor: 'abc' },
  ];

  function detectVendor(iccid) {
    for (const item of prefixVendorMap) {
      if (iccid.startsWith(item.prefix)) {
        return item.vendor;
      }
    }
    return null;
  }

  function formatBytes(usageBytes) {
    if (usageBytes >= 1024 * 1024 * 1024) {
      return (usageBytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
    } else if (usageBytes >= 1024 * 1024) {
      return (usageBytes / (1024 * 1024)).toFixed(2) + ' MB';
    } else if (usageBytes >= 1024) {
      return (usageBytes / 1024).toFixed(2) + ' KB';
    } else {
      return usageBytes + ' Byte';
    }
  }

  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return; // minimal 3 detik antar klik
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value.trim();
    const resultEl = document.getElementById('result');

    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid (minimal 10 digit)</p>`;
      return;
    }

    const vendor = detectVendor(iccid);
    if (!vendor) {
      resultEl.innerHTML = `<p style="color: red">ICCID invalid atau tidak dikenali vendor.</p>`;
      return;
    }

    button.disabled = true;
    button.innerText = 'Memproses...';
    resultEl.innerHTML = `<p>On Progress</p>`;

    fetch('https://gkomunika.id/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: new URLSearchParams({ iccid: iccid }),
    })
      .then(async (response) => {
        const contentType = response.headers.get('Content-Type') || '';
        const isJson = contentType.includes('application/json');

        let data = {};
        if (isJson) {
          try {
            data = await response.json();
          } catch (e) {
            data = { message: 'Response tidak valid' };
          }
        }

        if (data.status === 'rate_limited' || data.customCode === 429) {
          resultEl.innerHTML = `
            <p style="color: red">${data.message}</p>
          `;
          return;
        }

        if (
          data.tradeCode === '1000' &&
          data.tradeData &&
          data.tradeData.subOrderList &&
          data.tradeData.subOrderList.length > 0
        ) {
          const itemData = data.tradeData.subOrderList[0];
          const dataUsage = itemData.usageInfoList;

          let uniqueCountries = [];
          if (dataUsage && dataUsage.length > 0) {
            uniqueCountries = [
              ...new Set(
                dataUsage.map((item) => item.country).filter(Boolean)
              ),
            ];
          }

          let html = `
            <div class="check-data-usage__esim-information">
              <h3>Informasi Kartu SIM</h3>
              <div class="esim-information__wrapper">
                <p>Your eSIM Bundle</p>
                <p>${itemData.skuName || '-'}</p>
              </div>
              <div class="esim-information__wrapper">
                <p>Active Period</p>
                <p>${itemData.planStartTime || '-'}</p>
              </div>
              <div class="esim-information__wrapper">
                <p>End Date</p>
                <p>${itemData.planEndTime || '-'}</p>
              </div>
            </div>

            <div>
              <h3>Total Usage:</h3>
              ${
                uniqueCountries.length > 0
                  ? `<div>${uniqueCountries.map((c) => `<span>${c}</span>`).join('')}</div>`
                  : '<div>no data usage yet.</div>'
              }
            </div>

            <div>
              <h3>Data Usage</h3>
              <div>
                ${
                  dataUsage && dataUsage.length > 0
                    ? dataUsage
                        .map((item) => {
                          let formattedUsage = '-';
                          if (item.usedAmount) {
                            formattedUsage = formatBytes(Number(item.usedAmount));
                          }
                          return `
                            <div class="data-usage__wrapper">
                              <p>${item.country || '-'}</p>
                              <p>${formattedUsage}</p>
                              <p>${item.usedDate || '-'}</p>
                            </div>
                          `;
                        })
                        .join('')
                    : '<p>no data usage yet.</p>'
                }
              </div>
            </div>

            <pre>${JSON.stringify(data, null, 2)}</pre>
          `;

          resultEl.innerHTML = html;
        } else {
          resultEl.innerHTML = `<p style="color: red">ICCID invalid atau tidak dikenali di server.</p>
          <pre>${JSON.stringify(data, null, 2)}</pre>`;
        }
      })
      .catch((error) => {
        resultEl.innerHTML = `
          <p style="color: red">Connection Error</p>
        `;
      })
      .finally(() => {
        button.disabled = false;
        button.innerText = 'Next';
      });
  }
</script>

{% schema %}
{
  "name": "Check Data Usage",
  "settings": [],
  "presets": [
    {
      "name": "Check Data Usage",
      "category": "Custom"
    }
  ]
}
{% endschema %}
