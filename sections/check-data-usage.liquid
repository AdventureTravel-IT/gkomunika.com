{% style %}
      .invalid-popup {
      display: none;
      position: fixed;
      z-index: 9999;
      top: 0;
      right: 0;
      width: 100%;
      height: 100dvh;
      overflow: auto;
      background-color: rgba(0, 0, 0, 0.5);
    }

    .invalid-popup__content {
      background-color: var(--color-neutral);
      padding: 30px;
      width: 100%;
      max-width: 450px;
      border-radius: 10px;
      text-align: center;
      color: var(--color-primary);
      font-size: var(--font-extra-large);
    }

    .invalid-popup__content h2 {
      color: var(--color-primary);
      font-size: 34px;
      font-weight: bold;
      line-height: 1.5;
      margin: 10px 0;
    }

    .invalid-popup__button {
      display: flex;
      gap: 15px;
    }

    .invalid-popup__button button {
      width: 100%;
      padding: 15px;
      border-radius: 10px;
      border: none;
      outline: none;
      cursor: pointer;
      font-size: var(--font-large);
    }

    #invalid-popup__buy-button {
      background-color: var(--color-secondary);
      color: var(--color-neutral);
    }

    #invalid-popup__contact-button {
      background-color: #25D366;
      color: var(--color-neutral);
    }

    #invalid-popup__button-hide {
      margin-top: 15px;
      width: 100%;
      padding: 15px;
      border-radius: 10px;
      border: none;
      outline: none;
      cursor: pointer;
      background-color: var(--color-primary);
      color: var(--color-neutral);
      font-size: var(--font-large);
    }
    #iccid {
      padding: 15px;
      border-radius: 15px;
      outline: none;
      width: 100%;
      border: 1px solid var(--color-primary);
      background-color: var(--color-neutral);
      color: var(--color-primary);
      font-size: var(--font-large);
    }
    #check-iccid {
      padding: 15px;
      border-radius: 15px;
      outline: none;
      width: 100%;
      border: 1px solid var(--color-primary);
      background-color: var(--color-primary);
      color: var(--color-neutral);
      font-size: var(--font-large);
      font-weight: bold;
      margin-top: 20px;
    }
    .check-data-usage__container {
      margin: 0 auto;
      max-width: 1920px;
    }
    .check-data-usage__wrapper {
      padding: 20px 20%;
    }
    .check-data-usage__esim-information {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
      color: var(--color-primary);
      background-color: var(--color-neutral);
      border-radius: 15px;
      padding: 15px;
      margin-top: 20px;
      font-size: var(--font-large);
    }
    .check-data-usage__esim-information h3 {
      color: var(--color-primary);
      font-size: var(--font-supper-large);
      margin: 10px;
      font-weight: bold;
    }
    .esim-information__wrapper p {
      margin: 0;
      line-height: 1.3;
    }
    .esim-information__wrapper span {
      font-weight: bold;
    }
    .check-data-usage__usage-content {
      background-color: var(--color-neutral);
      border-radius: 15px;
      padding: 15px;
      color: var(--color-primary);
      font-size: var(--font-large);
      margin-top: 20px;
    }
  .check-data-usage__usage-content h2, h3 {
    color: var(--color-primary);
    font-weight: bold;
  }
    .data-usage__wrapper {
      display: flex;
      justify-content: space-between;
    }
    .data-usage__wrapper p {
      width: 150px;
      margin: 0;
    }
    .data-usage__wrapper p:nth-child(3) {
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    width: 150px;
  }
    .data-usage__wrapper p:nth-child(2) {
    display: flex;
      justify-content: center;
  }
  .check-data-usage__usage-content h2 {
    text-align: center
  }
  .check-data-usage__total-usage {
    border-bottom: 3px solid var(--color-border);
    margin-bottom: 20px;
    padding-bottom: 20px;
  }
  .check-data-usage__total-usage span {
    padding: 10px 300px 10px 10px;
    border-radius: 15px;
    border: 1px solid var(--color-border);
  }
  .total-data-usage__wrapper {
    display: flex;
  }
{% endstyle %}

<div class="check-data-usage__container">
  <div class="check-data-usage__wrapper">
    <div class="check-data-usage__header">
      <p>TOP UP</p>
      <span>Enter your iccid</span>
    </div>
    <div class="check-data-usage__input">
      <input
        type="number"
        id="iccid"
        placeholder="Input ICCID Number"
        value="22104483970"
        required
      >
      <button id="check-iccid" onclick="checkICCID()">Next</button>
    </div>

    <div class="check-data-usage__result">
      <div id="result"></div>
    </div>
  </div>
</div>

<div class="invalid-popup" id="invalid-popup">
  <div class="invalid-popup__content">
    <h2>ICCID Invalid</h2>
    <p>
      Sorry, currently your sim card does not support top up via the website. You can top up by contacting our CS via
      Whatsapp.
    </p>
    <p>If your device supports eSIM. You can buy an eSIM for your travel connectivity.</p>
    <div class="invalid-popup__button">
      <button id="invalid-popup__buy-button"><span>Buy eSIM</span></button>
      <button id="invalid-popup__contact-button"><span>Contact CS</span></button>
    </div>
    <button id="invalid-popup__button-hide"><span>OK</span></button>
  </div>
</div>

<script>
  let lastSubmit = 0;

  const prefixVendorMap = [
    { prefix: '89859', vendor: 'F' },
    { prefix: '89862', vendor: 'F' },
    { prefix: '89810', vendor: 'T' },
    { prefix: '2210', vendor: 'B' },
    { prefix: '8981200', vendor: 'B' },
  ];

  function detectVendor(iccid) {
    for (const item of prefixVendorMap) {
      if (iccid.startsWith(item.prefix)) {
        return item.vendor;
      }
    }
    return null;
  }

  function showInvalidPopup() {
    document.getElementById('invalid-popup').style.display = 'block';
  }

  function formatBytes(bytes) {
    console.log("Raw bytes:", bytes);

    const formatter = new Intl.NumberFormat('en-US', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });

    if (bytes >= 1024 * 1024 * 1024) {
      console.log("Converted to GB:", bytes / (1024 * 1024 * 1024));
      return formatter.format(bytes / (1024 * 1024 * 1024)) + ' GB';
    } else if (bytes >= 1024 * 1024) {
      console.log("Converted to MB:", bytes / (1024 * 1024));
      return formatter.format(bytes / (1024 * 1024)) + ' MB';
    } else if (bytes >= 1024) {
      console.log("Converted to KB:", bytes / 1024);
      return formatter.format(bytes / 1024) + ' KB';
    } else {
      console.log("Less than 1 KB, stay in Bytes");
      return formatter.format(bytes) + ' Byte';
    }
  }

  function formatDate(dateStr) {
    if (!dateStr || dateStr.length !== 8) return dateStr || '-';
    const year = dateStr.substring(0, 4);
    const month = dateStr.substring(4, 6);
    const day = dateStr.substring(6, 8);
    return `${day}/${month}/${year}`;
  }

  function formatDateTime(dateTimeStr) {
    if (!dateTimeStr) return '-';
    const parts = dateTimeStr.split(' ')[0];
    if (!parts) return '-';
    const [year, month, day] = parts.split('-');
    if (!year || !month || !day) return dateTimeStr;
    return `${day}/${month}/${year}`;
  }

  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return;
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value.trim();
    const resultEl = document.getElementById('result');

    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid (minimal 10 digit)</p>`;
      return;
    }

    const vendor = detectVendor(iccid);
    if (!vendor) {
      showInvalidPopup();
      return;
    }

    button.disabled = true;
    button.innerText = 'Loading..';

    fetch('https://gkomunika.id/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: new URLSearchParams({ iccid: iccid }),
    })
      .then(async (response) => {
        const contentType = response.headers.get('Content-Type') || '';
        const isJson = contentType.includes('application/json');

        let data = {};
        if (isJson) {
          try {
            data = await response.json();
          } catch (e) {
            data = { message: 'Response tidak valid' };
          }
        }

        if (data.status === 'rate_limited' || data.customCode === 429) {
          resultEl.innerHTML = `
          <p style="color: red">${data.message}</p>
        `;
          return;
        }

        if (
          data.tradeCode === '1000' &&
          data.tradeData &&
          data.tradeData.subOrderList &&
          data.tradeData.subOrderList.length > 0
        ) {
          const itemData = data.tradeData.subOrderList[0];
          const dataUsage = itemData.usageInfoList;

          // --- BUAT TOTAL USAGE PER NEGARA ---
          const countryUsageMap = {};

          if (dataUsage && dataUsage.length > 0) {
            dataUsage.forEach((item) => {
              const country = item.country || '-';
              const usedAmount = Number(item.usedAmount) || 0;

              if (!countryUsageMap[country]) {
                countryUsageMap[country] = 0;
              }
              countryUsageMap[country] += usedAmount;
            });
          }

          let totalUsageHtml = '';

          for (const country in countryUsageMap) {
            const totalBytes = countryUsageMap[country];
            const formattedTotal = formatBytes(totalBytes);
            totalUsageHtml += `
              <div class="total-data-usage__wrapper">
                <p>${country}</p>
                <p>${formattedTotal}</p>
              </div>
            `;
          }

          // --- TAMPILKAN HTML ---
          let html = `
          <div class="check-data-usage__esim-information">
            <h3>Informasi Kartu SIM</h3>
            <div class="esim-information__wrapper">
              <p>Your eSIM Bundle</p>
              <span>${itemData.skuName || '-'}</span>
            </div>
            <div class="esim-information__wrapper">
              <p>Active Period</p>
              <span>${formatDateTime(itemData.planStartTime) || '-'} ${itemData.timeZone || '-'}</span>
            </div>
            <div class="esim-information__wrapper">
              <p>End Date</p>
              <span>${formatDateTime(itemData.planEndTime) || '-'} ${itemData.timeZone || '-'}</span>
            </div>
          </div>

          <div class="check-data-usage__usage-content">
            <h2>Data Usage</h2>
            <div class="check-data-usage__total-usage">
              <h3>Total Usage:</h3>
              ${
                Object.keys(countryUsageMap).length > 0
                  ? totalUsageHtml
                  : '<div>no data usage yet.</div>'
              }
            </div>

            <div class="check-data-usage__data-usage">
              <div>
                ${
                  dataUsage && dataUsage.length > 0
                    ? dataUsage
                        .map((item) => {
                          let formattedUsage = '-';
                          if (item.usedAmount) {
                            formattedUsage = formatBytes(Number(item.usedAmount));
                          }
                          return `
                          <div class="data-usage__wrapper">
                            <p>${item.country || '-'}</p>
                            <p>${formatDate(item.usedDate) || '-'}</p>
                            <p>${formattedUsage}</p>
                          </div>
                        `;
                        })
                        .join('')
                    : '<p>no data usage yet.</p>'
                }
              </div>
            </div>
          </div>

          <pre>${JSON.stringify(data, null, 2)}</pre>
        `;

          resultEl.innerHTML = html;
        } else {
          resultEl.innerHTML = '';
          showInvalidPopup();
        }
      })
      .catch((error) => {
        resultEl.innerHTML = `
        <p style="color: red">Connection Error</p>
      `;
      })
      .finally(() => {
        button.disabled = false;
        button.innerText = 'Next';
      });
  }

  document.getElementById('invalid-popup__button-hide').addEventListener('click', () => {
    document.getElementById('invalid-popup').style.display = 'none';
  });

  document.getElementById('invalid-popup__buy-button').addEventListener('click', () => {
    window.location.href = 'https://gkomunika.com/pages/all-destination';
  });

  document.getElementById('invalid-popup__contact-button').addEventListener('click', () => {
    window.location.href = 'https://wa.me/628986454071';
  });
</script>


