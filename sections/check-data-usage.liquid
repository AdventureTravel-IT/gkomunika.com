<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID" required>
<button id="check-iccid" onclick="checkICCID()">Cek</button>

<div id="result"></div>

<script>
  let lastSubmit = 0;
  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return; // minimum 3 detik antar klik
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value;
    const resultEl = document.getElementById('result');

    // Validasi awal input
    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid</p>`;
      return;
    }

    // Disable button & tampilkan loading
    button.disabled = true;
    button.innerText = 'Memproses...';
    resultEl.innerHTML = `<p>Sedang memproses...</p>`;

    fetch('https://80e4-202-138-242-49.ngrok-free.app/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-API-KEY': 'x2341323'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      const contentType = response.headers.get("Content-Type") || "";
      const isJson = contentType.includes("application/json");
    
      let data = {};
      if (isJson) {
        try {
          data = await response.json();
        } catch (e) {
          data = { message: 'Response tidak valid' };
        }
      }

      if (!response.ok) {
        resultEl.innerHTML = `
          <p style="color: red">${data.message || 'Terjadi kesalahan'}</p>
        `;
        return;
      }

      if (data.tradeCode === "1000" &&
          data.tradeData &&
          (Array.isArray(data.tradeData)
            ? data.tradeData.length > 0
            : Object.keys(data.tradeData).length > 0)) {
        resultEl.innerHTML = `
          <pre>${JSON.stringify(data, null, 2)}</pre>
        `;
      } else {
        resultEl.innerHTML = `
          <p style="color: red">Data tidak ditemukan</p>
        `;
      }
    })
    .catch(error => {
      resultEl.innerHTML = `
        <p style="color: red">Terjadi kesalahan koneksi</p>
      `;
    })
    .finally(() => {
      // Kembalikan state tombol
      button.disabled = false;
      button.innerText = 'Cek';
    });
  }
</script>

{% schema %}
  {
    "name": "Check Data Usage",
    "settings": [],
    "presets": [
      {
        "name": "Check Data Usage",
        "category": "Custom"
      }
    ]
  }
{% endschema %}