<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID" required>
<button onclick="checkICCID()">Cek</button>

<div id="result"></div>

<script>
  function checkICCID() {
    const iccid = document.getElementById('iccid').value;
  
    fetch('https://80e4-202-138-242-49.ngrok-free.app/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      const data = await response.json();

      if (!response.ok) {
        document.getElementById('result').innerHTML = `
          <p style="color: red">${data.message || 'Terjadi kesalahan'}</p>
        `;
        return;
      }

      if (data.tradeCode === "1000" && data.tradeData &&
           (Array.isArray(data.tradeData) ? data.tradeData.length > 0 : Object.keys(data.tradeData).length > 0)
         ) {
        document.getElementById('result').innerHTML = `
          <pre></pre>
        `
      }
    })
    .catch(error => {
      error.text().then(msg => {
        document.getElementById('result').innerHTML = `<p style="color:red">Terjadi kesalahan</p>`;
      });
    });
    }
</script>

