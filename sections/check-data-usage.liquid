<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID">
<button onclick="checkICCID()">Cek</button>

<div id="result"></div>

<script>
  function checkICCID() {
    const iccid = document.getElementById('iccid').value;
  
    fetch('https://baa2-202-138-242-49.ngrok-free.app/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(response => response.json())
    .then(data => {
      if (data.tradeCode === "1000") {
        // Sukses
        document.getElementById('result').innerHTML = `
          <pre>${JSON.stringify(data.tradeData, null, 2)}</pre>
        `;
      } else {
        // Gagal
        const message = data.tradeMsg || "Terjadi kesalahan.";
        document.getElementById('result').innerHTML = `
          <p style="color: red;">Gagal mengambil data: ${message}</p>
        `;
      }
    })
    .catch(error => {
      error.text().then(msg => {
        document.getElementById('result').innerHTML = `<p style="color:red">Terjadi kesalahan</p>`;
      });
    });
    }
</script>

