<script>
  document.addEventListener('DOMContentLoaded', () => {
    const API_URL = 'https://v2.gkomunika.id/api/v1/check-usage';

    const iccidInput = document.getElementById('iccid');
    const checkBtn = document.getElementById('check-iccid');
    const resultEl = document.getElementById('result');
    const invalidPopup = document.getElementById('invalid-popup');
    const btnHidePopup = document.getElementById('invalid-popup__button-hide');
    const btnBuyEsim = document.getElementById('invalid-popup__buy-button');
    const btnContactCs = document.getElementById('invalid-popup__contact-button');
    let lastSubmit = 0;

    /* ==============================
       HELPER: Format KB ke unit yang readable
       Base selalu KB dari backend
    ============================== */
    function formatKB(kb) {
      if (kb == null) return '-';
      kb = Number(kb) || 0;
      if (kb >= 1048576) return (kb / 1048576).toFixed(2) + ' GB';
      if (kb >= 1024) return (kb / 1024).toFixed(2) + ' MB';
      return kb.toFixed(2) + ' KB';
    }

    /* ==============================
       HELPER: Format tanggal dari "YYYY-MM-DD HH:mm:ss" ke "DD Month YYYY HH:mm"
       Backend sudah kirim format readable, tapi kita rapikan tampilan
    ============================== */
    function formatDateTime(str) {
      if (!str || str === '-') return '-';
      try {
        const d = new Date(str.replace(' ', 'T'));
        if (isNaN(d.getTime())) return str;
        return d
          .toLocaleString('en-GB', {
            day: '2-digit',
            month: 'long',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
          })
          .replace(',', '');
      } catch {
        return str;
      }
    }

    /* ==============================
       HELPER: Map plan_status ke teks yang user-friendly
    ============================== */
    function formatStatus(planStatus, vendor) {
      // Support format baru: { status_code, status } maupun string lama
      const code = typeof planStatus === 'object' && planStatus !== null ? planStatus.status_code : planStatus;

      const maps = {
        D: {
          0: 'Subscription In Progress',
          1: 'Not Activated Yet',
          2: 'Active',
          3: 'Expired',
          4: 'Being Unsubscribed',
        }, // MM
        A: { 0: 'Not Activated Yet', 1: 'Active', 2: 'Data Depleted', 3: 'Terminated' }, // BC
        B: { 0: 'Not Activated Yet', 1: 'Active', 2: 'Data Depleted', 5: 'Terminated', 6: 'Expired' }, // FM
        C: { 0: 'Not Activated Yet', 1: 'Active', 2: 'Data Depleted', 5: 'Terminated', 6: 'Expired' }, // TGT (samakan FM dulu, sesuaikan kalau ada status berbeda)
      };

      const vendorMap = maps[vendor] || {};
      return vendorMap[code] ?? (typeof planStatus === 'object' ? planStatus.status : planStatus) ?? '-';
    }

    /* ==============================
       POPUP helpers
    ============================== */
    function showInvalidPopup() {
      invalidPopup.style.display = 'block';
    }
    function hideInvalidPopup() {
      invalidPopup.style.display = 'none';
    }

    /* ==============================
       RENDER: SIM Card Information
    ============================== */
    function renderEsimInfo(plan, vendor) {
      return `
      <div class="check-data-usage__esim-information">
        <h3>SIM Card Information</h3>
        <div class="esim-information__wrapper"><p>Status</p><span>${formatStatus(plan.plan_status, vendor)}</span></div>
        <div class="esim-information__wrapper"><p>Your Bundle</p><span>${plan.product_name || '-'}</span></div>
        <div class="esim-information__wrapper"><p>Active Date</p><span>${formatDateTime(
          plan.plan_start_time
        )}</span></div>
        <div class="esim-information__wrapper"><p>End Date</p><span>${formatDateTime(plan.plan_end_time)}</span></div>
      </div>`;
    }

    /* ==============================
       RENDER: Quota (Total / Used / Remaining)
       Jika total_kb null => tampilkan Used saja
    ============================== */
    function renderQuota(quota, vendor) {
      if (!quota) return '';

      const label = vendor === 'BC' ? 'Total Usage:' : 'Used:';

      return `<div style="display:flex;justify-content:space-between;">
        <h3>${label}</h3>
        <span style="font-weight:bold;">${formatKB(quota.used_kb)}</span>
      </div>`;
    }

    /* ==============================
       RENDER: Per-country aggregated totals (dari daily_usage)
    ============================== */
    function renderCountryTotals(dailyUsage) {
      if (!dailyUsage || dailyUsage.length === 0) return '';

      const perCountry = {};
      dailyUsage.forEach((u) => {
        const name = u.country_name || u.country_code || 'Unknown';
        perCountry[name] = (perCountry[name] || 0) + (Number(u.used_kb) || 0);
      });

      return Object.entries(perCountry)
        .map(
          ([country, kb]) => `
          <div class="total-data-usage__wrapper">
            <p>${country}</p>
            <p>${formatKB(kb)}</p>
          </div>`
        )
        .join('');
    }

    /* ==============================
       RENDER: Daily usage breakdown table
    ============================== */
    function renderDailyUsage(dailyUsage) {
      if (!dailyUsage || dailyUsage.length === 0) return '';

      return dailyUsage
        .map(
          (u) => `
          <div class="data-usage__wrapper">
            <p>${u.country_name || u.country_code || '-'}</p>
            <p>${u.date || '-'}</p>
            <p>${formatKB(u.used_kb)}</p>
          </div>`
        )
        .join('');
    }

    /* ==============================
       RENDER: Top Up button
    ============================== */
    function renderTopUpButton() {
      return `<button id="top-up-plan" class="top-up-plan-btn">Top Up</button>`;
    }

    /* ==============================
       RENDER: Buy eSIM buttons (fallback)
    ============================== */
    function renderBuyEsimButtons() {
      return `<div class="button-topup__usage-wrapper">
        <span>Need more data? Buy eSIM from our website.</span>
        <div class="btn-topup-information">
          <button id="btn-topup__contact-button"><span>Contact CS</span></button>
          <button id="btn-topup__buy-button"><span>Buy eSIM</span></button>
        </div>
      </div>`;
    }

    function renderTopUpUnavailable() {
      return `<div style="
    margin-top: 20px;
    padding: 15px;
    border-radius: 10px;
    background-color: #e0e0e0;
    color: #FFFFFF;
    text-align: center;
    font-size: var(--font-large);
    font-weight: 600;
    cursor: not-allowed;
  ">${topupFallbackText}</div>`;
    }

    function attachTopUpButtonListeners() {
      const btnTopUpBuy = document.getElementById('btn-topup__buy-button');
      const btnTopUpCs = document.getElementById('btn-topup__contact-button');
      if (btnTopUpBuy)
        btnTopUpBuy.onclick = () => (window.location.href = 'https://gkomunika.com/pages/all-destination');
      if (btnTopUpCs) btnTopUpCs.onclick = () => (window.location.href = 'https://wa.me/628986454071');
    }

    /* ==============================
       MAIN: Check ICCID
    ============================== */
    async function checkICCID() {
      const now = Date.now();
      if (now - lastSubmit < 3000) return;
      lastSubmit = now;

      const iccid = iccidInput.value.trim();
      if (!iccid || iccid.length < 10) {
        resultEl.innerHTML = `<p style="color:red;">Invalid ICCID</p>`;
        return;
      }

      checkBtn.disabled = true;
      checkBtn.textContent = 'Loading...';

      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ iccid }),
        });
        const data = await res.json();

        console.log(data);

        // Jika response gagal
        if (!data.success) {
          showInvalidPopup();
          return;
        }

        const plans = data.data?.plans || [];
        if (plans.length === 0) {
          showInvalidPopup();
          return;
        }

        // Simpan vendor untuk keperluan Top Up routing
        const vendor = data.vendor || null;
        window.lastDetectedVendor = vendor;
        const source = data.source || null;

        // Render semua plans
        let html = '';

        // Ambil hanya plan terbaru (index 0)
        const plansToShow = [plans[0]];
        plansToShow.forEach((plan) => {
          // SIM Card Information
          html += renderEsimInfo(plan, vendor);

          // Data Usage section
          const dailyUsage = plan.daily_usage || [];
          let quota = plan.quota || {};

          // Untuk vendor BC, hitung quota dari akumulasi daily_usage
          if (vendor === 'A') {
            const totalUsedKb = dailyUsage.reduce((sum, u) => sum + (Number(u.used_kb) || 0), 0);
            quota = {
              total_kb: null, // tidak ada total, supaya renderQuota hanya tampilkan Used
              used_kb: totalUsedKb,
              remaining_kb: null,
            };
          }

          html += `
          <div class="check-data-usage__usage-content">
            <div style="text-align:center;"><h2>Data Usage</h2></div>
            <div class="check-data-usage__total-usage">
              ${renderQuota(quota, vendor)}
              ${renderCountryTotals(dailyUsage)}
            </div>`;

          // Daily breakdown (jika ada)
          if (dailyUsage.length > 0) {
            html += `<div class="check-data-usage__data-usage">${renderDailyUsage(dailyUsage)}</div>`;
          }

          html += `
            ${source !== 'fallback' ? renderTopUpButton() : renderTopUpUnavailable()}
          </div>`;
        });

        resultEl.innerHTML = html;
        attachTopUpButtonListeners();
      } catch (err) {
        console.error(err);
        showInvalidPopup();
      } finally {
        checkBtn.disabled = false;
        checkBtn.textContent = 'Next';
      }
    }

    /* ==============================
       EVENT LISTENERS
    ============================== */
    checkBtn.addEventListener('click', checkICCID);
    document.getElementById('check-iccid-form').addEventListener('submit', (e) => {
      e.preventDefault();
      checkICCID();
    });
    btnHidePopup.addEventListener('click', hideInvalidPopup);
    btnBuyEsim.addEventListener('click', () => (window.location.href = 'https://gkomunika.com/pages/all-destination'));
    btnContactCs.addEventListener('click', () => (window.location.href = 'https://wa.me/628986454071'));

    /* ==============================
       TOP UP CONFIRM MODAL
    ============================== */
    const topupConfirmPopup = document.getElementById('topup-confirm-popup');
    const topupConfirmCancel = document.getElementById('topup-confirm-cancel');
    const topupConfirmContinue = document.getElementById('topup-confirm-continue');

    function showTopupConfirm() {
      if (topupConfirmPopup) topupConfirmPopup.style.display = 'block';
    }
    function hideTopupConfirm() {
      if (topupConfirmPopup) topupConfirmPopup.style.display = 'none';
    }

    function proceedTopUp() {
      const iccidValue = iccidInput.value.trim();
      if (iccidValue) sessionStorage.setItem('iccid', iccidValue);

      // Mapping vendor ke kategori Top Up
      const vendorCategoryMap = {
        A: 'Top_Up_A',
        B: 'Top_Up_B',
        C: 'Top_Up_C',
        D: 'Top_Up_D',
      };

      const lastVendor = window.lastDetectedVendor;
      if (lastVendor && vendorCategoryMap[lastVendor]) {
        sessionStorage.setItem('category', vendorCategoryMap[lastVendor]);
      }

      window.location.href = '/pages/top-up';
    }

    if (topupConfirmCancel) topupConfirmCancel.addEventListener('click', hideTopupConfirm);
    if (topupConfirmContinue)
      topupConfirmContinue.addEventListener('click', () => {
        hideTopupConfirm();
        proceedTopUp();
      });

    if (topupConfirmPopup) {
      topupConfirmPopup.addEventListener('click', (e) => {
        if (e.target === topupConfirmPopup) hideTopupConfirm();
      });
    }

    // Klik tombol top-up memunculkan modal konfirmasi dulu
    document.addEventListener('click', (e) => {
      const clickedTopUp = e.target?.id === 'top-up-plan' || e.target?.closest?.('#top-up-plan');
      if (clickedTopUp) {
        showTopupConfirm();
      }
    });
  });
</script>

