<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID" required>
<button id="check-iccid" onclick="checkICCID()">Next</button>

<div id="result"></div>

<script>
  let lastSubmit = 0;
  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return; // minimum 3 detik antar klik
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value;
    const resultEl = document.getElementById('result');

    // Validasi awal input
    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid</p>`;
      return;
    }

    // Disable button & tampilkan loading
    button.disabled = true;
    button.innerText = 'Memproses...';
    resultEl.innerHTML = `<p>Sedang memproses...</p>`;

    fetch('https://gkomunika.id/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      const contentType = response.headers.get("Content-Type") || "";
      const isJson = contentType.includes("application/json");
    
      let data = {};
      if (isJson) {
        try {
          data = await response.json();
        } catch (e) {
          data = { message: 'Response tidak valid' };
        }
      }

      if (data.status === 'rate_limited' || data.customCode === 429) {
        document.getElementById('result').innerHTML = `
          <p style="color: red">${data.message}</p>
        `;
        return;
      }

      if (
  data.tradeCode === "1000" &&
  data.tradeData &&
  data.tradeData.subOrderList &&
  data.tradeData.subOrderList.length > 0
) {
  let html = "";

  data.tradeData.subOrderList.forEach((order, index) => {
    html += `
      <div style="border:1px solid #ccc; margin-bottom:10px; padding:10px;">
        <h4>Order #${index + 1}</h4>
        <p><strong>Sub Order ID:</strong> ${order.subOrderId}</p>
        <p><strong>SKU Name:</strong> ${order.skuName}</p>
        <p><strong>Copies:</strong> ${order.copies}</p>
        <p><strong>Plan Status:</strong> ${order.planStatus}</p>
        <p><strong>Plan Start Time:</strong> ${order.planStartTime}</p>
        <p><strong>Plan End Time:</strong> ${order.planEndTime}</p>
        <p><strong>Total Days:</strong> ${order.totalDays}</p>
        <p><strong>Remaining Days:</strong> ${order.remainingDays}</p>
        <p><strong>Total Traffic (MB):</strong> ${Math.round(parseInt(order.totalTraffic)/1024/1024)}</p>
        <p><strong>Remaining Traffic (MB):</strong> ${Math.round(parseInt(order.remainingTraffic)/1024/1024)}</p>
        <h5>Countries:</h5>
        <ul>
          ${
            order.country.map(c => 
              `<li>${c.name} (${c.operator}) - APN: ${c.apn}</li>`
            ).join("")
          }
        </ul>
        <h5>Usage Info:</h5>
        <ul>
          ${
            order.usageInfoList && order.usageInfoList.length > 0
              ? order.usageInfoList.map(u =>
                  `<li>${u.country} - Used: ${Math.round(parseInt(u.usedAmount)/1024/1024)} MB on ${u.usedDate}</li>`
                ).join("")
              : "<li>No usage data</li>"
          }
        </ul>
      </div>
    `;
  });

  resultEl.innerHTML = html;
} else {
  resultEl.innerHTML = `
    <p style="color: red">Data tidak ditemukan.</p>
  `;
}

    })
    .catch(error => {
      resultEl.innerHTML = `
        <p style="color: red">Connection Error</p>
      `;
    })
    .finally(() => {
      // Kembalikan state tombol
      button.disabled = false;
      button.innerText = 'Next';
    });
  }
</script>

{% schema %}
  {
    "name": "Check Data Usage",
    "settings": [],
    "presets": [
      {
        "name": "Check Data Usage",
        "category": "Custom"
      }
    ]
  }
{% endschema %}