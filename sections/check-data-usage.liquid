<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID" required>
<button id="check-iccid" onclick="checkICCID()">Cek</button>

<div id="result"></div>

<script>
  let lastSubmit = 0;

  const prefixVendorMap = [
    { prefix: "89859", vendor: "fmf" },
    { prefix: "89862", vendor: "fmf" },
    { prefix: "89810", vendor: "atgt" },
    { prefix: "2210", vendor: "abc" },
    { prefix: "8981200", vendor: "abc" },
  ];

  function detectVendor(iccid) {
    for (const item of prefixVendorMap) {
      if (iccid.startsWith(item.prefix)) {
        return item.vendor;
      }
    }
    return null;
  }

  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return; // minimum 3 detik antar klik
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value.trim();
    const resultEl = document.getElementById('result');

    // Validasi awal input
    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid (minimal 10 digit)</p>`;
      return;
    }

    // DEBUG: tampilkan vendor di console
    console.log("DEBUG ICCID Vendor →", vendor);

    // Disable button & tampilkan loading
    button.disabled = true;
    button.innerText = 'Memproses...';
    resultEl.innerHTML = `<p>Sedang memproses...</p>`;

    fetch('https://gkomunika.id/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      const contentType = response.headers.get("Content-Type") || "";
      const isJson = contentType.includes("application/json");
    
      let data = {};
      if (isJson) {
        try {
          data = await response.json();
        } catch (e) {
          data = { message: 'Response tidak valid' };
        }
      }

      if (data.status === 'rate_limited' || data.customCode === 429) {
        resultEl.innerHTML = `
          <p style="color: red">${data.message}</p>
        `;
        return;
      }

      if (data.tradeCode === "1000" &&
          data.tradeData &&
          (Array.isArray(data.tradeData)
            ? data.tradeData.length > 0
            : Object.keys(data.tradeData).length > 0)) {

        resultEl.innerHTML = `
          <p><strong>ICCID Vendor:</strong> ${vendor}</p>
          <pre>${JSON.stringify(data, null, 2)}</pre>
        `;

      } else {
        resultEl.innerHTML = `
          <p style="color: red">Data tidak ditemukan</p>
          <p><strong>ICCID Vendor:</strong> ${vendor}</p>
        `;
      }
    })
    .catch(error => {
      resultEl.innerHTML = `
        <p style="color: red">Connection Error</p>
        <p><strong>ICCID Vendor:</strong> ${vendor}</p>
      `;
    })
    .finally(() => {
      button.disabled = false;
      button.innerText = 'Next';
    });
  }
</script>

{% schema %}
  {
    "name": "Check Data Usage",
    "settings": [],
    "presets": [
      {
        "name": "Check Data Usage",
        "category": "Custom"
      }
    ]
  }
{% endschema %}
