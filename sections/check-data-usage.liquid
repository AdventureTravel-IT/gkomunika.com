<input
  type="text"
  id="iccid"
  placeholder="Masukkan ICCID" required>
<button onclick="checkICCID()">Cek</button>

<div id="result"></div>

<script>
  function checkICCID() {
    const iccid = document.getElementById('iccid').value;
  
    fetch('https://80e4-202-138-242-49.ngrok-free.app/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      let data = {};
      try {
        data = await response.json();
      } catch (e) {
        // Tidak JSON valid, diamkan atau buat data tetap kosong
      }
    
      if (!response.ok) {
        document.getElementById('result').innerHTML = `
          <p style="color: red">${data.message || 'Terjadi kesalahan'}</p>
        `;
        return;
      }
    
      if (
        data.tradeCode === "1000" &&
        data.tradeData &&
        (Array.isArray(data.tradeData)
          ? data.tradeData.length > 0
          : Object.keys(data.tradeData).length > 0)
      ) {
        document.getElementById('result').innerHTML = `
          <pre>${JSON.stringify(data, null, 2)}</pre>
        `;
      } else {
        document.getElementById('result').innerHTML = `
          <p style="color: red">Data tidak ditemukan</p>
        `;
      }
    })
    .catch(error => {
      document.getElementById('result').innerHTML = `
        <p style="color: red">Terjadi kesalahan koneksi</p>
      `;
    });
  }
</script>

{% schema %}
  {
    "name": "Check Data Usage",
    "settings": [],
    "presets": [
      {
        "name": "Check Data Usage",
        "category": "Custom"
      }
    ]
  }
{% endschema %}