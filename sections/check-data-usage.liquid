<input
  type="number"
  id="iccid"
  placeholder="Masukkan ICCID"
  required
>
<button id="check-iccid" onclick="checkICCID()">Cek</button>

<div id="result"></div>

<div class="invalid-popup" id="invalid-popup">
  <div class="invalid-popup__content">
    <h2>ICCID Invalid</h2>
    <p>
      Sorry, currently your sim card does not support top up via the website. You can top up by contacting our CS via
      Whatsapp.
    </p>
    <p>If your device supports eSIM. You can buy an eSIM for your travel connectivity.</p>
    <div class="invalid-popup__button">
      <button id="invalid-popup__buy-button">Buy eSIM</button>
      <button id="invalid-popup__contact-button">Contact CS</button>
    </div>
    <button id="invalid-popup__button-hide">OK</button>
  </div>
</div>

<script>
  let lastSubmit = 0;

  const prefixVendorMap = [
    { prefix: "89859", vendor: "fmf" },
    { prefix: "89862", vendor: "fmf" },
    { prefix: "89810", vendor: "atgt" },
    { prefix: "2210", vendor: "abc" },
    { prefix: "8981200", vendor: "abc" },
  ];

  function detectVendor(iccid) {
    for (const item of prefixVendorMap) {
      if (iccid.startsWith(item.prefix)) {
        return item.vendor;
      }
    }
    return null;
  }

  function showInvalidPopup() {
    document.getElementById("invalid-popup").style.display = "block";
  }

  function checkICCID() {
    const now = Date.now();
    if (now - lastSubmit < 3000) return; // minimum 3 detik antar klik
    lastSubmit = now;

    const button = document.getElementById('check-iccid');
    const iccid = document.getElementById('iccid').value.trim();
    const resultEl = document.getElementById('result');

    // Validasi awal input
    if (!iccid || iccid.length < 10) {
      resultEl.innerHTML = `<p style="color: red">ICCID tidak valid (minimal 10 digit)</p>`;
      return;
    }

    // Cek prefix
    const vendor = detectVendor(iccid);
    if (!vendor) {
      // Tampilkan modal popup
      showInvalidPopup();
      return;
    }

    // Disable button & tampilkan loading
    button.disabled = true;
    button.innerText = 'Memproses...';
    resultEl.innerHTML = `<p>Sedang memproses...</p>`;

    fetch('https://gkomunika.id/api/v1/check/data_info', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({ iccid: iccid })
    })
    .then(async (response) => {
      const contentType = response.headers.get("Content-Type") || "";
      const isJson = contentType.includes("application/json");
    
      let data = {};
      if (isJson) {
        try {
          data = await response.json();
        } catch (e) {
          data = { message: 'Response tidak valid' };
        }
      }

      if (data.status === 'rate_limited' || data.customCode === 429) {
        resultEl.innerHTML = `
          <p style="color: red">${data.message}</p>
        `;
        return;
      }

      if (
  data.tradeCode === "1000" &&
  data.tradeData &&
  (
    Array.isArray(data.tradeData)
      ? data.tradeData.length > 0
      : Object.keys(data.tradeData).length > 0
  )
) {
  const tradeData = data.tradeData;

  // HTML awal
  let html = `
    <h3>Informasi Kartu SIM</h3>
    <p><strong>Bundle mu:</strong> ${tradeData.skuName || "-"}</p>
    <p><strong>Masa Aktif:</strong> ${tradeData.planStartTime || "-"}</p>
    <p><strong>Tanggal Berakhir:</strong> ${tradeData.planEndTime || "-"}</p>
    <br>
  `;

  if (tradeData.usageList && tradeData.usageList.length > 0) {
    tradeData.usageList.forEach((usage) => {
      html += `
        <div style="
          border: 1px solid #ccc; 
          border-radius: 5px;
          padding: 15px; 
          margin-bottom: 20px;
        ">
          <h4>Total Penggunaan</h4>
          <div style="
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: bold;
            font-size: 1.2em;
            margin-bottom: 10px;
          ">
            <span>${usage.country}</span>
            <span>${usage.totalUsage}</span>
          </div>
      `;

      if (usage.dailyUsage && usage.dailyUsage.length > 0) {
        html += `
          <table style="
            width: 100%; 
            border-collapse: collapse;
            font-size: 0.9em;
          ">
            <thead>
              <tr style="background-color: #f0f0f0;">
                <th style="text-align: left; padding: 8px;">Negara</th>
                <th style="text-align: right; padding: 8px;">Tanggal</th>
                <th style="text-align: right; padding: 8px;">Penggunaan</th>
              </tr>
            </thead>
            <tbody>
        `;

        usage.dailyUsage.forEach(day => {
          html += `
            <tr>
              <td style="padding: 8px;">${usage.country}</td>
              <td style="padding: 8px; text-align: right;">${day.date}</td>
              <td style="padding: 8px; text-align: right;">${day.usage}</td>
            </tr>
          `;
        });

        html += `
            </tbody>
          </table>
        `;
      }

      html += `</div>`;
    });
  } else {
    html += `<p>Tidak ada data penggunaan.</p>`;
  }

  html += `<hr><pre>${JSON.stringify(data, null, 2)}</pre>`;

  resultEl.innerHTML = html;
} else {
  resultEl.innerHTML = "";
  showInvalidPopup();
}


    })
    .catch(error => {
      resultEl.innerHTML = `
        <p style="color: red">Connection Error</p>
      `;
    })
    .finally(() => {
      button.disabled = false;
      button.innerText = 'Next';
    });
  }

  // Tutup popup saat tombol OK diklik
  document.getElementById('invalid-popup__button-hide').addEventListener('click', () => {
    document.getElementById('invalid-popup').style.display = 'none';
  });

  // Tambahkan event ke tombol Buy eSIM dan Contact CS
  document.getElementById('invalid-popup__buy-button').addEventListener('click', () => {
    window.location.href = "https://example.com/esim";
  });

  document.getElementById('invalid-popup__contact-button').addEventListener('click', () => {
    window.location.href = "https://wa.me/6281234567890";
  });
</script>

<style>
  .invalid-popup {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0,0,0,0.5);
  }

  .invalid-popup__content {
    background-color: #fff;
    margin: 10% auto;
    padding: 20px;
    width: 90%;
    max-width: 400px;
    border-radius: 8px;
    text-align: center;
  }

  .invalid-popup__button button {
    margin: 5px;
    padding: 10px 20px;
    cursor: pointer;
  }
</style>

