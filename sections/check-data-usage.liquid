  [role~='tooltip'][data-microtip-bullets]::after {
    white-space: pre-line;
    text-align: left;
    line-height: 1.35;
  }

  /* opsional: lebarkan tooltip biar nggak terlalu memanjang */
  [role~='tooltip'][data-microtip-bullets][data-microtip-size='large']::after {
