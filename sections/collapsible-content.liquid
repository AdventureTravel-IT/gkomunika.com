<style>
  /* Scope: hanya untuk section FAQ ini */
  [data-gk-faq] .gk-rte p {
    margin: 0 0 10px;
  }

  /* Bullet list */
  [data-gk-faq] .gk-rte ul,
  [data-gk-faq] .gk-rte ol {
    margin: 10px 0;
    padding-left: 22px; /* indent bullet */
  }

  [data-gk-faq] .gk-rte ul {
    list-style: disc;
  }

  [data-gk-faq] .gk-rte ol {
    list-style: decimal;
  }

  [data-gk-faq] .gk-rte li {
    margin: 6px 0;
  }

  /* Link / text primary */
  [data-gk-faq] .gk-rte a {
    text-decoration: underline;
    text-underline-offset: 2px;

    /* Dawn (umum): accent */
    color: rgb(var(--color-base-accent-1));
  }

  [data-gk-faq] .gk-rte a:hover {
    opacity: 0.85;
  }
</style>


<section data-gk-faq="{{ section.id }}" class="py-6">
  <div class="max-w-[980px] mx-auto px-4">
    <div>
      {% if section.settings.heading != blank %}
        <h2 class="text-[28px] text-primary font-extrabold mb-3.5">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      <div class="w-full" role="region" aria-label="FAQ">
        {% for block in section.blocks %}
          {% assign idx = forloop.index0 %}
          {% assign is_open = false %}
          {% if section.settings.open_first_collapsible_row and forloop.first %}
            {% assign is_open = true %}
          {% endif %}

          {% assign content_id = 'gk-faq-content-' | append: section.id | append: '-' | append: idx %}
          {% assign trigger_id = 'gk-faq-trigger-' | append: section.id | append: '-' | append: idx %}

          <div class="border-b border-black/10 last:border-b-0" {{ block.shopify_attributes }}>
            <button
              type="button"
              id="{{ trigger_id }}"
              aria-controls="{{ content_id }}"
              aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
              data-gk-trigger
              class="w-full flex items-center justify-start gap-3 py-3.5 bg-transparent border-0 text-left cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-black focus-visible:outline-offset-4 rounded-lg"
            >
              <span class="text-lg text-primary leading-snug break-words">
                {{ block.settings.heading }}
              </span>

              <span
                aria-hidden="true"
                class="ml-auto text-lg leading-none transition-transform duration-200 [button[aria-expanded='true']_&]:rotate-180"
              >
                ▾
              </span>
            </button>

            <div
              id="{{ content_id }}"
              role="region"
              aria-labelledby="{{ trigger_id }}"
              {% unless is_open %}
                hidden
              {% endunless %}
              data-gk-content
              class="overflow-hidden"
            >
              <div class="pb-3.5 text-base leading-relaxed gk-rte text-primary">
                {%- if block.settings.page != blank -%}
                  {{ pages[block.settings.page].content }}
                {%- else -%}
                  {{ block.settings.row_content }}
                {%- endif -%}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const root = document.querySelector('[data-gk-faq="{{ section.id }}"]');
    if (!root) return;

    const list = root.querySelector('[role="region"][aria-label="FAQ"]');
    if (!list) return;

    const allowMultiple = false;

    function animateOpen(panel) {
      panel.hidden = false;
      panel.style.height = 'auto';
      const h = panel.scrollHeight;
      panel.style.height = '0px';
      panel.offsetHeight;
      panel.style.transition = 'height 200ms ease';
      panel.style.height = h + 'px';
      panel.addEventListener('transitionend', function onEnd() {
        panel.style.height = 'auto';
        panel.style.transition = '';
        panel.removeEventListener('transitionend', onEnd);
      });
    }

    function animateClose(panel) {
      panel.style.height = panel.scrollHeight + 'px';
      panel.offsetHeight;
      panel.style.transition = 'height 200ms ease';
      panel.style.height = '0px';
      panel.addEventListener('transitionend', function onEnd() {
        panel.hidden = true;
        panel.style.height = '';
        panel.style.transition = '';
        panel.removeEventListener('transitionend', onEnd);
      });
    }

    function closeAllExcept(exceptTrigger) {
      const triggers = root.querySelectorAll('[data-gk-trigger]');
      triggers.forEach((t) => {
        if (t === exceptTrigger) return;
        if (t.getAttribute('aria-expanded') === 'true') {
          const panel = document.getElementById(t.getAttribute('aria-controls'));
          t.setAttribute('aria-expanded', 'false');
          if (panel) animateClose(panel);
        }
      });
    }

    root.addEventListener('click', function (e) {
      const trigger = e.target.closest('[data-gk-trigger]');
      if (!trigger) return;

      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      const panel = document.getElementById(trigger.getAttribute('aria-controls'));
      if (!panel) return;

      if (!allowMultiple) closeAllExcept(trigger);

      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        animateClose(panel);
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        animateOpen(panel);
      }
    });
  })();
</script>

