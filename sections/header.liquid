</div>

<!-- CURRENCY DROPDOWN JS (Desktop + Mobile) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initCurrency = (suffix) => {
      const wrap = document.getElementById(`CurrencyForm-${suffix}`);
      if (!wrap) return;

      const btn     = document.getElementById(`CurrencyTrigger-${suffix}`);
      const menu    = document.getElementById(`CurrencyMenu-${suffix}`);
      const label   = document.getElementById(`CurrencyLabel-${suffix}`);
      const arrow   = document.getElementById(`CurrencyArrow-${suffix}`);

      if (!btn || !menu || !label) return;

      // Restore saved currency
      const saved = sessionStorage.getItem('buckscc_customer_currency');
      if (saved) {
        try {
          const val = JSON.parse(saved);
          label.textContent = val;
          // Mark active item
          menu.querySelectorAll('[data-currency]').forEach(item => {
            const isActive = item.dataset.currency === val;
            item.classList.toggle('bg-black/10', isActive);
            item.classList.toggle('font-semibold', isActive);
          });
        } catch (e) {}
      }

      const open = () => {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (arrow) arrow.classList.add('rotate-[270deg]');
      };

      const close = () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (arrow) arrow.classList.remove('rotate-[270deg]');
      };

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        menu.classList.contains('hidden') ? open() : close();
      });

      menu.querySelectorAll('[data-currency]').forEach((item) => {
        item.addEventListener('click', () => {
          const val = item.dataset.currency;

          // Save to sessionStorage
          sessionStorage.setItem('buckscc_customer_currency', JSON.stringify(val));

          // Update label both desktop & mobile
          ['desktop', 'mobile'].forEach(s => {
            const lbl = document.getElementById(`CurrencyLabel-${s}`);
            if (lbl) lbl.textContent = val;

            // Update active state
            const m = document.getElementById(`CurrencyMenu-${s}`);
            if (m) {
              m.querySelectorAll('[data-currency]').forEach(i => {
                const isActive = i.dataset.currency === val;
                i.classList.toggle('bg-black/10', isActive);
                i.classList.toggle('font-semibold', isActive);
              });
            }
          });

          close();
        });
      });

      document.addEventListener('click', (e) => {
        if (!wrap.contains(e.target)) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    };

    initCurrency('desktop');
    initCurrency('mobile');
  });
</script>

