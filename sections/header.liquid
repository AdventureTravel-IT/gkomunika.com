              {% render 'icon-plus', class: 'text-primary w-[26px] h-[26px]' %}
              <span>Top Up</span>
            </a>
          </li>

          <li class="sidebar-item">
            <a href="{{ locale_prefix }}/pages/about-us" class="sidebar-link">
              {% render 'icon-people-outline', class: 'text-primary w-[26px] h-[26px]' %}
              <span>About Us</span>
            </a>
          </li>

          <li class="sidebar-item">
            <a href="{{ locale_prefix }}/pages/faq" class="sidebar-link">
              {% render 'icon-comment-question', class: 'text-primary w-[26px] h-[26px]' %}
              <span>FAQ</span>
            </a>
          </li>

          <li class="sidebar-item">
            <a href="{{ locale_prefix }}/pages/news" class="sidebar-link">
              {% render 'icon-news', class: 'text-primary w-[26px] h-[26px]' %}
              <span>News</span>
            </a>
          </li>
        </ul>

        <div class="sidebar-footer">
          <div class="sidebar-footer-inner">
            <div class="sidebar-footer-controls">

              <!-- Currency (MOBILE) -->
              <div class="dropdown-wrap" id="CurrencyForm-mobile">
                <button
                  id="CurrencyTrigger-mobile"
                  type="button"
                  class="dropdown-trigger-lang"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-controls="CurrencyMenu-mobile"
                >
                  <span class="lang-icon">
                    {{- 'header-currency.svg' | inline_asset_content -}}
                  </span>
                  <span id="CurrencyLabel-mobile" class="dropdown-label">USD</span>
                  <span id="CurrencyArrow-mobile" class="dropdown-arrow" aria-hidden="true">
                    {% render 'icon-arrow-right', class: 'text-primary w-[26px] h-[26px]' %}
                  </span>
                </button>

                <ul
                  id="CurrencyMenu-mobile"
                  class="dropdown-menu-up"
                  role="listbox"
                  aria-label="Select currency"
                >
                  <li role="option">
                    <button type="button" data-currency="USD" class="dropdown-option">
                      <span>USD</span>
                    </button>
                  </li>
                  <li role="option">
                    <button type="button" data-currency="IDR" class="dropdown-option">
                      <span>IDR</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Language (MOBILE) -->
            {% form 'localization', id: 'LanguageFormUX-mobile', class: 'dropdown-wrap' %}
              <input
                type="hidden"
                name="locale_code"
                id="LangLocaleInput-mobile"
                value="{{ localization.language.iso_code }}"
              >

              {% assign current_code_m = localization.language.iso_code | upcase | slice: 0, 2 %}

              <button
                id="LangTrigger-mobile"
                type="button"
                class="dropdown-trigger-lang"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="LangMenu-mobile"
              >
                <span class="lang-icon" aria-hidden="true">
                  {{- 'header-language.svg' | inline_asset_content -}}
                </span>
                <span class="dropdown-label">{{ current_code_m }}</span>
                <span id="LangArrow-mobile" class="dropdown-arrow" aria-hidden="true">
                  {% render 'icon-arrow-right', class: 'text-primary w-[26px] h-[26px]' %}
                </span>
              </button>

              <ul
                id="LangMenu-mobile"
                class="dropdown-menu-up"
                role="listbox"
                aria-label="Select language"
              >
                {% for locale in localization.available_languages %}
                  {% assign code = locale.iso_code | upcase | slice: 0, 2 %}
                  <li
                    role="option"
                    aria-selected="{% if locale.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                  >
                    <button
                      type="button"
                      class="dropdown-option{% if locale.iso_code == localization.language.iso_code %} is-active{% endif %}"
                      data-locale="{{ locale.iso_code }}"
                    >
                      <span>{{ code }}</span>
                      {% if locale.iso_code == localization.language.iso_code %}
                        <span class="check" aria-hidden="true">✓</span>
                      {% endif %}
                    </button>
                  </li>
                {% endfor %}
              </ul>
            {% endform %}

          </div>
        </div>
      </div>
    </div>
  </header>
{% endunless %}

<!-- SEARCH OVERLAY -->
<div id="header-search-overlay" class="search-overlay" hidden></div>

<!-- MENU MOBILE TOGGLE (ID-based) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('menu-toggle');
    const panel = document.getElementById('sidebar-panel');
    if (!btn || !panel) return;

    const isOpen = () => btn.getAttribute('aria-expanded') === 'true';

    const open = () => {
      panel.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
    };

    const close = () => {
      panel.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
    };

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      isOpen() ? close() : open();
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => close());
    });

    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      if (btn.contains(e.target)) return;
      if (panel.contains(e.target)) return;
      close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });
  });
</script>

<!-- LANGUAGE DROPDOWN JS (Desktop + Mobile) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initLang = (suffix) => {
      const form = document.getElementById(`LanguageFormUX-${suffix}`);
      if (!form) return;

      const btn = document.getElementById(`LangTrigger-${suffix}`);
      const menu = document.getElementById(`LangMenu-${suffix}`);
      const input = document.getElementById(`LangLocaleInput-${suffix}`);
      const arrowWrap = document.getElementById(`LangArrow-${suffix}`);

      if (!btn || !menu || !input) return;

      const open = () => {
        menu.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        if (arrowWrap) arrowWrap.classList.add('is-open');
      };

      const close = () => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        if (arrowWrap) arrowWrap.classList.remove('is-open');
      };

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        menu.classList.contains('is-open') ? close() : open();
      });

      menu.querySelectorAll('[data-locale]').forEach((item) => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          input.value = item.getAttribute('data-locale');
          form.submit();
        });
      });

      document.addEventListener('click', (e) => {
        if (!form.contains(e.target)) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    };

    initLang('desktop');
    initLang('mobile');
  });
</script>

<!-- SEARCH MODAL -->
<script type="module" defer>
  (() => {
    const triggers = [
      document.getElementById('header-search-trigger-mobile'),
      document.getElementById('header-search-trigger-desktop'),
    ].filter(Boolean);

    const modal = document.getElementById('header-search-modal');
    const overlay = document.getElementById('header-search-overlay');
    const closeBtn = document.getElementById('header-search-close');

    if (!triggers.length || !modal || !overlay || !closeBtn) return;

    let lastTrigger = null;

    const open = (triggerEl) => {
      lastTrigger = triggerEl;
      overlay.hidden = false;
      modal.hidden = false;
      document.documentElement.style.overflow = 'hidden';

      const input = modal.querySelector('input, textarea, select, button');
      if (input) input.focus();
    };

    const close = () => {
      overlay.hidden = true;
      modal.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastTrigger) lastTrigger.focus();
    };

    triggers.forEach((btn) => btn.addEventListener('click', () => open(btn)));

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  })();
</script>

<!-- SEARCH MODAL MARKUP -->
<div
  id="header-search-modal"
  class="search-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="header-search-title"
  hidden
>
  <div class="search-modal-inner">
    <div class="search-modal-spacer">
      <button
        id="header-search-close"
        type="button"
        aria-label="Close search"
        class="search-close-btn"
      >
        {% render 'icon-close', class: 'w-6 h-6 text-primary' %}
      </button>
    </div>

    <div class="search-body">
      {% render 'search-bar', class: 'search-bar-wrap' %}
    </div>
  </div>
</div>

<!-- CURRENCY DROPDOWN JS (Desktop + Mobile) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initCurrency = (suffix) => {
      const wrap = document.getElementById(`CurrencyForm-${suffix}`);
      if (!wrap) return;

      const btn = document.getElementById(`CurrencyTrigger-${suffix}`);
      const menu = document.getElementById(`CurrencyMenu-${suffix}`);
      const label = document.getElementById(`CurrencyLabel-${suffix}`);
      const arrow = document.getElementById(`CurrencyArrow-${suffix}`);

      if (!btn || !menu || !label) return;

      const saved = sessionStorage.getItem('buckscc_customer_currency');
      if (saved) {
        try {
          const val = JSON.parse(saved);
          label.textContent = val;
          menu.querySelectorAll('[data-currency]').forEach((item) => {
            const isActive = item.dataset.currency === val;
            item.classList.toggle('is-active', isActive);
          });
        } catch (e) {}
      }

      const open = () => {
        menu.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        if (arrow) arrow.classList.add('is-open');
      };

      const close = () => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        if (arrow) arrow.classList.remove('is-open');
      };

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        menu.classList.contains('is-open') ? close() : open();
      });

      menu.querySelectorAll('[data-currency]').forEach((item) => {
        item.addEventListener('click', () => {
          const val = item.dataset.currency;

          sessionStorage.setItem('buckscc_customer_currency', JSON.stringify(val));

          ['desktop', 'mobile'].forEach((s) => {
            const lbl = document.getElementById(`CurrencyLabel-${s}`);
            if (lbl) lbl.textContent = val;

            const m = document.getElementById(`CurrencyMenu-${s}`);
            if (m) {
              m.querySelectorAll('[data-currency]').forEach((i) => {
                i.classList.toggle('is-active', i.dataset.currency === val);
              });
            }
          });

          close();
        });
      });

      document.addEventListener('click', (e) => {
        if (!wrap.contains(e.target)) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    };

    initCurrency('desktop');
    initCurrency('mobile');
  });
</script>

