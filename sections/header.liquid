              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/news" class="{{ menu_item_class }}">
                <img
                  src="{{ 'header-news.svg' | asset_url }}"
                  alt="News icon"
                  class="{{ icon_class }}"
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                >
                <span class="{{ menu_label_class }}">News</span>
              </a>
            </li>

            <li>
              <a href="{{ routes.cart_url }}" class="{{ menu_item_class }}" aria-label="Cart">
                <span class="relative inline-flex items-center">
                  <img
                    src="{{ 'header-cart.svg' | asset_url }}"
                    alt="Cart icon"
                    class="{{ icon_class }}"
                    width="24"
                    height="24"
                    loading="eager"
                    decoding="async"
                  >
                  {% if cart.items.size > 0 %}
                    <span class="absolute -top-1 -right-[6px] bg-[var(--color-primary)] text-[var(--color-neutral)] text-[10px] w-4 h-4 rounded-full inline-flex items-center justify-center text-center leading-none">
                      {{ cart.items.size }}
                    </span>
                  {% endif %}
                </span>
                <span class="{{ menu_label_class }}">Cart</span>
              </a>
            </li>

            <li>
              <a href="{{ profile_url }}" class="{{ menu_item_class }}">
                <img
                  src="{{ 'header-profile.svg' | asset_url }}"
                  alt="Profile icon"
                  class="{{ icon_class }}"
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                >
                <span class="{{ menu_label_class }}">Profile</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- SIDEBAR MOBILE (absolute di bawah header) -->
