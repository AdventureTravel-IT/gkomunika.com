{% style %}
  /* ============================================================
   HEADER SECTION — Vanilla CSS
   (Converted from Tailwind utility classes)
   ============================================================ */

/* ----------------------------------------------------------
   1. SIDEBAR PANEL STATE (ID-based, kept as-is)
   ---------------------------------------------------------- */
#sidebar-panel {
  max-height: 0 !important;
  overflow: hidden !important;
  opacity: 0;
  pointer-events: none;
}
#sidebar-panel.is-open {
  max-height: calc(100vh - 70px) !important;
  overflow-y: auto !important;
  opacity: 1;
  pointer-events: auto;
}

#CurrencyMenu-desktop,
#CurrencyMenu-mobile,
#LangMenu-desktop,
#LangMenu-mobile {
  display: none !important;
}
#CurrencyMenu-desktop.is-open,
#CurrencyMenu-mobile.is-open,
#LangMenu-desktop.is-open,
#LangMenu-mobile.is-open {
  display: block !important;
}

/* ----------------------------------------------------------
   2. SITE HEADER
   ---------------------------------------------------------- */
.site-header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 200;
  background-color: var(--color-neutral);
  max-width: 1920px;
  margin-left: auto;
  margin-right: auto;
  height: fit-content;
  padding: 5px 0;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
              0 2px 4px -2px rgba(0, 0, 0, 0.1);
}

@media (min-width: 768px) {
  .site-header {
    padding: 15px 0;
  }
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}

/* ----------------------------------------------------------
   3. HEADER LEFT
   ---------------------------------------------------------- */
.header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ----------------------------------------------------------
   4. MOBILE MENU TOGGLE BUTTON
   ---------------------------------------------------------- */
.menu-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  padding: 0;
  margin: 0 0 0 -20px;
  border: 0;
  background: transparent;
  line-height: 1;
  font-size: 0;
  box-sizing: border-box;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}

@media (min-width: 768px) {
  .menu-toggle {
    display: none;
  }
}

.menu-icon {
  position: relative;
  width: 20px;
  height: 20px;
  cursor: pointer;
}

.menu-icon span {
  position: absolute;
  left: 0;
  width: 100%;
  height: 3px;
  background-color: var(--color-primary);
  border-radius: 2px;
  pointer-events: none;
}

.menu-icon span:nth-child(1) { top: 0; }
.menu-icon span:nth-child(2) { top: 8px; }
.menu-icon span:nth-child(3) { top: 16px; }

/* ----------------------------------------------------------
   5. LOGO
   ---------------------------------------------------------- */
.header-logo-link {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
}

/* ----------------------------------------------------------
   6. MOBILE RIGHT ACTIONS
   ---------------------------------------------------------- */
.header-mobile-right {
  display: flex;
  align-items: center;
  gap: 20px;
}

@media (min-width: 768px) {
  .header-mobile-right {
    display: none;
  }
}

/* Shared icon button / icon link */
.header-icon-btn {
  display: inline-flex;
  align-items: center;
  padding: 8px;
  margin: -8px;
  background: transparent;
  border: none;
  cursor: pointer;
  text-decoration: none;
}

/* Cart icon wrapper (for badge positioning) */
.header-cart-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  pointer-events: none;
}

.header-cart-badge {
  position: absolute;
  top: -4px;
  right: -6px;
  background-color: var(--color-primary);
  color: var(--color-neutral);
  font-size: 10px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1;
}

/* ----------------------------------------------------------
   7. DESKTOP RIGHT ACTIONS
   ---------------------------------------------------------- */
.header-desktop-right {
  display: none;
}

@media (min-width: 768px) {
  .header-desktop-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
}

.header-search-btn {
  margin-right: 10px;
  background: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  padding: 0;
}

/* ----------------------------------------------------------
   8. CURRENCY + LANGUAGE CONTROLS WRAPPER
   ---------------------------------------------------------- */
.header-controls {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ----------------------------------------------------------
   9. DROPDOWN (Currency & Language — shared styles)
   ---------------------------------------------------------- */
.dropdown-wrap {
  position: relative;
  display: inline-block;
}

/* Desktop currency trigger (gap-3) */
.dropdown-trigger {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 8px 10px;
  transition: all 0.2s;
  user-select: none;
  background: transparent;
  border: none;
  cursor: pointer;
}

/* Language trigger (gap-2) */
.dropdown-trigger-lang {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  transition: all 0.2s;
  user-select: none;
  background: transparent;
  border: none;
  cursor: pointer;
}

.dropdown-label {
  font-size: 14px;
  letter-spacing: 0.05em;
  color: var(--color-primary);
}

.dropdown-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transform: rotate(90deg);
  transition: transform 0.2s;
  transform-origin: center;
}

.dropdown-arrow.is-open {
  transform: rotate(270deg);
}

/* Dropdown menu — opens downward (desktop) */
.dropdown-menu {
  position: absolute;
  right: 0;
  top: calc(100% + 8px);
  min-width: 120px;
  margin: 0;
  padding: 6px;
  list-style: none;
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.15);
  border-radius: 12px;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
              0 4px 6px -4px rgba(0, 0, 0, 0.1);
  z-index: 50;
}

/* Dropdown menu — opens upward (mobile) */
.dropdown-menu-up {
  position: absolute;
  right: 0;
  bottom: calc(100% + 8px);
  min-width: 120px;
  margin: 0;
  padding: 6px;
  list-style: none;
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.15);
  border-radius: 12px;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
              0 4px 6px -4px rgba(0, 0, 0, 0.1);
  z-index: 50;
}

.dropdown-option {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  color: var(--color-primary);
  padding: 8px 10px;
  border-radius: 12px;
  font-size: 14px;
  background: transparent;
  border: none;
  cursor: pointer;
  transition: background 0.2s;
  box-sizing: border-box;
}

.dropdown-option:hover {
  background-color: rgba(0, 0, 0, 0.05);
}

.dropdown-option.is-active {
  background-color: rgba(0, 0, 0, 0.1);
  font-weight: 600;
}

.dropdown-option .check {
  opacity: 0.8;
}

.lang-icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  width: 30px;
  height: 30px;
}

/* ----------------------------------------------------------
   10. DESKTOP NAVIGATION
   ---------------------------------------------------------- */
.header-nav {
  display: flex;
  align-items: center;
}

.header-nav-list {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin: 0;
  padding: 0;
  list-style: none;
  max-width: 100%;
}

.nav-item-link {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  white-space: nowrap;
  font-weight: 700;
  line-height: 1.1;
  color: var(--color-primary);
  text-decoration: none;
}

.nav-item-label {
  font-size: 14px;
  color: var(--color-primary);
}

/* Nav cart badge (same pattern as mobile) */
.nav-cart-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
}

/* ----------------------------------------------------------
   11. MOBILE SIDEBAR
   ---------------------------------------------------------- */
.sidebar-wrapper {
  display: block;
}

@media (min-width: 768px) {
  .sidebar-wrapper {
    display: none;
  }
}

.sidebar-panel {
  position: absolute;
  top: 50px;
  left: 0;
  width: 100%;
  background-color: var(--color-neutral);
  z-index: 1000;
  transition: max-height 0.2s ease, opacity 0.2s ease;
}

.sidebar-list {
  margin: 0;
  padding: 0 12px;
  list-style: none;
}

.sidebar-item {
  border-bottom: 1px solid #d9d9d9;
  padding: 12px 0;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--color-primary);
  font-weight: 700;
  text-decoration: none;
}

.sidebar-link span {
  font-size: 14px;
}

.sidebar-footer {
  padding: 0 8px 16px;
}

.sidebar-footer-inner {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sidebar-footer-controls {
  display: flex;
  align-items: center;
}

/* ----------------------------------------------------------
   12. SEARCH OVERLAY
   ---------------------------------------------------------- */
.search-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 9998;
}

/* ----------------------------------------------------------
   13. SEARCH MODAL
   ---------------------------------------------------------- */
.search-modal {
  position: fixed;
  top: 30px;
  left: 50%;
  transform: translateX(-50%);
  width: min(720px, calc(100vw - 32px));
  max-height: 400px;
  overflow: auto;
  background: transparent;
  z-index: 9999;
}

.search-modal-inner {
  position: relative;
  padding: 16px;
}

.search-modal-spacer {
  margin-bottom: 100px;
}

.search-close-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  border-radius: 50%;
  padding: 10px;
  background: #fff;
  cursor: pointer;
  line-height: 1;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-body {
  overflow: auto;
}

.search-bar-wrap {
  border: 1px solid #cbd5e1; /* slate-300 */
  border-radius: 15px;
}
{% endstyle %}

{% unless template == 'customers/login' or template == 'customers/register' %}
  {%- comment -%}
    Deteksi bahasa aktif untuk menambahkan prefix /id pada bahasa Indonesia
  {%- endcomment -%}
  {% if request.locale.iso_code == 'id' %}
    {% assign locale_prefix = '/id' %}
  {% else %}
    {% assign locale_prefix = '' %}
  {% endif %}

  {% if customer %}
    {% assign profile_url = routes.account_url %}
  {% else %}
    {% assign profile_url = routes.account_login_url %}
  {% endif %}

  <style>
    #sidebar-panel {
      max-height: 0 !important;
      overflow: hidden !important;
      opacity: 0;
      pointer-events: none;
    }
    #sidebar-panel.is-open {
      max-height: calc(100vh - 70px) !important;
      overflow-y: auto !important;
      opacity: 1;
      pointer-events: auto;
    }
    #CurrencyMenu-desktop,
    #CurrencyMenu-mobile,
    #LangMenu-desktop,
    #LangMenu-mobile {
      display: none !important;
    }
    #CurrencyMenu-desktop.is-open,
    #CurrencyMenu-mobile.is-open,
    #LangMenu-desktop.is-open,
    #LangMenu-mobile.is-open {
      display: block !important;
    }
  </style>

  <header class="site-header">
    <div class="header-inner">

      <!-- LEFT -->
      <div class="header-left">

        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          type="button"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="sidebar-panel"
          class="menu-toggle"
        >
          <div id="menu-icon" class="menu-icon">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>

        {% assign alt_global = 'Global Komunika' %}
        {% if section.settings.logo != blank %}
          <a href="{{ routes.root_url }}" class="header-logo-link">
            <img
              src="{{ section.settings.logo | image_url: width: 120 }}"
              srcset="
                {{ section.settings.logo | image_url: width: 120 }} 1x,
                {{ section.settings.logo | image_url: width: 240 }} 2x,
                {{ section.settings.logo | image_url: width: 360 }} 3x
              "
              class="header-content-logo"
              alt="{{ alt_global }}"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="120"
              height="40"
            >
          </a>
        {% endif %}
      </div>

      <!-- MOBILE RIGHT -->
      <div class="header-mobile-right" aria-label="Quick actions">
        {% if template.name == 'product' %}
          <button
            id="header-search-trigger-mobile"
            type="button"
            aria-label="Search"
            aria-haspopup="dialog"
            aria-controls="header-search-modal"
            class="header-icon-btn"
          >
            {% render 'icon-search', class: 'w-6 h-6 text-primary pointer-events-none' %}
          </button>
        {% endif %}

        <a href="{{ routes.cart_url }}" aria-label="Cart" class="header-icon-btn">
          <span class="header-cart-wrap">
            {% render 'icon-cart', class: 'w-[28px] h-[28px] text-primary' %}
            {% if cart.items.size > 0 %}
              <span class="header-cart-badge">{{ cart.items.size }}</span>
            {% endif %}
          </span>
        </a>

        <a href="{{ profile_url }}" aria-label="Profile" class="header-icon-btn">
          {% render 'icon-profile-outline', class: 'w-[28px] h-[28px] text-primary pointer-events-none' %}
        </a>
      </div>

      <!-- DESKTOP RIGHT -->
      <div class="header-desktop-right">
        {% if template.name == 'product' %}
          <button
            id="header-search-trigger-desktop"
            type="button"
            aria-label="Search"
            aria-haspopup="dialog"
            aria-controls="header-search-modal"
            class="header-search-btn"
          >
            {% render 'icon-search', class: 'w-[26px] h-[26px] text-primary' %}
          </button>
        {% endif %}

        <div class="header-controls">

          <!-- Currency (DESKTOP) -->
          <div class="dropdown-wrap" id="CurrencyForm-desktop">
            <button
              id="CurrencyTrigger-desktop"
              type="button"
              class="dropdown-trigger"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="CurrencyMenu-desktop"
            >
              <span class="lang-icon">
                {{- 'header-currency.svg' | inline_asset_content -}}
              </span>
              <span id="CurrencyLabel-desktop" class="dropdown-label">USD</span>
              <span id="CurrencyArrow-desktop" class="dropdown-arrow" aria-hidden="true">
                {% render 'icon-arrow-right', class: 'text-primary w-[26px] h-[26px]' %}
              </span>
            </button>

            <ul
              id="CurrencyMenu-desktop"
              class="dropdown-menu"
              role="listbox"
              aria-label="Select currency"
            >
              <li role="option">
                <button type="button" data-currency="USD" class="dropdown-option">
                  <span>USD</span>
                </button>
              </li>
              <li role="option">
                <button type="button" data-currency="IDR" class="dropdown-option">
                  <span>IDR</span>
                </button>
              </li>
            </ul>
          </div>

          <!-- Language (DESKTOP) -->
          {% form 'localization', id: 'LanguageFormUX-desktop', class: 'dropdown-wrap' %}
            <input
              type="hidden"
              name="locale_code"
              id="LangLocaleInput-desktop"
              value="{{ localization.language.iso_code }}"
            >

            {% assign current_code = localization.language.iso_code | upcase | slice: 0, 2 %}

            <button
              id="LangTrigger-desktop"
              type="button"
              class="dropdown-trigger-lang"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="LangMenu-desktop"
            >
              <span class="lang-icon" aria-hidden="true">
                {{- 'header-language.svg' | inline_asset_content -}}
              </span>
              <span class="dropdown-label">{{ current_code }}</span>
              <span id="LangArrow-desktop" class="dropdown-arrow" aria-hidden="true">
                {% render 'icon-arrow-right', class: 'text-primary w-[26px] h-[26px]' %}
              </span>
            </button>

            <ul
              id="LangMenu-desktop"
              class="dropdown-menu"
              role="listbox"
              aria-label="Select language"
            >
              {% for locale in localization.available_languages %}
                {% assign code = locale.iso_code | upcase | slice: 0, 2 %}
                <li
                  role="option"
                  aria-selected="{% if locale.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                >
                  <button
                    type="button"
                    class="dropdown-option{% if locale.iso_code == localization.language.iso_code %} is-active{% endif %}"
                    data-locale="{{ locale.iso_code }}"
                  >
                    <span>{{ code }}</span>
                    {% if locale.iso_code == localization.language.iso_code %}
                      <span class="check" aria-hidden="true">✓</span>
                    {% endif %}
                  </button>
                </li>
              {% endfor %}
            </ul>
          {% endform %}
        </div>

        <!-- Desktop navigation -->
        <nav role="navigation" aria-label="Main navigation" class="header-nav">
          <ul class="header-nav-list">

            <li>
              <a href="{{ routes.root_url }}" class="nav-item-link">
                {% render 'icon-home', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">Home</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/product-category?q=esim" class="nav-item-link">
                <img
                  src="{{ 'header-esim.svg' | asset_url }}"
                  alt="eSIM icon"
                  class="w-[26px] h-[26px] block"
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                >
                <span class="nav-item-label">eSIM</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/product-category?q=sim-card" class="nav-item-link">
                {% render 'icon-simcard', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">SIM Card</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/product-category?q=insurance" class="nav-item-link">
                {% render 'icon-insurance', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">Insurance</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/check-data-usage" class="nav-item-link">
                {% render 'icon-chart-donut', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">Data Usage</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/check-data-usage-topup" class="nav-item-link">
                {% render 'icon-plus', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">Top Up</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/about-us" class="nav-item-link">
                {% render 'icon-people-outline', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">About Us</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/faq" class="nav-item-link">
                {% render 'icon-comment-question', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">FAQ</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/news" class="nav-item-link">
                {% render 'icon-news', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">News</span>
              </a>
            </li>

            <li>
              <a href="{{ routes.cart_url }}" class="nav-item-link" aria-label="Cart">
                <span class="nav-cart-wrap">
                  {% render 'icon-cart', class: 'text-primary w-[26px] h-[26px]' %}
                  {% if cart.items.size > 0 %}
                    <span class="header-cart-badge">{{ cart.items.size }}</span>
                  {% endif %}
                </span>
                <span class="nav-item-label">Cart</span>
              </a>
            </li>

            <li>
              <a href="{{ profile_url }}" class="nav-item-link">
                {% render 'icon-profile-outline', class: 'text-primary w-[26px] h-[26px]' %}
                <span class="nav-item-label">Profile</span>
              </a>
            </li>

          </ul>
        </nav>
      </div>
    </div>

    <!-- SIDEBAR MOBILE -->
    <div id="sidebar" class="sidebar-wrapper">
      <div
        id="sidebar-panel"
        aria-hidden="true"
        class="sidebar-panel"
      >
        <ul class="sidebar-list">

          <li class="sidebar-item">
            <a href="{{ routes.root_url }}" class="sidebar-link">
