<section></section>

{% comment %}
  FULL CODE (Tailwind refactor + JS selector pakai ID + HEADER NORMAL (NOT FIXED))

  FIX UTAMA:
  - ID language desktop & mobile dibuat unik:
    LanguageFormUX-desktop / LanguageFormUX-mobile
    LangTrigger-desktop / LangTrigger-mobile
    LangMenu-desktop / LangMenu-mobile
    LangLocaleInput-desktop / LangLocaleInput-mobile
    LangArrow-desktop / LangArrow-mobile

  - JS language di-init untuk desktop & mobile.
{% endcomment %}

{% unless template == 'customers/login' or template == 'customers/register' %}
  {%- comment -%}
    Deteksi bahasa aktif untuk menambahkan prefix /id pada bahasa Indonesia
  {%- endcomment -%}
  {% if request.locale.iso_code == 'id' %}
    {% assign locale_prefix = '/id' %}
  {% else %}
    {% assign locale_prefix = '' %}
  {% endif %}

  {% if customer %}
    {% assign profile_url = routes.account_url %}
  {% else %}
    {% assign profile_url = routes.account_login_url %}
  {% endif %}

  <header
    class="fixed top-0 w-full z-[200] bg-neutral max-w-[1920px] mx-auto h-fit py-[5px] md:py-[15px] shadow-md"
  >
    <div class="flex items-center justify-between px-6">
      <!-- LEFT -->
      <div class="flex items-center gap-8 md:gap-2.5">
        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          type="button"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="sidebar-panel"
          class="inline-flex md:hidden items-center justify-center w-[44px] h-[44px] p-0 m-0 border-0 bg-transparent leading-none text-[0px] box-border -ml-5 [-webkit-tap-highlight-color:transparent]"
        >
          <div id="menu-icon" class="relative w-5 h-5 cursor-pointer">
            <span class="absolute left-0 top-0 w-full h-[3px] bg-[var(--color-primary)] rounded-[2px]"></span>
            <span class="absolute left-0 top-2 w-full h-[3px] bg-[var(--color-primary)] rounded-[2px]"></span>
            <span class="absolute left-0 top-4 w-full h-[3px] bg-[var(--color-primary)] rounded-[2px]"></span>
          </div>
        </button>

        {% assign alt_global = 'Global Komunika' %}
        {% if section.settings.logo != blank %}
          <a href="{{ routes.root_url }}" class="inline-flex items-center no-underline">
            {{
              section.settings.logo
              | image_url: width: 120
              | image_tag:
                class: 'header-content-logo',
                widths: '120, 240',
                sizes: '120px',
                alt: alt_global,
                loading: 'eager',
                fetchpriority: 'high',
                decoding: 'async',
                width: 120,
                height: 40
            }}
          </a>
        {% endif %}
      </div>

      <!-- MOBILE RIGHT -->
      <div class="flex md:hidden items-center gap-2.5" aria-label="Quick actions">
        {% if template.name == 'product' %}
          <button
            id="header-search-trigger-mobile"
            type="button"
            aria-label="Search"
            aria-haspopup="dialog"
            aria-controls="header-search-modal"
            class="mr-[10px]"
          >
            {% render 'icon-search', class: 'w-6 h-6 text-primary' %}
          </button>
        {% endif %}

        <a href="{{ routes.cart_url }}" aria-label="Cart" class="inline-flex items-center no-underline">
          <span class="relative inline-flex items-center">
            <img
              src="{{ 'header-cart.svg' | asset_url }}"
              alt="Cart"
              class="w-6 h-6 inline-block"
              width="24"
              height="24"
              loading="eager"
              decoding="async"
            >
            {% if cart.items.size > 0 %}
              <span
                class="absolute -top-1 -right-[6px] bg-[var(--color-primary)] text-[var(--color-neutral)] text-[10px] w-4 h-4 rounded-full inline-flex items-center justify-center text-center leading-none"
              >
                {{ cart.items.size }}
              </span>
            {% endif %}
          </span>
        </a>

        <a href="{{ profile_url }}" aria-label="Profile" class="inline-flex items-center no-underline">
          <img
            src="{{ 'header-profile.svg' | asset_url }}"
            alt="Profile"
            class="w-6 h-6 inline-block"
            width="24"
            height="24"
            loading="eager"
            decoding="async"
          >
        </a>
      </div>

      <!-- DESKTOP RIGHT -->
      <div class="hidden md:flex items-center gap-3">
        {% if template.name == 'product' %}
          <button
            id="header-search-trigger-desktop"
            type="button"
            aria-label="Search"
            aria-haspopup="dialog"
            aria-controls="header-search-modal"
            class="mr-[10px]"
          >
            {% render 'icon-search', class: 'w-6 h-6 text-primary' %}
          </button>
        {% endif %}

        <div class="flex items-center gap-2.5">
          <!-- Currency -->
          <!-- Currency (DESKTOP) -->
          <div class="relative inline-block" id="CurrencyForm-desktop">
            <button
              id="CurrencyTrigger-desktop"
              type="button"
              class="inline-flex items-center gap-3 px-2.5 py-2 transition select-none"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="CurrencyMenu-desktop"
            >
              <span class="inline-flex items-center">
                {{- 'header-currency.svg' | inline_asset_content -}}
              </span>
              <span id="CurrencyLabel-desktop" class="text-sm tracking-wider text-[var(--color-primary)]">USD</span>
              <span
                id="CurrencyArrow-desktop"
                class="inline-flex items-center justify-center rotate-90 transition-transform duration-200 origin-center"
                aria-hidden="true"
              >
                {% render 'icon-arrow-right', class: 'text-primary w-[30px] h-[30px]' %}
              </span>
            </button>

            <ul
              id="CurrencyMenu-desktop"
              class="hidden absolute right-0 top-[calc(100%+8px)] min-w-[120px] m-0 p-1.5 list-none bg-white border border-black/15 rounded-xl shadow-lg z-50"
              role="listbox"
              aria-label="Select currency"
            >
              <li role="option">
                <button
                  type="button"
                  data-currency="USD"
                  class="w-full flex items-center justify-between gap-2 text-[var(--color-primary)] px-2.5 py-2 rounded-xl text-sm hover:bg-black/5 transition"
                >
                  <span>USD</span>
                </button>
              </li>
              <li role="option">
                <button
                  type="button"
                  data-currency="IDR"
                  class="w-full flex items-center justify-between gap-2 text-[var(--color-primary)] px-2.5 py-2 rounded-xl text-sm hover:bg-black/5 transition"
                >
                  <span>IDR</span>
                </button>
              </li>
            </ul>
          </div>

          <!-- Language (DESKTOP) -->
          {% form 'localization', id: 'LanguageFormUX-desktop', class: 'relative inline-block' %}
            <input
              type="hidden"
              name="locale_code"
              id="LangLocaleInput-desktop"
              value="{{ localization.language.iso_code }}"
            >

            {% assign current_code = localization.language.iso_code | upcase | slice: 0, 2 %}

            <button
              id="LangTrigger-desktop"
              type="button"
              class="inline-flex items-center gap-2 px-2.5 py-2 transition select-none"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="LangMenu-desktop"
            >
              <span class="flex items-center w-[30px] h-[30px]" aria-hidden="true">
                {{- 'header-language.svg' | inline_asset_content -}}
              </span>

              <span class="text-sm tracking-wider text-[var(--color-primary)]">{{ current_code }}</span>

              <span
                id="LangArrow-desktop"
                class="inline-flex items-center justify-center rotate-90 transition-transform duration-200 origin-center"
                aria-hidden="true"
              >
                {% render 'icon-arrow-right', class: 'text-primary w-[30px] h-[30px]' %}
              </span>
            </button>

            <ul
              id="LangMenu-desktop"
              class="hidden absolute right-0 top-[calc(100%+8px)] min-w-[120px] m-0 p-1.5 list-none bg-white border border-black/15 rounded-xl shadow-lg z-50"
              role="listbox"
              aria-label="Select language"
            >
              {% for locale in localization.available_languages %}
                {% assign code = locale.iso_code | upcase | slice: 0, 2 %}
                <li
                  role="option"
                  aria-selected="{% if locale.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                >
                  <button
                    type="button"
                    class="w-full flex items-center justify-between gap-2 text-[var(--color-primary)] px-2.5 py-2 rounded-xl text-sm hover:bg-black/5 transition {% if locale.iso_code == localization.language.iso_code %}bg-black/10 font-semibold{% endif %}"
                    data-locale="{{ locale.iso_code }}"
                  >
                    <span>{{ code }}</span>
                    {% if locale.iso_code == localization.language.iso_code %}
                      <span class="opacity-80" aria-hidden="true">✓</span>
                    {% endif %}
                  </button>
                </li>
              {% endfor %}
            </ul>
          {% endform %}
        </div>

        <!-- Menu desktop -->
        <nav role="navigation" aria-label="Main navigation" class="flex items-center">
          <ul class="flex items-center gap-3.5 flex-wrap m-0 p-0 max-w-full list-none">
            {%- assign menu_item_class = 'inline-flex flex-col items-center justify-center gap-1 whitespace-nowrap font-bold leading-[1.1] text-[var(--color-primary)] no-underline' -%}
            {%- assign menu_label_class = 'text-sm font-[790] text-[var(--color-primary)]' -%}
            {%- assign icon_class = 'w-[26px] h-[26px] block' -%}

            <li>
              <a href="{{ routes.root_url }}" class="{{ menu_item_class }}">
                <img
                  src="{{ 'header-home.svg' | asset_url }}"
