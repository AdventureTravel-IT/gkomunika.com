                >
                <span class="{{ menu_label_class }}">Top Up</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/about-us" class="{{ menu_item_class }}">
                <img
                  src="{{ 'header-about.svg' | asset_url }}"
                  alt="About Us icon"
                  class="{{ icon_class }}"
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                >
                <span class="{{ menu_label_class }}">About Us</span>
              </a>
            </li>

            <li>
              <a href="{{ locale_prefix }}/pages/faq" class="{{ menu_item_class }}">
                <img
                  src="{{ 'header-faq.svg' | asset_url }}"
                  alt="FAQ icon"
                  class="{{ icon_class }}"
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
