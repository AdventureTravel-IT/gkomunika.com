                        <span class="opacity-80" aria-hidden="true">✓</span>
                      {% endif %}
                    </button>
                  </li>
                {% endfor %}
              </ul>
            {% endform %}
          </div>
        </div>
      </div>
    </div>
  </header>
{% endunless %}

<!-- SEARCH OVERLAY -->
<div id="header-search-overlay" class="fixed inset-0 bg-black/70 z-[9998]" hidden></div>

<!-- MENU MOBILE TOGGLE (ID-based) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('menu-toggle');
    const panel = document.getElementById('sidebar-panel');
    if (!btn || !panel) return;

    const OPEN_CLASSES = ['max-h-[calc(100vh-70px)]', 'opacity-100', 'pointer-events-auto'];
    const CLOSE_CLASSES = ['max-h-0', 'opacity-0', 'pointer-events-none'];

    const isOpen = () => btn.getAttribute('aria-expanded') === 'true';

    const open = () => {
      panel.classList.remove(...CLOSE_CLASSES);
      panel.classList.add(...OPEN_CLASSES);
      btn.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
    };

    const close = () => {
      panel.classList.remove(...OPEN_CLASSES);
      panel.classList.add(...CLOSE_CLASSES);
      btn.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
    };

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      isOpen() ? close() : open();
    });

    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      if (btn.contains(e.target)) return;
      if (panel.contains(e.target)) return;
      close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) close();
    });
  });
</script>

<!-- LANGUAGE DROPDOWN JS (Desktop + Mobile) -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initLang = (suffix) => {
      const form = document.getElementById(`LanguageFormUX-${suffix}`);
      if (!form) return;

      const btn = document.getElementById(`LangTrigger-${suffix}`);
      const menu = document.getElementById(`LangMenu-${suffix}`);
      const input = document.getElementById(`LangLocaleInput-${suffix}`);
      const arrowWrap = document.getElementById(`LangArrow-${suffix}`);

      if (!btn || !menu || !input) return;

      const open = () => {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (arrowWrap) arrowWrap.classList.add('rotate-[270deg]');
      };

      const close = () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (arrowWrap) arrowWrap.classList.remove('rotate-[270deg]');
      };

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        menu.classList.contains('hidden') ? open() : close();
      });

      menu.querySelectorAll('[data-locale]').forEach((item) => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          input.value = item.getAttribute('data-locale');
          form.submit();
        });
      });

      document.addEventListener('click', (e) => {
        if (!form.contains(e.target)) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    };

    initLang('desktop');
    initLang('mobile');
  });
</script>

<!-- SEARCH MODAL (Tailwind + ID-based triggers) -->
<script type="module" defer>
  (() => {
    const triggers = [
      document.getElementById('header-search-trigger-mobile'),
      document.getElementById('header-search-trigger-desktop'),
    ].filter(Boolean);

    const modal = document.getElementById('header-search-modal');
    const overlay = document.getElementById('header-search-overlay');
    const closeBtn = document.getElementById('header-search-close');

    if (!triggers.length || !modal || !overlay || !closeBtn) return;

    let lastTrigger = null;

    const open = (triggerEl) => {
      lastTrigger = triggerEl;
      overlay.hidden = false;
      modal.hidden = false;
      document.documentElement.style.overflow = 'hidden';

      const input = modal.querySelector('input, textarea, select, button');
      if (input) input.focus();
    };

    const close = () => {
      overlay.hidden = true;
      modal.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastTrigger) lastTrigger.focus();
    };

    triggers.forEach((btn) => btn.addEventListener('click', () => open(btn)));

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  })();
</script>

<!-- SEARCH MODAL MARKUP (Tailwind) -->
<div
