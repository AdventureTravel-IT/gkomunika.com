<div id="header-search-overlay" class="header-search-overlay" hidden></div>

<script type="module" defer>
  (() => {
    const triggers = document.querySelectorAll('.header-search-trigger');
    const modal = document.getElementById('header-search-modal');
    const overlay = document.getElementById('header-search-overlay');
    const closeBtn = document.getElementById('header-search-close');

    if (!triggers.length || !modal || !overlay || !closeBtn) return;

    let lastTrigger = null;

    const open = (triggerEl) => {
      lastTrigger = triggerEl;
      overlay.hidden = false;
      modal.hidden = false;
      document.documentElement.style.overflow = 'hidden';

      const input = modal.querySelector('input, textarea, select, button');
      if (input) input.focus();
    };

    const close = () => {
      overlay.hidden = true;
      modal.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastTrigger) lastTrigger.focus();
    };

    triggers.forEach((btn) => {
      btn.addEventListener('click', () => open(btn));
    });

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  })();
</script>

<div
  id="header-search-modal"
  class="header-search-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="header-search-title"
  hidden
>
  <div class="header-search-modal__inner">
    <div class="header-search-modal__header">
      <button id="header-search-close" type="button" class="header-search-modal__close" aria-label="Close search">
        {% render 'icon-close', class: 'icon-24 text-primary' %}
      </button>
    </div>

    <div class="header-search-modal__body">
      {% render 'search-bar', class: 'border border-slate-300 rounded-[15px]' %}
    </div>
  </div>
</div>

