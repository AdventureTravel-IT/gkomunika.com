{% style %}
  /* BANNER STYLE */
.banner-container {
  position: relative;
  width: 100%;
  max-width: 1920px;
  margin: 0 auto;
  height: 100%;
  background: transparent;
  display: flex;
  justify-content: center;
}

.banner__wrapper {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  height: 800px;
  overflow: visible;
}

.banner__image {
  position: absolute;
  bottom: 0;
  left: 70%;
  width: 100%;
  height: 100%;
  transform: translateX(-70%);
  object-fit: cover;
  z-index: 0;
  pointer-events: none;
  user-select: none;
}

.banner__content--wrapper {
  position: absolute;
  width: 100%;
  padding: 0 5% 0 10%;
  z-index: 1;
}

.banner__heading--text p,
.banner__heading--desc p {
  color: var(--color-neutral);
  margin: 0;
  font-size: 18x;
}

#default-heading {
  font-weight: bold;
  color: var(--color-neutral);
  margin: 0;
}

.banner__heading-text p {
  letter-spacing: 0.1em;
}

.banner__heading-desc {
  font-weight: bold;
}

.banner__heading--search {
  margin-top: 10px;
  max-width: 500px;
}

.cta-desktop {
  display: block;
  width: 470px;
  max-width: calc(100% - 100px);
  font-size: 18px;
  font-weight: bold;
  cursor: pointer;
  border-radius: 999px;
  border: 3px solid #fff;
  background: var(--color-primary);
  color: #fff;
  transition: transform 0.2s ease;
  text-decoration: none;
  text-align: center;
  position: absolute;
  right: 320px;
  bottom: -240px;
}

.cta-desktop:hover {
  transform: translateY(-3px);
  box-shadow: 0 3px 6px rgba(0, 0, 0, 0.3);
}

.cta-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  justify-content: flex-end;
  background-color: #f40932;
}

@media (max-width: 1680px) {
  .cta-desktop {
    position: absolute;
    right: 220px;
    bottom: -230px;
  }
}

@media (max-width: 1440px) {
  .banner__wrapper {
    height: 650px;
  }
  .cta-desktop {
    position: absolute;
    right: 160px;
    bottom: -170px;
  }
}

@media (max-width: 1366px) {
  .banner__wrapper {
    height: 550px;
  }
  .cta-desktop {
    position: absolute;
    right: 150px;
    bottom: -130px;
  }
}

@media (max-width: 1280px) {
  .cta-desktop {
    position: absolute;
    right: 120px;
    bottom: -150px;
  }
}

@media (max-width: 1024px) {
  .cta-desktop {
    position: absolute;
    right: 0;
    bottom: -150px;
  }
}

@media (max-width: 768px) {
  .banner__wrapper {
    height: 800px;
    overflow: hidden;
  }

  .banner__image {
    width: 100%;
    height: 800px;
    top: 0;
    bottom: auto;
    left: 70%;
    transform: translateX(-70%);
    object-fit: cover;
    object-position: 70% bottom;
  }

  .banner__content--wrapper {
    width: 100%;
    padding: 0 24px;
    position: absolute;
    top: 10px;
  }

  .banner__heading--search {
    width: 100%;
  }

  .banner__heading--text p,
  .banner__heading--desc p {
    color: var(--color-primary);
  }

  #default-heading {
    font-weight: bold;
    color: var(--color-primary);
  }

  .cta-desktop {
    position: absolute;
    right: 50px;
    bottom: -500px;
  }
}

@media (max-width: 426px) {
  .cta-desktop {
    width: 100%;
    font-size: 16px;
    max-width: none;
    position: absolute;
    right: 0;
    bottom: -480px;
  }
  .banner__heading--text p,
  #default-heading,
  .banner__heading--desc p {
    color: var(--color-primary);
  }
}

@media (max-width: 320px) {
  .cta-desktop {
    width: 300px;
    font-size: 14px;
    /* padding: 0 20px; */
    max-width: none;
    position: absolute;
    right: 0;
    bottom: -255px;
    white-space: nowrap;
  }
}
{% endstyle %}

<div class="banner-container">
  <div class="banner__wrapper">
    <img 
      class="banner__image"
      src="{{ section.settings.image | img_url: 'master' }}" 
      alt="Banner Image"
      fetchpriority="high"
    />
    <div class="banner__content--wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="text-[35px]"
              {{ block.shopify_attributes }}
              id="default-heading"
            >
              {{ block.settings.heading }}
            </h2>

            <h2
              class="banner__heading--result {{ block.settings.heading_size }}"
              id="search-heading"
              style="display: none;"
            >
              Search Result for “{{ search.terms }}”
            </h2>

          {%- when 'text' -%}
            <div class="banner__heading--text {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'desc' -%}
            <div class="banner__heading--desc{{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.desc }}</p>
            </div>
          {%- when 'search' -%}
            <div class="banner__heading--search">
              {% render 'search-bar' %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
      <div class="cta-wrapper">
        <a href="/pages/gsim" class="cta-desktop"> Learn more our latest product gSIM! </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Select Image"
    }
  ],
  "presets": [
    {
      "name": "Image Banner",
      "category": "Section"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading Text",
          "default": "Default Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ],
          "default": "h1",
          "label": "Heading Size"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Body Text",
          "default": "This is sample text."
        }
      ]
    },
    {
      "type": "desc",
      "name": "desc",
      "settings": [
        {
          "type": "text",
          "id": "desc",
          "label": "Body Text",
          "default": "This is sample text."
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Button 1 Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 Link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button 2 Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 Link"
        }
      ]
    },
    {
      "type": "search",
      "name": "Search Block",
      "limit": 1,
      "settings": []
    }
  ],
}
{% endschema %}