      <div class="gk-container gk-hero-inner">
        <div class="gk-hero-content">
          {%- if section.settings.hero_tagline != blank -%}
            <span class="gk-tagline-badge">
              {{ section.settings.hero_tagline }}
            </span>
          {%- endif -%}
          
          <h1 class="gk-hero-title">
            <span class="gk-hero-title-line">Internet di China</span>
            <span class="gk-hero-title-line">Tanpa Drama</span>
          </h1>
          
          <div class="gk-hero-price-wrapper">
            <div class="gk-hero-price">{{ section.settings.hero_price }}</div>
          </div>
          
          {%- if section.settings.hero_button_text != blank -%}
            <a
              href="{{ buy_now_url }}"
              class="gk-btn gk-add-to-cart"
              data-variant-id="{{ buy_now_variant_id | escape }}"
              data-cart-add-url="{{ routes.cart_add_url }}.js"
              data-cart-url="{{ routes.cart_url }}"
            >
              {{ section.settings.hero_button_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Mascot overlay -->
    {%- if section.settings.hero_mascot != blank -%}
      <img
        src="{{ section.settings.hero_mascot | image_url: width: 600 }}"
        alt="{{ section.settings.hero_mascot_alt | default: 'Mascot Global Komunika' | escape }}"
        class="gk-hero-mascot"
        width="600"
        height="600"
        loading="eager"
      >
    {%- elsif section.settings.hero_mascot_asset_filename != blank -%}
      <!-- Fallback: upload file ke Edit code > Assets, lalu samakan nama file di setting ini -->
      <img
        src="{{ section.settings.hero_mascot_asset_filename | asset_url }}"
        onerror="this.style.display='none'"
        alt="{{ section.settings.hero_mascot_alt | default: 'Mascot Global Komunika' | escape }}"
        class="gk-hero-mascot"
        width="600"
        height="600"
        loading="eager"
      >
    {%- endif -%}
    
    <div class="gk-hero-spacer"></div>
  </section>

  <!-- VALUE PROPOSITION (FEATURES) -->
  <section class="gk-features-section">
    <div class="gk-container">
      <div class="gk-section-header">
        <h2 class="gk-section-title">{{ section.settings.features_title }}</h2>
        {%- if section.settings.features_subtitle != blank -%}
          <p class="gk-section-subtitle">{{ section.settings.features_subtitle }}</p>
        {%- endif -%}
      </div>
      
      <div class="gk-features-grid">
        {%- assign feature_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            {%- assign feature_count = feature_count | plus: 1 -%}
            <div class="gk-feature-card{% if block.settings.highlight %} gk-feature-card-highlight{% endif %}" {{ block.shopify_attributes }}>
              <div class="gk-feature-card-header">
                <span class="gk-feature-number{% if block.settings.highlight %} gk-feature-number-highlight{% endif %}">
                  {%- if block.settings.number != blank -%}
                    {{ block.settings.number }}
                  {%- else -%}
                    {{ feature_count | prepend: '0' | slice: -2, 2 }}
                  {%- endif -%}
                </span>
                {%- if block.settings.highlight -%}
                  <span class="gk-feature-badge">Best value</span>
                {%- endif -%}
              </div>
              <h3 class="gk-feature-title">{{ block.settings.title }}</h3>
              <p class="gk-feature-body">{{ block.settings.body }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.hero_price != blank -%}
        <div class="gk-features-cta">
          <div class="gk-features-cta-label">eSIM China</div>
          <div class="gk-features-cta-price">{{ section.settings.hero_price }}</div>
          {%- if section.settings.hero_button_text != blank -%}
            <a
              href="{{ buy_now_url }}"
              class="gk-btn gk-add-to-cart"
              data-variant-id="{{ buy_now_variant_id | escape }}"
              data-cart-add-url="{{ routes.cart_add_url }}.js"
              data-cart-url="{{ routes.cart_url }}"
            >
              {{ section.settings.hero_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  <!-- SOCIAL PROOF (TESTIMONIALS) -->
  {%- assign has_testimonials = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'testimonial' -%}{%- assign has_testimonials = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- if has_testimonials -%}
    <section class="gk-testimonials-section">
      <div class="gk-container">
        {%- if section.settings.testimonials_title != blank -%}
          <h2 class="gk-testimonials-header">{{ section.settings.testimonials_title }}</h2>
        {%- endif -%}
        
        <div class="gk-carousel-wrapper">
          <div class="gk-carousel-slides">
            {%- assign testimonial_count = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <div class="gk-carousel-slide{% if testimonial_count == 0 %} active{% endif %}" data-index="{{ testimonial_count }}" {{ block.shopify_attributes }}>
                  <div class="gk-stars" aria-hidden="true">
                    {%- assign stars = block.settings.rating | default: 5 -%}
                    {%- for i in (1..stars) -%}★{%- endfor -%}
                  </div>
                  <p class="gk-quote">"{{ block.settings.quote }}"</p>
                  <div class="gk-author">{{ block.settings.name }}</div>
                </div>
                {%- assign testimonial_count = testimonial_count | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
          
          {%- if testimonial_count > 1 -%}
            <div class="gk-carousel-controls">
              <button type="button" class="gk-carousel-btn gk-prev" aria-label="Sebelumnya">←</button>
                <div class="gk-carousel-dots">
                  {%- for i in (1..testimonial_count) -%}
                    {%- assign index_zero = i | minus: 1 -%}
                    <button type="button" class="gk-carousel-dot{% if index_zero == 0 %} active{% endif %}" data-index="{{ index_zero }}" aria-label="Testimoni {{ i }}"></button>
                  {%- endfor -%}
                </div>
              <button type="button" class="gk-carousel-btn gk-next" aria-label="Selanjutnya">→</button>
            </div>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <!-- FAQ ACCORDION -->
  {%- assign has_faqs = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' -%}{%- assign has_faqs = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- if has_faqs -%}
    <section class="gk-faq-section">
      <div class="gk-container gk-faq-container">
        {%- if section.settings.faq_title != blank -%}
          <h2 class="gk-faq-title-main">{{ section.settings.faq_title }}</h2>
        {%- endif -%}
        
        <div class="gk-faq-list">
          {%- assign faq_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
