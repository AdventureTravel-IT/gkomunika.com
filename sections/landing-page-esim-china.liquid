          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

</div>

<script>
  (function() {
    function initGKSection(container) {
      if (!container) return;

      // Testimonials Carousel
      const carousels = container.querySelectorAll(".gk-carousel-wrapper");
      carousels.forEach(carousel => {
        const slides = carousel.querySelectorAll(".gk-carousel-slide");
        const dots = carousel.querySelectorAll(".gk-carousel-dot");
        const prevBtn = carousel.querySelector(".gk-prev");
        const nextBtn = carousel.querySelector(".gk-next");
        
        if (slides.length <= 1) return;
        
        let currentIndex = 0;
        
        function goToSlide(index) {
          slides[currentIndex].classList.remove("active");
          if (dots[currentIndex]) dots[currentIndex].classList.remove("active");
          
          currentIndex = (index + slides.length) % slides.length;
          
          slides[currentIndex].classList.add("active");
          if (dots[currentIndex]) dots[currentIndex].classList.add("active");
        }
        
        if (prevBtn) {
          prevBtn.onclick = (e) => {
            e.preventDefault();
            goToSlide(currentIndex - 1);
          };
        }
        if (nextBtn) {
          nextBtn.onclick = (e) => {
            e.preventDefault();
            goToSlide(currentIndex + 1);
          };
        }
        
        dots.forEach((dot, idx) => {
          dot.onclick = (e) => {
            e.preventDefault();
            goToSlide(idx);
          };
        });
      });

      // FAQ Accordion
      const faqItems = container.querySelectorAll(".gk-faq-item");
      faqItems.forEach(item => {
        const header = item.querySelector(".gk-faq-header");
        
        if (header) {
          header.onclick = (e) => {
            e.preventDefault();
            const isOpen = item.classList.contains("active");
            
            // Close other items in this section for a clean accordion effect
            const parentList = item.closest(".gk-faq-list");
            if (parentList) {
              parentList.querySelectorAll(".gk-faq-item").forEach(otherItem => {
                if (otherItem !== item) {
                  otherItem.classList.remove("active");
                  const otherHeader = otherItem.querySelector(".gk-faq-header");
                  if (otherHeader) otherHeader.setAttribute("aria-expanded", "false");
                }
              });
            }
            
            if (isOpen) {
              item.classList.remove("active");
              header.setAttribute("aria-expanded", "false");
            } else {
              item.classList.add("active");
              header.setAttribute("aria-expanded", "true");
            }
          };
        }
      });

      // Add the selected variant through Shopify Ajax Cart API, then open cart.
      const addToCartButtons = container.querySelectorAll(".gk-add-to-cart[data-variant-id]");
      addToCartButtons.forEach(button => {
        const variantId = button.dataset.variantId;
        if (!variantId) return;

        // Restore the button when this page is reopened from the browser cache.
        if (!button.dataset.originalText) {
          button.dataset.originalText = button.textContent.trim();
        }
        button.removeAttribute("aria-disabled");
        button.textContent = button.dataset.originalText;

        if (button.dataset.cartHandlerInitialized === "true") return;

        button.dataset.cartHandlerInitialized = "true";
        button.addEventListener("click", async (event) => {
          event.preventDefault();
          if (button.getAttribute("aria-disabled") === "true") return;

          const originalText = button.dataset.originalText;
          button.setAttribute("aria-disabled", "true");
          button.textContent = "Menambahkan...";

          try {
            const response = await fetch(button.dataset.cartAddUrl, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
              },
              body: JSON.stringify({
                items: [{
                  id: Number(variantId),
                  quantity: 1
                }]
              })
            });

            const result = await response.json();
            if (!response.ok) {
              throw new Error(result.description || "Produk tidak dapat ditambahkan ke cart.");
            }

            window.location.assign(button.dataset.cartUrl);
          } catch (error) {
            console.error("Add to cart failed:", error);
            window.alert(error.message || "Produk tidak dapat ditambahkan ke cart. Silakan coba lagi.");
            button.removeAttribute("aria-disabled");
            button.textContent = originalText;
          }
        });
      });
    }

    // Run on initial load
    document.addEventListener("DOMContentLoaded", () => {
      initGKSection(document.getElementById("gk-section-{{ section.id }}"));
    });

    // The pageshow event also runs when returning from cart with the Back button.
    window.addEventListener("pageshow", () => {
      initGKSection(document.getElementById("gk-section-{{ section.id }}"));
    });

    // Run when section loads/reloads in Shopify Theme Editor
    document.addEventListener("shopify:section:load", (event) => {
      if (event.target && event.target.querySelector("#gk-section-{{ section.id }}")) {
        initGKSection(event.target);
      }
    });
  })();
</script>

