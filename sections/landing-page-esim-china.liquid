                <div class="gk-faq-answer">
                  <p class="gk-faq-answer-inner">{{ block.settings.answer }}</p>
                </div>
              </div>
              {%- assign faq_count = faq_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <!-- FOUNDER NOTE -->
  <section class="gk-founder-section" style="background-color: {{ section.settings.founder_bg_color | default: '#005496' }};">
