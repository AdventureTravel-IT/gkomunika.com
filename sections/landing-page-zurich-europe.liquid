  border-radius:10px;padding:15px 36px;font-weight:700;font-size:16px;
  transition:opacity .2s,transform .2s;
}
.zurich-europe-landing .btn-cta2:hover{opacity:.9;transform:translateY(-2px);}

/* ===== FLOATING WA ===== */
.zurich-europe-landing .wa-btn{
  position:fixed;bottom:24px;right:24px;z-index:9999;
  width:58px;height:58px;border-radius:50%;
  background:#25D366;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(37,211,102,.5);
  animation:zurich-europe-pulse 2s infinite;
}
.zurich-europe-landing .wa-btn:hover{transform:scale(1.08);}
@keyframes zurich-europe-pulse{
  0%,100%{box-shadow:0 0 0 0 rgba(37,211,102,.6);}
  70%{box-shadow:0 0 0 14px rgba(37,211,102,0);}
}
.zurich-europe-landing .wa-btn svg{width:28px;height:28px;}

/* ===== RESPONSIVE ===== */
@media(max-width:768px){
