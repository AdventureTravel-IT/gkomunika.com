  text-align:left;padding:20px 0;
  display:flex;justify-content:space-between;align-items:center;
  font-family:'Gotham','Nunito',sans-serif;
  font-weight:700;font-size:15px;color:var(--dark);
}
.zurich-europe-landing .faq-icon{font-size:22px;color:var(--blue);font-weight:700;flex-shrink:0;transition:transform .3s;}
.zurich-europe-landing .faq-icon.open{transform:rotate(45deg);}
.zurich-europe-landing .faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.zurich-europe-landing .faq-a-inner{font-size:14px;color:var(--gray);padding:0 0 18px;}

/* ===== CTA2 ===== */
.zurich-europe-landing .cta2{background:var(--grad);text-align:center;color:#fff;padding:80px 0;}
.zurich-europe-landing .cta2-sub{font-size:20px;font-weight:700;opacity:.95;max-width:580px;margin:0 auto 32px;}
.zurich-europe-landing .btn-cta2{
