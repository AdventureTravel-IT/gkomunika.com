.zurich-europe-landing .section-title{font-size:28px;font-weight:700;color:var(--dark);text-align:center;margin-bottom:12px;}
.zurich-europe-landing .section-sub{text-align:center;color:var(--gray);margin-bottom:40px;max-width:560px;margin-left:auto;margin-right:auto;}
.zurich-europe-landing .pain-sub-highlight{text-align:center;font-size:16px;font-weight:700;color:var(--dark);margin:0 auto 36px;max-width:500px;}
.zurich-europe-landing .pain-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:36px;}
.zurich-europe-landing .pain-card{border:1.5px solid #D0E8F7;border-radius:var(--radius-md);padding:22px 20px;background:#fff;}
.zurich-europe-landing .pain-card-top{display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.zurich-europe-landing .pain-card-icon{width:44px;height:44px;border-radius:12px;background:#E6F4FC;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.zurich-europe-landing .pain-card h3{font-size:15px;font-weight:800;color:var(--dark);margin:0;}
.zurich-europe-landing .pain-card p{font-size:13.5px;color:var(--gray);line-height:1.55;}
.zurich-europe-landing .pain-closing{text-align:center;margin-top:36px;}
.zurich-europe-landing .pain-closing-inner{display:inline-block;font-size:20px;font-weight:900;padding:16px 32px;border:2.5px solid var(--dark);border-radius:12px;background:#fff;line-height:1.4;}
.zurich-europe-landing .pain-closing-normal{color:var(--dark);}
.zurich-europe-landing .pain-closing-accent{color:var(--blue);}

/* ===== COMBINED OFFER+PROMO SECTION ===== */
.zurich-europe-landing .offer-combined{background:linear-gradient(160deg,#003d72,#0092d0);color:#fff;text-align:center;padding:80px 0;}
.zurich-europe-landing .offer-eyebrow{display:inline-block;font-size:13px;font-weight:600;color:rgba(255,255,255,.85);position:relative;padding-bottom:4px;margin-bottom:14px;}
.zurich-europe-landing .offer-eyebrow::after{content:'';position:absolute;left:0;bottom:0;width:100%;height:2px;background:linear-gradient(90deg,#FBB526,transparent);}
.zurich-europe-landing .offer-combined h2{font-size:28px;font-weight:900;color:#fff;margin-bottom:6px;}
.zurich-europe-landing .offer-price-wrap{margin-bottom:28px;}
.zurich-europe-landing .offer-price-label{font-size:12px;font-weight:600;opacity:.5;display:block;margin-bottom:2px;}
.zurich-europe-landing .offer-price{font-size:28px;font-weight:900;color:#fff;}
.zurich-europe-landing .offer-benefits{display:grid;grid-template-columns:1fr 1fr;gap:10px 20px;max-width:540px;margin:0 auto 32px;}
.zurich-europe-landing .benefit-item{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);border-radius:9px;padding:10px 12px;font-size:13.5px;display:flex;align-items:center;gap:10px;text-align:left;}
.zurich-europe-landing .benefit-item .chk{width:20px;height:20px;border-radius:6px;background:#005496;display:flex;align-items:center;justify-content:center;font-size:11px;color:#fff;flex-shrink:0;font-weight:900;}
.zurich-europe-landing .offer-kalimat{font-size:14px;color:rgba(255,255,255,.75);max-width:440px;margin:0 auto 24px;line-height:1.65;}
.zurich-europe-landing .promo-card{background:#fff;border:2px solid var(--blue);border-radius:var(--radius-lg);padding:28px 32px;max-width:360px;margin:0 auto 28px;text-align:center;}
.zurich-europe-landing .promo-label{font-size:12px;font-weight:800;color:var(--blue);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;}
.zurich-europe-landing .promo-strike{font-size:18px;font-weight:800;color:#e05555;text-decoration:line-through;text-decoration-color:#e05555;text-decoration-thickness:2px;margin-bottom:6px;}
.zurich-europe-landing .promo-price{font-size:52px;font-weight:900;color:var(--dark);line-height:1;margin-bottom:8px;}
.zurich-europe-landing .promo-desc{font-size:13px;color:var(--gray);}
.zurich-europe-landing .btn-offer{display:inline-block;background:#FBB526;color:#005496;border-radius:10px;padding:14px 48px;font-weight:900;font-size:15px;transition:opacity .2s;}
.zurich-europe-landing .btn-offer:hover{opacity:.9;}

/* ===== TABLE SECTION ===== */
.zurich-europe-landing .table-section{background:#fff;}
.zurich-europe-landing .table-wrap{overflow-x:auto;margin-top:40px;border-radius:var(--radius-md);box-shadow:var(--shadow);}
.zurich-europe-landing .benefits-table{width:100%;border-collapse:collapse;font-size:13.5px;}
.zurich-europe-landing .benefits-table th{padding:14px 16px;font-weight:700;font-size:14px;}
.zurich-europe-landing .benefits-table td{padding:12px 16px;border:0.5px solid var(--border);}
.zurich-europe-landing .col-benefit{text-align:left;min-width:220px;}
.zurich-europe-landing .col-prime th{background:var(--dark);color:#fff;text-align:center;min-width:200px;}
.zurich-europe-landing .col-edge th{background:var(--blue);color:#fff;text-align:center;min-width:200px;}
.zurich-europe-landing .col-prime td,.zurich-europe-landing .col-edge td{text-align:center;color:#2a4a6b;}
.zurich-europe-landing .col-benefit td{color:#2a4a6b;}
.zurich-europe-landing .row-alt td{background:#F8FBFF;color:#2a4a6b;}
.zurich-europe-landing .row-cat td{background:#E6F4FC;font-weight:900;color:var(--dark);font-size:12.5px;letter-spacing:.06em;text-transform:uppercase;border-top:3px solid var(--blue);}
.zurich-europe-landing .table-mobile-cards{display:none;}

/* ===== SOCIAL PROOF ===== */
.zurich-europe-landing .social-proof{background:#F8F8F8;}
.zurich-europe-landing .testimonials{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:40px;}
.zurich-europe-landing .testi-card{
  background:#fff;border-radius:var(--radius-md);
  box-shadow:var(--shadow);padding:24px;
}
.zurich-europe-landing .testi-stars{color:#f5a623;font-size:16px;margin-bottom:4px;}
.zurich-europe-landing .testi-meta{font-size:12px;color:#aaa;margin-bottom:8px;}
.zurich-europe-landing .testi-name{font-size:13px;font-weight:700;color:var(--dark);margin-bottom:4px;}
.zurich-europe-landing .testi-variant{font-size:11px;color:var(--blue);margin-bottom:12px;}
.zurich-europe-landing .testi-text{font-size:13.5px;color:var(--gray);font-style:italic;}

/* ===== FAQ ===== */
.zurich-europe-landing .faq-section{background:#fff;}
.zurich-europe-landing .faq-list{max-width:700px;margin:40px auto 0;}
.zurich-europe-landing .faq-item{border-bottom:1px solid #eee;}
.zurich-europe-landing .faq-q{
