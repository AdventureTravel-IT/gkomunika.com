    top:80px;right:-15px;
    width:clamp(132px,38vw,180px);
  }
  .zurich-europe-landing .hero-image{width:100%;max-width:none;}
  .zurich-europe-landing .hero h1{
    position:relative;z-index:2;
    font-size:clamp(28px,8vw,38px);line-height:1.15;
