  --dark:#005496;
  --grad:linear-gradient(135deg,#00ADEE,#005496);
  --grad-rev:linear-gradient(135deg,#005496,#00ADEE);
  --light:#F0F8FF;
  --gray:#4a6080;
  --border:#e0eef8;
  --radius-sm:8px;
  --radius-md:12px;
  --radius-lg:16px;
  --shadow:0 4px 20px rgba(0,84,150,.10);
  --shadow-md:0 8px 32px rgba(0,84,150,.15);
}

/* ===== LAYOUT ===== */
.zurich-europe-landing .container{width:100%;max-width:1140px;margin:0 auto;padding:0 24px;}
.zurich-europe-landing .section{padding:80px 0;}

/* ===== HERO ===== */
.zurich-europe-landing .hero{background:var(--light);padding:80px 0;}
.zurich-europe-landing .hero-inner{display:flex;align-items:center;gap:48px;}
.zurich-europe-landing .hero-left{flex:1;min-width:0;}
.zurich-europe-landing .hero-right{flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.zurich-europe-landing .hero-image{display:block;width:100%;max-width:420px;height:auto;}
.zurich-europe-landing .badge-pill{
  display:inline-block;
  border:2px solid var(--blue);color:var(--dark);
  border-radius:999px;padding:5px 18px;font-size:13px;font-weight:700;
  margin-bottom:20px;
}
.zurich-europe-landing .hero h1{
  font-size:38px;font-weight:800;color:var(--dark);
  line-height:1.2;margin-bottom:16px;
}
.zurich-europe-landing .hero-sub{font-size:15px;color:var(--gray);margin-bottom:28px;max-width:480px;}
.zurich-europe-landing .hero-sub strong{color:var(--dark);}
.zurich-europe-landing .btn-hero{
  display:inline-block;
  background:var(--grad);color:#fff;
  border-radius:10px;padding:15px 32px;
  font-weight:800;font-size:16px;
  transition:opacity .2s,transform .2s;
  margin-bottom:20px;
}
.zurich-europe-landing .btn-hero:hover{opacity:.9;transform:translateY(-2px);}
.zurich-europe-landing .trust-badges{font-size:12px;color:var(--dark);font-weight:700;display:flex;flex-wrap:wrap;gap:16px;}

/* ===== PAIN SECTION ===== */
