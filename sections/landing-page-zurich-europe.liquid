  .zurich-europe-landing .btn-hero{
    position:relative;z-index:2;
    display:block;box-sizing:border-box;
    width:64%;max-width:340px;
    font-size:12px;line-height:1.35;text-align:center;
    padding:14px 10px;margin:0;
  }
  .zurich-europe-landing .trust-badges{
    display:flex;flex-direction:row;flex-wrap:nowrap;
    align-items:center;gap:10px;margin-top:14px;font-size:11px;
  }
  .zurich-europe-landing .section{padding:56px 0;}
  .zurich-europe-landing .section-title{font-size:22px;}
  .zurich-europe-landing .pain-grid{grid-template-columns:1fr;}
  .zurich-europe-landing .offer-benefits{grid-template-columns:1fr;}
  .zurich-europe-landing .promo-card{padding:24px 20px;}
  .zurich-europe-landing .testimonials{grid-template-columns:1fr;}
  .zurich-europe-landing .table-wrap{display:none;}
  .zurich-europe-landing .table-mobile-cards{display:block;margin-top:32px;}
  .zurich-europe-landing .mobile-benefit-card{background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);overflow:hidden;margin-bottom:16px;}
  .zurich-europe-landing .mobile-benefit-header{background:#EEF5FB;color:var(--dark);font-weight:700;font-size:13px;padding:10px 16px;letter-spacing:.04em;}
  .zurich-europe-landing .mobile-benefit-row{display:grid;grid-template-columns:1fr 1fr;border-top:0.5px solid var(--border);}
  .zurich-europe-landing .mobile-benefit-name{padding:10px 14px;font-size:13px;color:var(--gray);border-right:0.5px solid var(--border);}
  .zurich-europe-landing .mobile-benefit-vals{display:grid;grid-template-columns:1fr 1fr;}
  .zurich-europe-landing .mval{padding:10px 12px;font-size:12px;text-align:center;}
  .zurich-europe-landing .mval-header{font-weight:700;font-size:12px;padding:8px 12px;text-align:center;}
  .zurich-europe-landing .prime-h{background:var(--dark);color:#fff;}
  .zurich-europe-landing .edge-h{background:var(--blue);color:#fff;}
  .zurich-europe-landing .row-item{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:0.5px solid var(--border);}
  .zurich-europe-landing .ri-name{padding:10px 14px;font-size:13px;color:#2a4a6b;border-right:0.5px solid var(--border);grid-column:1;}
  .zurich-europe-landing .ri-prime,.zurich-europe-landing .ri-edge{padding:10px 10px;font-size:12px;text-align:center;color:#2a4a6b;}
  .zurich-europe-landing .ri-prime{border-right:0.5px solid var(--border);}
  .zurich-europe-landing .prime-h.ri-prime{color:#fff !important;}
  .zurich-europe-landing .edge-h.ri-edge{color:#fff !important;}
  .zurich-europe-landing .cta2{padding:56px 0;}
  .zurich-europe-landing .promo-card{padding:28px 24px;}
  .zurich-europe-landing .trust-badges{gap:10px;}
}
@media(prefers-reduced-motion:reduce){
  .zurich-europe-landing *{transition:none!important;animation:none!important;}
}
