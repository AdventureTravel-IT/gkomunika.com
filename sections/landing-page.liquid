  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const sid = '{{ sid }}';

      const viewport = document.getElementById(`reviewViewport-${sid}`);
      const track = document.getElementById(`reviewTrack-${sid}`);
      const prevBtn = document.getElementById(`reviewPrev-${sid}`);
      const nextBtn = document.getElementById(`reviewNext-${sid}`);
      const tpl = document.getElementById(`reviewSlideTpl-${sid}`);

      const modal = document.getElementById(`reviewModal-${sid}`);
      const modalImg = document.getElementById(`reviewModalImg-${sid}`);
      const modalClose = document.getElementById(`reviewModalClose-${sid}`);

      if (!viewport || !track || !prevBtn || !nextBtn || !tpl) return;

      // ===== DATA (5) =====
      const items = [
        {
          src: 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/fadya-landing-page-china-esim.avif?v=1768636213',
          alt: 'review',
        },
        {
          src: 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/widi-landing-page-china-esim.avif?v=1768636214',
          alt: 'review',
        },
        {
          src: 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/michael-landing-page-china-esim.avif?v=1768636214',
          alt: 'review',
        },
        {
          src: 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/andreas-landing-page-china-esim.avif?v=1768636213',
          alt: 'review',
        },
        {
          src: 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/yoelia-landing-page-china-esim.avif?v=1768636214',
          alt: 'review',
        },
      ];

      const MOD = (n, m) => ((n % m) + m) % m;

      // ===== SETTINGS =====
      const RENDER_COUNT = 7; // DOM ringan
      let startIndex = 0; // item paling kiri dalam track
      let step = 0;
      let isAnimating = false;

      const setTransition = (on) => {
        track.style.transition = on ? 'transform 320ms cubic-bezier(.22,.61,.36,1)' : 'none';
      };

      const applyX = (x) => {
        track.style.transform = `translate3d(${x}px,0,0)`;
      };

      const forceReflow = () => {
        // paksa browser nge-apply style (anti kedip)
        void track.offsetHeight;
      };

      const toSizedShopifyUrl = (url, width) => {
        try {
          const u = new URL(url);
          u.searchParams.set('width', String(width));
          return u.toString();
        } catch (e) {
          return url;
        }
      };

      const makeSlide = (idx) => {
        const node = tpl.content.firstElementChild.cloneNode(true);
        const img = node.querySelector('img');
        const item = items[MOD(idx, items.length)];

        img.src = toSizedShopifyUrl(item.src, 480);
        img.alt = item.alt;

        // OPTIONAL: srcset biar makin hemat
        img.srcset = `
    ${toSizedShopifyUrl(item.src, 240)} 240w,
    ${toSizedShopifyUrl(item.src, 360)} 360w,
    ${toSizedShopifyUrl(item.src, 480)} 480w,
    ${toSizedShopifyUrl(item.src, 640)} 640w
  `;
        img.sizes = '(max-width: 768px) 200px, 333px';

        return node;
      };

      const renderInitial = () => {
        track.innerHTML = '';
        for (let i = 0; i < RENDER_COUNT; i++) {
          track.appendChild(makeSlide(startIndex + i));
        }
        setTransition(false);
        applyX(0);
        forceReflow();
        setTransition(true);
      };

      const measureStep = () => {
        const c = track.children;
        if (!c || c.length < 2) return 0;
        const dist = c[1].offsetLeft - c[0].offsetLeft;
        return dist > 0 ? dist : c[0].getBoundingClientRect().width;
      };

      const refresh = () => {
        step = measureStep();
        setTransition(false);
        applyX(0);
        forceReflow();
        setTransition(true);
      };

      // ====== PREV (sudah benar) ======
      const goPrev = () => {
        if (isAnimating || !step) return;
        isAnimating = true;

        // mundur index dulu
        startIndex = MOD(startIndex - 1, items.length);

        // insert item baru di kiri
        const newLeft = makeSlide(startIndex);
        track.insertBefore(newLeft, track.firstElementChild);

        // kompensasi: geser -step tanpa animasi (biar visual tetap sama)
        setTransition(false);
        applyX(-step);
        forceReflow();

        // animasi balik ke 0 -> terlihat "muncul dari kiri"
        setTransition(true);
        applyX(0);

        track.addEventListener(
          'transitionend',
          () => {
            // hapus kanan biar count stabil
            if (track.children.length > RENDER_COUNT) {
              track.lastElementChild.remove();
            }
            isAnimating = false;
          },
          { once: true }
        );
      };

      // ====== NEXT (DIBIKIN SIMETRIS KAYAK PREV) ======
      const goNext = () => {
        if (isAnimating || !step) return;
        isAnimating = true;

        // append item baru di kanan
        const newRight = makeSlide(startIndex + RENDER_COUNT);
        track.appendChild(newRight);

        // animasi geser ke kiri 1 step -> terlihat "muncul dari kanan"
        setTransition(true);
        applyX(-step);

        track.addEventListener(
          'transitionend',
          () => {
            // ✅ BAGIAN PENTING: rapihin DOM + reset TANPA KEDIP
            setTransition(false);

            // hapus kiri 1
            if (track.firstElementChild) track.firstElementChild.remove();

            // update index kiri
            startIndex = MOD(startIndex + 1, items.length);

            // reset posisi balik ke 0
            applyX(0);
            forceReflow();

            // nyalakan lagi transisi
            setTransition(true);
            isAnimating = false;
          },
          { once: true }
        );
      };

      // ===== INIT =====
      renderInitial();
      requestAnimationFrame(() => requestAnimationFrame(refresh));
      window.addEventListener('load', refresh);
      window.addEventListener('resize', refresh);

      // ===== BUTTONS =====
      nextBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goNext();
      });

      prevBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goPrev();
      });

      // ===== DRAG / SWIPE (opsional) =====
      let isDragging = false;
      let startX = 0;
      let dragDx = 0;

      const onDown = (clientX) => {
        if (!step || isAnimating) return;
        isDragging = true;
        dragDx = 0;
        startX = clientX;

        viewport.classList.add('cursor-grabbing');
        setTransition(false);
        applyX(0);
      };

      const onMove = (clientX) => {
        if (!isDragging) return;
        dragDx = clientX - startX;
        applyX(dragDx);
      };

      const onUp = () => {
        if (!isDragging) return;
        isDragging = false;
        viewport.classList.remove('cursor-grabbing');

        const threshold = step * 0.25;
        setTransition(true);

        if (dragDx < -threshold) {
          setTransition(false);
          applyX(0);
          forceReflow();
          goNext();
          return;
        }

        if (dragDx > threshold) {
          setTransition(false);
          applyX(0);
          forceReflow();
          goPrev();
          return;
        }

        applyX(0);
      };

      viewport.addEventListener('mousedown', (e) => onDown(e.clientX));
      window.addEventListener('mousemove', (e) => onMove(e.clientX));
      window.addEventListener('mouseup', onUp);

      viewport.addEventListener(
        'touchstart',
        (e) => {
          if (!e.touches || !e.touches[0]) return;
          onDown(e.touches[0].clientX);
        },
        { passive: true }
      );

      viewport.addEventListener(
        'touchmove',
        (e) => {
          if (!e.touches || !e.touches[0]) return;
          onMove(e.touches[0].clientX);
        },
        { passive: true }
      );

      viewport.addEventListener('touchend', onUp);

      // ===== MODAL =====
      track.addEventListener('click', (e) => {
        const img = e.target.closest('img');
        if (!img) return;
        if (Math.abs(dragDx) > 6) return;

        modalImg.src = img.src;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });

      const closeModal = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modalImg.src = '';
      };

      modalClose.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });
    });
  </script>

