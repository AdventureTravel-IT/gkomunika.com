{% assign is_au = false %}
{% if request.path contains '/en-au' %}
  {% assign is_au = true %}
{% endif %}

{% style %}
  /* Chrome, Safari, Edge, Opera */
  input[type='number']::-webkit-outer-spin-button,
  input[type='number']::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Firefox */
  input[type='number'] {
    -moz-appearance: textfield;
    appearance: textfield;
  }
{% endstyle %}

<div data-cart-section data-section-id="{{ section.id }}" data-customer-logged-in="{% if customer %}1{% else %}0{% endif %}">

  <!-- Smart checkout data: di-render fresh setiap kali section di-fetch -->
  <script type="application/json" data-smart-checkout-data>
  [
  {%- for item in cart.items -%}
    {%- assign p = item.product -%}
    {%- assign sk = p.metafields.search.key.value -%}

    {%- capture sk_json -%}
    [
      {%- assign first = true -%}
      {%- if sk != blank -%}
        {%- for k in sk -%}
          {%- assign label = k.name.value
            | default: k.name
            | default: k.title.value
            | default: k.title
            | default: k.system.handle
            | default: ''
          -%}
          {%- unless label == blank -%}
            {%- unless first -%},{%- endunless -%}
            {{ label | json }}
            {%- assign first = false -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    ]
    {%- endcapture -%}

    {%- assign item_cat = p.metafields.product.category.value
      | default: p.metafields.product.category
      | default: ''
      | strip
    -%}

    {
      "productTitle":    {{ item.product.title | json }},
      "category":        {{ item_cat | json }},
      "variantType":     {{ item.variant.metafields.variant.type | json }},
      "variantTitle":    {{ item.variant.title | json }},
      "variantId":       {{ item.variant.id }},
      "quantity":        {{ item.quantity }},
      "variantCoverage": {{ sk_json | strip }},
      "defaultPurpose":  {{ item.variant.metafields.airport.purpose | json }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
  ]
  </script>

  {% if cart.item_count > 0 %}
    <!-- Header (HANYA tampil jika cart ada item) -->
    <div class="px-6 pt-10 md:pt-[100px] md:px-[10%] flex items-center justify-between">
      <h2 class="text-2xl md:text-[40px] text-primary">Your cart</h2>
      <a href="{{ routes.search_url }}" class="text-sm md:text-lg text-primary underline"> Continue shopping </a>
    </div>

    <!-- Desktop table header only (HANYA tampil jika cart ada item) -->
    <div class="pt-[20px] px-[24px] md:pt-20px md:px-[10%]">
      <div class="hidden md:flex justify-between text-primary items-center mt-10 border-b border-slate-300 pb-[20px]">
        <span>Product</span>
        <div class="flex gap-[250px] items-center">
          <span>Quantity</span>
          <span>Total</span>
        </div>
      </div>
    </div>

    <form action="{{ routes.cart_url }}" method="post" id="CartForm" class="wrapper md:wrapper-base">
      <div class="divide-y divide-slate-200">
        {% for item in cart.items %}
          {% assign p = item.product %}

          {%- assign mf_category = p.metafields.product.category -%}
          {%- assign category_value = '' -%}
          {%- if mf_category != blank -%}
            {%- if mf_category.value != blank -%}
              {%- assign category_value = mf_category.value -%}
            {%- else -%}
              {%- assign category_value = mf_category -%}
            {%- endif -%}
          {%- endif -%}

          {% assign days_value = item.properties.Days | default: '' %}
          {% assign data_plan_value = item.properties['Data Plan'] | default: '' %}

          {%- assign variant_purpose = '' -%}
          {%- if item.product.metafields.product.category.value == 'Airport_Transfer' -%}
            {%- assign variant_purpose = item.variant.metafields.airport.purpose -%}
            {%- assign auto_variantId = item.variant.metafields.airport.auto_variant.value.id | default: '' | json -%}
            {%- assign auto_variantTitle = item.variant.metafields.airport.auto_variant.value.title
              | default: ''
              | json
            -%}
          {%- endif -%}

          {%- assign raw_cat = category_value -%}
          {%- assign cat_label_display = raw_cat | replace: '_', ' ' -%}
          {%- if raw_cat contains 'Top_Up_' -%}
            {%- assign cat_label_display = 'Top Up Plan' -%}
          {%- elsif raw_cat == 'gSIM' -%}
            {%- assign cat_label_display = 'eSIM' -%}
          {%- endif -%}

          {%- comment -%}
            ============================================================
            UPSELL LOGIC (gSIM only)
            - Days harus sama
            - Big Data hanya ke Big Data
            - Unlimited hanya ke Unlimited
            - Previous tidak boleh di bawah harga original (item._original_variant_id)
            ============================================================
          {%- endcomment -%}

          {% assign current_variant_id = item.variant.id | plus: 0 %}
          {% assign current_variant_price = item.variant.price | plus: 0 %}
          {% assign current_option1 = item.variant.option1 | default: '' %}
          {% assign current_option2 = item.variant.option2 | default: '' %}
          {% assign current_option3 = item.variant.option3 | default: '' %}

          {% assign original_variant_id = item.properties._original_variant_id
            | default: current_variant_id
            | plus: 0
          %}
          {% assign original_variant_price = current_variant_price %}

          {% assign sorted_variants = item.product.variants | sort: 'price' %}
          {% assign next_variant = blank %}
          {% assign previous_variant = blank %}

          {% assign product_title_downcase = item.product.title | downcase %}
          {% assign is_gsim_upsell = false %}

          {% if product_title_downcase contains 'gsim' %}
            {% assign is_gsim_upsell = true %}
          {% endif %}

          {% assign current_plan_title = current_option2 %}
          {% if current_plan_title == blank %}
            {% assign current_plan_title = data_plan_value %}
          {% endif %}
          {% if current_plan_title == blank %}
            {% assign current_plan_title = item.variant.title %}
          {% endif %}

          {% assign current_plan_downcase = current_plan_title | downcase %}
          {% assign current_plan_family = 'other' %}

          {% if current_plan_downcase contains 'big data' %}
            {% assign current_plan_family = 'big_data' %}
          {% elsif current_plan_downcase contains 'unlimited' %}
            {% assign current_plan_family = 'unlimited' %}
          {% endif %}

          {% for v in sorted_variants %}
            {% assign v_id = v.id | plus: 0 %}
            {% if v_id == original_variant_id %}
              {% assign original_variant_price = v.price | plus: 0 %}
              {% break %}
            {% endif %}
          {% endfor %}

          {% if is_gsim_upsell == true and item.product.has_only_default_variant == false %}
            {% for v in sorted_variants %}
              {% if v.available %}
                {% assign v_id = v.id | plus: 0 %}
                {% assign v_price = v.price | plus: 0 %}

                {% assign same_group = false %}

                {% if v.option1 == current_option1 %}
                  {% assign same_group = true %}
                {% endif %}

                {% if same_group %}
                  {% if is_gsim_upsell %}
                    {% assign v_plan_title = v.option2 %}
                    {% if v_plan_title == blank %}
                      {% assign v_plan_title = v.title %}
                    {% endif %}

                    {% assign v_plan_downcase = v_plan_title | downcase %}
                    {% assign v_plan_family = 'other' %}

                    {% if v_plan_downcase contains 'big data' %}
                      {% assign v_plan_family = 'big_data' %}
                    {% elsif v_plan_downcase contains 'unlimited' %}
                      {% assign v_plan_family = 'unlimited' %}
                    {% endif %}

                    {% if v_plan_family != current_plan_family %}
                      {% assign same_group = false %}
                    {% endif %}
                  {% endif %}
                {% endif %}

                {% if same_group %}
                  {% if v_id != current_variant_id and v_price > current_variant_price and next_variant == blank %}
                    {% assign next_variant = v %}
                  {% endif %}

                  {% if v_id != current_variant_id
                    and v_price < current_variant_price
                    and v_price >= original_variant_price
                  %}
                    {% assign previous_variant = v %}
                  {% endif %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}

          <!-- ITEM WRAP (mobile tetap rapih, desktop seperti design yang kamu mau) -->
          <div
            class="py-7 relative md:static"
            data-cart-item
            data-line="{{ forloop.index }}"
            data-category="{{ category_value | escape }}"
          >
            <!-- DESKTOP LAYOUT WRAPPER -->
            <div class="md:flex md:items-start md:justify-between md:gap-6">
              <!-- LEFT: image + info -->
              <div class="flex items-start gap-4 md:gap-5">
                <div class="shrink-0 w-[84px] md:min-w-[133px]">
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 180 }}"
                      alt="{{ item.product.title | escape }}"
                      loading="lazy"
                      class="h-[84px] w-[84px] md:h-[100px] md:w-auto rounded-[10px] object-cover"
                      height="auto"
                      width="auto"
                    >
                  {% else %}
                    <div class="h-[84px] w-[84px] md:h-[100px] md:w-full rounded-[10px] bg-slate-100"></div>
                  {% endif %}
                </div>

                <div class="min-w-0 flex-1">
                  {%- if item.variant.available %}
                    <a
                      href="{{ item.url }}"
                      class="mb-2 block mr-[50px] text-base font-semibold text-primary underline"
                    >
                      {{ item.product.title }}
                    </a>
                  {% else %}
                    <span class="mb-2 block text-base font-semibold text-primary">
                      {{ item.product.title }}
                    </span>
                  {% endif %}

                  <div class="text-sm text-primary">
                    {{ item.final_price | money_with_currency -}}
                    {%- if is_au %} AUD{% endif %}
                  </div>

                  <!-- VARIANT OPTIONS -->
                  {% if item.product.has_only_default_variant == false %}
                    {% if item.variant.option1 != blank %}
                      <div class="text-sm text-primary">
                        <span>{{ item.product.options[0] }}:</span> {{ item.variant.option1 }}
                      </div>
                    {% endif %}

                    {% if item.variant.option2 != blank %}
                      <div class="text-sm text-primary">
                        <span>{{ item.product.options[1] }}:</span> {{ item.variant.option2 }}
                      </div>
                    {% endif %}

                    {% if item.variant.option3 != blank %}
                      <div class="text-sm text-primary">
                        <span>{{ item.product.options[2] }}:</span> {{ item.variant.option3 }}
                      </div>
                    {% endif %}
                  {% endif %}

                  <!-- MOBILE INFO ORDER -->
                  <div class="md:hidden">
                    {% if days_value != blank %}
                      <div class="mt-2 text-sm text-primary"><span>Days:</span> {{ days_value }}</div>
                    {% endif %}

                    {% if data_plan_value != blank %}
                      <div class="text-sm text-primary"><span>Data Plan:</span> {{ data_plan_value }}</div>
                    {% endif %}

                    {% if category_value != blank %}
                      <div class="text-sm text-primary"><span>Category:</span> {{ cat_label_display }}</div>
                    {% endif %}
                  </div>

                  <!-- DESKTOP INFO ORDER -->
                  <div class="hidden md:block">
                    {% if category_value != blank %}
                      <div class="text-sm text-primary"><span>Category:</span> {{ cat_label_display }}</div>
                    {% endif %}

                    {% if days_value != blank %}
                      <div class="mt-2 text-sm text-primary"><span>Days:</span> {{ days_value }}</div>
                    {% endif %}

                    {% if data_plan_value != blank %}
                      <div class="text-sm text-primary"><span>Data Plan:</span> {{ data_plan_value }}</div>
                    {% endif %}
                  </div>

                  <!-- ============================================================ -->
                  <!-- UPSELL RECOMMENDATION BLOCK (only show if next/prev exist)    -->
                  <!-- ============================================================ -->
                  {% if next_variant != blank or previous_variant != blank %}
                    <div class="mt-3 rounded-[12px] border border-slate-200 p-3 w-[calc(100vw-48px)] -ml-[100px] md:w-auto md:ml-0">
                      <div class="text-sm font-medium text-primary">Recommendation</div>

                      {%- assign current_locale = localization.language.iso_code
                        | default: request.locale.iso_code
                        | downcase
                      -%}

                      {% if next_variant != blank %}
                        {%- assign upgrade_variant_price = next_variant.price -%}
                        {%- assign upgrade_diff = upgrade_variant_price | minus: current_variant_price -%}

                        <div class="mt-1 text-sm text-primary">
                          {% if current_locale contains 'id' %}
                            Tambah
                            <strong>
                              {{ upgrade_diff | money_with_currency -}}
                              {%- if is_au %} AUD{% endif %}
                            </strong>
                            untuk upgrade ke paket yang lebih tinggi
                          {% else %}
                            Add
                            <strong>
                              {{ upgrade_diff | money_with_currency -}}
                              {%- if is_au %} AUD{% endif %}
                            </strong>
                            to get more quota
                          {% endif %}
                        </div>
                      {% endif %}

                      {% assign upsell_button_count = 0 %}
                      {% if previous_variant != blank %}
                        {% assign upsell_button_count = upsell_button_count | plus: 1 %}
                      {% endif %}
                      {% if next_variant != blank %}
                        {% assign upsell_button_count = upsell_button_count | plus: 1 %}
                      {% endif %}

                      <div class="mt-3 grid gap-2 {% if upsell_button_count == 2 %}grid-cols-2{% else %}grid-cols-1{% endif %} md:flex md:flex-wrap">
                        {% if previous_variant != blank %}
                          {% assign previous_plan_label = previous_variant.option2
                            | default: previous_variant.title
                            | split: ' / '
                            | last
                            | replace: ' Unlimited', ''
                            | replace: ' unlimited', ''
                            | replace: ' - Big Data', ''
                            | replace: ' - big data', ''
                            | strip
                          %}

                          <button
                            type="button"
                            class="w-full md:w-auto min-h-[56px] md:min-h-0 text-center inline-flex items-center justify-center rounded-lg bg-secondary leading-snug text-neutral border border-primary px-4 py-2 text-sm transition disabled:opacity-50 disabled:cursor-not-allowed"
                            data-upsell-variant-id="{{ previous_variant.id }}"
                            data-upsell-qty="{{ item.quantity }}"
                            data-upsell-line-key="{{ item.key }}"
                            data-upsell-properties="{{ item.properties | json | escape }}"
                            data-original-variant-id="{{ original_variant_id }}"
                            data-upsell-default-text="Previous Plan: {{ previous_plan_label | escape }}"
                            data-upsell-loading-text="Switching..."
                          >
                            {% render 'icon-arrow-left', class: 'w-6 h-6 text-neutral' %}
                            Previous Plan: {{ previous_plan_label }}
                          </button>
                        {% endif %}

                        {% if next_variant != blank %}
                          {% assign next_plan_label = next_variant.option2
                            | default: next_variant.title
                            | split: ' / '
                            | last
                            | replace: ' Unlimited', ''
                            | replace: ' unlimited', ''
                            | replace: ' - Big Data', ''
                            | replace: ' - big data', ''
                            | strip
                          %}

                          <button
                            type="button"
                            class="w-full md:w-auto min-h-[56px] md:min-h-0 text-center inline-flex items-center justify-center rounded-lg bg-primary leading-snug text-neutral border border-primary px-4 py-2 text-sm transition disabled:opacity-50 disabled:cursor-not-allowed"
                            data-upsell-variant-id="{{ next_variant.id }}"
                            data-upsell-qty="{{ item.quantity }}"
                            data-upsell-line-key="{{ item.key }}"
                            data-upsell-properties="{{ item.properties | json | escape }}"
                            data-original-variant-id="{{ original_variant_id }}"
                            data-upsell-default-text="Upgrade to: {{ next_plan_label | escape }}"
                            data-upsell-loading-text="Upgrading..."
                          >
                            Upgrade to: {{ next_plan_label }}
                            {% render 'icon-arrow-right', class: 'w-6 h-6 text-neutral' %}
                          </button>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                  <!-- END UPSELL BLOCK -->
                </div>
              </div>

              <!-- RIGHT: qty + remove + line total -->
              <div class="mt-4 flex w-full items-center justify-between md:mt-0 md:w-auto md:items-center md:justify-end md:gap-4">
                <!-- Qty Stepper -->
                <div class="flex items-center overflow-hidden rounded-full border h-[35px] border-primary">
                  <button
                    type="button"
                    class="text-base px-[10px] text-center flex justify-center items-center text-primary hover:bg-sky-50 disabled:opacity-50 disabled:cursor-not-allowed"
                    data-qty="minus"
                    data-line="{{ forloop.index }}"
                    aria-label="Decrease quantity"
                    {% if item.quantity <= 1 %}
                      disabled
                    {% endif %}
                  >
                    {% render 'icon-minus' %}
                  </button>

                  <input
                    class="
                      border-0 bg-transparent text-center text-sm text-primary focus:outline-none
                      w-[30px] min-w-[10px] max-w-[30px] flex-none p-0
                    "
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="1"
                    inputmode="numeric"
                    data-qty-input
                    data-line="{{ forloop.index }}"
                  >

                  <button
                    type="button"
                    class="text-base px-[10px] flex justify-center items-center text-primary hover:bg-sky-50 disabled:opacity-50 disabled:cursor-not-allowed"
                    data-qty="plus"
                    data-line="{{ forloop.index }}"
                    aria-label="Increase quantity"
                  >
                    {% render 'icon-plus' %}
                  </button>
                </div>

                <!-- Trash + Total -->
                <div class="flex items-center gap-3 md:gap-4">
                  <button
                    type="button"
                    class="inline-flex h-11 w-11 items-center justify-center rounded-full hover:bg-slate-100 disabled:opacity-50 disabled:cursor-not-allowed absolute top-[17px] right-0 md:static md:top-auto md:right-auto"
                    data-remove
                    data-line="{{ forloop.index }}"
                    aria-label="Remove item"
                    title="Remove"
                  >
                    {% render 'icon-trash', class: 'text-primary w-[24px] h-[24px]' %}
                  </button>

                  <div
                    class="min-w-[140px] text-right text-base text-primary relative"
                    data-line-total="{{ forloop.index }}"
                    aria-live="polite"
                  >
                    <span data-price-text class="text-primary">
                      {{ item.final_line_price | money_with_currency -}}
                      {%- if is_au %} AUD{% endif %}
                    </span>

                    <span
                      class="absolute inset-0 hidden items-center justify-center pointer-events-none"
                      data-price-loader
                      aria-hidden="true"
                    >
                      <span class="inline-flex w-[24px] h-[24px] items-center justify-center text-primary">
                        {% render 'loading', class: 'text-primary w-[24px] h-[24px]' %}
                      </span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Footer -->
      <div class="pt-8 border-t border-slate-200 mt-2">
        <div class="flex items-center justify-between md:justify-end gap-4">
          <div class="text-sm text-primary">Estimated total</div>

          <div class="text-base font-semibold text-primary relative text-right" data-cart-total aria-live="polite">
            <span data-price-text>
              {{- cart.total_price | money_with_currency -}}
              {%- if is_au %} AUD{% endif -%}
            </span>

            <span
              class="absolute inset-0 hidden items-center justify-center pointer-events-none"
              data-price-loader
              aria-hidden="true"
            >
              <span class="inline-flex w-[24px] h-[24px] items-center justify-center text-primary">
                {% render 'loading', class: 'text-primary w-[24px] h-[24px]' %}
              </span>
            </span>
          </div>
        </div>

        <div class="mt-3 text-center md:text-right text-sm text-primary">
          Taxes, discounts and shipping calculated at checkout.
        </div>
      </div>

      {% assign hasInsuranceProduct = false %}
      {% assign hasAirportTransfer = false %}
      {% for item in cart.items %}
        {% assign cat = item.product.metafields.product.category.value
          | default: item.product.metafields.product.category
          | default: ''
          | strip
        %}
        {% if cat == 'Insurance' %}
          {% assign hasInsuranceProduct = true %}
        {% endif %}
        {% if cat == 'Airport_Transfer' %}
          {% assign hasAirportTransfer = true %}
        {% endif %}
      {% endfor %}

      <div class="mt-6 flex justify-center md:justify-end">
        {% if hasInsuranceProduct or hasAirportTransfer %}
          <button
            type="button"
            id="checkout-smart-unified"
            class="inline-flex items-center justify-center rounded-full bg-primary w-[350px] py-3 text-base tracking-wide text-neutral hover:bg-primary/70 focus:outline-none focus-visible:ring-4 transition"
          >
            Checkout
          </button>
        {% else %}
          <button
            type="submit"
            name="checkout"
            class="inline-flex items-center justify-center rounded-full bg-primary w-[350px] py-3 text-base tracking-wide text-neutral hover:bg-primary/70 focus:outline-none focus-visible:ring-4 transition"
          >
            Checkout
          </button>
        {% endif %}
      </div>
    </form>

  {% else %}
    <!-- EMPTY CART FALLBACK (HANYA ini yang tampil saat empty) -->
    <section class="wrapper md:wrapper-base">
      <div class="min-h-[320px] md:min-h-[420px] flex items-center justify-center">
        <div class="w-full max-w-[520px] text-center px-4 py-14 md:py-20">
          <h2 class="text-[30px] leading-tight font-medium text-primary">Your cart is empty</h2>

          <div class="mt-8 flex justify-center">
            <a
              href="{{ pages['all-destination'].url }}"
              class="
                inline-flex items-center justify-center rounded-full bg-sky-700 px-8 h-12 md:h-14 text-white font-semibold
                hover:bg-sky-800 focus:outline-none focus-visible:ring-4 focus-visible:ring-sky-200 transition
              "
            >
              Continue shopping
            </a>
          </div>

          <div class="mt-10 md:mt-12 text-primary">
            <div class="text-[24px] font-medium">Have an account?</div>
            <a
              href="/account/login"
              class="mt-3 inline-block text-base underline underline-offset-4 hover:opacity-80 transition"
            >
              Log in to check out faster.
            </a>
          </div>
        </div>
      </div>
    </section>
  {% endif %}
</div>

<script>
  // ============================================================
  // CART AJAX (NO FULL RELOAD)
  // - Pakai window.* state supaya tidak duplikat saat section
  //   re-render via Section Rendering API
  // - Listener idempotent (guard flag di window)
  // - cartBusy direset defensive di setiap exit path
  // ============================================================
  (function () {
    // ---- Single-instance guard ----
    // Kalau script ini sudah pernah inisialisasi listener di document,
    // jangan attach ulang. Cukup reset state-nya saja.
    if (window.__cartAjaxInit) {
      // Reset busy flag (kalau sebelumnya stuck), lalu sync UI tombol minus
      window.__cartBusy = false;
      try {
        document.querySelectorAll('input[data-qty-input][data-line]').forEach((input) => {
          const line = parseInt(input.getAttribute('data-line'), 10);
          let val = parseInt(input.value || '1', 10);
          if (isNaN(val) || val < 1) val = 1;
          input.value = val;
          const minus = document.querySelector(`button[data-qty="minus"][data-line="${line}"]`);
          if (minus) minus.disabled = val <= 1;
        });
      } catch (e) {}
      return;
    }
    window.__cartAjaxInit = true;
    window.__cartBusy = false;

    // ---- DOM helpers ----
    function getCartRoot() {
      return document.querySelector('[data-cart-section]');
    }

    function setControlsDisabled(line, disabled) {
      const minus = document.querySelector(`button[data-qty="minus"][data-line="${line}"]`);
      const plus = document.querySelector(`button[data-qty="plus"][data-line="${line}"]`);
      const remove = document.querySelector(`button[data-remove][data-line="${line}"]`);
      const input = document.querySelector(`input[data-qty-input][data-line="${line}"]`);
      [minus, plus, remove, input].forEach((el) => {
        if (!el) return;
        el.disabled = !!disabled;
      });
    }

    function togglePriceBox(box, isLoading) {
      if (!box) return;
      const text = box.querySelector('[data-price-text]');
      const loader = box.querySelector('[data-price-loader]');
      if (!text || !loader) return;
      if (isLoading) {
        text.classList.add('opacity-0');
        loader.classList.remove('hidden');
        loader.classList.add('flex');
      } else {
        text.classList.remove('opacity-0');
        loader.classList.add('hidden');
        loader.classList.remove('flex');
      }
    }

    function setInlinePriceLoading(line, isLoading) {
      togglePriceBox(document.querySelector(`[data-line-total="${line}"]`), isLoading);
      togglePriceBox(document.querySelector('[data-cart-total]'), isLoading);
    }

    function setCartTotalLoading(isLoading) {
      togglePriceBox(document.querySelector('[data-cart-total]'), isLoading);
    }

    async function refreshCartSection() {
      const root = getCartRoot();
      if (!root) return;

      const sectionId = root.getAttribute('data-section-id');
      const url = `${window.location.pathname}?section_id=${encodeURIComponent(sectionId)}`;

      const html = await fetch(url, { headers: { Accept: 'text/html' } }).then((r) => r.text());
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const newRoot = doc.querySelector('[data-cart-section]');

      if (!newRoot) {
        console.warn('Failed to find [data-cart-section] in response.');
        return;
      }

      // Replace DOM. Script type=application/json di dalam section
      // tidak perlu di-execute (cuma data); akan dibaca via JSON.parse
      // saat smart checkout di-klik, jadi selalu fresh.
      root.replaceWith(newRoot);
    }
    // Export buat skrip lain (purge blocked items, dll)
    window.refreshCartSection = refreshCartSection;

    // ---- API helpers ----
    async function cartChange(line, quantity) {
      if (window.__cartBusy) return;
      window.__cartBusy = true;
      setInlinePriceLoading(line, true);
      setControlsDisabled(line, true);

      try {
        const res = await fetch('{{ routes.cart_change_url }}.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ line, quantity }),
        });

        if (!res.ok) {
          let errText = '';
          try { errText = await res.text(); } catch (_) {}
          console.error('Cart change failed:', errText);
          alert('Gagal update cart. Coba lagi ya.');
          setInlinePriceLoading(line, false);
          setControlsDisabled(line, false);
          return;
        }

        await refreshCartSection();
      } catch (e) {
        console.error(e);
        alert('Terjadi error koneksi. Coba lagi ya.');
        setInlinePriceLoading(line, false);
        setControlsDisabled(line, false);
      } finally {
        window.__cartBusy = false;
      }
    }

    async function addVariantToCart(variantId, quantity, properties = {}) {
      const payload = { items: [{ id: variantId, quantity: quantity }] };
      if (properties && Object.keys(properties).length > 0) {
        payload.items[0].properties = properties;
      }
      const res = await fetch('{{ routes.cart_add_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        let errText = '';
        try { errText = await res.text(); } catch (_) {}
        console.error('Add replacement variant failed:', errText);
        throw new Error('Failed to add replacement variant');
      }
      return res.json();
    }

    async function removeCartItemByKey(lineKey) {
      const res = await fetch('{{ routes.cart_change_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ id: lineKey, quantity: 0 }),
      });
      if (!res.ok) {
        let errText = '';
        try { errText = await res.text(); } catch (_) {}
        console.error('Remove old variant failed:', errText);
        throw new Error('Failed to remove old variant');
      }
      return res.json();
    }

    async function getCartJson() {
      const res = await fetch('{{ routes.cart_url }}.js', { headers: { Accept: 'application/json' } });
      if (!res.ok) throw new Error('Failed to get cart');
      return res.json();
    }

    async function changeCartItemByKey(lineKey, quantity) {
      const res = await fetch('{{ routes.cart_change_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ id: lineKey, quantity }),
      });
      if (!res.ok) {
        let errText = '';
        try { errText = await res.text(); } catch (_) {}
        console.error('Change cart item by key failed:', errText);
        throw new Error('Failed to change cart item by key');
      }
      return res.json();
    }

    async function replaceUpsellVariant(variantId, quantity, lineKey, properties, triggerBtn, originalVariantId) {
      if (window.__cartBusy) return;
      window.__cartBusy = true;
      setCartTotalLoading(true);

      // Defensive UI update — node bisa saja sudah didetach kalau user double-klik
      const safeBtnUpdate = (btn, action) => {
        try {
          if (!btn || !btn.isConnected) return;
          action(btn);
        } catch (_) {}
      };
      safeBtnUpdate(triggerBtn, (b) => {
        b.disabled = true;
        b.style.opacity = '0.7';
        b.textContent = b.getAttribute('data-upsell-loading-text') || 'Processing...';
      });

      try {
        const finalProperties = { ...(properties || {}) };
        if (!finalProperties._original_variant_id) {
          finalProperties._original_variant_id = String(originalVariantId || '');
        }

        const cart = await getCartJson();
        const existingTargetItem = (cart.items || []).find((cartItem) => {
          return Number(cartItem.variant_id) === Number(variantId) && cartItem.key !== lineKey;
        });

        if (existingTargetItem) {
          const existingQty = parseInt(existingTargetItem.quantity || '0', 10) || 0;
          const addQty = parseInt(quantity || '1', 10) || 1;
          await changeCartItemByKey(existingTargetItem.key, existingQty + addQty);
          await removeCartItemByKey(lineKey);
        } else {
          await addVariantToCart(variantId, quantity, finalProperties);
          await removeCartItemByKey(lineKey);
        }

        await refreshCartSection();
      } catch (e) {
        console.error(e);
        alert('Gagal mengganti variant. Coba lagi ya.');
        setCartTotalLoading(false);
        safeBtnUpdate(triggerBtn, (b) => {
          b.disabled = false;
          b.style.opacity = '';
          b.textContent = b.getAttribute('data-upsell-default-text') || 'Upgrade';
        });
      } finally {
        // ⚠️ WAJIB direset apapun yang terjadi
        window.__cartBusy = false;
      }
    }

    function syncMinusDisabled(line, qty) {
      const minus = document.querySelector(`button[data-qty="minus"][data-line="${line}"]`);
      if (!minus) return;
      minus.disabled = qty <= 1;
    }

    // ---- Delegated listeners (attached ONCE on document) ----
    document.addEventListener('click', (e) => {
      const btnQty = e.target.closest('button[data-qty]');
      const btnRemove = e.target.closest('button[data-remove]');
      const btnUpsell = e.target.closest('button[data-upsell-variant-id]');

      // Pastikan tombol benar-benar berada di dalam cart section saat ini
      // (mencegah trigger pada tombol-tombol "hantu" hasil section render lama)
      if (btnQty || btnRemove || btnUpsell) {
        const root = getCartRoot();
        if (!root) return;
        const target = btnQty || btnRemove || btnUpsell;
        if (!root.contains(target)) return;
      }

      if (btnQty) {
        const line = parseInt(btnQty.getAttribute('data-line'), 10);
        const type = btnQty.getAttribute('data-qty');
        const input = document.querySelector('input[data-qty-input][data-line="' + line + '"]');
        let val = parseInt(input?.value || '1', 10);
        if (isNaN(val) || val < 1) val = 1;
        if (type === 'plus') val += 1;
        if (type === 'minus') val = Math.max(1, val - 1);
        if (input) input.value = val;
        syncMinusDisabled(line, val);
        cartChange(line, val);
        return;
      }

      if (btnRemove) {
        const line = parseInt(btnRemove.getAttribute('data-line'), 10);
        cartChange(line, 0);
        return;
      }

      if (btnUpsell) {
        // Block double-click di tombol yang sama
        if (btnUpsell.dataset.upsellLoading === '1') return;
        btnUpsell.dataset.upsellLoading = '1';

        const variantId = parseInt(btnUpsell.getAttribute('data-upsell-variant-id'), 10);
        const quantity = parseInt(btnUpsell.getAttribute('data-upsell-qty') || '1', 10);
        const lineKey = btnUpsell.getAttribute('data-upsell-line-key') || '';
        const propertiesRaw = btnUpsell.getAttribute('data-upsell-properties') || '{}';
        const originalVariantId = parseInt(btnUpsell.getAttribute('data-original-variant-id') || '0', 10);

        let properties = {};
        try { properties = JSON.parse(propertiesRaw); } catch (_) { properties = {}; }

        if (!variantId || !quantity || !lineKey) {
          btnUpsell.dataset.upsellLoading = '0';
          return;
        }

        replaceUpsellVariant(variantId, quantity, lineKey, properties, btnUpsell, originalVariantId);
        return;
      }
    });

    document.addEventListener('change', (e) => {
      const input = e.target.closest('input[data-qty-input]');
      if (!input) return;

      const root = getCartRoot();
      if (!root || !root.contains(input)) return;

      const line = parseInt(input.getAttribute('data-line'), 10);
      let val = parseInt(input.value || '1', 10);
      if (isNaN(val) || val < 1) val = 1;
      input.value = val;
      syncMinusDisabled(line, val);
      cartChange(line, val);
    });

    // Init sync minus button on first load
    function initSync() {
      document.querySelectorAll('input[data-qty-input][data-line]').forEach((input) => {
        const line = parseInt(input.getAttribute('data-line'), 10);
        let val = parseInt(input.value || '1', 10);
        if (isNaN(val) || val < 1) val = 1;
        input.value = val;
        syncMinusDisabled(line, val);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSync);
    } else {
      initSync();
    }

    // Safety net: kalau tab di-show kembali (bfcache), reset busy flag
    window.addEventListener('pageshow', () => {
      window.__cartBusy = false;
    });
  })();
</script>

<script>
  // =========================
  // AUTO-REMOVE BLOCKED CATEGORY (silent, no alert)
  // - jalan sekali per page load saja
  // =========================
  (function () {
    if (window.__cartPurgeInit) return;
    window.__cartPurgeInit = true;

    const BLOCKED = new Set(['Top_Up_A', 'Top_Up_B', 'Top_Up_C', 'Top_Up_D']);
    let purgeBusy = false;

    async function removeLineSilent(line) {
      await fetch('{{ routes.cart_change_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ line, quantity: 0 }),
      });
    }

    async function purgeBlockedItems() {
      if (purgeBusy) return;
      purgeBusy = true;

      try {
        const nodes = Array.from(document.querySelectorAll('[data-cart-item][data-line][data-category]'));
        if (!nodes.length) return;

        const linesToRemove = nodes
          .map((el) => {
            const cat = (el.getAttribute('data-category') || '').trim();
            const line = parseInt(el.getAttribute('data-line') || '0', 10);
            if (!line || !cat) return null;
            if (!BLOCKED.has(cat)) return null;
            return line;
          })
          .filter(Boolean);

        if (!linesToRemove.length) return;
        linesToRemove.sort((a, b) => b - a);

        for (const line of linesToRemove) {
          await removeLineSilent(line);
        }

        if (typeof window.refreshCartSection === 'function') {
          await window.refreshCartSection();
        } else {
          window.location.reload();
        }
      } catch (e) {
        console.warn('Auto-remove blocked items failed', e);
      } finally {
        purgeBusy = false;
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', purgeBlockedItems);
    } else {
      purgeBlockedItems();
    }
  })();
</script>

