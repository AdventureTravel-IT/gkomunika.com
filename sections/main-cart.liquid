<script>
  // ============================================================
  // SMART UNIFIED CHECKOUT
  // Handles: Insurance only | Airport Transfer only | Both
  // - Pakai event delegation supaya tetap jalan setelah section
  //   re-render (tombol baru dari refreshCartSection)
  // ============================================================
  (function () {
    if (window.__smartCheckoutInit) return;
    window.__smartCheckoutInit = true;

    function buildProductItems() {
      const items = [];
      // Selalu ambil ulang dari DOM cart yang aktual via Shopify cart.js,
      // tapi karena Liquid sudah di-render saat page load, kita rebuild
      // setiap kali user klik dengan fetch /cart.js
      return items;
    }

    function purposeLabelToValue(label) {
      const s = String(label || '').trim().toLowerCase();
      if (s === 'city to airport' || s.includes('city_to_airport')) return 'city_to_airport';
      if (s === 'airport to city' || s.includes('airport_to_city')) return 'airport_to_city';
      return '';
    }

    function readSmartCheckoutData() {
      const root = document.querySelector('[data-cart-section]');
      if (!root) return { items: [], loggedIn: false };
      const dataEl = root.querySelector('script[type="application/json"][data-smart-checkout-data]');
      let items = [];
      if (dataEl) {
        try {
          items = JSON.parse(dataEl.textContent || '[]') || [];
        } catch (e) {
          console.warn('Failed to parse smart checkout data:', e);
          items = [];
        }
      }
      const loggedIn = root.getAttribute('data-customer-logged-in') === '1';
      return { items, loggedIn };
    }

    async function handleSmartCheckout(btn) {
      if (btn.dataset.loading === '1') return;
      btn.dataset.loading = '1';
      btn.disabled = true;
      btn.style.opacity = '0.7';
      const originalText = btn.textContent;
      btn.textContent = 'Processing...';

      try {
        // Clear semua storage lama
        sessionStorage.removeItem('ProductItems');
        localStorage.removeItem('ProductItems');
        sessionStorage.removeItem('CheckoutFlow');
        localStorage.removeItem('CheckoutFlow');
        sessionStorage.removeItem('AT_Purposes');
        localStorage.removeItem('AT_Purposes');

        // ✅ Baca FRESH data dari DOM (selalu sinkron dengan cart terbaru)
        const { items: ProductItems, loggedIn } = readSmartCheckoutData();

        if (ProductItems.length === 0) {
          alert('Cart is empty.');
          btn.dataset.loading = '0';
          btn.disabled = false;
          btn.style.opacity = '';
          btn.textContent = originalText;
          return;
        }

        sessionStorage.setItem('ProductItems', JSON.stringify(ProductItems));
        localStorage.setItem('ProductItems', JSON.stringify(ProductItems));

        // ── Build AT_Purposes untuk item Airport Transfer ──
        const transferItems = ProductItems.filter((i) => i.category === 'Airport_Transfer');
        if (transferItems.length) {
          const purposes = [];
          transferItems.forEach((item) => {
            const qty = parseInt(item.quantity, 10) || 1;
            const lockedPurpose = item.defaultPurpose ? purposeLabelToValue(item.defaultPurpose) : '';
            for (let i = 0; i < qty; i++) {
              if (i === 0) purposes.push(lockedPurpose);
              else purposes.push('');
            }
          });
          sessionStorage.setItem('AT_Purposes', JSON.stringify(purposes));
          localStorage.setItem('AT_Purposes', JSON.stringify(purposes));
        }

        const hasInsurance = ProductItems.some((i) => i.category === 'Insurance');
        const hasTransfer = ProductItems.some((i) => i.category === 'Airport_Transfer');

        const flow = {
          hasInsurance,
          hasTransfer,
          steps: [
            ...(hasTransfer ? ['transfer'] : []),
            ...(hasInsurance ? ['insurance'] : []),
          ],
          currentStepIndex: 0,
        };
        sessionStorage.setItem('CheckoutFlow', JSON.stringify(flow));
        localStorage.setItem('CheckoutFlow', JSON.stringify(flow));

        const firstStep = flow.steps[0];
        const targetUrl = firstStep === 'insurance' ? '/pages/form-insurance' : '/pages/form-airport-transfer';

        if (loggedIn) {
          window.location.href = targetUrl;
        } else {
          window.location.href = `/account/login?return_url=${encodeURIComponent(targetUrl)}`;
        }
      } catch (e) {
        console.error('Smart checkout error', e);
        btn.dataset.loading = '0';
        btn.disabled = false;
        btn.style.opacity = '';
        btn.textContent = originalText;
      }
    }

    document.addEventListener('click', (e) => {
      const smartBtn = e.target.closest('#checkout-smart-unified');
      if (smartBtn) {
        handleSmartCheckout(smartBtn);
        return;
      }

      // Submit checkout button (type=submit name=checkout)
      const submitBtn = e.target.closest('button[type="submit"][name="checkout"]');
      if (submitBtn) {
        if (submitBtn.dataset.loading === '1') return;
        submitBtn.dataset.loading = '1';
        submitBtn.style.opacity = '0.7';
        submitBtn.style.pointerEvents = 'none';
        submitBtn.textContent = 'Processing...';
        // Form submit tetap jalan natural, tidak preventDefault
      }

      // Continue Shopping & link navigasi internal
      const link = e.target.closest('a[href]');
      if (link) {
        const href = link.getAttribute('href') || '';
        if (!href || href.startsWith('#') || href.startsWith('javascript')) return;
        if (link.hostname && link.hostname !== window.location.hostname) return;
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (link.dataset.loading === '1') return;
        // Skip kalau ini tombol upsell / qty / remove (sudah ditangani di blok lain)
        if (link.matches('button')) return;

        link.dataset.loading = '1';
        link.style.opacity = '0.6';
        link.style.pointerEvents = 'none';
      }
    });

    // Reset loading state saat user balik via bfcache
    window.addEventListener('pageshow', () => {
      document.querySelectorAll('[data-loading="1"]').forEach((el) => {
        el.dataset.loading = '0';
        el.style.opacity = '';
        el.style.pointerEvents = '';
        if (el.id === 'checkout-smart-unified') {
          el.disabled = false;
          el.textContent = 'Checkout';
        } else if (el.matches('button[type="submit"][name="checkout"]')) {
          el.textContent = 'Checkout';
        }
      });
    });
  })();
</script>



