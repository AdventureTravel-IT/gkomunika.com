<script>
// ============================================================
// SMART UNIFIED CHECKOUT
// Handles: Insurance only | Airport Transfer only | Both
// ============================================================
document.getElementById('checkout-smart-unified')?.addEventListener('click', function () {
  // Clear semua storage lama
  sessionStorage.removeItem('ProductItems');
  localStorage.removeItem('ProductItems');
  sessionStorage.removeItem('CheckoutFlow');
  localStorage.removeItem('CheckoutFlow');

  const ProductItems = [];

  {% for item in cart.items %}
    {% assign p = item.product %}
    {% assign sk = p.metafields.search.key.value %}

    {% capture sk_json %}
    [
      {% assign first = true %}
      {% if sk != blank %}
        {% for k in sk %}
          {% assign label = k.name.value
            | default: k.name
            | default: k.title.value
            | default: k.title
            | default: k.system.handle
            | default: ''
          %}
          {% unless label == blank %}
            {% unless first %},{% endunless %}
            {{ label | json }}
            {% assign first = false %}
          {% endunless %}
        {% endfor %}
      {% endif %}
    ]
    {% endcapture %}

    {% assign item_cat = p.metafields.product.category.value
      | default: p.metafields.product.category
      | default: ''
      | strip
    %}

    ProductItems.push({
      productTitle:    {{ item.product.title | json }},
      category:        {{ item_cat | json }},
      variantType:     {{ item.variant.metafields.variant.type | json }},
      variantTitle:    {{ item.variant.title | json }},
      variantId:       {{ item.variant.id }},
      quantity:        {{ item.quantity }},
      variantCoverage: {{ sk_json | strip }},
      defaultPurpose:  {{ item.variant.metafields.airport.purpose | json }}
    });
  {% endfor %}

  if (ProductItems.length === 0) {
    alert('Cart is empty.');
    return;
  }

  // Simpan ke BOTH storage (form pages butuh ini)
  sessionStorage.setItem('ProductItems', JSON.stringify(ProductItems));
  localStorage.setItem('ProductItems', JSON.stringify(ProductItems));

  // ── Build AT_Purposes untuk item Airport Transfer ──
  (function buildAndSaveAtPurposes() {
    function purposeLabelToValue(label) {
      const s = String(label || '').trim().toLowerCase();
      if (s === 'city to airport' || s.includes('city_to_airport')) return 'city_to_airport';
      if (s === 'airport to city' || s.includes('airport_to_city')) return 'airport_to_city';
      return '';
    }

    const transferItems = ProductItems.filter(i => i.category === 'Airport_Transfer');
    if (!transferItems.length) return;

    const purposes = [];
    transferItems.forEach(item => {
      const qty = parseInt(item.quantity, 10) || 1;
      const lockedPurpose = item.defaultPurpose
        ? purposeLabelToValue(item.defaultPurpose)
        : '';

      for (let i = 0; i < qty; i++) {
        if (i === 0) {
          // Unit pertama → lock dari metafield
          purposes.push(lockedPurpose);
        } else {
          // Unit ke-2, ke-3, dst → bebas dipilih user
          purposes.push('');
        }
      }
    });

    sessionStorage.setItem('AT_Purposes', JSON.stringify(purposes));
    localStorage.setItem('AT_Purposes', JSON.stringify(purposes));
  })();

  // ------------------------------------------------
  // Tentukan flow berdasarkan kategori yang ada
  // ------------------------------------------------
  const hasInsurance = ProductItems.some(i => i.category === 'Insurance');
  const hasTransfer  = ProductItems.some(i => i.category === 'Airport_Transfer');

  // Simpan flow metadata → dipakai form pages untuk "Next Step"
  const flow = {
    hasInsurance,
    hasTransfer,
    // Step mana yang perlu dikunjungi (urutan tetap: insurance dulu, lalu transfer)
    steps: [
      ...(hasTransfer  ? ['transfer']  : []),
      ...(hasInsurance ? ['insurance'] : []),
    ],
    currentStepIndex: 0,
  };
  sessionStorage.setItem('CheckoutFlow', JSON.stringify(flow));
  localStorage.setItem('CheckoutFlow', JSON.stringify(flow));

  // Redirect ke step pertama
  {% if customer %}
    const firstStep = flow.steps[0];
    if (firstStep === 'insurance') {
      window.location.href = '/pages/form-insurance';
    } else {
      window.location.href = '/pages/form-airport-transfer';
    }
  {% else %}
    // Simpan dulu step pertama, setelah login redirect sesuai
    const firstStep = flow.steps[0];
    const returnUrl = firstStep === 'insurance'
      ? '/pages/form-insurance'
      : '/pages/form-airport-transfer';
    window.location.href = `/account/login?return_url=${encodeURIComponent(returnUrl)}`;
  {% endif %}
});
</script>

<script>
  // ============================================================
  // CART LINK & CHECKOUT LOADING FEEDBACK
  // Mencegah quick backs karena user tidak tahu klik berhasil
  // ============================================================
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Continue Shopping & Product title links
    document.querySelectorAll('a[href]').forEach((a) => {
      // Skip link yang bukan navigasi halaman (anchor, javascript:, external)
      const href = a.getAttribute('href') || '';
      if (!href || href.startsWith('#') || href.startsWith('javascript')) return;
      if (a.hostname && a.hostname !== window.location.hostname) return;

      a.addEventListener('click', (e) => {
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.dataset.loading === '1') return;

        a.dataset.loading = '1';
        a.style.opacity = '0.6';
        a.style.pointerEvents = 'none';

        // Reset saat user balik (bfcache)
        window.addEventListener(
          'pageshow',
          () => {
            a.dataset.loading = '0';
            a.style.opacity = '';
            a.style.pointerEvents = '';
          },
          { once: true }
        );
      });
    });

    // 2. Checkout button (type="submit")
    // 2. Checkout button (type="submit")
    const checkoutSubmit = document.querySelector('button[type="submit"][name="checkout"]');
    if (checkoutSubmit) {
      checkoutSubmit.addEventListener('click', () => {
        if (checkoutSubmit.dataset.loading === '1') return;

        checkoutSubmit.dataset.loading = '1';
        // ✅ Jangan disabled=true, cukup visual feedback saja
        checkoutSubmit.style.opacity = '0.7';
        checkoutSubmit.style.pointerEvents = 'none'; // block double-click tanpa disable form
        checkoutSubmit.textContent = 'Processing...';

        window.addEventListener(
          'pageshow',
          () => {
            checkoutSubmit.dataset.loading = '0';
            checkoutSubmit.style.opacity = '';
            checkoutSubmit.style.pointerEvents = '';
            checkoutSubmit.textContent = 'Checkout';
          },
          { once: true }
        );
      });
    }

    // 3. Smart unified checkout button
    const smartCheckout = document.getElementById('checkout-smart-unified');
    if (smartCheckout) {
      smartCheckout.addEventListener('click', () => {
        if (smartCheckout.dataset.loading === '1') return;

        smartCheckout.dataset.loading = '1';
        smartCheckout.disabled = true;
        smartCheckout.style.opacity = '0.7';
        smartCheckout.textContent = 'Processing...';

        window.addEventListener(
          'pageshow',
          () => {
            smartCheckout.dataset.loading = '0';
            smartCheckout.disabled = false;
            smartCheckout.style.opacity = '';
            smartCheckout.textContent = 'Checkout';
          },
          { once: true }
        );
      });
    }
  });
</script>

