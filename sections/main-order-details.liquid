{% comment %} od = order details {% endcomment %}

{% style %}
  .od__container {
    max-width: 1920px;
    margin: 0 auto;
  }
  .od__wrapper {
    padding: 20px 10%;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .od__order-block {
    padding: 15px;
    background: var(--color-neutral);
    border-radius: 20px;
  }
  .od__order-title,
  .od__order-description {
    margin: 0;
    color: var(--color-primary);
    font-weight: bold;
  }

  .od__redeem {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .od__details-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #d9d9d9;
    border-radius: 10px;
    padding: 10px;
    gap: 10px;
    align-items: center;
    margin-top: 15px;
  }
  .od__redeem-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    border-radius: 5px;
    width: 100%;
  }
  .od__redeem-index {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
  }
  .od__redeem-index span {
    background: var(--color-secondary);
    border-radius: 15px;
    width: 80px;
    min-width: 80px;
    text-align: center;
    color: var(--color-neutral);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 0;
  }

  .od__redeem-product-name h2 {
    margin: 0;
    font-size: var(--font-large);
    font-weight: bold;
    color: var(--color-primary);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .od__toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--color-secondary);
    color: white;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 14px;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 9999;
    pointer-events: none;
    white-space: nowrap;
  }
  .od__toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .od__modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .od__modal.show {
    display: flex;
  }
  .od__modal-box {
    background: var(--color-neutral);
    border-radius: 16px;
    padding: 24px;
    max-width: 420px;
    width: 100%;
    color: var(--color-primary);
  }
  .od__modal-box h2,
  .od__modal-box p {
    margin-top: 0;
    color: var(--color-primary);
  }
  .od__modal-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    cursor: pointer;
    width: 100%;
    font-size: 14px;
    font-weight: 500;
  }

  .od__modal-label input[type='checkbox'] {
    margin: 0;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .od__modal-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 20px;
  }
  .od__modal-actions button {
    padding: 8px 16px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
  }
  .od__modal-cancel {
    background: #e5e5e5;
    color: var(--color-primary);
  }
  .od__modal-confirm {
    background: var(--color-primary);
    color: var(--color-neutral);
  }
  .od__modal-confirm:disabled,
  .od__resend-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .oh-details__quantity p {
    margin: 0;
  }

  .od__redeem-data h2 {
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .od__redeem-data h2:hover {
    color: var(--color-secondary);
  }

  .od__redeem-info {
    display: none;
    width: 100%;
    gap: 10px;
    overflow: hidden;
    transition: max-height 0.8s ease-out, opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .od__redeem-info-wrapper {
    display: flex;
    gap: 15px;
  }
  .od__redeem-data-wrapper {
    width: 100%;
  }
  .od__redeem-data {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  .od__redeem-data > div {
    flex: 1;
    min-width: 0;
  }

  .od__redeem-data h2 {
    margin: 0;
    font-size: var(--font-extra-large);
    font-weight: bold;
    color: var(--color-primary);
    word-break: break-all;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .copy-button {
    flex-shrink: 0;
    gap: 5px;
    background: transparent;
    display: flex;
    border: none;
    align-items: center;
    color: var(--color-primary);
  }

  .od__redeem-data p {
    margin: 0;
    font-size: var(--font-small);
    color: var(--color-primary);
  }

  .copy-button:hover p {
    color: var(--color-secondary);
  }
  .copy-button.copied p {
    color: var(--color-primary);
  }
  .copy-button-icon {
    color: var(--color-primary);
  }

  @media (max-width: 425px) {
    .od__wrapper {
      padding: 20px 24px;
    }
    .od__redeem-info-wrapper {
      display: flex;
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="od__container">
  <section class="od__wrapper">
    {% for order in customer.orders %}
      {% assign show_esim_details = false %}
      {% for item in order.line_items %}
        {% if item.product.metafields.product.category == 'eSIM' %}
          {% assign show_esim_details = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      <div class="od__order-block" data-order-id="{{ order.id }}">
        {% render 'order-history__details', order: order %}
      </div>

      {% if show_esim_details %}
        <div class="od__order-block" data-order-id="{{ order.id }}">
          <div class="flex flex-col md:flex-row gap-2 md:items-center justify-between">
            <div>
              <h2 class="od__order-title">eSIM Details</h2>
              <h3 class="od__order-description">
                QR Send To:
                <span style="color: var(--color-secondary);">{{ order.email }}</span>
              </h3>
            </div>
          </div>

          {% assign total_qty = 0 %}
          {% for item in order.line_items %}
            {% assign total_qty = total_qty | plus: item.quantity %}
          {% endfor %}

          {% for i in (1..total_qty) %}
            {% assign idx = i | minus: 1 %}
            {% assign data = order.metafields.sim_card.details.value.activation_code[idx] %}

            {% assign matched_item = null %}
            {% if data %}
              {% for item in order.line_items %}
                {% if item.sku == data.sku %}
                  {% assign matched_item = item %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}

            <section class="od__redeem">
              <div class="od__details-card">
                <div class="od__redeem-wrapper" onclick="toggleDetails(this)">
                  <div class="od__redeem-index">
                    <span>QR #{{ i }}</span>
                    {% if matched_item %}
                      <div class="od__redeem-product-name">
                        {% assign product_name_only = matched_item.title | split: ' - ' | first %}
                        {% assign product_name = matched_item.product.title %}
                        {% assign variant_name = matched_item.title | remove: product_name | strip %}
                        {% assign variant_parts = variant_name | split: ' / ' %}
                        {% assign formatted_variant = variant_parts | join: ', ' | strip | remove_first: '-' | strip %}

                        <h2>{{ product_name_only }}</h2>
                        <h2>{{ formatted_variant }}</h2>
                      </div>
                    {% else %}
                      <div class="od__redeem-product-name">
                        <h2>{{ product_name_only }}</h2>
                        <h2>{{ formatted_variant }}</h2>
                      </div>
                    {% endif %}
                  </div>
                  <img
                    class="od__redeem-icon"
                    src="{{ 'icon-arrow-back.svg' | asset_url }}"
                    alt="Icon"
                  >
                </div>

                <section class="od__redeem-info">
                  <div class="od__redeem-info-wrapper">
                    {% if data %}
                      <img
                        src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ data.qrcode | url_encode }}"
                        width="75"
                        height="75"
                        style="cursor:pointer; align-self: flex-start; object-fit: contain;"
                      >
                      <div class="od__redeem-data-wrapper">
                        {% assign fields = 'iccid,smdp,activationcode,qrcode' | split: ',' %}
                        {% for field in fields %}
                          <div class="od__redeem-data">
                            <div>
                              <p>{{ field | upcase }}:</p>
                              <h2
                                id="{{ field }}-{{ i }}"
                                onclick="copyText('{{ field }}-{{ i }}')"
                                style="cursor: pointer;"
                              >
                                {{ data[field] }}
                              </h2>
                            </div>
                            <button class="copy-button" onclick="copyText('{{ field }}-{{ i }}')" type="button">
                              <img
                                class="copy-button-icon"
                                src="{{ 'icon-copy.svg' | asset_url }}"
                                alt="Copy Icon"
                              >
                              <p>Copy</p>
                            </button>
                          </div>
                        {% endfor %}
                      </div>
                    {% else %}
                      <p style="font-style: italic; color: gray;">For complete details, kindly check your email.</p>
                    {% endif %}
                  </div>
                </section>
              </div>
            </section>
          {% endfor %}

          <div class="mt-3 w-full">
            <button
              class="w-full text-neutral bg-primary rounded-xl px-5 py-2 flex items-center gap-2 justify-center od__resend-btn"
              data-invoice="{{ order.name }}"
              data-email="{{ order.email }}"
              type="button"
            >
              {% render 'icon-send', class: 'text-neutral w-5 h-5 shrink-0' %}
              <span class="od__resend-text">Resend</span>
            </button>
          </div>
        </div>
      {% endif %}

      <div class="od__order-block" data-order-id="{{ order.id }}">
        {% render 'order-summary', order: order %}
      </div>
    {% endfor %}
  </section>
</div>

<div class="od__toast" id="od-toast">✓ Copied to clipboard!</div>

<div class="od__modal" id="od-resend-modal">
  <div class="od__modal-box">
    <p>Would you like to send a copy of the eSIM QR code to your email address?</p>

    <label class="od__modal-label">
      <input type="checkbox" id="od-send-email-checkbox">
      <span>Send a copy to email</span>
    </label>

    <div class="od__modal-actions">
      <button type="button" class="od__modal-cancel" id="od-modal-cancel">Cancel</button>
      <button type="button" class="od__modal-confirm" id="od-modal-confirm">Resend</button>
    </div>
  </div>
</div>

<script>
  let selectedResendButton = null;
  const RESEND_COOLDOWN_MS = 5 * 60 * 1000;

  document.addEventListener('DOMContentLoaded', function () {
    const orderIdParam = new URLSearchParams(window.location.search).get('order_id');

    if (orderIdParam) {
      document.querySelectorAll('.od__order-block').forEach((block) => {
        if (block.getAttribute('data-order-id') !== orderIdParam) {
          block.remove();
        }
      });
    }

    const first = document.querySelector('.od__redeem-wrapper');

    if (first) {
      const details = first.nextElementSibling;
      const icon = first.querySelector('.od__redeem-icon');

      details.style.display = 'block';

      if (icon) {
        icon.style.transform = 'rotate(90deg)';
      }
    }

    updateResendButtonsCooldown();
    setInterval(updateResendButtonsCooldown, 1000);
  });

  function toggleDetails(el) {
    document.querySelectorAll('.od__redeem-info').forEach((d) => {
      if (d !== el.nextElementSibling) {
        d.style.display = 'none';

        const ic = d.previousElementSibling.querySelector('.od__redeem-icon');

        if (ic) {
          ic.style.transform = 'rotate(0deg)';
        }
      }
    });

    const details = el.nextElementSibling;
    const icon = el.querySelector('.od__redeem-icon');
    const visible = details.style.display === 'block';

    details.style.display = visible ? 'none' : 'block';

    if (icon) {
      icon.style.transform = visible ? 'rotate(0deg)' : 'rotate(90deg)';
    }
  }

  function copyText(id) {
    const target = document.getElementById(id);

    if (!target) return;

    const text = target.innerText;

    navigator.clipboard.writeText(text).then(() => {
      document.querySelectorAll('.copy-button').forEach((btn) => {
        btn.classList.remove('copied');

        const label = btn.querySelector('p');
        if (label) {
          label.innerText = 'Copy';
          label.style.color = '';
        }
      });

      const btn = document.querySelector(`[onclick="copyText('${id}')"].copy-button`);

      if (btn) {
        const label = btn.querySelector('p');

        if (label) {
          label.innerText = 'Copied';
          label.style.color = 'var(--color-secondary)';
        }

        btn.classList.add('copied');
      }

      showToast('✓ Copied to clipboard!');
    });
  }

  function showToast(message) {
    const toast = document.getElementById('od-toast');

    if (!toast) return;

    toast.innerText = message;
    toast.classList.add('show');

    clearTimeout(window._toastTimeout);

    window._toastTimeout = setTimeout(() => {
      toast.classList.remove('show');
    }, 2000);
  }

  function getCooldownKey(invoiceNo) {
    return `resend_cooldown_${invoiceNo}`;
  }

  function getRemainingCooldown(invoiceNo) {
    const lastSent = Number(localStorage.getItem(getCooldownKey(invoiceNo)) || 0);
    const elapsed = Date.now() - lastSent;

    return Math.max(0, RESEND_COOLDOWN_MS - elapsed);
  }

  function formatCooldown(ms) {
    const totalSeconds = Math.ceil(ms / 1000);
    const minutes = Math.floor(totalSeconds / 60);
    const seconds = totalSeconds % 60;

    return `${minutes}:${String(seconds).padStart(2, '0')}`;
  }

  function updateResendButtonsCooldown() {
    document.querySelectorAll('.od__resend-btn').forEach((btn) => {
      const invoiceNo = btn.dataset.invoice;
      const remaining = getRemainingCooldown(invoiceNo);
      const textEl = btn.querySelector('.od__resend-text');

      if (remaining > 0) {
        btn.disabled = true;
        if (textEl) textEl.innerText = `Wait ${formatCooldown(remaining)}`;
      } else {
        btn.disabled = false;
        if (textEl) textEl.innerText = 'Resend';
      }
    });
  }

  document.addEventListener('click', function (e) {
    const btn = e.target.closest('.od__resend-btn');

    if (!btn) return;

    const invoiceNo = btn.dataset.invoice;
    const remaining = getRemainingCooldown(invoiceNo);

    if (remaining > 0) {
      showToast(`Resend bisa dilakukan lagi dalam ${formatCooldown(remaining)}`);
      return;
    }

    selectedResendButton = btn;

    const checkbox = document.getElementById('od-send-email-checkbox');
    const modal = document.getElementById('od-resend-modal');

    if (checkbox) {
      checkbox.checked = false;
    }

    if (modal) {
      modal.classList.add('show');
    }
  });

  document.getElementById('od-modal-cancel')?.addEventListener('click', function () {
    document.getElementById('od-resend-modal')?.classList.remove('show');
    selectedResendButton = null;
  });

  document.getElementById('od-resend-modal')?.addEventListener('click', function (e) {
    if (e.target.id === 'od-resend-modal') {
      e.currentTarget.classList.remove('show');
      selectedResendButton = null;
    }
  });

  document.getElementById('od-modal-confirm')?.addEventListener('click', async function () {
    if (!selectedResendButton) return;

    const btn = selectedResendButton;
    const invoiceNo = btn.dataset.invoice;
    const emailCustomer = btn.dataset.email;
    const isEmail = document.getElementById('od-send-email-checkbox')?.checked || false;

    const payload = {
      invoice_no: invoiceNo,
      email_customer: emailCustomer,
      is_email: isEmail,
    };

    const modal = document.getElementById('od-resend-modal');
    const confirmBtn = document.getElementById('od-modal-confirm');

    try {
      confirmBtn.disabled = true;
      confirmBtn.innerText = 'Sending...';

      const response = await fetch('https://v2.gkomunika.id/api/v1/shopify/resend-email', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      let result = {};

      try {
        result = await response.json();
      } catch (e) {}

      if (!response.ok) {
        throw new Error(result?.message || 'Gagal resend QR eSIM.');
      }

      localStorage.setItem(getCooldownKey(invoiceNo), Date.now().toString());

      modal?.classList.remove('show');
      selectedResendButton = null;

      updateResendButtonsCooldown();
      showToast('✓ QR eSIM berhasil dikirim ulang.');
    } catch (error) {
      console.error(error);
      showToast(error.message || 'Gagal resend QR eSIM.');
    } finally {
      confirmBtn.disabled = false;
      confirmBtn.innerText = 'Resend';
    }
  });
</script>

{% schema %}
{
  "name": "Main Order",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Main Orde"
    }
  ]
}
{% endschema %}