{% style %}
  :root {
    --header-height: 80px;
  }

  .pages-container {
    max-width: 1920px;
    margin: 0 auto;
  }

  .pages-wrapper {
    display: flex;
    flex-wrap: nowrap;
    padding: 50px 10% 10%;
    gap: 50px;
  }

  .pages-summary {
    position: sticky;
    top: calc(var(--header-height) + 20px);
    align-self: flex-start;
    height: fit-content;
    max-height: calc(60vh - var(--header-height) - 40px);
    overflow: auto; /* kalau list summary panjang, bisa scroll di box */
  }

  .page-summary__wrapper {
    margin: 0;
    padding: 0;
  }

  #summary {
    margin-left: 17px;
    color: var(--color-primary);
    list-style-type: disc;
  }

  #summary li {
    margin-top: 10px;
  }

  #summary li a {
    color: var(--color-primary);
    font-size: var(--font-large);
    transition: transform 0.3s;
    text-decoration: none;
  }
  #summary li a.active {
    color: var(--color-secondary);
  }
  #summary li a:hover {
    color: var(--color-secondary);
  }

  .pages-content {
    flex: 2;
    min-width: 0;
  }

  .pages-content__latest {
    display: flex;
    gap: 20px;
    margin-top: 50px;
  }

  .pages-content__latest > .pages-content__prev-container:only-child,
  .pages-content__latest > .pages-content__next-container:only-child {
    flex: 0 0 55%;
    max-width: 700px;
  }

  .pages-content__prev-container,
  .pages-content__next-container {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .pages-content__prev,
  .pages-content__next {
    flex: 1;
    background-color: var(--color-neutral);
    border-radius: 15px;
    padding: 15px;
    display: flex;
    flex-direction: column;
  }

  .pages-content__next-container h2 {
    text-align: right;
  }

  .pages-content__title {
    font-size: var(--font-supper-large);
    color: var(--color-primary);
    margin: 10px 0;
    line-height: 1.5;
  }

  .pages-content__prev img,
  .pages-content__next img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    aspect-ratio: 3 / 2;
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }

  .pages-content__prev a,
  .pages-content__next a {
    text-decoration: none;
  }

  .page-content__title {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 24px;
    margin-top: 0;
  }

  .pages-content__wrapper {
    background-color: var(--color-neutral);
    padding: 15px 30px;
    border-radius: 15px;
  }

  /* =========================
     SPACING FIX (Y spacing)
     ========================= */
  .pages-content__wrapper .pages-article__date {
    margin: 15px 0;
  }

  .pages-content__wrapper .page-content__wrapper {
    margin-top: 16px;
  }

  .page-content__wrapper > * + * {
    margin-top: 14px;
  }

  .page-content__wrapper h2,
  .page-content__wrapper h3 {
    margin-top: 28px;
    margin-bottom: 10px;
  }

  .page-content__wrapper p,
  .page-content__wrapper ul,
  .page-content__wrapper ol {
    margin: 0 0 12px;
    font-size: 16px;
  }

  /* =========================
   FIX: LIST (UL/OL) di page content tetap tampil bullet/number
   ========================= */
  .page-content__wrapper ul,
  .page-content__wrapper ol {
    padding-left: 1.25em; /* biar ada indent */
    margin-left: 0; /* optional */
    list-style-position: outside;
  }

  .page-content__wrapper ul {
    list-style-type: disc !important; /* paksa bullet muncul */
  }

  .page-content__wrapper ol {
    list-style-type: decimal !important; /* angka untuk ordered list */
  }

  /* pastikan li tetap jadi list-item (kadang di-reset theme) */
  .page-content__wrapper li {
    display: list-item;
  }

  /* optional: nested list biar lebih rapi */
  .page-content__wrapper ul ul {
    list-style-type: circle !important;
  }
  .page-content__wrapper ul ul ul {
    list-style-type: square !important;
  }

  .page-content__wrapper {
    color: var(--color-primary);
  }

  .page-content__wrapper {
    text-align: left !important;
  }

  .page-content__wrapper ul,
  .page-content__wrapper ol {
    text-align: left !important;
    padding-left: 2.1em !important;
    margin-left: 0 !important;
    list-style-position: outside;
  }

  .page-content__wrapper li {
    text-align: left !important;
    display: list-item;
  }

  .page-content__wrapper p,
  .page-content__wrapper h2,
  .page-content__wrapper h3,
  .page-content__wrapper h4 {
    text-align: left !important;
  }

  .page-content__wrapper h2 {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 20px;
  }

  .page-content__wrapper h3 {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 18px;
  }

  .page-content__wrapper img {
    max-width: 100%;
    height: auto;
    border-radius: 15px;
    cursor: zoom-in;
    display: block;
  }

  .page-content__wrapper a {
    color: #00adee;
    text-decoration: underline;
  }

  .page-content__wrapper a:hover,
  .page-content__wrapper a:focus {
    color: #0084b6;
    text-decoration: underline;
  }

  .pages-title {
    color: var(--color-primary);
    font-size: 22px;
    font-weight: bold;
    margin: 0;
  }

  .pages-article {
    display: flex;
    flex-direction: column;
    gap: 15px;
    flex: 1;
    min-width: 0;
  }

  .pages-article__title {
    margin: 0;
    color: var(--color-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--font-extra-large);
    font-weight: bold;
  }

  .pages-article__wrapper {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .related-article {
    background-color: var(--color-neutral);
    border-radius: 15px;
    transition: transform 0.3s ease;
  }

  .related-article:hover {
    transform: translateY(-5px);
    box-shadow: var(--box-shadow);
  }

  .related-article a {
    padding: 10px;
    display: flex;
    gap: 10px;
    text-decoration: none;
  }

  .related-article img {
    width: auto;
    height: 70px;
    aspect-ratio: 3 / 2;
    border-radius: 15px;
    border: 1px solid var(--color-border);
  }

  .pages-article__date {
    margin: 0;
    line-height: 1.5;
    color: var(--color-secondary);
  }

  .image-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;

    /* Overlay: blur + dim */
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);

    /* Hidden state */
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .image-modal.is-active {
    opacity: 1;
    visibility: visible;
  }

  /* Image wrapper — hanya image, tanpa padding tebal */
  .image-modal__inner {
    position: relative;
    max-width: 92vw;
    max-height: 92vh;
    line-height: 0; /* hilangkan gap bawah img */

    /* Animasi scale-in saat buka */
    transform: scale(0.88);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
    border-radius: 12px;
    overflow: visible;
  }

  .image-modal.is-active .image-modal__inner {
    transform: scale(1);
    opacity: 1;
  }

  .image-modal__img {
    display: block;
    max-width: 92vw;
    max-height: 88vh;
    width: auto;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.08);
    object-fit: contain;
  }

  /* Caption — hanya tampil kalau ada teks */
  .image-modal__caption:empty {
    display: none;
  }

  .image-modal__caption {
    position: absolute;
    bottom: -36px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
  }

  /* Close button — floating, lingkaran putih di pojok kanan atas */
  .image-modal__close {
    position: absolute;
    top: -14px;
    right: -14px;
    z-index: 10;

    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: none;
    background: #ffffff;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.4);
    cursor: pointer;

    display: flex;
    align-items: center;
    justify-content: center;

    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease, box-shadow 0.2s ease;

    /* Reset default button style */
    padding: 0;
    line-height: 1;
    font-size: 0; /* hide teks × asli, pakai pseudo */
  }

  /* Ikon × dari CSS — lebih clean dari karakter &times; */
  .image-modal__close::before,
  .image-modal__close::after {
    content: '';
    position: absolute;
    width: 14px;
    height: 1.8px;
    background: #222;
    border-radius: 2px;
    transition: background 0.2s ease;
  }
  .image-modal__close::before {
    transform: rotate(45deg);
  }
  .image-modal__close::after {
    transform: rotate(-45deg);
  }

  .image-modal__close:hover {
    transform: rotate(90deg) scale(1.12);
    background: #f4f4f4;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
  }

  /* Cursor zoom-in pada gambar artikel sebagai hint */
  .page-content__wrapper img {
    cursor: zoom-in;
    transition: opacity 0.2s ease, transform 0.3s ease;
  }

  .page-content__wrapper img:hover {
    opacity: 0.92;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .image-modal {
      padding: 16px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }

    .image-modal__img {
      max-width: 96vw;
      max-height: 80vh;
      border-radius: 10px;
    }

    .image-modal__close {
      top: -12px;
      right: -12px;
      width: 34px;
      height: 34px;
    }

    .image-modal__close::before,
    .image-modal__close::after {
      width: 12px;
    }
  }

  /* =========================
     MOBILE / RESPONSIVE LAYOUT
     ========================= */
  @media (max-width: 1024px) {
    .pages-wrapper {
      flex-direction: column;
    }

    .pages-summary,
    .pages-content,
    .pages-article {
      width: 100%;
      position: static;
    }
  }

  @media (max-width: 768px) {
    .page-content__title {
      font-size: 20px;
    }

    .pages-wrapper {
      flex-direction: column;
      padding: 60px 16px 50px; /* lebih kecil biar gak kepotong */
      gap: 1px;
    }

    .pages-content__wrapper {
      padding: 15px 16px; /* padding card diperkecil di mobile */
      max-width: 100%;
      box-sizing: border-box;
    }

    .pages-content__latest {
      display: flex;
      flex-direction: column;
    }

    .pages-content__next-container h2 {
      text-align: left;
    }

    .pages-summary {
      display: none;
    }

    .image-modal__inner {
      padding: 8px;
    }
  }

  /* =========================
   FIX: CONTENT JANGAN MEPET
   (padding dalam area artikel)
   ========================= */
  .pages-content__wrapper .page-content__wrapper {
    padding-left: 10px;
    padding-right: 10px;
  }

  /* Perkuat indent list biar bullet gak nempel kiri */
  .pages-content__wrapper .page-content__wrapper ul,
  .pages-content__wrapper .page-content__wrapper ol {
    padding-left: 2.1em !important; /* lebih lega dari 1.25em */
    margin-left: 0 !important;
    list-style-position: outside;
  }

  /* Jarak antar item list */
  .pages-content__wrapper .page-content__wrapper li {
    margin: 6px 0;
  }

  /* Gambar kasih margin biar gak nempel ke text/edge */
  .pages-content__wrapper .page-content__wrapper img {
    margin: 12px auto;
  }

  /* Mobile: tambah sedikit padding + indent lebih pas */
  @media (max-width: 768px) {
    .pages-content__wrapper .page-content__wrapper {
      padding-left: 12px;
      padding-right: 12px;
    }

    .pages-content__wrapper .page-content__wrapper ul,
    .pages-content__wrapper .page-content__wrapper ol {
      padding-left: 2.2em !important;
    }
  }

  /* =========================
     FIX MOBILE TERPOTONG (overflow)
     ========================= */
  .pages-container,
  .pages-wrapper,
  .pages-content,
  .pages-content__wrapper,
  .page-content__wrapper {
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Jangan ganggu sticky: biarkan wrapper utama overflow visible */
  .pages-wrapper,
  .pages-content__wrapper {
    overflow: visible;
  }

  /* Kalau kamu tetap butuh cegah horizontal scroll, taruh di level konten saja */
  .page-content__wrapper {
    overflow-x: hidden;
  }

  .page-content__wrapper {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* =========================
     TABLE BORDER + RESPONSIVE
     ========================= */
  .page-content__wrapper table {
    width: 100%;
    max-width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
  }

  .page-content__wrapper th,
  .page-content__wrapper td {
    border: 1px solid var(--color-border) !important;
    padding: 10px 12px;
    vertical-align: top;
  }

  .page-content__wrapper th {
    font-weight: 700;
  }

  /* kalau tabel kepanjangan di mobile, scroll horizontal */
  @media (max-width: 768px) {
    .page-content__wrapper table {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  /* Spacing untuk card Previous & Next */
  .pages-content__prev a,
  .pages-content__next a {
    display: flex;
    flex-direction: column;
    gap: 12px; /* jarak antara image dan blok text */
  }

  /* Jarak antara title dan date */
  .pages-content__prev .pages-article__title,
  .pages-content__next .pages-article__title {
    margin: 0 0 8px; /* 8px jarak ke date */
  }

  .pages-content__prev .pages-article__date,
  .pages-content__next .pages-article__date {
    margin: 0;
  }
{% endstyle %}

<div class="pages-container">
  <div class="pages-wrapper">
    <section class="pages-content">
      <div class="pages-content__wrapper">
        <h1 class="page-content__title">{{ page.title | escape }}</h1>
        <h2 class="pages-article__date">{{ page.published_at | date: '%d %B %Y' }}</h2>
        <div class="page-content__wrapper">{{ page.content }}</div>
      </div>

      <div class="pages-content__latest">
        {% if page.metafields.prev.pages %}
          <div class="pages-content__prev-container">
            <h2 class="pages-content__title">Previous Article</h2>
            <div class="pages-content__prev">
              {% for related_page in page.metafields.prev.pages.value %}
                <a href="{{ related_page.url }}">
                  {% assign first_image = null %}
                  {% assign img_tag_parts = related_page.content | split: '<img' %}

                  {% if img_tag_parts.size > 1 %}
                    {% assign src_parts = img_tag_parts[1] | split: 'src="' %}
                    {% if src_parts.size > 1 %}
                      {% assign first_image = src_parts[1] | split: '"' | first %}
                    {% endif %}
                  {% endif %}

                  {% if first_image and first_image contains 'http' %}
                    <img src="{{ first_image }}" alt="{{ related_page.title }}">
                  {% endif %}
                  <div>
                    <h3 class="pages-article__title" title="{{ related_page.title }}">{{ related_page.title }}</h3>
                    <p class="pages-article__date">{{ related_page.published_at | date: '%d %B %Y' }}</p>
                  </div>
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if page.metafields.next.pages %}
          <div class="pages-content__next-container">
            <h2 class="pages-content__title">Next Article</h2>
            <div class="pages-content__next">
              {% for related_page in page.metafields.next.pages.value %}
                <a href="{{ related_page.url }}">
                  {% assign first_image = null %}
                  {% assign img_tag_parts = related_page.content | split: '<img' %}

                  {% if img_tag_parts.size > 1 %}
                    {% assign src_parts = img_tag_parts[1] | split: 'src="' %}
                    {% if src_parts.size > 1 %}
                      {% assign first_image = src_parts[1] | split: '"' | first %}
                    {% endif %}
                  {% endif %}

                  {% if first_image and first_image contains 'http' %}
                    <img src="{{ first_image }}" alt="{{ related_page.title }}">
                  {% endif %}
                  <div>
                    <h3 class="pages-article__title" title="{{ related_page.title }}">{{ related_page.title }}</h3>
                    <p class="pages-article__date">{{ related_page.published_at | date: '%d %B %Y' }}</p>
                  </div>
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </section>

    <section class="pages-article">
      {% if page.metafields.latest.article %}
        <h2 class="pages-title">Related Articles</h2>
        <div class="pages-article__wrapper">
          {% for related_page in page.metafields.latest.article.value %}
            <div class="related-article">
              <a href="{{ related_page.url }}">
                {% assign first_image = null %}
                {% assign img_tag_parts = related_page.content | split: '<img' %}

                {% if img_tag_parts.size > 1 %}
                  {% assign src_parts = img_tag_parts[1] | split: 'src="' %}
                  {% if src_parts.size > 1 %}
                    {% assign first_image = src_parts[1] | split: '"' | first %}
                  {% endif %}
                {% endif %}

                {% if first_image and first_image contains 'http' %}
                  <img src="{{ first_image }}" alt="{{ related_page.title }}">
                {% endif %}
                <div>
                  <h3 class="pages-article__title" title="{{ related_page.title }}">{{ related_page.title }}</h3>
                  <h3 class="pages-article__date">{{ related_page.published_at | date: '%d %B %Y' }}</h3>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <section class="pages-summary">
        <h2 class="pages-title">Article Summary</h2>
        <ul id="summary" class="page-summary__wrapper"></ul>
      </section>
    </section>
  </div>
</div>

<div id="imageModal" class="image-modal" role="dialog" aria-modal="true" aria-label="Image preview" aria-hidden="true">
  <div class="image-modal__inner">
    <button type="button" class="image-modal__close" aria-label="Tutup preview gambar"></button>
    <img src="" alt="" class="image-modal__img">
    <p class="image-modal__caption"></p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const headings = document.querySelectorAll('.page-content__wrapper h2');
    const summary = document.getElementById('summary');
    const summarySection = document.querySelector('.pages-summary');

    const modal = document.getElementById('imageModal');
    const modalImg = modal ? modal.querySelector('.image-modal__img') : null;
    const modalCaption = modal ? modal.querySelector('.image-modal__caption') : null;
    const modalCloseBtn = modal ? modal.querySelector('.image-modal__close') : null;

    headings.forEach((heading, i) => {
      const id = `section-${i}`;
      heading.id = id;
      if (summary) {
        summary.innerHTML += `<li><a href="#${id}">${heading.textContent}</a></li>`;
      }
    });

    if (summary && summary.children.length === 0 && summarySection) {
      summarySection.style.display = 'none';
    }

    const links = summary ? summary.querySelectorAll('a') : [];

    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        links.forEach((l) => l.classList.remove('active'));
        link.classList.add('active');
        const target = document.querySelector(link.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0,
    };

    if (headings.length && summary) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const tocLink = summary.querySelector(`a[href="#${id}"]`);

          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            if (tocLink) tocLink.classList.add('active');
          }
        });
      }, observerOptions);

      headings.forEach((heading) => observer.observe(heading));
    }

    if (modal && modalImg) {
      const articleImages = document.querySelectorAll('.page-content__wrapper img');

      articleImages.forEach((img) => {
        img.addEventListener('click', () => {
          const src = img.getAttribute('src');
          const alt = img.getAttribute('alt') || '';

          modalImg.src = src;
          modalImg.alt = alt;
          if (modalCaption) {
            modalCaption.textContent = alt;
          }

          modal.classList.add('is-active');
          document.body.style.overflow = 'hidden';
        });
      });

      const closeModal = () => {
        modal.classList.remove('is-active');
        document.body.style.overflow = '';
        modalImg.src = '';
      };

      if (modalCloseBtn) {
        modalCloseBtn.addEventListener('click', closeModal);
      }

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('is-active')) {
          closeModal();
        }
      });
    }
  });
</script>

<!--
  =========================================================
  LINK RULES (FINAL):
  - SEMUA link di konten page (.page-content__wrapper) => TAB BARU
  - Kecuali anchor (#), mailto:, tel:
  Support: theme editor / konten berubah
  =========================================================
-->
<script>
  (function () {
    function applyBlankForAllContentLinks() {
      const container = document.querySelector('.page-content__wrapper');
      if (!container) return;

      container.querySelectorAll('a[href]').forEach((link) => {
        const href = link.getAttribute('href');

        if (
          !href ||
          href.startsWith('#') ||
          href.startsWith('javascript:') ||
          href.startsWith('mailto:') ||
          href.startsWith('tel:')
        ) {
          return;
        }

        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'noopener noreferrer');
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      applyBlankForAllContentLinks();

      const container = document.querySelector('.page-content__wrapper');
      if (container) {
        const mo = new MutationObserver(() => applyBlankForAllContentLinks());
        mo.observe(container, { childList: true, subtree: true });
      }
    });

    document.addEventListener('shopify:section:load', () => {
      applyBlankForAllContentLinks();
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contentWrapper = document.querySelector('.page-content__wrapper');
    if (!contentWrapper) return;

    // Fungsi bersihkan &nbsp; dari semua text node
    function cleanNbsp(node) {
      if (node.nodeType === Node.TEXT_NODE) {
        node.textContent = node.textContent.replace(/\u00A0/g, ' ').trim()
          ? node.textContent.replace(/\u00A0/g, ' ')
          : node.textContent;
      } else {
        node.childNodes.forEach(cleanNbsp);
      }
    }

    cleanNbsp(contentWrapper);
  });
</script>
