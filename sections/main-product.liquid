<style>
  /* ── Microtip tooltip base ── */
  [aria-label][role~='tooltip'] {
    position: relative;
  }
  [aria-label][role~='tooltip']::before,
  [aria-label][role~='tooltip']::after {
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    will-change: transform;
    opacity: 0;
    pointer-events: none;
    transition: all 0.18s ease-in-out 0s;
    position: absolute;
    box-sizing: border-box;
    z-index: 10;
    transform-origin: top;
  }
  [aria-label][role~='tooltip']::before {
    background-size: 100% auto !important;
    content: '';
  }
  [aria-label][role~='tooltip']::after {
    background: rgba(17, 17, 17, 0.9);
    border-radius: 4px;
    color: #fff;
    content: attr(aria-label);
    font-size: 13px;
    padding: 0.5em 1em;
    white-space: nowrap;
    box-sizing: content-box;
  }
  [aria-label][role~='tooltip']:hover::before,
  [aria-label][role~='tooltip']:hover::after {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Bottom position ── */
  [role~='tooltip'][data-microtip-position|='bottom']::before {
    background: url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20width%3D%2236px%22%20height%3D%2212px%22%3E%3Cpath%20fill%3D%22rgba%2817,%2017,%2017,%200.9%29%22%20transform%3D%22rotate%28180%2018%206%29%22%20d%3D%22M2.658,0.000%20C-13.615,0.000%2050.938,0.000%2034.662,0.000%20C28.662,0.000%2023.035,12.002%2018.660,12.002%20C14.285,12.002%208.594,0.000%202.658,0.000%20Z%22/%3E%3C/svg%3E')
      no-repeat;
    height: 6px;
    width: 18px;
    margin-top: 5px;
    margin-bottom: 0;
  }
  [role~='tooltip'][data-microtip-position|='bottom']::after {
    margin-top: 11px;
  }
  [role~='tooltip'][data-microtip-position|='bottom']::before {
    transform: translate3d(-50%, -10px, 0);
    bottom: auto;
    left: 50%;
    top: 100%;
  }
  [role~='tooltip'][data-microtip-position|='bottom']:hover::before {
    transform: translate3d(-50%, 0, 0);
  }
  [role~='tooltip'][data-microtip-position='bottom']::after {
    transform: translate3d(-50%, -10px, 0);
    top: 100%;
    left: 50%;
  }
  [role~='tooltip'][data-microtip-position='bottom']:hover::after {
    transform: translate3d(-50%, 0, 0);
  }

  /* ── Size ── */
  [role~='tooltip'][data-microtip-size='large']::after {
    white-space: initial;
    width: 260px;
  }

  /* ── Bullet / multiline support ── */
  [role~='tooltip'][data-microtip-bullets]::after {
    white-space: pre-line;
    text-align: left;
    line-height: 1.35;
  }
  [role~='tooltip'][data-microtip-bullets][data-microtip-size='large']::after {
    width: 24rem;
  }

  /* ── Info button ── */
  .info-tooltip {
    background-color: transparent;
    border: none;
    padding: 0;
    margin: 0;
    box-shadow: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .icon-info {
    color: var(--color-primary);
  }
</style>

<section>
  <div class="bg-neutral md:wrapper-base flex flex-col md:gap-5 md:flex-row">
    <div class="w-full md:w-1/2 h-auto">
      <img
        id="mainImage"
        src="{{ product.featured_image | image_url }}"
        class="bg-slate-300 md:rounded-[15px] w-full h-auto"
        width="300px"
        height="220px"
        alt="Global Komunika"
      >

      <div class="px-4 md:px-0 flex gap-4 overflow-x-auto overflow-y-hidden mt-4 pb-4">
        {% for media_item in product.media %}
          <img
            src="{{ media_item.preview_image.src | image_url }}"
            class="rounded-[10px] h-[90px] cursor-pointer w-auto"
            width="auto"
            height="auto"
            alt="{{ media_item.alt | default: 'Product Image' }}"
            title="{{ media_item.alt | default: 'Product Image' }}"
            onclick="updateMainImage('{{ media_item.preview_image.src | image_url }}')"
          >
        {% endfor %}
      </div>
    </div>

    <div class="wrapper md:p-0 w-full md:w-1/2 flex flex-col gap-5">
      <h1 class="hidden md:block text-primary font-bold text-[30px] leading-tight">
        {%- assign raw_cat = product.metafields.product.category.value | default: 'Gkomunika' -%}
        {%- assign cat_label = raw_cat | replace: '_', ' ' -%}

        <span class="bg-primary text-center px-2 rounded-[10px] leading-none text-neutral">
          {%- if raw_cat contains 'Top_Up_' -%}
            Top Up Plan
          {%- else -%}
            {{- cat_label -}}
          {%- endif -%}
        </span>
        {{ product.title | remove: 'Top Up ' }}
      </h1>

      <div class="flex gap-2 tracking-wider text-sm items-center text-primary">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block -%}
          {%- endcase -%}
        {%- endfor -%}

        <span>- {{ product.metafields.product.sold.value | default: '0' }} sold</span>
      </div>

      <div id="priceContainer" class="hidden md:block">
        <!-- IDR Price -->
        <div id="idr-price-wrapper" class="block">
          <span
            id="variantPriceIDR"
            class="text-secondary font-bold text-xl whitespace-nowrap text-left inline-block"
          ></span>
        </div>

        <!-- USD Price -->
        <div id="usd-price-wrapper" class="hidden">
          <span
            id="variantPriceUSD"
            class="text-secondary font-bold text-xl whitespace-nowrap text-left inline-block"
          ></span>
        </div>
      </div>

      <!-- Dynamic Option Selectors (✅ added id target scroll) -->
      <div id="selectorSection" class="flex items-end gap-3">
        <div
          id="variantSelectors"
          class="flex gap-3 w-full {% if product.metafields.product.category.value == 'Insurance' %}flex-col md:flex-row{% endif %}"
        ></div>

        {% if product.metafields.product.category.value != 'Insurance' %}
          <button
            id="resetSelectionBtn"
            type="button"
            onclick="resetSelection()"
            disabled
            aria-label="Reset selection"
            class="inline-flex items-center justify-center gap-2.5 rounded-[16px] bg-background-third text-primary px-4 py-3 h-[50px] font-semibold leading-thight cursor-pointer transition-all hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed "
          >
            <span class="inline-flex items-center justify-center">
              {% render 'icon-reset', class: 'w-[22px] h-[22px] text-primary' %}
            </span>

            <!-- 2 lines text (hidden on mobile) -->
            <span class="hidden md:flex flex-col text-[14px] lowercase text-left leading-[1.05]">
              <span>reset</span>
              <span>selection</span>
            </span>
          </button>
        {% endif %}
      </div>

      <!-- Insurance Add-on Selector (only for Insurance products) -->
      <div id="insuranceAddonWrapper" class="hidden">
        <label class="text-primary font-semibold tracking-normal block mb-2">Add On (Optional)</label>

        <div class="relative md:max-w-[50%] w-full">
          <button
            type="button"
            id="addon-button"
            class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary text-left bg-neutral truncate"
          >
            Choose Option
          </button>

          <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
            {% render 'icon-arrow-right', class: 'w-[20px] h-[20px] text-primary' %}
          </div>
        </div>

        <p id="addon-error-msg" class="hidden text-[14px] mt-1 text-red-500">Please select variant options first</p>
      </div>

      <div
        id="atPurposeSection"
        class="hidden"
        aria-live="polite"
      >
        <!-- QTY = 1: dropdown biasa -->
        <div id="atPurpose-single" class="hidden">
          <div class="relative md:max-w-[50%] w-full">
            <select
              id="atPurposeSingle"
              class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary appearance-none bg-neutral"
            >
              <option value="" disabled selected>Select Transfer Purpose</option>
              <option value="airport_to_city">Airport to City</option>
              <option value="city_to_airport">City to Airport</option>
            </select>
            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
              {% render 'icon-arrow-right', class: 'w-[20px] h-[20px] text-primary' %}
            </div>
          </div>
        </div>

        <!-- QTY = 2: checkbox same + optional 2 selects -->
        <div id="atPurpose-double" class="hidden space-y-3">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input
              type="checkbox"
              id="atPurposeSameDouble"
              class="w-5 h-5 cursor-pointer accent-[var(--color-secondary)]"
              onchange="handleAtPurposeSameDouble(this.checked)"
            >
            <span class="text-primary text-[15px]">Both transfers have the same purpose</span>
          </label>

          <!-- Jika SAMA: 1 dropdown -->
          <div id="atPurpose-double-same" class="hidden">
            <div class="relative md:max-w-[50%] w-full">
              <select
                id="atPurposeDoubleSame"
                class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary appearance-none bg-neutral"
              >
                <option value="" disabled selected>Select Purpose for All</option>
                <option value="airport_to_city">Airport to City</option>
                <option value="city_to_airport">City to Airport</option>
              </select>
              <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
                {% render 'icon-arrow-right', class: 'w-[20px] h-[20px] text-primary' %}
              </div>
            </div>
          </div>

          <!-- Jika BERBEDA: 2 dropdown -->
          <div id="atPurpose-double-diff" class="space-y-3">
            <div>
              <label class="text-primary text-[14px] font-semibold mb-1 block">1st Transfer Purpose</label>
              <div class="relative md:max-w-[50%] w-full">
                <select
                  id="atPurposeDouble1"
                  class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary appearance-none bg-neutral"
                >
                  <option value="" disabled selected>Select Purpose</option>
                  <option value="airport_to_city">Airport to City</option>
                  <option value="city_to_airport">City to Airport</option>
                </select>
                <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
                  {% render 'icon-arrow-right', class: 'w-[20px] h-[20px] text-primary' %}
                </div>
              </div>
            </div>
            <div>
              <label class="text-primary text-[14px] font-semibold mb-1 block">2nd Transfer Purpose</label>
              <div class="relative md:max-w-[50%] w-full">
                <select
                  id="atPurposeDouble2"
                  class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary appearance-none bg-neutral"
                >
                  <option value="" disabled selected>Select Purpose</option>
                  <option value="airport_to_city">Airport to City</option>
                  <option value="city_to_airport">City to Airport</option>
                </select>
                <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
                  {% render 'icon-arrow-right', class: 'w-[20px] h-[20px] text-primary' %}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- QTY > 2: input pergi + pulang -->
        <div id="atPurpose-multi" class="hidden space-y-3">
          <div class="flex flex-col md:flex-row gap-4 md:items-end">
            <!-- Pergi -->
            <div class="flex flex-col gap-1 flex-1">
              <label class="text-primary text-[14px] font-semibold" for="atMultiGo">
                Airport to City (How many trips?)
              </label>
              <div class="flex items-center border border-primary w-fit rounded-full bg-neutral">
                <button
                  type="button"
                  onclick="adjustAtMulti('go', -1)"
                  class="p-2"
                >
                  {% render 'icon-minus', class: 'w-[24px] h-[24px] text-primary' %}
                </button>
                <input
                  type="text"
                  id="atMultiGo"
                  value="0"
                  inputmode="numeric"
                  class="text-center text-primary w-[50px] outline-none border-l border-r border-primary bg-neutral"
                  oninput="onAtMultiInput('go', this.value)"
                >
                <button
                  type="button"
                  onclick="adjustAtMulti('go', 1)"
                  class="p-2"
                >
                  {% render 'icon-plus', class: 'w-[24px] h-[24px] text-primary' %}
                </button>
              </div>
            </div>

            <!-- Pulang -->
            <div class="flex flex-col gap-1 flex-1">
              <label class="text-primary text-[14px] font-semibold" for="atMultiReturn">
                City to Airport (How many trips?)
              </label>
              <div class="flex items-center border border-primary w-fit rounded-full bg-neutral">
                <button
                  type="button"
                  onclick="adjustAtMulti('return', -1)"
                  class="p-2"
                >
                  {% render 'icon-minus', class: 'w-[24px] h-[24px] text-primary' %}
                </button>
                <input
                  type="text"
                  id="atMultiReturn"
                  value="0"
                  inputmode="numeric"
                  class="text-center text-primary w-[50px] outline-none border-l border-r border-primary bg-neutral"
                  oninput="onAtMultiInput('return', this.value)"
                >
                <button
                  type="button"
                  onclick="adjustAtMulti('return', 1)"
                  class="p-2"
                >
                  {% render 'icon-plus', class: 'w-[24px] h-[24px] text-primary' %}
                </button>
              </div>
            </div>
          </div>

          <!-- Sisa warning -->
          <p id="atMultiWarning" class="hidden text-red-500 text-[13px]"></p>

          <p class="text-primary/60 text-[13px]">Note: Total of both must equal the total quantity purchased.</p>
        </div>
      </div>

      {%- assign cat = product.metafields.product.category.value | default: '' -%}

      {%- unless cat contains 'Top_Up_' -%}
        <!-- ✅ Quantity normal (non Top Up) -->
        <div id="qtySection">
          <span class="text-primary font-semibold tracking-normal">Quantity</span>

          <div class="flex items-center gap-3 mt-2 w-fit">
            <div class="flex items-center border border-primary w-fit rounded-full bg-neutral">
              <button id="qtyMinusBtn" type="button" onclick="decreaseQuantity()" class="p-2">
                {% render 'icon-minus', class: 'w-[24px] h-[24px] text-primary' %}
              </button>

              <input
                type="text"
                id="variant-quantity"
                value="1"
                min="1"
                max="50"
                class="text-center text-primary w-[50px] outline-none border-l border-r border-primary bg-neutral"
                inputmode="numeric"
                pattern="\d*"
              >

              <button type="button" onclick="increaseQuantity()" class="p-2">
                {% render 'icon-plus', class: 'w-[24px] h-[24px] text-primary' %}
              </button>
            </div>

            {% if product.metafields.product.category.value == 'Insurance' %}
              <button
                id="resetSelectionBtnInsurance"
                type="button"
                onclick="resetSelection()"
                disabled
                aria-label="Reset selection"
                class="inline-flex items-center justify-center gap-2.5 rounded-[16px] bg-background-third text-primary px-4 py-3 h-[50px] font-semibold leading-thight cursor-pointer transition-all hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed "
              >
                <span class="inline-flex items-center justify-center">
                  {% render 'icon-reset', class: 'w-[22px] h-[22px] text-primary' %}
                </span>
                <span class="hidden md:flex flex-col text-[14px] lowercase text-left leading-[1.05]">
                  <span>reset</span>
                  <span>selection</span>
                </span>
              </button>
            {% endif %}
          </div>
        </div>

      {%- else -%}
        <!-- ✅ Top Up: qty selalu 1 + input tetap ada biar JS tidak error -->
        <input type="hidden" id="variant-quantity" value="1" min="1" max="1">
      {%- endunless -%}

      <div class="max-h-[200px] overflow-y-scroll">
        <p id="productDesc" class="text-primary"></p>
      </div>

      {%- assign cat = product.metafields.product.category.value | default: '' -%}

      <!-- Desktop buttons (mobile akan pakai fixed bar di bawah) -->
      <div class="hidden md:flex items-center gap-3">
        {%- unless cat contains 'Top_Up_' -%}
          <button
            id="btnAddToCartDesktop"
            type="button"
            onclick="addToCart()"
            class="bg-secondary text-neutral hover:opacity-80 hover:-translate-y-[3px] transition-all rounded-[15px] text-nowrap py-3 cursor-pointer font-bold flex-1 shrink-0 items-center justify-center flex gap-2"
          >
            <span data-btn-text>Add to Cart</span>
            <span data-btn-loader class="hidden">
              {% render 'loading', class: 'text-neutral w-[24px] h-[24px]' %}
            </span>
          </button>
        {%- endunless -%}

        <button
          id="btnBuyNowDesktop"
          type="button"
          onclick="buyNow()"
          class="bg-primary text-neutral hover:opacity-80 hover:-translate-y-[3px] transition-all rounded-[15px] text-nowrap py-3 cursor-pointer font-bold flex-1 shrink-0 items-center justify-center flex gap-2"
        >
          <span data-btn-text>Buy Now</span>
          <span data-btn-loader class="hidden">
            {% render 'loading', class: 'text-neutral w-[24px] h-[24px]' %}
          </span>
        </button>
      </div>
    </div>
  </div>

  {% comment %} SECTION PRODUCT DETAILS & COVERAGE {% endcomment %}
  <div class="wrapper md:wrapper-base">
    <div class="bg-background">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {%- assign type = product.metafields.product.category -%}

        <div class="flex w-full flex-col">
          <h3 class="text-primary font-bold text-[22px] md:text-[26px]">
            {% if type and type.value == 'Airport_Transfer' %}
              Variant Seater
            {% else %}
              Product Details
            {% endif %}
          </h3>

          <div class="mt-3 w-full rounded-[15px] bg-neutral p-4 md:p-5 h-[360px] overflow-hidden">
            <ul class="m-0 list-none p-0 max-h-[320px] overflow-y-auto">
              {% case type.value %}
                {% when 'Insurance' %}
                  {% assign fields = '' %}
                  {% assign fields = fields | append: 'type-of-plans:type of plans,' %}
                  {% assign fields = fields | append: 'insurance-requirements:Insurance Requirements,' %}
                  {% assign fields = fields | append: 'children-requirements:Children Requirements' %}
                  {% assign fields_array = fields | split: ',' %}

                  {% for field in fields_array %}
                    {% assign field_parts = field | split: ':' %}
                    {% assign field_key = field_parts[0] %}
                    {% assign title = field_parts[1] %}
                    {% assign metafield = product.metafields['insurance-product'][field_key] %}

                    {% if metafield != blank %}
                      <div class="flex gap-3 items-start py-2">
                        <div class="w-[30px] h-[30px] shrink-0">
                          {{- field_key | append: '.svg' | inline_asset_content -}}
                        </div>

                        <div class="flex-1">
                          {% assign t = title | replace: '-', ' ' | replace: '_', ' ' | strip %}
                          {% assign words = t | split: ' ' %}
                          {% capture title_case %}
                        {% for w in words %}
                          {% if w != '' %}
                            {{ w | capitalize }}{% unless forloop.last %} {% endunless %}
                          {% endif %}
                        {% endfor %}
                      {% endcapture %}

                          <p class="m-0 text-primary font-bold text-[16px] md:text-[18px] leading-snug">
                            {{ title_case }}
                          </p>

                          {% if metafield.value %}
                            <ul class="mt-1 list-disc pl-5 space-y-1">
                              {% for v in metafield.value %}
                                <li class="text-primary text-[14px] md:text-[16px] leading-snug">{{ v }}</li>
                              {% endfor %}
                            </ul>
                          {% else %}
                            <p class="mt-1 text-primary text-[14px] md:text-[16px] leading-snug">{{ metafield }}</p>
                          {% endif %}
                        </div>
                      </div>

                      <hr class="border-border my-2">
                    {% endif %}
                  {% endfor %}
                {% when 'Airport_Transfer' %}
                  <div class="max-h-[320px] overflow-y-auto space-y-4 pr-1">
                    <div>
                      <p class="m-0 text-primary font-bold text-[18px] md:text-[20px] leading-snug">5 Seater</p>
                      <ul class="mt-1 list-disc pl-5 space-y-1">
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Capacity: 5 passengers (Toyota Alphard / similar vehicle)
                        </li>
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Luggage: 3 × 28", or 4 × 25", or 5 × 24"
                        </li>
                      </ul>
                    </div>
                    <hr class="border-border">

                    <div>
                      <p class="m-0 text-primary font-bold text-[18px] md:text-[20px] leading-snug">9 Seater</p>
                      <ul class="mt-1 list-disc pl-5 space-y-1">
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Capacity: 9 passengers (Toyota Hiace / similar vehicle)
                        </li>
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Luggage: 9 × 28", or 10 × 26", or 14 × 24"
                        </li>
                      </ul>
                    </div>
                    <hr class="border-border">

                    <div>
                      <p class="m-0 text-primary font-bold text-[18px] md:text-[20px] leading-snug">11 Seater</p>
                      <ul class="mt-1 list-disc pl-5 space-y-1">
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Capacity: 11 passengers (Toyota Hiace / similar vehicle)
                        </li>
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Luggage: 7 × 28", or 8 × 26", or 8 × 24"
                        </li>
                      </ul>
                    </div>
                    <hr class="border-border">

                    <div>
                      <p class="m-0 text-primary font-bold text-[18px] md:text-[20px] leading-snug">18 Seater</p>
                      <ul class="mt-1 list-disc pl-5 space-y-1">
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Capacity: 18 passengers (Toyota Coaster / similar vehicle)
                        </li>
                        <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                          Luggage: 18 × 28", or 20 × 26", or 2 × 24"
                        </li>
                      </ul>
                    </div>
                  </div>
                {% else %}
                  {% for item in product.metafields.details %}
                    {% assign key = item.first %}
                    {% assign value = item.last %}
                    {% if value != blank %}
                      <div class="flex gap-3 items-start py-2">
                        <div class="w-[30px] h-[30px] shrink-0">
                          {{- key | append: '.svg' | inline_asset_content -}}
                        </div>

                        <div class="flex-1">
                          <p class="m-0 text-primary font-bold text-[16px] md:text-[18px] leading-snug">
                            {% if key == 'apn' %}
                              {{ key | upcase }}
                            {% else %}
                              {{ key | replace: '_', ' ' | capitalize }}
                            {% endif %}
                          </p>

                          {% if value.value %}
                            <ul class="mt-1 list-disc pl-5 space-y-1">
                              {% for v in value.value %}
                                <li class="text-primary text-[14px] md:text-[16px] leading-snug">{{ v }}</li>
                              {% endfor %}
                            </ul>
                          {% else %}
                            <p class="mt-1 text-primary text-[14px] md:text-[16px] leading-snug">{{ value }}</p>
                          {% endif %}
                        </div>
                      </div>

                      <hr class="border-border my-2">
                    {% endif %}
                  {% endfor %}
              {% endcase %}
            </ul>
          </div>
        </div>

        {%- comment -%} ======================== COVERAGE ======================== {%- endcomment -%}
        <div class="flex w-full flex-col">
          <h3 class="text-primary font-bold text-[22px] md:text-[26px]">
            {% if type and type.value == 'Airport_Transfer' %}
              Syarat &amp; Ketentuan
            {% else %}
              Coverage
            {% endif %}
          </h3>

          <div class="mt-3 w-full rounded-[15px] bg-neutral p-4 md:p-5 h-[360px] overflow-hidden">
            {% if type and type.value == 'Airport_Transfer' %}
              <div class="h-full overflow-y-auto">
                <ol class="list-decimal pl-5 space-y-3">
                  <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                    Layanan Private Airport Transfer ini sudah termasuk pengemudi profesional, biaya bahan bakar, tol,
                    dan parkir.
                  </li>

                  <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                    Penjemputan pada malam hari dikenakan biaya tambahan dengan rincian sebagai berikut:
                    <div class="mt-2">
                      Penjemputan malam mulai dari jam 10:00pm - 6:00am dikenakan biaya tambahan berdasarkan jangka
                      waktu 2.000JPY - 5.000JPY. Pembayaran langsung di tempat kepada pengemudi.
                    </div>
                  </li>

                  <li class="text-primary text-[14px] md:text-[16px] leading-snug">
                    Waktu tunggu driver:
                    <ul class="mt-2 list-disc pl-5 space-y-1">
                      <li>Waktu tunggu untuk pengantaran ke Bandara: 30 menit</li>
                      <li>Waktu tunggu untuk penjemputan di Bandara: 90 menit</li>
                    </ul>

                    <div class="mt-2 space-y-1">
                      <div>Jika melebihi waktu tunggu akan dikenakan biaya 5.000JPY/ 1 Jam untuk 6-9 Seater</div>
                      <div>Jika melebihi waktu tunggu akan dikenakan biaya 10.000JPY/ 1 Jam untuk 18 Seater</div>
                    </div>
                  </li>
                </ol>
              </div>
            {% else %}
              <div class="h-full flex flex-col overflow-hidden">
                {% if product.metafields.search.key.value.size > 10 %}
                  <div class="bg-neutral shrink-0 z-10">
                    {% render 'coverage-search' %}
                  </div>
                {% endif %}

                <div class="flex-1 overflow-y-auto {% if product.metafields.search.key.value.size > 10 %}mt-3{% endif %}">
                  {% render 'coverage' %}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      {%- comment -%} ================== INSURANCE BENEFITS (ONLY) ================== {%- endcomment -%}
      {% assign product_category = product.metafields.product.category.value | default: 'Undefined' %}
      {% if product_category == 'Insurance' %}
        <div class="mt-6 md:mt-8">
          {% render 'insurance-benefits' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

