<h1 id="title" class="text-xl font-semibold"></h1>
<div id="desc" class="prose max-w-none mt-2"></div>

<div id="optionsWrap" class="mt-4 space-y-4"></div>

<div class="mt-6 flex items-center gap-3">
  <span class="text-sm font-medium text-gray-900">Qty</span>

  <div class="inline-flex items-center rounded-xl border border-gray-300 overflow-hidden">
    <button id="qtyDec" type="button" class="px-3 py-2 text-sm hover:bg-gray-100" aria-label="Decrease quantity">−</button>
    <input id="qtyInput" type="text" value="1" readonly
           class="w-12 text-center text-sm outline-none border-x border-gray-300 py-2" />
    <button id="qtyInc" type="button" class="px-3 py-2 text-sm hover:bg-gray-100" aria-label="Increase quantity">+</button>
  </div>
</div>

<div class="mt-3 text-sm leading-6">
  <div>
    <span class="font-semibold">Total:</span>
    <span id="variantTotalPrice" class="money" data-cents="">-</span>
  </div>
</div>

<div class="mt-6 text-sm leading-6">
  <div><span class="font-semibold">Variant ID:</span> <span id="variantId">-</span></div>
  <div><span class="font-semibold">Variant:</span> <span id="variantTitle">-</span></div>
  <div><span class="font-semibold">Price:</span> <span id="variantPrice">-</span></div>
  <div><span class="font-semibold">Available:</span> <span id="variantAvail">-</span></div>
</div>

<div id="variant-picker"></div>

<div style="margin-top:8px;">
  <strong id="variant-price"></strong>
</div>

<script>
  const productData = {{ product | json }};

  // priceMap berisi HTML span.money dari Liquid
  const priceMap = {
    {%- for v in product.variants -%}
      "{{ v.id }}": {{ v.price | money_with_currency | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  };

  (function () {
    const root = document.getElementById('variant-picker');
    if (!root) return;

    const optionCount = (productData.options || []).length;
    const selectors = [];

    function uniqueOptionValues(optionIndex1Based) {
      const key = 'option' + optionIndex1Based;
      const set = new Set();
      (productData.variants || []).forEach(v => v[key] && set.add(v[key]));
      return Array.from(set);
    }

    for (let i = 1; i <= optionCount; i++) {
      const wrap = document.createElement('div');
      wrap.style.marginBottom = '8px';

      const label = document.createElement('label');
      label.textContent = productData.options[i - 1] || ('Option ' + i);
      label.style.display = 'block';
      label.style.marginBottom = '4px';

      const select = document.createElement('select');
      select.dataset.optionIndex = String(i);

      uniqueOptionValues(i).forEach(val => {
        const opt = document.createElement('option');
        opt.value = val;
        opt.textContent = val;
        select.appendChild(opt);
      });

      wrap.appendChild(label);
      wrap.appendChild(select);
      root.appendChild(wrap);

      selectors.push(select);
    }

    const priceEl = document.getElementById('variant-price');

    function findMatchingVariant() {
      const selected = {};
      selectors.forEach(sel => selected['option' + sel.dataset.optionIndex] = sel.value);

      return (productData.variants || []).find(v => {
        for (let i = 1; i <= optionCount; i++) {
          const k = 'option' + i;
          if ((selected[k] || null) !== (v[k] || null)) return false;
        }
        return true;
      }) || null;
    }

    function updateUI() {
      const variant = findMatchingVariant();
      if (!variant) {
        if (priceEl) priceEl.innerHTML = '';
        return;
      }

      // IMPORTANT: pakai innerHTML supaya span.money terbentuk dan Bucks bisa convert
      const htmlMoney = priceMap[String(variant.id)] || '';
      if (priceEl) priceEl.innerHTML = htmlMoney;

      // Optional: kalau Bucks butuh “refresh” manual setelah DOM berubah,
      // coba panggil fungsi global converter-nya kalau ada:
      // if (window.Bucks?.refresh) window.Bucks.refresh();
      // if (window.Currency?.convertAll) window.Currency.convertAll();
    }

    selectors.forEach(sel => sel.addEventListener('change', updateUI));
    updateUI();
  })();
</script>

<script>
(async () => {
  const getProductHandle = () => {
    const parts = location.pathname.split('/').filter(Boolean);
    const i = parts.indexOf('products');
    return i >= 0 ? parts[i + 1] : null;
  };

  const handle = getProductHandle();
  if (!handle) return console.warn('Handle tidak ditemukan. Path:', location.pathname);

  const url = `/products/${encodeURIComponent(handle)}?view=product-api-json`;

  try {
    const text = await (await fetch(url, { credentials: 'same-origin' })).text();
    const data = JSON.parse(text);

    const product = data?.product ?? {};
    const title = product?.title ?? '';
    const descHtml = product?.description_html ?? '';
    const options = product?.options ?? [];
    const variants = product?.variants ?? [];

    // Render title/desc
    const elTitle = document.getElementById('title');
    if (elTitle) elTitle.textContent = title;

    const elDesc = document.getElementById('desc');
    if (elDesc) elDesc.innerHTML = descHtml;

    const wrap = document.getElementById('optionsWrap');
    if (!wrap) return;

    // ===== Qty state + controls =====
    const MAX_QTY = 20; // harus sama dengan range yang kamu generate di JSON view
    let qty = 1;

    const elQtyInput = document.getElementById('qtyInput');
    const elQtyDec = document.getElementById('qtyDec');
    const elQtyInc = document.getElementById('qtyInc');

    const setQty = (next) => {
      qty = Math.max(1, Math.min(MAX_QTY, Number(next) || 1));
      if (elQtyInput) elQtyInput.value = String(qty);
    };

    const incrementQty = () => setQty(qty + 1);
    const decrementQty = () => setQty(qty - 1);

    if (elQtyInc) elQtyInc.addEventListener('click', () => { incrementQty(); onChange(); });
    if (elQtyDec) elQtyDec.addEventListener('click', () => { decrementQty(); onChange(); });

    // bikin select per option (Tailwind classes)
    wrap.innerHTML = options.map((opt, idx) => {
      const opts = (opt.values || [])
        .map(v => `<option value="${String(v).replace(/"/g,'&quot;')}">${v}</option>`)
        .join('');

      return `
        <div class="space-y-1">
          <label for="opt-${idx}" class="block text-sm font-medium text-gray-900">
            ${opt.name}
          </label>

          <div class="relative">
            <select
              id="opt-${idx}"
              data-opt-name="${opt.name}"
              class="block w-full rounded-xl border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900
                     shadow-sm focus:border-gray-900 focus:ring-2 focus:ring-gray-900/20
                     disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-500">
              <option value="">Choose Option</option>
              ${opts}
            </select>

            <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-500"
                 viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/>
            </svg>
          </div>

          <p id="hint-${idx}" class="hidden text-xs text-gray-500"></p>
        </div>
      `;
    }).join('');

    const getSelections = () => {
      const selects = wrap.querySelectorAll('select[id^="opt-"]');
      const selections = {};
      selects.forEach(sel => {
        const name = sel.getAttribute('data-opt-name');
        selections[name] = sel.value;
      });
      return selections;
    };

    const findMatchingVariant = (selections) => {
      for (const opt of options) {
        if (!selections[opt.name]) return null;
      }

      return variants.find(v => {
        const so = v.selected_options || [];
        return options.every(opt => {
          const picked = selections[opt.name];
          const row = so.find(x => x.name === opt.name);
          return row && row.value === picked;
        });
      }) || null;
    };

    const renderVariantInfo = (variant) => {
      const elId = document.getElementById('variantId');
      const elT = document.getElementById('variantTitle');
      const elP = document.getElementById('variantPrice');
      const elA = document.getElementById('variantAvail');
      const elTotal = document.getElementById('variantTotalPrice');

      if (!variant) {
        if (elId) elId.textContent = '-';
        if (elT) elT.textContent = '-';
        if (elP) elP.textContent = '-';
        if (elA) elA.textContent = '-';
        if (elTotal) elTotal.textContent = '-';
        return;
      }

      if (elId) elId.textContent = variant.id ?? '-';
      if (elT) elT.textContent = variant.title ?? '-';

      // Unit price (sudah diformat Liquid di JSON view)
      if (elP) elP.textContent = variant.price_money_with_currency ?? '-';

      // Total price (ambil dari map qty yang sudah diformat Liquid)
      const totalByQty = variant.total_money_with_currency_by_qty || {};
      if (elTotal) elTotal.textContent = totalByQty[String(qty)] ?? '-';

      if (elA) elA.textContent = variant.available ? 'Yes' : 'No';
    };

    // Disable options yang tidak mungkin menghasilkan variant AVAILABLE
    const updateDisabledOptions = () => {
      const selections = getSelections();
      const availableVariants = variants.filter(v => !!v.available);

      const validValuesByOption = {};
      options.forEach(o => validValuesByOption[o.name] = new Set());

      options.forEach(targetOpt => {
        const targetName = targetOpt.name;
        const base = { ...selections };
        delete base[targetName];

        availableVariants.forEach(v => {
          const so = v.selected_options || [];

          const matchBase = Object.entries(base).every(([name, picked]) => {
            if (!picked) return true;
            const row = so.find(x => x.name === name);
            return row && row.value === picked;
          });

          if (!matchBase) return;

          const rowTarget = so.find(x => x.name === targetName);
          if (rowTarget?.value) validValuesByOption[targetName].add(rowTarget.value);
        });
      });

      wrap.querySelectorAll('select[id^="opt-"]').forEach(sel => {
        const optName = sel.getAttribute('data-opt-name');
        const validSet = validValuesByOption[optName] || new Set();

        Array.from(sel.options).forEach((optEl, idx) => {
          if (idx === 0) return;
          optEl.disabled = !validSet.has(optEl.value);
        });

        if (sel.value && !validSet.has(sel.value)) sel.value = "";
      });

      wrap.querySelectorAll('select[id^="opt-"]').forEach((sel, idx) => {
        const optName = sel.getAttribute('data-opt-name');
        const validSet = validValuesByOption[optName] || new Set();
        const hint = document.getElementById(`hint-${idx}`);

        const shouldDisableSelect = validSet.size === 0;
        sel.disabled = shouldDisableSelect;

        if (hint) {
          if (shouldDisableSelect) {
            hint.textContent = 'Tidak ada kombinasi tersedia untuk pilihan saat ini.';
            hint.className = 'block text-xs text-gray-500';
          } else {
            hint.textContent = '';
            hint.className = 'hidden text-xs text-gray-500';
          }
        }
      });
    };

    const onChange = () => {
      updateDisabledOptions();
      const selections = getSelections();
      const variant = findMatchingVariant(selections);
      renderVariantInfo(variant);
    };

    wrap.querySelectorAll('select[id^="opt-"]').forEach(sel => {
      sel.addEventListener('change', onChange);
    });

    updateDisabledOptions();
    onChange();

  } catch (err) {
    console.error('Fetch/parse error:', err, { url });
  }
})();
</script>


<script src="{{ 'section-main-product.js' | asset_url }}" defer="defer"></script>

<style>
  .gw-full-width {
    width: 200px !important;
    display: flex;
    align-items: center;
  }

  .cart-popup {
    position: fixed !important;
    top: 10% !important;
    right: 5% !important;
    background-color: var(--color-primary);
    padding: 0 10px;
    border-radius: 5px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.4);
    z-index: 9999;
  }

  .cart-popup-content {
    text-align: center;
    color: var(--color-neutral);
  }

  @media (max-width: 768px) {
    .cart-popup {
      top: 30%;
      right: 0;
    }

    .product-title-mobile {
      display: none !important;
    }

    .main-product-container {
      padding-top: 50px;
    }

    .main-product-sub-images-wrapper .scroll-btn {
      display: none !important;
    }

    .main-product-sub-images {
      display: flex;
      gap: 8px;
      padding-left: 8px;
      padding-right: 8px;
      margin: 0;
      scroll-padding-left: 8px;
      scroll-padding-right: 8px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
      overscroll-behavior-x: contain;
      background-color: transparent;
    }

    .main-product-sub-images img {
      flex: 0 0 auto;
      margin: 0;
    }
  }
</style>

<product-info
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  <div id="cart-popup" class="cart-popup" style="display: none;">
    <div class="cart-popup-content">
      <p id="popup-product-title">Success add to cart</p>
    </div>
  </div>
  <div class="main-product-container">
    <div class="main-product-header">
      {% if product.title %}
        <h2 class="product-title-mobile">{{ product.title }}</h2>
      {% endif %}
      <div class="main-product-header-left">
        <img
          class="main-product-main-images"
          id="mainImage"
          src="{{ product.featured_image | img_url: 'master' }}"
          alt="{{ product.title | escape }}"
          width="auto"
          height="auto"
          loading="lazy"
        >
        <div class="main-product-sub-images-wrapper">
          <button
            class="scroll-btn left"
            style="transform: rotate(180deg);"
            onclick="scrollSubImages(-1)"
            aria-label="Scroll left"
          >
            {{- 'icon-arrow-back.svg' | inline_asset_content -}}
          </button>
          <div class="main-product-sub-images">
            {% for image in product.images %}
              <img
                class="sub-image"
                src="{{ image | img_url: 'master' }}"
                alt="Sub Image {{ forloop.index }}"
                width="auto"
                height="auto"
                data-src="{{ image | img_url: 'large' }}"
                loading="lazy"
              >
            {% endfor %}
          </div>
          <button class="scroll-btn right" onclick="scrollSubImages(1)" aria-label="Scroll right">
            {{- 'icon-arrow-back.svg' | inline_asset_content -}}
          </button>
        </div>
      </div>

      {% assign product-sold = product.metafields.product.sold %}
      <div class="main-product-header-right">
        {% if product.title %}
          <h2 class="product-title">{{ product.title }}</h2>
        {% endif %}
        <div style="display: flex; align-items: center">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block -%}
                {%- if product-sold %}
                  <ul
                    style="
                      padding: 0 0 0 10  px; display: flex;
                      align-items: center;
                    "
                  >
                    <li style="padding: 0; font-size: 0.875em;">{{ product-sold.value }} sold</li>
                  </ul>
                {% endif %}
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {% assign min_price = product.variants.first.price %}
        {% assign max_price = product.variants.first.price %}
        {% for variant in product.variants %}
          {% if variant.price < min_price %} {% assign min_price = variant.price %} {% endif %}
          {% if variant.price > max_price %}
            {% assign max_price = variant.price %}
          {% endif %}
        {% endfor %}

        {% assign min_price_formatted = min_price | money_with_currency %}
        {% assign max_price_formatted = max_price | money_with_currency %}

        <div id="variant-price-desktop" class="money">
          {{ min_price_formatted -}}
          {%- unless min_price == max_price %}
            - {{ max_price_formatted -}}
          {%- endunless %}
        </div>
        <div class="main-product-variant-picker">
          {% render 'custom-variant-picker', product: product %}
        </div>
      </div>
    </div>
    <div class="main-product-main-content">
      <div class="main-product-content">
        <div class="main-product__content-container">
          {% assign type = product.metafields.product.category %}
          {% if type and type.value != 'Insurance' %}
            <div class="main-product-content-wrapper">
              <label>Product Details</label>
              <div class="main-product-content-left">
                <ul>
                  {% for item in product.metafields.details %}
                    {% assign key = item.first %}
                    {% assign value = item.last %}
                    {% if value != blank %}
                      <div class="mp-content-wrapper">
                        <div class="mp-content-icon-img">
                          {{- key | append: '.svg' | inline_asset_content -}}
                        </div>
                        <div class="mp-content-text">
                          <p class="title">
                            {% if key == 'apn' %}
                              {{ key | upcase }}
                            {% else %}
                              {{ key | replace: '_', ' ' | capitalize }}
                            {% endif %}
                          </p>
                          {% if value.value %}
                            {% for v in value.value %}
                              <li>{{ v }}</li>
                            {% endfor %}
                          {% else %}
                            <p>{{ value }}</p>
                          {% endif %}
                        </div>
                      </div>
                      <hr class="mp-content-divider">
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>
          {% else %}
            <div class="main-product-content-wrapper">
              <label>Product Details</label>
              <div class="main-product-content-left">
                <ul>
                  {% assign fields = '' %}
                  {% assign fields = fields | append: 'type-of-plans:type of plans,' %}
                  {% assign fields = fields | append: 'insurance-requirements:Insurance Requirements,' %}
                  {% assign fields = fields | append: 'children-requirements:Children Requirements' %}

                  {% assign fields_array = fields | split: ',' %}

                  {% for field in fields_array %}
                    {% assign field_parts = field | split: ':' %}
                    {% assign field_key = field_parts[0] %}
                    {% assign title = field_parts[1] %}
                    {% assign metafield = product.metafields['insurance-product'][field_key] %}
                    {% if metafield != blank %}
                      <div class="mp-content-wrapper">
                        <div class="mp-content-icon-img">
                          {{- field_key | append: '.svg' | inline_asset_content -}}
                        </div>
                        <div class="mp-content-text">
                          {% assign t = title | replace: '-', ' ' | replace: '_', ' ' | strip %}
                          {% assign words = t | split: ' ' %}
                          {% capture title_case %}
                    {% for w in words %}
                    {% if w != '' %}{{ w | capitalize }}{% unless forloop.last %} {% endunless %}{% endif %}
                    {% endfor %}
                    {% endcapture %}

                          <p class="title">{{ title_case }}</p>

                          {% if metafield.value %}
                            {% for v in metafield.value %}
                              <li style="margin-left: 20px; list-style-type: disc;">{{ v }}</li>
                            {% endfor %}
                          {% else %}
                            <p>{{ metafield }}</p>
                          {% endif %}
                        </div>
                      </div>
                      <hr class="mp-content-divider">
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>
          {% endif %}

          <div class="main-product-content-wrapper">
            <label>Coverage</label>
            <div class="main-product-content-right">
              <div class="main-product-content-right-wrapper">
                {% if product.metafields.coverage.country.value.size > 10 %}
                  {% render 'coverage-search' %}
                {% endif %}
                {% render 'coverage' %}
              </div>
            </div>
          </div>
        </div>
        {% assign product_category = product.metafields.product.category.value | default: 'Undefined' %}
        {% if product_category == 'Insurance' %}
          {% render 'insurance-benefits' %}
        {% endif %}
      </div>
      <div class="main-product-ratting"></div>
    </div>
  </div>
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
</product-info>

{% schema %}
{
  "name": "Main Product",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Main Product"
    }
  ]
}
{% endschema %}
