  id="iccid-modal"
  class="hidden fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-neutral p-4 rounded-[15px] z-[1000] w-[90%] max-w-md shadow-lg"
>
  <div class="flex gap-3">
    <h3 class="text-primary font-bold text-lg">{{ 'products.top_up.label_input_iccid' | t }}</h3>

    <button
      class="info-tooltip"
      aria-label="{{ 'products.check_data.tooltip_iccid' | t }}"
