<script>
  /* =========================================================
   * GLOBALS (paling atas)
   * ========================================================= */
  const shopCurrency = '{{ shop.currency }}';
  const customerLoggedIn = {% if customer %}true{% else %}false{% endif %};

  let isAddingToCart = false;
  let isBuyingNow = false;
  let isIccidSubmitting = false;

  let cachedUSDRate = null;

  // State
  let selectedOptions = [];
  let selectedVariant = null;
  let lastCurrency = null;
  let selectedAddons = [];
  let lastSelectedVariantId = null;

  // Internal timers
  let toastTimer = null;
  let currencyPollTimer = null;

  /* =========================================================
   * DATA (Shopify product → filtered object)
   * ========================================================= */
  const data = {{ product | json }};

  const filtered = {
    id: data.id,
    title: data.title,
    handle: data.handle,
    description: data.description,
    price: '{{ product.price | money_with_currency }}',
    price_min: '{{ product.price_min | money_with_currency }}',
    price_max: '{{ product.price_max | money_with_currency }}',
    price_min_raw: {{ product.price_min }},
    price_max_raw: {{ product.price_max }},
    available: data.available,
    images: data.images || [],
    featured_image: data.featured_image || null,
    media: data.media || [],
    category: "{{ product.metafields.product.category.value }}",
    metafields: {
      category: "{{ product.metafields.product.category.value }}",
      coverage: [
        {% for country in product.metafields.search.key.value %}
          {
            country_en: "{{ country.country.value }}",
            country_id: "{{ country.country_id.value }}",
            country_alias: [
              {% for alias in country.alias.value %}
                "{{ alias }}"{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ],
            flag: {% if country.flag.value %}"{{ country.flag.value | image_url }}"{% else %}null{% endif %}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      insurance_addons: [
        {% assign ProductAddon = product.metafields.product['insurance-addon'].value %}
        {% if ProductAddon %}
          {% for addon_product in ProductAddon %}
            {
              addon_type: "{{ addon_product.metafields.insurance['addon-type'].value }}",
              variants: [
                {% for variant in addon_product.variants %}
                  {
                    id: {{ variant.id }},
                    title: "{{ variant.title | escape }}",
                    option1: "{{ variant.option1 | escape }}",
                    option2: "{{ variant.option2 | escape }}",
                    option3: "{{ variant.option3 | escape }}",
                    price: "{{ variant.price | money_with_currency }}",
                    priceRaw: {{ variant.price }}
                  }{% unless forloop.last %},{% endunless %}
                {% endfor %}
              ]
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% endif %}
      ]
    },
    options: data.options || [],
    variants: [
      {% for variant in product.variants %}
        {
          id: {{ variant.id }},
          title: "{{ variant.title }}",
          price: "{{ variant.price | money_with_currency }}",
          priceRaw: {{ variant.price }},
          sku: "{{ variant.sku }}",
          available: {{ variant.available }},
          variantType: {{ variant.metafields.variant.type | json }},
          airportPurpose: {{ variant.metafields.airport.purpose.value | default: '' | json }},
          airportAutoVariantId: {{ variant.metafields.airport.auto_variant.value.id | default: '' | json }},
          airportAutoVariantTitle: {{ variant.metafields.airport.auto_variant.value.title | default: 0 | json }},
          options: [
            {% for option in variant.options %}
              "{{ option }}"{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };

  // Debug JSON output (tetap)
  const resultEl = document.getElementById('result');
  if (resultEl) resultEl.textContent = JSON.stringify(filtered, null, 2);

  /* =========================================================
   * DOM HELPERS
   * ========================================================= */
  const $ = (id) => document.getElementById(id);

  const dom = () => ({
    mainImage: $('mainImage'),

    variantSelectors: $('variantSelectors'),

    idrWrapper: $('idr-price-wrapper'),
    usdWrapper: $('usd-price-wrapper'),
    priceIDR: $('variantPriceIDR'),
    priceUSD: $('variantPriceUSD'),
    btnAddToCartDesktop: $('btnAddToCartDesktop'),
    btnBuyNowDesktop: $('btnBuyNowDesktop'),
    btnAddToCartMobile: $('btnAddToCartMobile'),
    btnBuyNowMobile: $('btnBuyNowMobile'),
    iccidSubmitBtn: $('iccid-submit-btn'),


    resetBtnNonInsurance: $('resetSelectionBtn'),
    resetBtnInsurance: $('resetSelectionBtnInsurance'),

    qtyInput: $('variant-quantity'),

    productDesc: $('productDesc'),

    toast: $('toast-notification'),

    // Insurance addon UI
    addonWrapper: $('insuranceAddonWrapper'),
    addonButton: $('addon-button'),
    addonErrorMsg: $('addon-error-msg'),
    addonList: $('selected-addon-list'),

    popupOverlay: $('addon-popup-overlay'),
    closePopupBtn: $('close-popup__choose-addon'),

    displayOpt1: $('display-option1'),
    displayOpt2: $('display-option2'),
    displayOpt3: $('display-option3')
  });

  function releaseBuyNowLock() {
    isBuyingNow = false;
    setBuyNowLoading(false);
  }

  function setButtonLoading(btn, loading) {
    if (!btn) return;

    btn.disabled = !!loading;
    btn.setAttribute('aria-busy', loading ? 'true' : 'false');
    btn.classList.toggle('opacity-70', loading);
    btn.classList.toggle('pointer-events-none', loading);

    const textEl = btn.querySelector('[data-btn-text]');
    const loaderEl = btn.querySelector('[data-btn-loader]');

    if (textEl) textEl.classList.toggle('hidden', loading);
    if (loaderEl) loaderEl.classList.toggle('hidden', !loading);
  }

  function setAddToCartLoading(loading) {
    const { btnAddToCartDesktop, btnAddToCartMobile } = dom();
    setButtonLoading(btnAddToCartDesktop, loading);
    setButtonLoading(btnAddToCartMobile, loading);
  }

  function setBuyNowLoading(loading) {
    const { btnBuyNowDesktop, btnBuyNowMobile } = dom();
    setButtonLoading(btnBuyNowDesktop, loading);
    setButtonLoading(btnBuyNowMobile, loading);
  }

  function setIccidLoading(loading) {
    const { iccidSubmitBtn } = dom();
    setButtonLoading(iccidSubmitBtn, loading);

    const cancelBtn = document.getElementById('iccid-cancel');
    if (cancelBtn) cancelBtn.disabled = !!loading;
  }


  /* =========================================================
   * MOBILE BAR HELPERS
   * ========================================================= */
  function scrollToSelectors() {
    const el = document.getElementById('selectorSection');
    const bar = document.getElementById('mobileBuyBar');
    if (!el) return;

    const offset = (bar?.offsetHeight || 0) + 16;
    const y = el.getBoundingClientRect().top + window.pageYOffset - offset;

    window.scrollTo({ top: y, behavior: 'smooth' });
  }

  function updateMobileSelectedVariantLabel() {
    const btn = document.getElementById('mobileSelectedVariant');
    if (!btn) return;

    if (selectedVariant?.title) btn.textContent = selectedVariant.title;
    else btn.textContent = 'Selected Variant';
  }

  /* =========================================================
   * INIT: DESCRIPTION
   * ========================================================= */
  function initDescription() {
    const { productDesc } = dom();
    if (!productDesc) return;

    productDesc.innerHTML = (filtered.description || '')
      .replace(/&nbsp;/g, ' ')
      .replace(/\s+/g, '  ')
      .trim()
      .replace(/<a /g, '<a class="underline text-secondary" ');
  }

  /* =========================================================
   * CURRENCY + PRICE HELPERS
   * ========================================================= */
  async function getExchangeRate() {
    if (cachedUSDRate) return cachedUSDRate;

    try {
      const res = await fetch('https://api.exchangerate-api.com/v4/latest/IDR');
      const json = await res.json();
      cachedUSDRate = json?.rates?.USD || 0.000066;
      return cachedUSDRate;
    } catch (err) {
      console.error('Failed to fetch exchange rate:', err);
      cachedUSDRate = 0.000066; // fallback
      return cachedUSDRate;
    }
  }

  function convertIDRtoUSDInstant(idrAmount) {
    const rate = cachedUSDRate || 0.000066;
    return (idrAmount * rate).toFixed(2);
  }

  function formatIDR(amount) {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    })
      .format(amount)
      .replace(/\u00A0/g, ' ');
  }

  function formatUSD(amount) {
    return `$${parseFloat(amount).toFixed(2)}`;
  }

  function getUserCurrency() {
    let c = sessionStorage.getItem('buckscc_customer_currency');
    if (c) c = c.replace(/"/g, '');
    return c || 'IDR';
  }

  function formatAddonPrice(priceRaw, quantity = 1) {
    const totalIDR = (priceRaw / 100) * quantity;
    const cur = getUserCurrency();

    if (cur === 'USD') {
      return formatUSD(convertIDRtoUSDInstant(totalIDR));
    }
    return formatIDR(totalIDR);
  }

  function toggleCurrencyDisplay() {
    let userCurrency = sessionStorage.getItem('buckscc_customer_currency');
    if (userCurrency) userCurrency = userCurrency.replace(/"/g, '');

    const { idrWrapper, usdWrapper } = dom();
    if (!idrWrapper || !usdWrapper) return;

    // ✅ mobile wrappers
    const mobileIDR = document.getElementById('mobile-idr-price-wrapper');
    const mobileUSD = document.getElementById('mobile-usd-price-wrapper');

    if (userCurrency === 'USD') {
      idrWrapper.classList.add('hidden');
      idrWrapper.classList.remove('block');

      usdWrapper.classList.remove('hidden');
      usdWrapper.classList.add('block');

      mobileIDR?.classList.add('hidden');
      mobileIDR?.classList.remove('block');

      mobileUSD?.classList.remove('hidden');
      mobileUSD?.classList.add('block');
    } else {
      idrWrapper.classList.remove('hidden');
      idrWrapper.classList.add('block');

      usdWrapper.classList.add('hidden');
      usdWrapper.classList.remove('block');

      mobileIDR?.classList.remove('hidden');
      mobileIDR?.classList.add('block');

      mobileUSD?.classList.add('hidden');
      mobileUSD?.classList.remove('block');
    }
  }

  function updateIDRPrice(priceRaw, quantity = 1) {
    const totalIDR = (priceRaw / 100) * quantity;
    const { priceIDR } = dom();
    const mobile = document.getElementById('variantPriceIDRMobile');

    const text = formatIDR(totalIDR);
    if (priceIDR) priceIDR.textContent = text;
    if (mobile) mobile.textContent = text;
  }

  async function updateUSDPrice(priceRaw, quantity = 1) {
    const totalIDR = (priceRaw / 100) * quantity;

    const { priceUSD } = dom();
    const mobile = document.getElementById('variantPriceUSDMobile');

    if (!priceUSD && !mobile) return;

    // instant (cached/fallback)
    const instant = formatUSD(convertIDRtoUSDInstant(totalIDR));
    if (priceUSD) priceUSD.textContent = instant;
    if (mobile) mobile.textContent = instant;

    // fetch rate if belum ada
    if (!cachedUSDRate) {
      const rate = await getExchangeRate();
      const finalText = formatUSD((totalIDR * rate).toFixed(2));
      if (priceUSD) priceUSD.textContent = finalText;
      if (mobile) mobile.textContent = finalText;
    }
  }

  async function updatePriceDisplay(priceRaw = null) {
    const qty = parseInt(dom().qtyInput?.value) || 1;
    const { priceIDR, priceUSD } = dom();

    if (priceRaw !== null) {
      updateIDRPrice(priceRaw, qty);
      await updateUSDPrice(priceRaw, qty);
      toggleCurrencyDisplay();
      return;
    }

    // Range price
    if (priceIDR) {
      const minIDR = formatIDR(filtered.price_min_raw / 100);
      const maxIDR = formatIDR(filtered.price_max_raw / 100);
      const range = `${minIDR} - ${maxIDR}`;
      priceIDR.textContent = range;

      const mobileIDRText = document.getElementById('variantPriceIDRMobile');
      if (mobileIDRText) mobileIDRText.textContent = range;
    }

    if (priceUSD) {
      const minUSD = convertIDRtoUSDInstant(filtered.price_min_raw / 100);
      const maxUSD = convertIDRtoUSDInstant(filtered.price_max_raw / 100);
      const range = `${formatUSD(minUSD)} - ${formatUSD(maxUSD)}`;
      priceUSD.textContent = range;

      const mobileUSDText = document.getElementById('variantPriceUSDMobile');
      if (mobileUSDText) mobileUSDText.textContent = range;

      if (!cachedUSDRate) {
        await getExchangeRate();
        const minFinal = convertIDRtoUSDInstant(filtered.price_min_raw / 100);
        const maxFinal = convertIDRtoUSDInstant(filtered.price_max_raw / 100);
        const range2 = `${formatUSD(minFinal)} - ${formatUSD(maxFinal)}`;
        priceUSD.textContent = range2;
        if (mobileUSDText) mobileUSDText.textContent = range2;
      }
    }

    toggleCurrencyDisplay();
  }

  function calculateInsuranceTotalRawCents() {
    if (!selectedVariant) return null;

    const mainQty = parseInt(dom().qtyInput?.value, 10) || 1;

    // main variant total (cents)
    let total = (selectedVariant.priceRaw || 0) * mainQty;

    // addons total (cents) => price addon * mainQty
    if (Array.isArray(selectedAddons) && selectedAddons.length) {
      total += selectedAddons.reduce((sum, a) => {
        const pr = parseInt(a.priceRaw || 0, 10);
        return sum + (pr * mainQty);
      }, 0);
    }

    return total;
  }

  async function updateTotalPriceDisplayIfInsurance() {
    if (filtered.category !== 'Insurance') return false;

    if (!selectedVariant) {
      await updatePriceDisplay(null);
      return true;
    }

    const totalRaw = calculateInsuranceTotalRawCents();
    if (totalRaw === null) {
      await updatePriceDisplay(null);
      return true;
    }

    const totalIDR = totalRaw / 100;

    const priceIDR = document.getElementById('variantPriceIDR');
    const priceUSD = document.getElementById('variantPriceUSD');
    const mobileIDR = document.getElementById('variantPriceIDRMobile');
    const mobileUSD = document.getElementById('variantPriceUSDMobile');

    const idrText = formatIDR(totalIDR);
    if (priceIDR) priceIDR.textContent = idrText;
    if (mobileIDR) mobileIDR.textContent = idrText;

    const usdInstant = formatUSD(convertIDRtoUSDInstant(totalIDR));
    if (priceUSD) priceUSD.textContent = usdInstant;
    if (mobileUSD) mobileUSD.textContent = usdInstant;

    if (!cachedUSDRate) {
      const rate = await getExchangeRate();
      const usdFinal = formatUSD((totalIDR * rate).toFixed(2));
      if (priceUSD) priceUSD.textContent = usdFinal;
      if (mobileUSD) mobileUSD.textContent = usdFinal;
    }

    toggleCurrencyDisplay();
    return true;
  }

  /* =========================================================
   * VARIANT SELECTORS
   * ========================================================= */
  function getUniqueOptionValues(optionIndex) {
    const values = new Set();
    filtered.variants.forEach(v => {
      if (v.options[optionIndex]) values.add(v.options[optionIndex]);
    });
    return Array.from(values);
  }

  function isOptionAvailable(optionIndex, optionValue) {
    return filtered.variants.some(v => {
      if (!v.available) return false;
      if (v.options[optionIndex] !== optionValue) return false;

      return selectedOptions.every((selected, idx) => {
        if (idx === optionIndex || !selected) return true;
        return v.options[idx] === selected;
      });
    });
  }

  function updateAvailableOptions() {
    filtered.options.forEach((_, index) => {
      const selectEl = document.getElementById(`option${index}`);
      if (!selectEl) return;

      const optionEls = selectEl.querySelectorAll('option');
      optionEls.forEach((opt, optIndex) => {
        if (optIndex === 0) return;

        const value = opt.value;
        const available = isOptionAvailable(index, value);

        opt.disabled = !available;

        if (!available && !opt.textContent.includes('(Unavailable)')) {
          opt.textContent = `${value} (Unavailable)`;
        } else if (available && opt.textContent.includes('(Unavailable)')) {
          opt.textContent = value;
        }
      });
    });
  }

  function generateSelectors() {
    const { variantSelectors, addonWrapper } = dom();
    if (!variantSelectors) return;

    variantSelectors.innerHTML = '';

    filtered.options.forEach((optionName, index) => {
      const optionValues = getUniqueOptionValues(index);

      const wrapper = document.createElement('div');
      wrapper.style.width = "100%";
      wrapper.innerHTML = `
        <label for="option${index}" class="text-primary font-semibold tracking-normal">${optionName}</label>
        <div class="relative">
          <select
            name="option${index}"
            id="option${index}"
            class="w-full p-3 pr-10 border border-primary rounded-[15px] outline-none text-primary appearance-none bg-neutral"
            onchange="handleOptionChange(${index}, this.value)"
          >
            <option class="text-primary" value="" disabled selected>Choose Option</option>
            ${optionValues.map(value => {
              const available = isOptionAvailable(index, value);
              return `<option value="${value}" ${!available ? 'disabled' : ''}>
                ${value}${!available ? ' (Unavailable)' : ''}
              </option>`;
            }).join('')}
          </select>
          <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none rotate-90">
            {% render 'icon-arrow-right', class: "w-[20px] h-[20px] text-primary" %}
          </div>
        </div>
      `;

      variantSelectors.appendChild(wrapper);
    });

    selectedOptions = new Array(filtered.options.length).fill(null);

    if (filtered.category === 'Insurance' && addonWrapper) {
      addonWrapper.classList.remove('hidden');
    }

    updatePriceDisplay();
    updateResetButtonState();
    updateMobileSelectedVariantLabel();
  }

  function updateResetButtonState() {
    const { resetBtnNonInsurance, resetBtnInsurance } = dom();
    const hasSelection = selectedOptions.some(v => v !== null);

    if (resetBtnNonInsurance) resetBtnNonInsurance.disabled = !hasSelection;
    if (resetBtnInsurance) resetBtnInsurance.disabled = !hasSelection;
  }

  function resetSelection() {
    selectedOptions = new Array(filtered.options.length).fill(null);
    selectedVariant = null;
    lastSelectedVariantId = null;

    updateMobileSelectedVariantLabel();

    resetAddons();
    resetInsurancePlanPreview();

    filtered.options.forEach((_, index) => {
      const el = document.getElementById(`option${index}`);
      if (!el) return;
      el.value = '';
      el.selectedIndex = 0;
    });

    const { qtyInput } = dom();
    if (qtyInput) {
      qtyInput.min = "1";
      qtyInput.value = "1";
    }

    updateAvailableOptions();
    updatePriceDisplay();
    updateResetButtonState();
  }

  async function handleOptionChange(optionIndex, value) {
    selectedOptions[optionIndex] = value;
    updateAvailableOptions();

    const variant = filtered.variants.find(v =>
      selectedOptions.every((selected, idx) => !selected || v.options[idx] === selected)
    );

    const allSelected = selectedOptions.every(opt => opt !== null);

    if (!(variant && allSelected)) {
      selectedVariant = null;
      lastSelectedVariantId = null;

      updateMobileSelectedVariantLabel();

      if (filtered.category === 'Insurance') {
        resetAddons();
        resetInsurancePlanPreview();
      }

      updatePriceDisplay();
      updateResetButtonState();
      return;
    }

    selectedVariant = variant;

    updateMobileSelectedVariantLabel();

    enforceMinQtyByVariant(selectedVariant);

    const handled = await updateTotalPriceDisplayIfInsurance();
    if (!handled) {
      updatePriceDisplay(variant.priceRaw);
    }

    if (filtered.category === 'Insurance') {
      if (lastSelectedVariantId && lastSelectedVariantId !== variant.id) {
        resetAddons();
      }
      lastSelectedVariantId = variant.id;

      updateInsuranceAddonDisplay(variant);
    }

    if (!variant.available) {
      showToast('This variant is not available. Please select another option.', 'error');
    }

    updateResetButtonState();
  }

  /* =========================================================
   * INSURANCE: ADDONS
   * ========================================================= */
  function resetInsurancePlanPreview() {
    const { displayOpt1, displayOpt2, displayOpt3 } = dom();
    if (displayOpt1) displayOpt1.textContent = '-';
    if (displayOpt2) displayOpt2.textContent = '-';
    if (displayOpt3) displayOpt3.textContent = '-';
  }

  function resetAddons() {
    selectedAddons = [];
    sessionStorage.removeItem('SelectedAddons');

    const { addonButton, addonErrorMsg, addonList } = dom();

    if (addonButton) {
      addonButton.textContent = 'Choose Option';
      addonButton.classList.remove('border-red-500', 'ring-2', 'ring-red-500/30');
      addonButton.classList.add('border-primary');
    }

    if (addonErrorMsg) addonErrorMsg.classList.add('hidden');
    if (addonList) addonList.innerHTML = '';
  }

  function updateInsuranceAddonDisplay(mainVariant) {
    const { displayOpt1, displayOpt2, displayOpt3 } = dom();

    if (displayOpt1) displayOpt1.textContent = mainVariant.options[0] || '-';
    if (displayOpt2) displayOpt2.textContent = mainVariant.options[1] || '-';
    if (displayOpt3) displayOpt3.textContent = mainVariant.options[2] || '-';

    const matched = matchInsuranceAddons(mainVariant);
    renderAddonList(matched);
  }

  function matchInsuranceAddons(mainVariant) {
    const matchedList = [];
    const qty = parseInt(dom().qtyInput?.value) || 1;

    const groups = filtered?.metafields?.insurance_addons || [];
    if (!groups.length) return matchedList;

    groups.forEach(group => {
      group.variants.forEach(v => {
        let isMatch = false;

        if (group.addon_type === 'Covid') {
          isMatch =
            v.option1 === mainVariant.options[0] &&
            v.option2 === mainVariant.options[1] &&
            v.option3 === mainVariant.options[2];
        }

        if (group.addon_type === 'General') {
          isMatch =
            v.option1 === mainVariant.options[0] &&
            v.option2 === mainVariant.options[1];
        }

        if (!isMatch) return;

        let title = '';
        let benefits = [];

        if (group.addon_type === 'Covid') {
          title = 'Covid-19 Protection';
          benefits = [
            'Trip Cancellation',
            'Medical Expenses Including Emergency Medical Evacuation',
            'Additional Expenses',
            'Trip Curtailment or Return of Children',
            'Automatic extension of Cover'
          ];
        } else if (group.addon_type === 'General') {
          title = v.option3 || v.title;

          if (v.option3 === 'Business Travel') {
            benefits = ['Staff Replacement', 'Business Equipment', 'Missed Events Fee'];
          } else if (v.option3 === 'Cruise Cover') {
            benefits = ['Cabin Confinement', 'Itinerary Change', 'Unused Excursion', 'Cruise Trip Interruption'];
          } else if (v.option3 === 'Winter Sport' || v.option3 === 'Winter Sports') {
            benefits = ['Winter Sport Pack', 'On piste Closure'];
          }
        }

        matchedList.push({
          title,
          addonType: group.addon_type,
          priceRaw: v.priceRaw,
          id: v.id,
          option1: v.option1,
          option2: v.option2,
          option3: v.option3,
          quantity: qty,
          benefits
        });
      });
    });

    return matchedList;
  }

  function renderAddonList(addons) {
    const { addonList } = dom();
    if (!addonList) return;

    if (!addons.length) {
      addonList.innerHTML =
        '<p class="py-5 text-center text-primary">No matching add-ons available for this insurance plan</p>';
      return;
    }

    addonList.innerHTML = addons.map(addon => {
      const benefitList = (addon.benefits || [])
        .map(b => `<li class="mb-1 leading-[1.4] text-[14px] text-primary">${b}</li>`)
        .join('');

      const isChecked = selectedAddons.some(sa => String(sa.id) === String(addon.id));

      return `
        <div
          class="mt-4 rounded-[10px] border border-border bg-background p-4 transition-all hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)] cursor-pointer select-none"
          data-addon-card="true"
        >
          <div class="mb-2 flex gap-5 md:flex-row md:items-center md:justify-between">
            <div class="flex w-full flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <h1 class="m-0 text-[18px] font-bold leading-[1.3] text-primary md:text-[20px]">${addon.title}</h1>
              <span class="whitespace-nowrap text-[16px] font-bold text-secondary md:text-[18px]">
                ${formatAddonPrice(addon.priceRaw, addon.quantity)}
              </span>
            </div>

            <label class="flex items-center justify-between gap-2 text-primary md:justify-end">
              <input
                type="checkbox"
                class="h-5 w-5 cursor-pointer accent-[var(--color-secondary)]"
                ${isChecked ? 'checked' : ''}
                data-id="${addon.id}"
                data-variant-title="${addon.title}"
                data-price-raw="${addon.priceRaw}"
                data-option1="${addon.option1}"
                data-option2="${addon.option2}"
                data-option3="${addon.option3}"
                data-quantity="${addon.quantity}"
                onchange="handleAddonCheckboxChange(this)"
              />
              <span class="text-[14px] font-medium">select</span>
            </label>
          </div>

          <div class="mt-2 pl-1">
            <ul class="list-disc pl-5">${benefitList}</ul>
          </div>
        </div>
      `;
    }).join('');
  }

  function handleAddonCheckboxChange(checkbox) {
    const addonData = {
      id: checkbox.dataset.id,
      variantTitle: checkbox.dataset.variantTitle,
      option1: checkbox.dataset.option1,
      option2: checkbox.dataset.option2,
      option3: checkbox.dataset.option3,
      quantity: parseInt(checkbox.dataset.quantity || '1', 10),
      priceRaw: parseInt(checkbox.dataset.priceRaw || '0', 10)
    };

    const card = checkbox.closest('[data-addon-card="true"]');
    if (card) {
      card.classList.toggle('ring-2', checkbox.checked);
      card.classList.toggle('ring-secondary/30', checkbox.checked);
    }

    if (checkbox.checked) {
      if (!selectedAddons.some(a => String(a.id) === String(addonData.id))) {
        selectedAddons.push(addonData);
      }
    } else {
      selectedAddons = selectedAddons.filter(a => String(a.id) !== String(addonData.id));
    }

    sessionStorage.setItem('SelectedAddons', JSON.stringify(selectedAddons));
    updateAddonButtonPreview();
    updateTotalPriceDisplayIfInsurance();
  }

  function bindAddonCardToggle() {
    const list = document.getElementById('selected-addon-list');
    if (!list) return;

    list.addEventListener('click', (e) => {
      const interactive = e.target.closest('input, label, a, button, select, textarea');
      if (interactive) return;

      const card = e.target.closest('[data-addon-card="true"]');
      if (!card) return;

      const checkbox = card.querySelector('input[type="checkbox"]');
      if (!checkbox) return;

      checkbox.checked = !checkbox.checked;
      handleAddonCheckboxChange(checkbox);
    });
  }

  function updateAddonButtonPreview() {
    const { addonButton } = dom();
    if (!addonButton) return;

    if (!selectedAddons.length) {
      addonButton.textContent = 'Choose Option';
      return;
    }

    const titles = selectedAddons.map(a => a.variantTitle).join(', ');
    addonButton.textContent = titles.length > 50 ? titles.slice(0, 47) + '...' : titles;
  }

  /* =========================================================
   * QUANTITY
   * ========================================================= */
  function updatePriceWithQuantity() {
    if (!selectedVariant) return;

    if (filtered.category === 'Insurance') {
      updateTotalPriceDisplayIfInsurance();
    } else {
      updatePriceDisplay(selectedVariant.priceRaw);
    }
  }

  function decreaseQuantity() {
  const input = dom().qtyInput;
  if (!input) return;

  const min = parseInt(input.min, 10) || 1;
  const current = parseInt(input.value, 10);

  if (current > min) {
    input.value = String(current - 1);
    updatePriceWithQuantity();

    if (filtered.category === 'Insurance' && selectedVariant) {
      updateInsuranceAddonDisplay(selectedVariant);
      updateTotalPriceDisplayIfInsurance();
    }
  } else {
    input.value = String(min);
  }

  // ✅ ini penting
  updateMinusButtonState();
}

  function increaseQuantity() {
  const input = dom().qtyInput;
  if (!input) return;

  const current = parseInt(input.value, 10);
  const max = parseInt(input.max, 10);

  if (current < max) {
    input.value = String(current + 1);
    updatePriceWithQuantity();

    if (filtered.category === 'Insurance' && selectedVariant) {
      updateInsuranceAddonDisplay(selectedVariant);
      updateTotalPriceDisplayIfInsurance();
    }
  }

  // ✅ ini penting
  updateMinusButtonState();
}

  function updateMinusButtonState() {
    const input = dom().qtyInput;
    const minusBtn = document.getElementById('qtyMinusBtn');
    if (!input || !minusBtn) return;

    const min = parseInt(input.min, 10) || 1;
    const current = parseInt(input.value, 10) || min;

    const disabled = current <= min;

    minusBtn.disabled = disabled;
    minusBtn.classList.toggle('opacity-50', disabled);
    minusBtn.classList.toggle('cursor-not-allowed', disabled);
  }

  function bindQuantityInput() {
    const input = dom().qtyInput;
    if (!input) return;

    input.addEventListener('focus', () => input.select());

    input.addEventListener('input', (e) => {
      let v = e.target.value;

      if (v === '') {
        updateMinusButtonState();
        return;
      }

      v = v.replace(/[^\d]/g, '');
      e.target.value = v;

      updateMinusButtonState();
    });

    input.addEventListener('blur', () => {
      const min = parseInt(input.min, 10) || 1;
      const max = parseInt(input.max, 10) || 50;

      let val = parseInt(input.value, 10);

      if (isNaN(val)) val = min;

      if (val < min) val = min;
      if (val > max) val = max;

      input.value = String(val);

      updateMinusButtonState();
      updatePriceWithQuantity();

      if (filtered.category === 'Insurance' && selectedVariant) {
        updateInsuranceAddonDisplay(selectedVariant);
        updateTotalPriceDisplayIfInsurance();
      }
    });
  }

  /* =========================================================
   * TOAST
   * ========================================================= */
  function showToast(message, type = 'success') {
    const { toast } = dom();
    if (!toast) return;

    toast.textContent = message;

    toast.classList.remove('hidden');

    toast.classList.remove('bg-red-500');
    toast.classList.add('bg-primary', 'text-neutral');

    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full', 'opacity-0', 'pointer-events-none');
      toast.classList.add('translate-x-0', 'opacity-100');
    });

    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toast.classList.remove('translate-x-0', 'opacity-100');
      toast.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');

      setTimeout(() => toast.classList.add('hidden'), 300);
    }, 3000);
  }

  /* -------------------------------------------------------------------------- */
  /*                         TOP UP ICCID VALIDATION                            */
  /* -------------------------------------------------------------------------- */

  // ✅ mapping vendor -> category Top Up (HANYA 1x, jangan double)
  const categoryVendorMap = [
    { vendor: 'BC', category: 'Top_Up_A' },
    { vendor: 'FM', category: 'Top_Up_B' },
    { vendor: 'TGT', category: 'Top_Up_C' },
    { vendor: 'MM', category: 'Top_Up_D' },
  ];

  const TOPUP_CATEGORIES = new Set(['Top_Up_A', 'Top_Up_B', 'Top_Up_C', 'Top_Up_D']);

  const SS_KEY_ICCID = 'iccid';
  const SS_KEY_CATEGORY = 'category';

  let pendingTopUpCheckout = null; // { variantId, qty }

  function isTopUpProductCategory(cat) {
    return TOPUP_CATEGORIES.has((cat || '').trim());
  }

  function mapVendorToTopUpCategory(vendor) {
    const row = categoryVendorMap.find(x => String(x.vendor).toUpperCase() === String(vendor).toUpperCase());
    return row?.category || null;
  }

  function openIccidModal() {
    releaseBuyNowLock(); // ✅ penting biar Buy Now gak nyangkut loading

    const modal = document.getElementById('iccid-modal');
    const input = document.getElementById('iccid-input');
    if (!modal) return;

    modal.classList.remove('hidden');
    document.body.classList.add('no-scroll');

    if (input) {
      input.value = '';
      setTimeout(() => input.focus(), 50);
    }
  }

  function closeIccidModal({ releaseLock = true } = {}) {
    if (releaseLock) releaseBuyNowLock(); // ✅ hanya release kalau memang cancel/close biasa

    const modal = document.getElementById('iccid-modal');
    if (!modal) return;

    modal.classList.add('hidden');
    document.body.classList.remove('no-scroll');
  }

  function openInvalidPopup() {
    releaseBuyNowLock(); // ✅ juga reset di sini

    const el = document.getElementById('invalid-popup');
    if (!el) return;
    el.classList.remove('hidden');
    document.body.classList.add('no-scroll');
  }

  function closeInvalidPopup() {
    releaseBuyNowLock();

    const el = document.getElementById('invalid-popup');
    if (!el) return;
    el.classList.add('hidden');
    document.body.classList.remove('no-scroll');
  }

  function goToBuySim() {
    const coverage = filtered?.metafields?.coverage || [];
    const first = coverage[0];

    let query = '';

    if (first) {
      // Ambil nama negara sesuai bahasa (gunakan country_en sebagai fallback)
      const name = first.country_en || first.country_id || '';
      query = name.replace(/_/g, ' ').trim();
    }

    const url = query
      ? `/search?q=${encodeURIComponent(query)}`
      : '/search';

    window.location.href = url;
  }

  window.goToBuySim = goToBuySim;


  /**
   * ⚠️ Sesuaikan cara kirim ICCID kalau backend kamu beda.
   * Aku pakai query param: /check-usage?iccid=xxxx
   */
  async function checkUsageByICCID(iccid) {
    try {
      const url = new URL('https://v2.gkomunika.id/api/v1/check-usage');
      url.searchParams.set('iccid', String(iccid || '').trim());

      const res = await fetch(url.toString(), {
        method: 'POST',
        headers: { Accept: 'application/json' },
      });

      if (!res.ok) return null;

      const json = await res.json();

      console.log('[checkUsage] response:', JSON.stringify(json, null, 2))

      if (!json?.success) return null;

      const vendor = json?.vendor || null;
      const mappedCategory = mapVendorToTopUpCategory(vendor);

      return { json, vendor, mappedCategory };
    } catch (err) {
      console.error('checkUsageByICCID failed:', err);
      return null;
    }
  }

  async function goCheckoutTopUpWithICCID({ variantId, qty, iccid }) {
    await fetch('/cart/clear.js', { method: 'POST' });

    await fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
      },
      body: JSON.stringify({
        id: variantId,
        quantity: qty,
        properties: { ICCID: String(iccid) }, // ✅ line item properties
      }),
    });

    // ✅ cart attributes (optional)
    try {
      await fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          attributes: { ICCID: String(iccid) },
        }),
      });
    } catch (e) {
      console.warn('cart attributes update failed (ignored):', e);
    }

    window.location.href = '/checkout';
  }

  async function handleTopUpBuyNow(qty) {
    pendingTopUpCheckout = { variantId: selectedVariant?.id, qty };

    const productCat = filtered.category;
    const storedIccid = sessionStorage.getItem(SS_KEY_ICCID);

    // (3) kalau kosong -> form
    if (!storedIccid) {
      openIccidModal();
      return;
    }

    // cek iccid stored
    const result = await checkUsageByICCID(storedIccid);

    // vendor tidak ada map -> invalid
    if (!result?.mappedCategory) {
      openInvalidPopup();
      return;
    }

    // (1) cocok -> langsung checkout
    if (result.mappedCategory === productCat) {
      await goCheckoutTopUpWithICCID({
        variantId: pendingTopUpCheckout.variantId,
        qty: pendingTopUpCheckout.qty,
        iccid: storedIccid,
      });
      return;
    }

    // (2) tidak cocok -> show form input iccid
    openIccidModal();
  }

  function bindTopUpIccidUI() {
    document.getElementById('iccid-modal')?.classList.add('hidden');
    document.getElementById('invalid-popup')?.classList.add('hidden');

    document.getElementById('iccid-cancel')?.addEventListener('click', closeIccidModal);

    const form = document.getElementById('iccid-form');
    const input = document.getElementById('iccid-input');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (isIccidSubmitting) return;
      isIccidSubmitting = true;

      // ✅ loader di tombol Next
      setIccidLoading(true);

      // ✅ loader di tombol Buy Now juga
      isBuyingNow = true;
      setBuyNowLoading(true);

      let willRedirect = false;

      try {
        const iccid = String(input?.value || '').trim();

        if (!iccid) {
          showToast('Please input ICCID', 'error');
          return;
        }

        const result = await checkUsageByICCID(iccid);

        if (!result?.mappedCategory) {
          // ❌ invalid -> tidak redirect
          closeIccidModal();        // releaseLock default true -> unlock buy now
          openInvalidPopup();       // openInvalidPopup juga release (aman)
          return;
        }

        sessionStorage.setItem(SS_KEY_ICCID, iccid);
        sessionStorage.setItem(SS_KEY_CATEGORY, result.mappedCategory);

        if (result.mappedCategory === filtered.category) {
          // ✅ redirect ke checkout
          willRedirect = true;

          closeIccidModal({ releaseLock: false }); // ✅ keep Buy Now loading
          await goCheckoutTopUpWithICCID({
            variantId: pendingTopUpCheckout?.variantId || selectedVariant?.id,
            qty: pendingTopUpCheckout?.qty || (parseInt(dom().qtyInput?.value, 10) || 1),
            iccid,
          });
          return;
        }

        // ❌ mismatch -> redirect ke /pages/top-up setelah toast
        willRedirect = true;

        closeIccidModal({ releaseLock: false }); // ✅ keep Buy Now loading
        showToast(
          'ICCID invalid, please select another product',
          'error'
        );

        setTimeout(() => {
          window.location.href = '/pages/top-up';
        }, 1200);

      } catch (err) {
        console.error(err);
        showToast('Failed to validate ICCID', 'error');
      } finally {
        isIccidSubmitting = false;
        setIccidLoading(false);

        // ✅ kalau tidak jadi redirect, balikin state Buy Now
        if (!willRedirect) {
          isBuyingNow = false;
          setBuyNowLoading(false);
        }
      }
    });



    document.getElementById('invalid-popup-close')?.addEventListener('click', () => {
      closeInvalidPopup();
      openIccidModal();
    });
    document.querySelector('[data-invalid-overlay]')?.addEventListener('click', closeInvalidPopup);
  }

  /* =========================================================
   * CART
   * ========================================================= */
  function updateCartCount() {
    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => {
        const countEl = $('cart-count');
        if (countEl) countEl.textContent = cart.item_count;
      })
      .catch(err => console.error('Failed to update cart count:', err));
  }

  async function addToCart() {
    if (isAddingToCart) return;

    if (!selectedVariant) {
      showToast('Please select all options', 'error');
      scrollToSelectors();
      return;
    }
    if (!selectedVariant.available) return showToast('This variant is not available', 'error');

    const qty = parseInt(dom().qtyInput?.value, 10) || 1;

    isAddingToCart = true;
    setAddToCartLoading(true);

    try {
      const r = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ id: selectedVariant.id, quantity: qty })
      });

      if (!r.ok) {
        const errJson = await r.json().catch(() => null);
        throw new Error(errJson?.description || 'Failed to add item to cart');
      }

      await r.json().catch(() => null);
      showToast('Item successfully added to cart!', 'success');
      updateCartCount();
    } catch (err) {
      console.error('Error:', err);
      showToast(err?.message || 'Failed to add item to cart', 'error');
    } finally {
      isAddingToCart = false;
      setAddToCartLoading(false);
    }
  }


  function getVariantType(variant) {
    if (!variant?.variantType) return '';
    if (Array.isArray(variant.variantType)) return variant.variantType.join(', ');
    if (typeof variant.variantType === 'object' && variant.variantType.value) return variant.variantType.value;
    return variant.variantType;
  }

  function enforceMinQtyByVariant(variant) {
    const { qtyInput } = dom();
    if (!qtyInput) return;

    // ✅ Airport Transfer: selalu boleh turun sampai 1
    if ((filtered?.category || '').trim() === 'Airport_Transfer') {
      qtyInput.min = "1";
      if ((parseInt(qtyInput.value,10) || 1) < 1) qtyInput.value = "1";
      updateMinusButtonState();
      return;
    }

    // --- logic lama tetap ---
    const variantType = getVariantType(variant);
    const isDuoPlus = (variantType || '').toLowerCase().trim() === 'duo plus';

    const minQty = isDuoPlus ? 2 : 1;

    qtyInput.min = String(minQty);

    let current = parseInt(qtyInput.value, 10);
    if (isNaN(current) || current < minQty) current = minQty;
    qtyInput.value = String(current);
    updateMinusButtonState();
  }

  async function buyNow() {
    if (isBuyingNow) return;

    if (!selectedVariant) {
      showToast('Please select all options', 'error');
      scrollToSelectors();
      return;
    }
    if (!selectedVariant.available) return showToast('This variant is not available', 'error');

    const qty = isTopUpProductCategory(filtered.category)
    ? 1
    : (parseInt(dom().qtyInput?.value, 10) || 1);


    isBuyingNow = true;
    setBuyNowLoading(true);

    try {
      // ✅ TOP UP ICCID FLOW
      if (isTopUpProductCategory(filtered.category)) {
        await handleTopUpBuyNow(qty);
        return;
      }

      // Insurance flow
      if (filtered.category === 'Insurance') {
        sessionStorage.removeItem('CheckoutFlow');
        localStorage.removeItem('CheckoutFlow');
        sessionStorage.removeItem('TransferAttributes');
        localStorage.removeItem('TransferAttributes');
        sessionStorage.removeItem('TransferHeaderData');
        localStorage.removeItem('TransferHeaderData');

        const variantType = getVariantType(selectedVariant);

        const variantCoverage = Array.from(new Set(
          (filtered.metafields.coverage || [])
            .map(c => (c?.country_en || '').trim())
            .filter(Boolean)
        ));

        sessionStorage.removeItem('ProductItems');

        const savedAddons = safeParseJSON(sessionStorage.getItem('SelectedAddons'), []);

        const newItem = {
          productTitle: filtered.title,
          category: filtered.category,
          variantType,
          variantId: selectedVariant.id,
          variantTitle: selectedVariant.title,
          quantity: qty,
          variantCoverage,
          addonItems: (savedAddons || []).map(addon => ({
            productTitle: addon.variantTitle,
            variantId: addon.id,
            variantTitle: addon.variantTitle,
            quantity: addon.quantity,
            option1: addon.option1,
            option2: addon.option2,
            option3: addon.option3
          }))
        };

        sessionStorage.setItem('ProductItems', JSON.stringify([newItem]));

        window.location.href = customerLoggedIn
          ? '/pages/form-insurance'
          : '/account/login?return_url=/pages/form-insurance';
        return;
      }

      // Airport Transfer flow
      if (filtered.category === 'Airport_Transfer') {
        const savedPurposes = JSON.parse(sessionStorage.getItem('AT_Purposes') || '[]');

        const goCount  = savedPurposes.filter(p => p === 'airport_to_city').length;
        const retCount = savedPurposes.filter(p => p === 'city_to_airport').length;

        const autoVariantId    = selectedVariant.airportAutoVariantId    || null;
        const autoVariantTitle = selectedVariant.airportAutoVariantTitle || selectedVariant.title;

        // Tentukan arah variant utama yang dipilih user
        const rawPurpose      = String(selectedVariant.airportPurpose || '').trim().toLowerCase();
        const selectedIsGo    = rawPurpose === 'airport to city';   // variant utama = Airport to City
        const selectedIsRet   = rawPurpose === 'city to airport';   // variant utama = City to Airport

        const items           = [];
        const orderedPurposes = [];

        const hasMixed = goCount > 0 && retCount > 0;

        if (hasMixed && autoVariantId) {
          // ── MIXED: dua arah, masing-masing pakai variantId yang sesuai ──────
          if (selectedIsGo) {
            // selectedVariant  = Airport to City  → pakai untuk go trips
            // autoVariant      = City to Airport  → pakai untuk ret trips
            items.push({
              productId    : filtered.id,
              productTitle : filtered.title,
              category     : filtered.category,
              variantId    : selectedVariant.id,
              variantTitle : selectedVariant.title,
              variantOptions: selectedVariant.options,
              quantity     : goCount,
            });
            items.push({
              productId    : filtered.id,
              productTitle : filtered.title,
              category     : filtered.category,
              variantId    : autoVariantId,
              variantTitle : autoVariantTitle,
              variantOptions: selectedVariant.options,
              quantity     : retCount,
            });
          } else {
            // selectedVariant  = City to Airport  → pakai untuk ret trips
            // autoVariant      = Airport to City  → pakai untuk go trips
            items.push({
              productId    : filtered.id,
              productTitle : filtered.title,
              category     : filtered.category,
              variantId    : autoVariantId,
              variantTitle : autoVariantTitle,
              variantOptions: selectedVariant.options,
              quantity     : goCount,
            });
            items.push({
              productId    : filtered.id,
              productTitle : filtered.title,
              category     : filtered.category,
              variantId    : selectedVariant.id,
              variantTitle : selectedVariant.title,
              variantOptions: selectedVariant.options,
              quantity     : retCount,
            });
          }

          // Urutan purposes: airport_to_city dulu, baru city_to_airport
          for (let i = 0; i < goCount;  i++) orderedPurposes.push('airport_to_city');
          for (let i = 0; i < retCount; i++) orderedPurposes.push('city_to_airport');
          sessionStorage.setItem('AT_Purposes', JSON.stringify(orderedPurposes));

        } else {
          // ── SINGLE ARAH: semua trip satu arah, cukup 1 item ────────────────
          // Tidak perlu auto variant, pakai selectedVariant saja
          items.push({
            productId    : filtered.id,
            productTitle : filtered.title,
            category     : filtered.category,
            variantId    : selectedVariant.id,
            variantTitle : selectedVariant.title,
            variantOptions: selectedVariant.options,
            quantity     : qty,
          });
          // AT_Purposes sudah benar dari patched buyNow, tidak perlu reorder
        }

        sessionStorage.setItem('ProductItems', JSON.stringify(items));
        localStorage.setItem('ProductItems',  JSON.stringify(items));

        window.location.href = customerLoggedIn
          ? '/pages/form-airport-transfer'
          : '/account/login?return_url=/pages/form-airport-transfer';
        return;
      }

      // Non-insurance flow
      await fetch('/cart/clear.js', { method: 'POST' });

      const r = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: selectedVariant.id, quantity: qty })
      });

      if (!r.ok) {
        const errJson = await r.json().catch(() => null);
        throw new Error(errJson?.description || 'Failed to process buy now');
      }

      window.location.href = '/checkout';
    } catch (err) {
      console.error('Error:', err);
      showToast(err?.message || 'Failed to process buy now', 'error');
      setBuyNowLoading(false);
      isBuyingNow = false;
    }
  }


  /* =========================================================
   * IMAGE
   * ========================================================= */
  function updateMainImage(imageSrc) {
    const { mainImage } = dom();
    if (mainImage) mainImage.src = imageSrc;
  }

  /* =========================================================
   * POPUP: ADDON (Insurance)
   * ========================================================= */
  function bindAddonPopup() {
    const { addonButton, addonErrorMsg, popupOverlay, closePopupBtn } = dom();
    if (!addonButton || !popupOverlay) return;

    addonButton.addEventListener('click', () => {
      const allSelected = selectedOptions.every(opt => opt !== null);

      if (!allSelected) {
        if (addonErrorMsg) addonErrorMsg.classList.remove('hidden');
        addonButton.classList.add('border-red-500', 'ring-2', 'ring-red-500/30');
        addonButton.classList.remove('border-primary');
        return;
      }

      popupOverlay.classList.remove('hidden');
      requestAnimationFrame(() => syncAddonHeaderOffset());
      document.body.classList.add('no-scroll');

      addonButton.classList.remove('border-red-500', 'ring-2', 'ring-red-500/30');
      addonButton.classList.add('border-primary');
      if (addonErrorMsg) addonErrorMsg.classList.add('hidden');
    });

    popupOverlay.addEventListener('click', (e) => {
      if (e.target === popupOverlay) {
        popupOverlay.classList.add('hidden');
        document.body.classList.remove('no-scroll');
      }
    });

    closePopupBtn?.addEventListener('click', () => {
      popupOverlay.classList.add('hidden');
      document.body.classList.remove('no-scroll');
    });
  }

  /* =========================================================
   * SESSION UTILS
   * ========================================================= */
  function safeParseJSON(value, fallback) {
    try {
      return value ? JSON.parse(value) : fallback;
    } catch (e) {
      return fallback;
    }
  }

  function restoreAddonsFromSession() {
    const saved = safeParseJSON(sessionStorage.getItem('SelectedAddons'), []);
    if (Array.isArray(saved) && saved.length) {
      selectedAddons = saved;
      updateAddonButtonPreview();
    }
  }

  /* =========================================================
   * CURRENCY MONITOR (polling)
   * ========================================================= */
  function startCurrencyMonitor() {
    if (currencyPollTimer) clearInterval(currencyPollTimer);

    currencyPollTimer = setInterval(() => {
      const current = sessionStorage.getItem('buckscc_customer_currency');
      if (current !== lastCurrency) {
        lastCurrency = current;
        toggleCurrencyDisplay();

        if (filtered.category === 'Insurance' && selectedVariant) {
          updateInsuranceAddonDisplay(selectedVariant);
        }
      }
    }, 500);
  }

  /* =========================================================
   * PUBLIC API (untuk inline onclick)
   * ========================================================= */
  window.updateMainImage = updateMainImage;
  window.handleOptionChange = handleOptionChange;
  window.resetSelection = resetSelection;
  window.decreaseQuantity = decreaseQuantity;
  window.increaseQuantity = increaseQuantity;
  window.addToCart = addToCart;
  window.buyNow = buyNow;
  window.handleAddonCheckboxChange = handleAddonCheckboxChange;
  window.scrollToSelectors = scrollToSelectors;

  /* =========================================================
   * INIT
   * ========================================================= */

   async function fetchAllVariants() {
    try {
      let allVariants = [];
      let page = 1;

      while (true) {
        const res = await fetch(`/products/${filtered.handle}.json?limit=250&page=${page}`);
        const json = await res.json();
        const variants = json.product?.variants || [];

        const mapped = variants.map(v => {
          const original = filtered.variants.find(orig => orig.id === v.id);
          return {
            id: v.id,
            title: v.title,
            priceRaw: Math.round(parseFloat(v.price) * 100),
            sku: v.sku || '',
            available: v.inventory_management === null
              ? true
              : (v.inventory_quantity > 0 || v.inventory_policy === 'continue'),
            variantType: original?.variantType ?? null,
            airportPurpose: original?.airportPurpose ?? '',
            airportAutoVariantId: original?.airportAutoVariantId ?? '',
            airportAutoVariantTitle: original?.airportAutoVariantTitle ?? 0,
            options: [v.option1, v.option2, v.option3].filter(o => o != null && o !== '')
          };
        });

        allVariants = allVariants.concat(mapped);
        if (variants.length < 250) break;
        page++;
      }

      return allVariants;
    } catch (err) {
      console.warn('⚠️ Gagal fetch variants, pakai data Liquid:', err);
      return [];
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    initDescription();

    // ✅ 1. Render selector SEGERA, jangan tunggu apapun
    generateSelectors();
    bindQuantityInput();
    bindAddonPopup();
    bindTopUpIccidUI();
    updateMinusButtonState();
    updateMobileSelectedVariantLabel();
    bindAddonCardToggle();

    lastCurrency = sessionStorage.getItem('buckscc_customer_currency');
    toggleCurrencyDisplay();
    startCurrencyMonitor();
    restoreAddonsFromSession();
    updateTotalPriceDisplayIfInsurance();

    // ✅ 2. Exchange rate & variants fetch jalan di background
    getExchangeRate().then(() => {
      // refresh harga setelah rate tersedia
      if (selectedVariant) {
        updatePriceDisplay(selectedVariant.priceRaw);
      } else {
        updatePriceDisplay();
      }
    });

    // ✅ 3. Fetch semua variants di background, lalu re-render selector
    fetchAllVariants().then((allVariants) => {
      if (allVariants.length > 0) {
        filtered.variants = allVariants;

        // Simpan state yang sudah dipilih user
        const prevSelected = [...selectedOptions];
        generateSelectors();

        // Restore pilihan user jika ada
        prevSelected.forEach((val, idx) => {
          if (!val) return;
          const el = document.getElementById(`option${idx}`);
          if (el) {
            el.value = val;
            selectedOptions[idx] = val;
          }
        });

        updateAvailableOptions();
        updateResetButtonState();
      }
    });
  });

  function resetTransientStates() {
    isAddingToCart = false;
    isBuyingNow = false;
    isIccidSubmitting = false;

    setAddToCartLoading(false);
    setBuyNowLoading(false);
    setIccidLoading(false);

    document.getElementById('iccid-modal')?.classList.add('hidden');
    document.getElementById('invalid-popup')?.classList.add('hidden');
    document.body.classList.remove('no-scroll');
  }

  // ✅ kepanggil saat balik (Back) maupun normal load
  window.addEventListener('pageshow', () => {
    resetTransientStates();
  });


  /* -------------------------------------------------------------------------- */
  /*                     Dynamic height add on title                            */
  /* -------------------------------------------------------------------------- */
  function syncAddonHeaderOffset() {
    const header = document.getElementById('addonHeader');
    const popup = document.getElementById('addon-popup');
    if (!header || !popup) return;

    const h = Math.ceil(header.getBoundingClientRect().height);
    popup.style.setProperty('--addon-header-h', `${h}px`);
  }

  function initAddonHeaderSync() {
    syncAddonHeaderOffset();
    window.addEventListener('resize', syncAddonHeaderOffset);

    const header = document.getElementById('addonHeader');
    if (header && 'ResizeObserver' in window) {
      const ro = new ResizeObserver(() => syncAddonHeaderOffset());
      ro.observe(header);
    }
  }

  document.addEventListener('DOMContentLoaded', initAddonHeaderSync);
</script>

<script>
  /* ----------------------------------------------------------
   * AT PURPOSE: State
   * ---------------------------------------------------------- */
  const atPurposeState = {
    mode: 'single', // 'single' | 'multi'
    qty: 1,
    requiredDir: null, // 'go' | 'return' | null
  };

  function purposeLabelToValue(label) {
    const s = String(label || '')
      .trim()
      .toLowerCase();
    if (s === 'city to airport') return 'city_to_airport';
    if (s === 'airport to city') return 'airport_to_city';

    const normalized = s.replace(/\s+/g, '_');
    if (normalized.includes('city_to_airport')) return 'city_to_airport';
    if (normalized.includes('airport_to_city')) return 'airport_to_city';
    return '';
  }

  function lockSinglePurposeSelect(val, locked = true) {
    const sel = document.getElementById('atPurposeSingle');
    if (!sel) return;

    if (val) sel.value = val;

    sel.disabled = !!locked;
    sel.classList.toggle('opacity-70', !!locked);
    sel.classList.toggle('cursor-not-allowed', !!locked);
  }

  function requiredDirFromVariantPurpose(label) {
    const s = String(label || '')
      .trim()
      .toLowerCase();
    if (s === 'airport to city') return 'go';
    if (s === 'city to airport') return 'return';
    return null;
  }

  /* ----------------------------------------------------------
   * AT PURPOSE: Show/hide mode
   * qty = 1: ambil dari metafield & lock
   * qty >= 2: pakai design multi (go/return)
   * dan wajib min 1 sesuai metafield
   * ---------------------------------------------------------- */
  function renderAtPurposeSection() {
    const cat = filtered?.category || '';
    if (cat !== 'Airport_Transfer') return;

    const section = document.getElementById('atPurposeSection');
    const singleEl = document.getElementById('atPurpose-single');
    const doubleEl = document.getElementById('atPurpose-double'); // tidak dipakai
    const multiEl = document.getElementById('atPurpose-multi');

    if (!section) return;

    // butuh selectedVariant karena ambil metafield
    if (!selectedVariant) {
      section.classList.add('hidden');
      return;
    }

    const qty = parseInt(document.getElementById('variant-quantity')?.value, 10) || 1;
    atPurposeState.qty = qty;

    // set required direction dari metafield variant
    atPurposeState.requiredDir = requiredDirFromVariantPurpose(selectedVariant?.airportPurpose);

    section.classList.remove('hidden');

    // hide all
    singleEl?.classList.add('hidden');
    doubleEl?.classList.add('hidden');
    multiEl?.classList.add('hidden');

    // ---------- QTY = 1 (LOCK dari metafield) ----------
    if (qty === 1) {
      atPurposeState.mode = 'single';
      singleEl?.classList.remove('hidden');

      const metaLabel = selectedVariant?.airportPurpose;
      const mappedVal = purposeLabelToValue(metaLabel);

      // kalau metafield kosong, biarkan user pilih manual
      if (!mappedVal) {
        lockSinglePurposeSelect('', false);
        return;
      }

      lockSinglePurposeSelect(mappedVal, true);
      return;
    }

    // ---------- QTY >= 2 (MULTI) ----------
    atPurposeState.mode = 'multi';
    multiEl?.classList.remove('hidden');

    const totalLabel = document.getElementById('atMultiTotalLabel');
    if (totalLabel) totalLabel.textContent = qty;

    const goEl = document.getElementById('atMultiGo');
    const retEl = document.getElementById('atMultiReturn');
    if (!goEl || !retEl) return;

    const minGo = atPurposeState.requiredDir === 'go' ? 1 : 0;
    const minRet = atPurposeState.requiredDir === 'return' ? 1 : 0;

    // default awal: arah wajib dapat minimal 1
    let go = 0,
      ret = 0;
    if (atPurposeState.requiredDir === 'return') {
      ret = Math.max(minRet, qty); // biasanya qty
      go = qty - ret; // 0
    } else {
      go = Math.max(minGo, qty); // biasanya qty
      ret = qty - go; // 0
    }

    // clamp final supaya tetap valid
    go = Math.max(minGo, Math.min(qty - minRet, go));
    ret = qty - go;

    goEl.value = String(go);
    retEl.value = String(ret);

    validateAtMultiSum();
  }

  /* ----------------------------------------------------------
   * MULTI steppers (wajib min 1 sesuai metafield)
   * ---------------------------------------------------------- */
  function adjustAtMulti(type, delta) {
    const qty = atPurposeState.qty;
    const goEl = document.getElementById('atMultiGo');
    const retEl = document.getElementById('atMultiReturn');
    if (!goEl || !retEl) return;

    const minGo = atPurposeState.requiredDir === 'go' ? 1 : 0;
    const minRet = atPurposeState.requiredDir === 'return' ? 1 : 0;

    let go = parseInt(goEl.value, 10) || 0;
    let ret = parseInt(retEl.value, 10) || 0;

    if (type === 'go') {
      go = Math.max(minGo, Math.min(qty - minRet, go + delta));
      ret = qty - go;
    } else {
      ret = Math.max(minRet, Math.min(qty - minGo, ret + delta));
      go = qty - ret;
    }

    goEl.value = String(go);
    retEl.value = String(ret);
    validateAtMultiSum();
  }
  window.adjustAtMulti = adjustAtMulti;

  function onAtMultiInput(type, rawVal) {
    const qty = atPurposeState.qty;
    const goEl = document.getElementById('atMultiGo');
    const retEl = document.getElementById('atMultiReturn');
    if (!goEl || !retEl) return;

    const minGo = atPurposeState.requiredDir === 'go' ? 1 : 0;
    const minRet = atPurposeState.requiredDir === 'return' ? 1 : 0;

    const cleaned = String(rawVal).replace(/\D/g, '');
    let val = parseInt(cleaned, 10);
    if (isNaN(val)) val = 0;

    if (type === 'go') {
      val = Math.max(minGo, Math.min(qty - minRet, val));
      goEl.value = String(val);
      retEl.value = String(qty - val);
    } else {
      val = Math.max(minRet, Math.min(qty - minGo, val));
      retEl.value = String(val);
      goEl.value = String(qty - val);
    }

    validateAtMultiSum();
  }
  window.onAtMultiInput = onAtMultiInput;

  function validateAtMultiSum() {
    const qty = atPurposeState.qty;
    const go = parseInt(document.getElementById('atMultiGo')?.value, 10) || 0;
    const ret = parseInt(document.getElementById('atMultiReturn')?.value, 10) || 0;
    const warn = document.getElementById('atMultiWarning');
    if (!warn) return;

    if (go + ret !== qty) {
      warn.textContent = `Total trips (${go + ret}) does not match total quantity (${qty}).`;
      warn.classList.remove('hidden');
    } else {
      warn.classList.add('hidden');
    }
  }

  /* ----------------------------------------------------------
   * Collect purposes
   * ---------------------------------------------------------- */
  function collectAtPurposeData() {
    const qty = atPurposeState.qty;
    const mode = atPurposeState.mode;

    if (mode === 'single') {
      const val = document.getElementById('atPurposeSingle')?.value || '';
      if (!val) return null;
      return [val];
    }

    // multi
    const go = parseInt(document.getElementById('atMultiGo')?.value, 10) || 0;
    const ret = parseInt(document.getElementById('atMultiReturn')?.value, 10) || 0;
    if (go + ret !== qty) return null;

    const purposes = [];
    for (let i = 0; i < go; i++) purposes.push('airport_to_city');
    for (let i = 0; i < ret; i++) purposes.push('city_to_airport');
    return purposes;
  }

  /* ----------------------------------------------------------
   * Hooks qty & variant change
   * ---------------------------------------------------------- */
  (function patchAtPurposeHooks() {
    const _origDecrease = window.decreaseQuantity;
    const _origIncrease = window.increaseQuantity;

    window.decreaseQuantity = function () {
      _origDecrease?.();
      if (filtered?.category === 'Airport_Transfer') renderAtPurposeSection();
    };

    window.increaseQuantity = function () {
      _origIncrease?.();
      if (filtered?.category === 'Airport_Transfer') renderAtPurposeSection();
    };

    const _origHandleOptionChange = window.handleOptionChange;
    window.handleOptionChange = async function (optionIndex, value) {
      await _origHandleOptionChange?.(optionIndex, value);
      if (filtered?.category === 'Airport_Transfer') renderAtPurposeSection();
    };

    document.addEventListener('DOMContentLoaded', () => {
      const qtyInput = document.getElementById('variant-quantity');
      if (qtyInput && filtered?.category === 'Airport_Transfer') {
        qtyInput.addEventListener('change', () => renderAtPurposeSection());
        qtyInput.addEventListener('blur', () => renderAtPurposeSection());
      }
    });
  })();

  /* ----------------------------------------------------------
   * Patch buyNow: validate + save
   * ---------------------------------------------------------- */
  (function patchBuyNowForAtPurpose() {
    const _origBuyNow = window.buyNow;

    window.buyNow = async function () {
      if (filtered?.category !== 'Airport_Transfer') {
        return _origBuyNow?.();
      }

      const purposes = collectAtPurposeData();
      if (!purposes) {
        showToast('Please select Transfer Purpose for all trips', 'error');
        document.getElementById('atPurposeSection')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      sessionStorage.setItem('AT_Purposes', JSON.stringify(purposes));
      return _origBuyNow?.();
    };
  })();

  /* ----------------------------------------------------------
   * Reset hook
   * ---------------------------------------------------------- */
  (function patchResetForAtPurpose() {
    const _origReset = window.resetSelection;
    window.resetSelection = function () {
      _origReset?.();
      if (filtered?.category === 'Airport_Transfer') {
        document.getElementById('atPurposeSection')?.classList.add('hidden');
        lockSinglePurposeSelect('', false);
      }
    };
  })();

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('atPurposeSection')?.classList.add('hidden');
    if (filtered?.category === 'Airport_Transfer' && selectedVariant) {
      renderAtPurposeSection();
    }
  });
</script>

