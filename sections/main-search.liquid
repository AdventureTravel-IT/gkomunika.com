  // =========================
  // ✅ UPDATED: wireFilterAndSearch (topup mode supported)
  // =========================

  function getSearchIconHtml() {
    return `{% render 'icon-search' %}`;
  }

  function getLoadingIconHtml() {
    return `{% render 'loading', class: 'text-neutral h-[24px] w-[24px]' %}`;
  }

  function setSearchButtonLoading(rootEl, isLoading) {
    const btn = rootEl.querySelector('#realtimeSearchInput')?.parentElement?.querySelector('.absolute');
    if (!btn) return;
    btn.innerHTML = isLoading ? getLoadingIconHtml() : getSearchIconHtml();
  }

  function wireFilterAndSearch(rootEl, mode = 'main') {
    // ✅ TOPUP: tanpa tabs, tampil semua produk top-up-plan + optional search filter
    if (mode === 'topup') {
      const searchInput = rootEl.querySelector('#realtimeSearchInput');
      const wrappers = Array.from(rootEl.querySelectorAll('.collection-wrapper'));
      const cards = Array.from(rootEl.querySelectorAll('.product-card-container'));

      const state = { q: '' };
      let debounce = null;

      function setUrlQueryKeyword(qValue) {
        const u = new URL(window.location.href);
        const v = String(qValue || '').trim();
        if (v) u.searchParams.set('q', v);
        else u.searchParams.delete('q');
        history.replaceState(null, '', u);
      }

      function apply() {
        const q = (state.q || '').trim().toLowerCase();
        const keywordActive = q.length >= 2;

        cards.forEach((card) => {
          const hay = (card.getAttribute('data-search-text') || '').toLowerCase();
          const matchSearch = !keywordActive || hay.includes(q);
          card.style.display = matchSearch ? 'flex' : 'none';
        });

        wrappers.forEach((w) => {
          const inside = Array.from(w.querySelectorAll('.product-card-container'));
          const anyVisible = inside.some((c) => c.style.display !== 'none');
          w.style.display = anyVisible ? 'block' : 'none';
        });

        const emptyEl = rootEl.querySelector('#noResults');
        if (emptyEl) {
          const anyCardVisible = cards.some((c) => c.style.display !== 'none');
          emptyEl.style.display = anyCardVisible ? 'none' : 'flex';
        }
      }

      // preload dari URL (?q=)
      if (searchInput) {
        const urlQ = new URL(window.location.href).searchParams.get('q') || '';
        if (urlQ) {
          searchInput.value = urlQ;
          state.q = urlQ;
        }

        searchInput.addEventListener('input', (e) => {
          const val = e.target.value || '';
          clearTimeout(debounce);
          setSearchButtonLoading(rootEl, true); // ← tambah ini
          debounce = setTimeout(() => {
            state.q = val;
            apply();
            updateIncludedBadges(rootEl, val);
            setUrlQueryKeyword(val);
            sortSingleCountryByTitle(rootEl, val);
            setSearchButtonLoading(rootEl, false); // ← tambah ini
          }, 80);
        });

        window.addEventListener('popstate', () => {
          const qFromUrl = new URL(window.location.href).searchParams.get('q') || '';
          searchInput.value = qFromUrl;
          state.q = qFromUrl;
          apply();
          updateIncludedBadges(rootEl, qFromUrl);
          sortSingleCountryByTitle(rootEl, qFromUrl);
        });
      }

      apply();
      updateIncludedBadges(rootEl, searchInput ? searchInput.value : '');
      sortSingleCountryByTitle(rootEl, searchInput ? searchInput.value : '');
      return; // ✅ stop di sini biar logic tabs tidak jalan
    }

    const tabs = Array.from(rootEl.querySelectorAll('.filter-tab'));
    const tabScrollUI = wireTabScrollArrows(rootEl);
    const searchInput = rootEl.querySelector('#realtimeSearchInput');
    const wrappers = Array.from(rootEl.querySelectorAll('.collection-wrapper'));
    const cards = Array.from(rootEl.querySelectorAll('.product-card-container'));

    const CATEGORY_TABS = ['esim', 'sim-card', 'insurance'];
    const DEFAULT_CATEGORY = 'esim';

    // ✅ MULTI-SELECT: filter sekarang Set, bukan string tunggal
    const state = {
      filters: mode === 'category' ? new Set([DEFAULT_CATEGORY]) : new Set(['all']),
      q: '',
    };

    function setActiveTab(filterOrSet) {
      // support string (single) atau Set (multi)
      const activeSet = filterOrSet instanceof Set ? filterOrSet : new Set([filterOrSet]);

      tabs.forEach((btn) => {
        const f = (btn.getAttribute('data-filter') || '').trim();
        const isActive = activeSet.has(f);
        btn.classList.toggle('is-active', isActive);
        if (isActive) tabScrollUI.scrollIntoView(btn);
      });
    }

    function updateTabsVisibility() {
      const q = (state.q || '').trim().toLowerCase();
      const keywordActive = q.length >= 2;

      const counts = {};
      let totalMatches = 0;

      cards.forEach((card) => {
        const cardType = card.getAttribute('data-sim-type') || '';
        const hay = (card.getAttribute('data-search-text') || '').toLowerCase();

        const matchSearch = !keywordActive || hay.includes(q);
        if (!matchSearch) return;

        totalMatches++;
        counts[cardType] = (counts[cardType] || 0) + 1;
      });

      tabs.forEach((btn) => {
        const f = (btn.getAttribute('data-filter') || '').trim();

        if (f === 'all') {
          btn.style.display = totalMatches > 0 ? '' : 'none';
          return;
        }

        const c = counts[f] || 0;
        btn.style.display = c > 0 ? '' : 'none';
      });

      // ✅ Multi-select: hapus filter yang tersembunyi (tidak ada hasil)
      state.filters.forEach((f) => {
        if (f === 'all') return;
        const btn = tabs.find((b) => (b.getAttribute('data-filter') || '').trim() === f);
        if (btn && btn.style.display === 'none') {
          state.filters.delete(f);
        }
      });

      // ✅ Fallback ke "All" kalau kosong
      if (state.filters.size === 0) {
        state.filters = new Set(['all']);
      }

      setActiveTab(state.filters);
    }

    function apply() {
      updateTabsVisibility();
      tabScrollUI.update();

      // const filter = state.filter;
      const q = (state.q || '').trim().toLowerCase();
      const keywordActive = q.length >= 2;

      cards.forEach((card) => {
        const cardType = card.getAttribute('data-sim-type') || '';
        const hay = card.getAttribute('data-search-text') || '';

        const filters = state.filters;
        const matchType = filters.has('all') || filters.size === 0 || filters.has(cardType);
        const matchSearch = !keywordActive || hay.includes(q);

        card.style.display = matchType && matchSearch ? 'flex' : 'none';
      });

      wrappers.forEach((w) => {
        const inside = Array.from(w.querySelectorAll('.product-card-container'));
        const anyVisible = inside.some((c) => c.style.display !== 'none');
        w.style.display = anyVisible ? 'block' : 'none';
      });

      const emptyEl = rootEl.querySelector('#noResults');
      if (emptyEl) {
        const anyCardVisible = cards.some((c) => c.style.display !== 'none');
        emptyEl.style.display = anyCardVisible ? 'none' : 'flex';
      }
    }

    function setUrlQueryKeyword(qValue) {
      const u = new URL(window.location.href);
      const v = String(qValue || '').trim();
      if (v) u.searchParams.set('q', v);
      else u.searchParams.delete('q');
      history.replaceState(null, '', u);
    }

    function normalizeCategoryParam(v) {
      const raw = String(v || '')
        .trim()
        .toLowerCase();
      return raw.replace(/_/g, ' ').replace(/\s+/g, '-');
    }

    function getCategoryFromUrl() {
      const u = new URL(window.location.href);
      const qCat = normalizeCategoryParam(u.searchParams.get('q'));
      if (CATEGORY_TABS.includes(qCat)) return qCat;
      return DEFAULT_CATEGORY;
    }

    function setUrlCategory(catValue) {
      const u = new URL(window.location.href);
      const v = normalizeCategoryParam(catValue);
      u.searchParams.set('q', v);
      history.replaceState(null, '', u);
    }

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        const clicked =
          (btn.getAttribute('data-filter') || '').trim() || (mode === 'category' ? DEFAULT_CATEGORY : 'all');

        if (clicked === 'all') {
          // ✅ Klik "All" → reset semua, hanya aktifkan "All"
          state.filters = new Set(['all']);
        } else {
          // ✅ Hapus "all" dari set dulu
          state.filters.delete('all');

          if (state.filters.has(clicked)) {
            // ✅ Sudah aktif → toggle off
            state.filters.delete(clicked);
          } else {
            // ✅ Belum aktif → tambahkan
            state.filters.add(clicked);
          }

          // ✅ Kalau tidak ada yang dipilih, fallback ke "All"
          if (state.filters.size === 0) {
            state.filters = new Set(['all']);
          }
        }

        setActiveTab(state.filters);
        apply();
        sortSingleCountryByTitle(rootEl, state.q);

        if (mode === 'category') {
          // ambil filter pertama untuk URL (atau gabungkan)
          const firstFilter = Array.from(state.filters)[0] || DEFAULT_CATEGORY;
          setUrlCategory(firstFilter);
        }
      });
    });

    let debounce = null;

    if (searchInput) {
      if (mode === 'main') {
        const urlQ = new URL(window.location.href).searchParams.get('q') || '';
        if (urlQ) {
          searchInput.value = urlQ;
          state.q = urlQ;
        }

        searchInput.addEventListener('input', (e) => {
          const val = e.target.value || '';
          clearTimeout(debounce);
          setSearchButtonLoading(rootEl, true);
          debounce = setTimeout(() => {
            state.q = val;
            apply();
            sortSingleCountryByTitle(rootEl, val);
            updateIncludedBadges(rootEl, val);
            setUrlQueryKeyword(val);
            setSearchButtonLoading(rootEl, false);
            updateSearchPageTitle(rootEl, val);
          }, 80);
        });

        window.addEventListener('popstate', () => {
          const qFromUrl = new URL(window.location.href).searchParams.get('q') || '';
          searchInput.value = qFromUrl;
          state.q = qFromUrl;
          apply();

          // ✅ NEW: sort on history navigation
          sortSingleCountryByTitle(rootEl, qFromUrl);

          updateIncludedBadges(rootEl, qFromUrl);
          updateSearchPageTitle(rootEl, qFromUrl);
        });
      } else {
        searchInput.addEventListener('input', (e) => {
          const val = e.target.value || '';
          clearTimeout(debounce);
          setSearchButtonLoading(rootEl, true);
          debounce = setTimeout(() => {
            state.q = val;
            apply();
            sortSingleCountryByTitle(rootEl, val);
            updateIncludedBadges(rootEl, val);
            setSearchButtonLoading(rootEl, false);
          }, 80);
        });

        window.addEventListener('popstate', () => {
          const cat = getCategoryFromUrl();
          state.filter = cat;
          setActiveTab(cat);
          apply();

          sortSingleCountryByTitle(rootEl, state.q);
        });
      }
    }

    if (mode === 'category') {
      const urlCat = getCategoryFromUrl();
      const initCat = CATEGORY_TABS.includes(urlCat) ? urlCat : 'all';
      state.filters = new Set([initCat]);
      setActiveTab(state.filters);
    } else {
      state.filters = new Set(['all']);
      setActiveTab(state.filters);
    }

    apply();

    const initialQ = searchInput ? searchInput.value : '';
    updateIncludedBadges(rootEl, initialQ);

    // ✅ NEW: sort on initial render
    sortSingleCountryByTitle(rootEl, initialQ);
    updateSearchPageTitle(rootEl, initialQ);
  }

  function wireTabScrollArrows(rootEl) {
    const scroller = rootEl.querySelector('[data-tabs-scroll]');
    const btnLeft = rootEl.querySelector('[data-tabs-left]');
    const btnRight = rootEl.querySelector('[data-tabs-right]');
    const fadeLeft = rootEl.querySelector('.tab-scroll-fade--left');
    const fadeRight = rootEl.querySelector('.tab-scroll-fade--right');

    if (!scroller || !btnLeft || !btnRight) return { update: () => {}, scrollIntoView: () => {} };

    const getStep = () => Math.max(220, Math.floor(scroller.clientWidth * 0.7));

    function update() {
      const maxScroll = scroller.scrollWidth - scroller.clientWidth;
      const canScroll = maxScroll > 4;

      if (!canScroll) {
        btnLeft.classList.remove('is-visible');
        btnRight.classList.remove('is-visible');
        fadeLeft && fadeLeft.classList.remove('is-visible');
        fadeRight && fadeRight.classList.remove('is-visible');
        return;
      }

      const atStart = scroller.scrollLeft <= 2;
      const atEnd = scroller.scrollLeft >= maxScroll - 2;

      btnLeft.classList.toggle('is-visible', !atStart);
      btnRight.classList.toggle('is-visible', !atEnd);

      fadeLeft && fadeLeft.classList.toggle('is-visible', !atStart);
      fadeRight && fadeRight.classList.toggle('is-visible', !atEnd);
    }

    const rafUpdate = () => requestAnimationFrame(update);

    scroller.addEventListener('scroll', rafUpdate, { passive: true });
    window.addEventListener('resize', rafUpdate);

    btnLeft.addEventListener('click', () => {
      scroller.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });

    btnRight.addEventListener('click', () => {
      scroller.scrollBy({ left: getStep(), behavior: 'smooth' });
    });

    function scrollIntoView(activeBtn) {
      if (!activeBtn) return;
      const btnRect = activeBtn.getBoundingClientRect();
      const scRect = scroller.getBoundingClientRect();
      const padding = 44;

      if (btnRect.left < scRect.left + padding || btnRect.right > scRect.right - padding) {
        const delta = btnRect.left - scRect.left - (scRect.width / 2 - btnRect.width / 2);
        scroller.scrollBy({ left: delta, behavior: 'smooth' });
      }
    }

    update();

    return { update, scrollIntoView };
  }

  function resetCtaLoadingState() {
    document.querySelectorAll('a.js-cta-loading[data-loading="1"]').forEach((a) => {
      // ✅ Cancel safety timer kalau ada
      if (a.dataset.safetyTimer) {
        clearTimeout(Number(a.dataset.safetyTimer));
        delete a.dataset.safetyTimer;
      }

      a.dataset.loading = '0';
      a.removeAttribute('aria-busy');
      a.style.pointerEvents = '';
      a.style.opacity = '';
      a.innerHTML = a.dataset.originalHtml || a.innerHTML;
    });
  }

  if (!window.__ctaResetBound) {
    window.__ctaResetBound = true;

    // ✅ kepanggil saat normal load & saat balik via Back (bfcache)
    window.addEventListener('pageshow', () => {
      resetCtaLoadingState();
    });

    // optional tambahan: kalau tab balik visible juga reset
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') resetCtaLoadingState();
    });
  }

  function wireCtaLoading(rootEl) {
    if (!rootEl) return;
    const links = Array.from(rootEl.querySelectorAll('a.js-cta-loading'));

    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.dataset.loading === '1') {
          e.preventDefault();
          return;
        }

        const url = a.href;
        if (!url || url === '#') return;

        a.dataset.loading = '1';
        a.setAttribute('aria-busy', 'true');
        a.style.pointerEvents = 'none';
        a.style.opacity = '0.9';

        if (!a.dataset.originalHtml) {
          a.dataset.originalHtml = a.innerHTML;
        }

        a.innerHTML = `${LOADING_ICON_HTML}<span class="ml-2">Loading...</span>`;
      });
    });
  }

  function wireFlip(rootEl) {
    if (!rootEl) return;

    rootEl.querySelectorAll('.flipped-trigger').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = btn.closest('.product-card-container');
        if (!card) return;
        card.classList.toggle('flipped');
      });
    });

    rootEl.querySelectorAll('.product-card-content-flip-back').forEach((back) => {
      back.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = back.closest('.product-card-container');
        if (card) card.classList.remove('flipped');
      });
    });

    document.addEventListener('click', (event) => {
      rootEl.querySelectorAll('.product-card-container.flipped').forEach((card) => {
        if (!card.contains(event.target)) card.classList.remove('flipped');
      });
    });
  }

  // =========================
  // CATEGORY BADGE STYLING
  // =========================
  function getCategoryBadgeStyle(item, mode) {
    if (mode === 'topup') {
      return 'background:var(--color-primary); color:var(--color-neutral);';
    }

    const raw = String(item?.category_raw || item?.category || '')
      .toLowerCase()
      .trim()
      .replace(/\s+/g, '_')
      .replace(/-/g, '_');

    if (raw === 'esim') {
      return 'background:var(--color-primary); color:var(--color-neutral);';
    }
    if (raw === 'sim_card') {
      return 'background:var(--color-secondary); color:var(--color-neutral);';
    }
    if (raw === 'insurance') {
      return 'background:#CFEFFC; color:var(--color-primary);';
    }
    if (raw === 'airport_transfer') {
      return 'background:#007BB0; color:var(--color-neutral);';
    }

    // fallback
    return 'background:var(--color-primary); color:var(--color-neutral);';
  }

  function renderCollections(results) {
    const root = document.getElementById('collections');
    if (!root) return;

    const skeleton = root.querySelector('#collections-skeleton');
    if (skeleton) skeleton.remove();

    const visible = (results ?? []).filter((col) => (col.items ?? []).length > 0);
    if (visible.length === 0) {
      root.innerHTML = `
          <div id="noResults" class="no-results" style="display:flex;">
            <h3 class="no-results__title">No results found</h3>
            <p class="no-results__desc">
              No available products for this Top Up category. Please check stock / availability.
            </p>
            <div class="flex gap-5 mt-5">
              <a href="/search" class="bg-primary text-neutral font-bold px-5 py-2 rounded-[10px]">Buy SIM</a>
              <a href="https://wa.me/628986454071" class="bg-[#25d366] text-neutral font-bold px-5 py-2 rounded-[10px]">WhatsApp CS</a>
            </div>
          </div>
        `;
      return;
    }

    const allTypes = collectAllTypes(visible);
    const mode = (root.getAttribute('data-search-type') || 'main').trim().toLowerCase();
    const filterBarHtml = renderFilterBar(allTypes, mode);

    const groupsHtml = visible
      .map((col, colIdx) => {
        const groupTitle = col.title ?? col.handle ?? 'Untitled';
        const isSingleCountryCollection = col.handle === 'single-country';

        const cardsHtml = sortGsimByRegion(col.items ?? [])
          .map((item) => {
            const simTypeRaw = mode === 'topup' ? 'Top Up Plan' : item.category ?? 'Undefined';
            const simType = normalizeType(simTypeRaw);

            const itemTitleRaw = item.title ?? item.name ?? item.handle ?? 'Untitled Item';
            const itemTitle = mode === 'topup' ? stripTopUpPrefix(itemTitleRaw) : itemTitleRaw;
            const href = item.url ?? item.href ?? (item.handle ? `/products/${item.handle}` : '#');

            const searchText = getCardSearchText(item);

            const countryMap = buildCountryAliasMap(item);
            const countryMapStr = escapeHtml(JSON.stringify(countryMap));

            return `
                <section
                  class="product-card-container bg-neutral hover:shadow-lg hover:-translate-y-[5px] transition-all rounded-[20px] p-[15px] shadow-md flex flex-col h-full"
                  data-sim-type="${escapeHtml(simType)}"
                  data-search-text="${escapeHtml(searchText)}"
                  data-country-map="${countryMapStr}"
                  data-title="${escapeHtml(itemTitle)}"
                  data-collection="${escapeHtml(col.handle)}"
                  data-category-raw="${escapeHtml(item.category_raw || '')}"
                >
                  <a href="${escapeHtml(href)}" class="w-full flex items-center gap-3 h-auto pb-3">
                    ${renderCountryVisual(item, { primaryOnly: isSingleCountryCollection })}

                    <div class="min-w-0 w-full flex items-center">
                      <h2 class="text-[20px] text-primary font-bold leading-tight line-clamp-2 overflow-hidden">
                        <span class="text-center px-2 rounded-[10px] leading-none font-bold" style="${getCategoryBadgeStyle(
                          item,
                          mode
                        )}">${escapeText(getCategoryLabel(item, mode))}</span> ${escapeText(itemTitle)}
                      </h2>
                    </div>
                  </a>

                  <div class="product-card-content">
                    <div class="product-card-content-flip-front">
                      ${renderBenefits(item, {
                        excludePrimary: isSingleCountryCollection,
                        labelMode: isSingleCountryCollection ? 'coverage_transit' : 'coverage',
                        minCount: 1,
                      })}
                    </div>

                    <div class="product-card-content-flip-back">
                      ${renderCoverageBack(item, { excludePrimary: isSingleCountryCollection })}
                    </div>
                  </div>

                  <a
                    href="${escapeHtml(href)}"
                    class="js-cta-loading mt-auto flex w-full items-center justify-center bg-primary font-bold text-neutral px-5 py-4 rounded-[15px] tracking-wide hover:bg-primary/70"
                  >
                    ${escapeHtml(t('button_gsim'))}
                  </a>
                </section>
              `;
          })
          .join('');

        return `
            <div data-base-idx="${colIdx}" class="collection-wrapper mb-10">
              <h2 class="text-primary font-bold text-[30px] mb-6">${escapeHtml(groupTitle)}</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-[20px] items-stretch">
                ${cardsHtml}
              </div>
            </div>
          `;
      })
      .join('');

    root.innerHTML = `
        ${filterBarHtml}

        <div id="noResults" class="no-results" style="display:none;">
          <h3 class="no-results__title">No results found</h3>
          <p class="no-results__desc">
            We couldn't find any products for that destination. Try another country or check the spelling.
          </p>
        </div>

        ${groupsHtml}
      `;

    wireFilterAndSearch(root, mode);
    wireFlip(root);
    wireCtaLoading(root);
  }

  function showLoading(rootEl) {
    rootEl.setAttribute('aria-busy', 'true');
    rootEl.classList.add('is-loading');
  }

  function hideLoading(rootEl) {
    rootEl.setAttribute('aria-busy', 'false');
    rootEl.classList.remove('is-loading');
  }

  function renderError(rootEl) {
    rootEl.innerHTML = `
        <div style="padding:16px; border:1px solid var(--color-border); border-radius:12px;">
          <strong style="color:var(--color-primary)">Gagal memuat data.</strong>
          <div style="margin-top:6px; color:var(--color-secondary)">Coba refresh halaman.</div>
        </div>
      `;
  }

  (async () => {
    const root = document.getElementById('collections');
    if (!root) return;

    showLoading(root);

    try {
      const mode = (root.getAttribute('data-search-type') || 'main').trim().toLowerCase();
      const results = await fetchAllCollections(mode); // ✅ mode-aware fetch
      renderCollections(results);
    } catch (e) {
      console.error(e);
      renderError(root);
    } finally {
      hideLoading(root);
    }
  })();
</script>

