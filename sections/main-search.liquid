<div style="margin: 0 auto; max-width: 1920px;">
  <div
    id="collections"
    data-search-type="{{ section.settings.search_type | default: 'main' }}"
    class="container-search"
  >
    <div id="collections-skeleton">
      <div class="w-full mb-5">
        <div class="mt-[20px] mb-[50px] space-y-4 md:max-w-[50%]">
          <ui-skeleton class="w-64 h-10 rounded-xl"></ui-skeleton>
          <ui-skeleton class="w-full h-5 rounded"></ui-skeleton>
          <ui-skeleton class="w-3/4 h-5 rounded"></ui-skeleton>
          <ui-skeleton class="w-full h-[54px] rounded-[15px]"></ui-skeleton>
        </div>
        <div class="flex gap-2 mb-4">
          <ui-skeleton class="w-16 h-9 rounded-full"></ui-skeleton>
          <ui-skeleton class="w-16 h-9 rounded-full"></ui-skeleton>
          <ui-skeleton class="w-24 h-9 rounded-full"></ui-skeleton>
          <ui-skeleton class="w-20 h-9 rounded-full"></ui-skeleton>
        </div>
      </div>
      <div class="mb-10">
        <ui-skeleton class="w-48 h-8 rounded-lg mb-6"></ui-skeleton>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-[20px]">
          {%- for i in (1..6) -%}
            <div class="bg-neutral rounded-[20px] p-[15px] shadow-md flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <ui-skeleton class="w-[50px] h-[50px] rounded-[15px] shrink-0"></ui-skeleton>
                <ui-skeleton class="h-6 rounded-lg flex-1"></ui-skeleton>
              </div>
              <div class="flex items-center justify-between border-t border-slate-200 pt-4">
                <div class="flex items-center gap-2">
                  <ui-skeleton class="w-[33px] h-[33px] rounded-full shrink-0"></ui-skeleton>
                  <ui-skeleton class="w-20 h-4 rounded"></ui-skeleton>
                </div>
                <ui-skeleton class="w-24 h-4 rounded"></ui-skeleton>
              </div>
              <div class="flex items-center justify-between border-t border-slate-200 pt-3">
                <div class="flex items-center gap-2">
                  <ui-skeleton class="w-[33px] h-[33px] rounded-full shrink-0"></ui-skeleton>
                  <ui-skeleton class="w-12 h-4 rounded"></ui-skeleton>
                </div>
                <ui-skeleton class="w-32 h-4 rounded"></ui-skeleton>
              </div>
              <ui-skeleton class="w-full h-[52px] rounded-[15px] mt-2"></ui-skeleton>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .container-search {
    padding: 20px 10% 10%;
  }

  @media (max-width: 768px) {
    .container-search {
      padding: 20px 24px;
    }
  }
  @media (max-width: 426px) {
  }

  /* ===== SWITCH TABS (segmented control) ===== */

  /* ===== SWITCH TABS (Tilt Shadow Retro) ===== */

  .filter-tab {
    position: relative;
    top: 0;
    left: 0;

    padding: 9px 22px;
    border-radius: 10px;
    line-height: 1;

    background: var(--color-neutral);
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);

    box-shadow: 3px 4px 0 var(--color-primary);
    transition: top 0.12s ease, left 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
    cursor: pointer;
    font-weight: 700;
  }

  /* hover: geser naik-kiri, shadow makin besar */
  .filter-tab:not(.is-active):hover {
    top: -2px;
    left: -2px;
    box-shadow: 5px 6px 0 var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-neutral));
  }

  /* active / pressed: geser bawah-kanan, shadow mengecil */
  .filter-tab:active {
    top: 3px;
    left: 3px;
    box-shadow: 0px 0px 0 var(--color-primary);
  }

  /* is-active: filled + shadow lebih kecil (tanda sudah "dipencet") */
  .filter-tab.is-active {
    background: var(--color-primary);
    color: var(--color-neutral);
    top: 2px;
    left: 2px;
    box-shadow: 1px 2px 0 color-mix(in srgb, var(--color-primary) 60%, black);
  }

  .product-card-content {
    position: relative;
    width: 100%;
    height: 100%;
    margin-bottom: 10px;
    transform-style: preserve-3d;
    transition: transform 0.6s ease-in-out;
  }
  .product-card-container .product-card-content {
    transform: rotateY(0deg);
  }
  .product-card-container.flipped .product-card-content {
    transform: rotateY(180deg);
  }
  .product-card-content-flip-front,
  .product-card-content-flip-back {
    backface-visibility: hidden;
    transition: transform 0.6s ease-in-out;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .product-card-content-flip-back {
    position: absolute;
    top: 0;
    left: 0;
    overflow-y: hidden;
    background: var(--color-neutral);
    text-align: center;
    cursor: pointer;
    transform: rotateY(180deg);
    border-radius: 15px;
  }
  .product-card-container.flipped .product-card-content-flip-back {
    overflow-y: auto;
  }

  /* ===== COVERAGE LIST (flag + nama) ===== */
  .coverage {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .coverage li {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .coverage h3 {
    margin: 0;
    font-size: 12px;
    color: var(--color-primary);
    text-align: left;
  }
  .coverage img {
    width: 50px;
    height: 50px;
    border-radius: 15px;
    border: 1px solid var(--color-border);
    object-fit: cover;
  }

  .coverage-title {
    margin: 10px 0 6px;
    font-size: 18px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .country-total-atribut {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  /* tombol coverage (front) */
  .country-total-atribut button {
    width: 100%;
    padding: 5px 10px;
    cursor: pointer;
    border-radius: 12px;
    border: 1px solid var(--color-primary);
    background: none;
  }

  /* fallback badge included kalau tailwind tidak kebaca */
  .included-badge {
    white-space: nowrap;
    width: max-content;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 4px 12px;
    border-radius: 5px;
    line-height: 1;
    display: none;
  }
  .included-badge.is-visible {
    display: inline-block;
  }

  .countries-count.has-included {
    margin-bottom: 3px;
  }

  #realtimeSearchInput:focus::placeholder {
    opacity: 0.25;
  }

  .no-results {
    width: 100%;
    padding: 80px 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .no-results__title {
    font-size: 22px;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 10px;
  }

  .no-results__desc {
    max-width: 520px;
    margin: 0;
    color: var(--color-secondary);
    font-size: 16px;
    line-height: 1.6;
  }

  /* ===== TAB SCROLL ARROWS ===== */
  .tab-scroll-wrap {
    position: relative;
    width: 100%;
  }

  .tab-scroll {
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tab-scroll::-webkit-scrollbar {
    display: none;
  }

  .tab-scroll-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 6;

    width: 36px;
    height: 36px;
    border-radius: 9999px;

    display: flex;
    align-items: center;
    justify-content: center;

    background: var(--color-neutral);
    border: 1px solid var(--color-border);
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);

    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .tab-scroll-arrow.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .tab-scroll-arrow--left {
    left: 0;
  }
  .tab-scroll-arrow--right {
    right: 0;
  }

  .tab-scroll-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 44px;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .tab-scroll-fade.is-visible {
    opacity: 1;
  }

  .tab-scroll-fade--left {
    left: 0;
    background: linear-gradient(90deg, var(--color-neutral), rgba(255, 255, 255, 0));
  }
  .tab-scroll-fade--right {
    right: 0;
    background: linear-gradient(270deg, var(--color-neutral), rgba(255, 255, 255, 0));
  }
  /* value di kanan (mis. 50GB - Big Data, Start From Rp...) */
  .benefit-value {
    max-width: 220px; /* batas lebar */
    white-space: normal; /* boleh turun baris */
    overflow-wrap: anywhere; /* aman untuk kata panjang */
    word-break: break-word;
    text-align: right; /* tetap rata kanan */
    line-height: 1.2;
  }

  /* opsional: kalau mau maksimal 2 baris + ellipsis */
  .benefit-value.clamp-2 {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  @media screen and (max-width: 764px) {
    .benefit-value {
      max-width: 180px;
    }
  }
</style>

<script type="module" defer>
  // =========================
  // I18N (from Shopify locale)
  // =========================
  const I18N = {
    coverage: "{{ 'product.card.coverage' | t | escape }}",
    countries: "{{ 'product.card.countries' | t | escape }}",
    including: "{{ 'product.card.including' | t | escape }}",
    data: "{{ 'product.card.data' | t | escape }}",
    days: "{{ 'product.card.days' | t | escape }}",
    price: "{{ 'product.card.price' | t | escape }}",
    price_from_prefix: "{{ 'product.card.price_from_prefix' | t | escape }}",
    button_gsim: "{{ 'product.card.button_gsim' | t | escape }}",
  };

  // HTML loader dari snippet Shopify
  const LOADING_ICON_HTML = `{% render 'loading', class: 'text-neutral w-[24px] h-[24px]' %}`;

  function t(key, vars = {}) {
    let s = I18N[key] ?? key;

    const OPEN = '{% raw %}{{{% endraw %}';
    const CLOSE = '{% raw %}}}{% endraw %}';

    for (const [k, v] of Object.entries(vars)) {
      s = s.split(`${OPEN} ${k} ${CLOSE}`).join(String(v));
    }
    return s;
  }

  // =========================
  // ✅ NEW: Collections by mode
  // =========================
  function getCollectionsForMode(mode) {
    // pastikan handle ini sama persis dengan collection kamu
    if (mode === 'topup') {
      return [{ handle: 'top-up-plan', title: 'Top Up Plan' }];
    }

    return [
      { handle: 'single-country', title: 'Single Country' },
      { handle: 'multi-country', title: 'Multi Country' },
      { handle: 'airport-transfer', title: 'Airport Transfer' },
    ];
  }

  async function fetchCollection(handle) {
    const res = await fetch(`/collections/${handle}?view=product-api-json`, {
      priority: 'high',
    });
    if (!res.ok) return { ok: false, handle, error: 'Failed to fetch data' };
    return { ok: true, handle, json: await res.json() };
  }

  async function fetchCollectionAllPages(handle) {
    let page = 1;
    let pages = 1;
    const all = [];

    while (page <= pages) {
      const res = await fetch(`/collections/${handle}?view=product-api-json&page=${page}`, {
        priority: 'high',
      });

      if (!res.ok) {
        console.error(`[${handle}] page ${page} fetch failed`, res.status);
        break;
      }

      const json = await res.json();
      pages = Number(json.pages || 1);

      all.push(...(json.items || []));
      page += 1;
    }

    return all;
  }

  function normalizeTopupCategory(v = '') {
    return String(v || '')
      .trim()
      .replace(/\s+/g, '_')
      .replace(/-/g, '_')
      .toLowerCase();
  }

  // =========================
  // ✅ PRIORITY: gSIM first
  // =========================
  function normalizeKey(v = '') {
    return String(v || '')
      .trim()
      .replace(/\s+/g, '_')
      .replace(/-/g, '_')
      .toLowerCase();
  }

  // skor: paling tinggi kalau title ada "gsim" DAN category_raw == "gsim"
  function gsimScore(item) {
    const title = String(item?.title || '').toLowerCase();
    const hasTitleGsim = title.includes('gsim');

    const catRaw = normalizeKey(item?.category_raw);
    const hasCatGsim = catRaw === 'gsim';

    return (hasTitleGsim ? 10 : 0) + (hasCatGsim ? 10 : 0);
  }

  function sortItemsGsimFirst(items = []) {
    return items
      .map((it, idx) => ({ it, idx, score: gsimScore(it) }))
      .sort((a, b) => b.score - a.score || a.idx - b.idx) // stable
      .map((x) => x.it);
  }

  // untuk DOM card (pakai data-attribute yang sudah kamu set)
  function isGsimPriorityCard(cardEl) {
    const title = (cardEl.getAttribute('data-title') || '').toLowerCase();
    const catRaw = normalizeKey(cardEl.getAttribute('data-category-raw') || '');
    return title.includes('gsim') || catRaw === 'gsim';
  }

  // =========================
  // ✅ GSIM REGION SORT
  // =========================
  const GSIM_REGION_ORDER = ['asia', 'europe', 'australia', 'america', 'middle'];

  function getGsimRegionScore(title = '') {
    const t = String(title).toLowerCase();
    for (let i = 0; i < GSIM_REGION_ORDER.length; i++) {
      if (t.includes(GSIM_REGION_ORDER[i])) return i;
    }
    return GSIM_REGION_ORDER.length; // gSIM tanpa region dikenal → paling belakang
  }

  function isGsimItem(item) {
    const title = String(item?.title || '').toLowerCase();
    const catRaw = normalizeKey(item?.category_raw || '');
    return title.includes('gsim') || catRaw === 'gsim';
  }

  function sortGsimByRegion(items = []) {
    // Kumpulkan index posisi semua item gSIM
    const gsimIndices = [];
    items.forEach((item, idx) => {
      if (isGsimItem(item)) gsimIndices.push(idx);
    });

    if (gsimIndices.length === 0) return items; // tidak ada gSIM, skip

    // Ambil item gSIM lalu sort berdasarkan region
    const gsimItems = gsimIndices.map((i) => items[i]);
    gsimItems.sort((a, b) => getGsimRegionScore(a.title) - getGsimRegionScore(b.title));

    // Kembalikan ke posisi asalnya (hanya slot gSIM yang diganti, non-gSIM tidak bergerak)
    const result = [...items];
    gsimIndices.forEach((origIdx, i) => {
      result[origIdx] = gsimItems[i];
    });

    return result;
  }

  async function fetchAllCollections(mode = 'main') {
    const COLLECTIONS = getCollectionsForMode(mode);

    const wantedTopup = mode === 'topup' ? normalizeTopupCategory(sessionStorage.getItem('category')) : '';

    const results = await Promise.all(
      COLLECTIONS.map(async ({ handle, title }) => {
        let items = await fetchCollectionAllPages(handle);

        // FILTER TOPUP BERDASARKAN sessionStorage.category
        if (mode === 'topup' && wantedTopup) {
          items = items.filter((it) => normalizeTopupCategory(it.category_raw) === wantedTopup);
        }

        // ✅ gSIM FIRST (untuk semua mode: topup, main, category)
        // items = sortItemsGsimFirst(items);

        return { handle, title, items };
      })
    );

    return results;
  }

  function escapeHtml(str = '') {
    return String(str).replace(
      /[&<>"']/g,
      (m) =>
        ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#039;',
        }[m])
    );
  }

  // ✅ khusus buat text (nama negara dll) biar "_" tampil jadi spasi
  function escapeText(str = '') {
    return escapeHtml(String(str).replace(/_/g, ' '));
  }

  function stripTopUpPrefix(str = '') {
    return (
      String(str)
        // hapus "Top Up", "Top-Up", "top up -", dst di awal kalimat
        .replace(/^\s*top\s*up[\s-]*/i, '')
        .trim()
    );
  }

  // =========================
  // LOCALE HELPERS (EN/ID)
  // =========================
  function getLocale() {
    return (window.Shopify && Shopify.locale) || document.documentElement.lang || 'en';
  }

  function getCoverageLabelLines(opts = {}) {
    const locale = getLocale();
    const isID = String(locale).toLowerCase().startsWith('id');

    const defaultLabel = "{{ 'product.card.coverage' | t | escape }}";

    if (opts.labelMode === 'coverage_transit') {
      return isID ? { line1: 'Cakupan', line2: '+ Transit' } : { line1: 'Coverage', line2: '+ Transit' };
    }

    return { line1: defaultLabel, line2: '' };
  }

  function getCountryNameByLocale(entry, locale) {
    const c = entry?.country || {};
    const isID = String(locale).toLowerCase().startsWith('id');

    const raw = isID
      ? c.country_name_id || c.country_id || c.name_id || c.title_id || c.country_name || c.name || c.title
      : c.country_name_en || c.country_en || c.name_en || c.title_en || c.country_name || c.name || c.title;

    const fallback = (Array.isArray(c.country_alias) ? c.country_alias[0] : '') || entry?.country_name || '';

    return String(raw || fallback || '').trim();
  }

  function normalizeUrl(url = '') {
    if (typeof url !== 'string') return '';
    if (url.startsWith('//')) return 'https:' + url;
    return url;
  }

  function normalizeImageSrc(src = '') {
    const s = normalizeUrl(src);
    return escapeHtml(String(s).replace(/\s+/g, '_'));
  }

  function getSearchKey(item) {
    return Array.isArray(item?.search_key) ? item.search_key : [];
  }

  function getCountryFlag(entry) {
    const flag = entry?.country?.country_flag;
    return typeof flag === 'string' && flag.length ? flag : null;
  }

  function getValidFlags(item) {
    return getSearchKey(item).map(getCountryFlag).filter(Boolean);
  }

  // =========================
  // COVERAGE HELPERS
  // =========================
  function getCountryName(entry) {
    const c = entry?.country || {};
    const raw =
      c.country_name ||
      c.name ||
      c.title ||
      (Array.isArray(c.country_alias) ? c.country_alias[0] : '') ||
      entry?.country_name ||
      '';
    return String(raw || '').trim();
  }

  function getPrimaryCountry(item) {
    const sk = getSearchKey(item);
    for (const entry of sk) {
      const flag = getCountryFlag(entry);
      const name = getCountryName(entry);
      if (flag && name) return { name, flag };
    }
    return null;
  }

  function getCoverageItems(item, opts = {}) {
    const sk = getSearchKey(item);

    const primary = opts.excludePrimary ? getPrimaryCountry(item) : null;
    const primaryKey = primary ? `${primary.name}__${primary.flag}` : null;

    const map = new Map();
    sk.forEach((entry) => {
      const flag = getCountryFlag(entry);
      const name = getCountryName(entry);
      if (!flag || !name) return;

      const key = `${name}__${flag}`;
      if (primaryKey && key === primaryKey) return;

      if (!map.has(key)) map.set(key, { name, flag });
    });

    return Array.from(map.values());
  }

  function renderCoverageBack(item, opts = {}) {
    let cov = getCoverageItems(item, opts);

    if (!cov.length && opts.excludePrimary) {
      cov = getCoverageItems(item, { ...opts, excludePrimary: false });
    }

    if (!cov.length) {
      return `
      <ul class="coverage" role="list">
        <li style="padding:10px; color: var(--color-secondary); font-weight:700;">
          No coverage data
        </li>
      </ul>
    `;
    }

    const rows = cov
      .map((c) => {
        const src = normalizeImageSrc(c.flag);
        const nm = escapeText(c.name);

        return `
            <li>
              <img src="${src}" alt="${nm}" loading="lazy" />
              <span class="text-primary text-[16px]">${nm}</span>
            </li>
          `;
      })
      .join('');

    return `
        <ul class="coverage" role="list">
          ${rows}
        </ul>
      `;
  }

  // =========================
  // Included (dynamic) by alias -> country name EN/ID
  // =========================
  function buildCountryAliasMap(item) {
    const map = {};
    const sk = getSearchKey(item);

    sk.forEach((entry) => {
      const c = entry?.country || {};
      const aliases = Array.isArray(c.country_alias) ? c.country_alias : [];

      const nameEn = getCountryNameByLocale(entry, 'en');
      const nameId = getCountryNameByLocale(entry, 'id');

      aliases.forEach((a) => {
        const key = String(a || '')
          .toLowerCase()
          .trim();
        if (!key) return;
        if (!map[key]) map[key] = { en: nameEn, id: nameId };
      });
    });

    return map;
  }

  function resolveIncludedFromQuery(cardEl, q, locale) {
    const qLower = String(q || '')
      .toLowerCase()
      .trim();
    if (!qLower) return null;

    try {
      const raw = cardEl.getAttribute('data-country-map') || '{}';
      const map = JSON.parse(raw);
      const hit = map[qLower];
      if (!hit) return null;

      const isID = String(locale).toLowerCase().startsWith('id');
      return isID ? hit.id : hit.en;
    } catch (e) {
      return null;
    }
  }

  function updateIncludedBadges(rootEl, q) {
    const locale = getLocale();
    const cards = Array.from(rootEl.querySelectorAll('.product-card-container'));
    const qTrim = String(q || '').trim();

    cards.forEach((card) => {
      const badge = card.querySelector('.included-badge');
      const countSpan = card.querySelector('.countries-count');
      if (!badge) return;

      if (qTrim.length < 2) {
        badge.textContent = '';
        badge.classList.remove('is-visible');
        if (countSpan) countSpan.classList.remove('has-included');
        return;
      }

      const name = resolveIncludedFromQuery(card, qTrim, locale);

      if (!name) {
        badge.textContent = '';
        badge.classList.remove('is-visible');
        if (countSpan) countSpan.classList.remove('has-included');
        return;
      }

      badge.textContent = `Include: ${name}`;
      badge.classList.add('is-visible');
      if (countSpan) countSpan.classList.add('has-included');
    });
  }

  function updateSearchPageTitle(rootEl, q) {
    const titleEl = rootEl.querySelector('#searchPageTitle');
    if (!titleEl) return;

    const trimmed = String(q || '').trim();
    if (trimmed.length >= 1) {
      titleEl.textContent = `Search Result for "${trimmed}"`;
    } else {
      titleEl.textContent = 'All Destinations';
    }
  }

  function renderCoverageFieldFront(item, opts = {}) {
    const cov = getCoverageItems(item, opts);

    const minShow = opts.minCount !== undefined ? opts.minCount : 1;
    if (cov.length < minShow) return '';

    const iconWorld = "{{ 'icon-park-outline_world.svg' | asset_url }}";
    const count = cov.length;

    const { line1, line2 } = getCoverageLabelLines(opts);

    const labelHtml = line2
      ? `
      <div class="flex flex-col leading-tight">
        <h3 class="text-primary font-extrabold leading-tight">${escapeHtml(line1)}</h3>
        <h3 class="text-primary font-extrabold leading-tight">${escapeHtml(line2)}</h3>
      </div>
    `
      : `<h3 class="text-primary font-bold leading-tight">${escapeHtml(line1)}</h3>`;

    return `
    <div class="py-4 w-full flex items-center justify-between border-t border-slate-300">
      <div class="flex items-center gap-2">
        <div class="w-[33px] h-[33px] shrink-0 flex items-center justify-center">
          <img class="w-[30px] h-[30px]" src="${iconWorld}" alt="Icon">
        </div>
        ${labelHtml}
      </div>

      <div class="country-total-atribut">
        <button class="flipped-trigger w-full cursor-pointer" type="button">
          <span class="countries-count font-semibold text-secondary leading-relaxed">
           ${escapeHtml(count === 1 ? `${count} Country` : t('countries', { count }))}
          </span>
        </button>
        <p class="included-badge text-neutral text-[12px] min-w-full text-center text-semibold bg-secondary"></p>
      </div>
    </div>
  `;
  }

  function hasValue(v) {
    if (v === null || v === undefined) return false;
    const s = String(v).trim();
    if (!s) return false;
    const low = s.toLowerCase();
    if (low === 'null' || low === 'undefined') return false;
    if (s === '-') return false;
    return true;
  }

  function renderBenefits(item, opts = {}) {
    const benefits = [];

    const catRaw = String(item.category_raw || item.category || '')
      .toLowerCase()
      .replace(/\s+/g, '_');
    const isAirportTransfer = catRaw === 'airport_transfer' || catRaw === 'airport-transfer';

    if (isAirportTransfer && hasValue(item.option1)) {
      benefits.push({
        iconSnippet: `{% render 'icon-people', class: 'text-primary w-[24px] h-[24px]' %}`,
        label: 'Seater',
        value: item.option1,
      });
    }

    benefits.push({
      icon: "{{ 'icon-dollar.svg' | asset_url }}",
      label: t('price'),
      valueHtml: `${escapeHtml(t('price_from_prefix'))} <span class="money">${escapeHtml(item.price_min_money_with_currency)}</span>`,
    });

    // ✅ render coverage dulu, supaya kita tahu ada coverage atau tidak
    let coverageHtml = renderCoverageFieldFront(item, opts);
    if (!coverageHtml.trim() && opts.excludePrimary) {
      coverageHtml = renderCoverageFieldFront(item, {
        ...opts,
        excludePrimary: false,
        labelMode: 'coverage',
        minCount: 1,
      });
    }
    const hasCoverage = Boolean((coverageHtml || '').trim());

    return `
    <div class="space-y-0">
      ${coverageHtml}

      ${benefits
        .map((b, idx) => {
          const isLast = idx === benefits.length - 1;

          // ✅ kalau TIDAK ADA coverage dan benefit cuma 1 baris (price doang),
          // kasih border-b biar ada garis bawah sebelum tombol
          const needsBottomBorder = !hasCoverage && benefits.length === 1 && isLast;

          return `
            <div class="py-3 w-full flex items-center justify-between border-t border-slate-300 ${
              needsBottomBorder ? 'border-b border-slate-300' : ''
            }" style="min-width:0;">
              <div class="flex items-center gap-2">
                <div class="w-[33px] h-[33px] shrink-0 flex items-center justify-center">
                  ${
                    b.iconSnippet
                      ? b.iconSnippet
                      : `<img class="w-[30px] h-[30px]" src="${b.icon}" alt="${escapeHtml(b.label)}">`
                  }
                </div>
                <h3 class="text-primary font-bold">${escapeHtml(b.label)}</h3>
              </div>
              <h3 class="text-secondary font-bold benefit-value clamp-2">
                ${b.valueHtml ? b.valueHtml : escapeHtml(b.value)}
              </h3>
            </div>
          `;
        })
        .join('')}
    </div>
  `;
  }

  function getCategoryLabel(item, mode) {
    if (mode === 'topup') return 'Top Up Plan';
    return item?.category || '';
  }

  function normalizeType(raw = '') {
    return String(raw || 'undefined')
      .trim()
      .toLowerCase()
      .replace(/_/g, ' ')
      .replace(/\s+/g, '-');
  }

  function collectAllTypes(results = []) {
    const set = new Set();
    const HIDE_TABS = new Set(['top-up-plan', 'top-up', 'topup-plan', 'topup']);

    results.forEach((col) => {
      (col.items || []).forEach((item) => {
        const t = normalizeType(item.category);
        if (!t || t === 'undefined') return;
        if (HIDE_TABS.has(t)) return;
        set.add(t);
      });
    });

    const desired = ['esim', 'sim-card', 'insurance'];
    const types = Array.from(set);
    const ordered = desired.filter((t) => types.includes(t));
    const extras = types.filter((t) => !desired.includes(t));
    return [...ordered, ...extras];
  }

  function getCardSearchText(item) {
    const sk = Array.isArray(item?.search_key) ? item.search_key : [];

    // Helper: sertakan versi asli + versi underscore-diganti-spasi
    function withNormalized(val) {
      const s = String(val || '').trim();
      if (!s) return [];
      const normalized = s.replace(/_/g, ' ');
      return normalized !== s ? [s, normalized] : [s];
    }

    const countryTokens = sk
      .flatMap((x) => {
        const c = x?.country || {};
        const aliases = Array.isArray(c.country_alias) ? c.country_alias : [];
        return [c.country_en, c.country_id, ...aliases].flatMap(withNormalized);
      })
      .filter(Boolean);

    const regionTokens = sk
      .flatMap((x) => {
        const regions = Array.isArray(x?.regions) ? x.regions : x?.region ? [x.region] : [];
        return regions.flatMap((r) => {
          const aliases = Array.isArray(r?.region_alias) ? r.region_alias : [];
          return [r?.region_en, r?.region_id, ...aliases].flatMap(withNormalized);
        });
      })
      .filter(Boolean);

    const title = item?.title ? [item.title] : [];
    const handle = item?.handle ? [item.handle] : [];
    const category = item?.category ? [item.category] : [];

    return [...title, ...handle, ...category, ...countryTokens, ...regionTokens].join(' ').toLowerCase();
  }

  function renderCountryVisual(item, opts = {}) {
    const flags = getValidFlags(item);
    const total = flags.length;

    if (opts.primaryOnly) {
      const primary = getPrimaryCountry(item);
      if (primary?.flag) {
        const src = normalizeImageSrc(primary.flag);
        return `
            <div class="w-[50px] h-[50px] shrink-0 border border-slate-300 overflow-hidden rounded-[15px]">
              <img src="${src}" alt="flag" class="w-full h-full object-cover" loading="lazy" />
            </div>
          `;
      }
    }

    if (total === 0) {
      return `
          <div class="w-[50px] h-[50px] shrink-0 border border-slate-300 overflow-hidden rounded-[15px]">
            <div class="rounded-xl bg-slate-300 h-full w-full"></div>
          </div>
        `;
    }

    if (total === 1) {
      const src = normalizeImageSrc(flags[0]);

      return `
          <div class="w-[50px] h-[50px] shrink-0 border border-slate-300 overflow-hidden rounded-[15px]">
            <img src="${src}" alt="flag" class="w-full h-full object-cover" loading="lazy" />
          </div>
        `;
    }

    const showCounter = total > 4;
    const displayFlags = showCounter ? flags.slice(0, 3) : flags.slice(0, 4);
    const remaining = total - 3;

    const cellsHtml = [
      ...displayFlags.map((f) => {
        const src = normalizeImageSrc(f);

        return `
            <div class="border border-slate-300 bg-neutral rounded-[5px] h-[24px] w-[24px] overflow-hidden shrink-0">
              <img src="${src}" alt="flag" class="w-full h-full object-cover" loading="lazy" />
            </div>
          `;
      }),
      ...(showCounter
        ? [
            `
                <div class="rounded-[5px] border border-slate-300 h-[24px] w-[24px] overflow-hidden shrink-0 flex items-center justify-center">
                  <span class="text-[11px] font-bold text-primary">+${escapeHtml(remaining)}</span>
                </div>
              `,
          ]
        : []),
    ].join('');

    return `
        <div class="w-[50px] h-[50px] gap-0.5 items-center" style="display:grid; grid-template-columns:repeat(2,1fr);">
          ${cellsHtml}
        </div>
      `;
  }

  // =========================
  // ✅ NEW: SORTING SINGLE-COUNTRY (prioritize TITLE match)
  // =========================
  function normalizeQ(s = '') {
    return String(s).toLowerCase().trim().replace(/\s+/g, ' ');
  }

  function scoreTitleMatch(title = '', q = '') {
    const t = normalizeQ(title);
    const k = normalizeQ(q);
    if (!k) return 0;

    if (t === k) return 1000; // exact
    if (t.startsWith(k)) return 900; // starts with

    const safe = k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(`\\b${safe}\\b`, 'i');
    if (re.test(t)) return 800; // whole-word

    if (t.includes(k)) return 700; // contains
    return 0;
  }

  function sortSingleCountryByTitle(rootEl, q) {
    const keyword = String(q || '').trim();
    if (keyword.length < 2) return;

    const wrappers = Array.from(rootEl.querySelectorAll('.collection-wrapper'));

    wrappers.forEach((wrapper) => {
      const grid = wrapper.querySelector('.grid');
      if (!grid) return;

      const cards = Array.from(grid.querySelectorAll('.product-card-container'));

      // ✅ DIHAPUS: filter single-country saja — sekarang semua collection ikut di-sort
      if (!cards.length) return;

      cards.forEach((c, idx) => (c.__origIdx = idx));

      cards.sort((a, b) => {
        const ta = a.getAttribute('data-title') || '';
        const tb = b.getAttribute('data-title') || '';
        const sa = scoreTitleMatch(ta, keyword);
        const sb = scoreTitleMatch(tb, keyword);

        if (sb !== sa) return sb - sa;
        return (a.__origIdx ?? 0) - (b.__origIdx ?? 0);
      });

      cards.forEach((c) => grid.appendChild(c));
    });
  }

