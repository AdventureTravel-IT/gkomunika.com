{% capture icon_arrow_right %}
  {% render 'icon-arrow-right', class: 'text-primary w-[24px] h-[24px]' %}
{% endcapture %}

{% capture icon_arrow_left %}
  {% render 'icon-arrow-right', class: 'text-primary w-[24px] h-[24px] rotate-180' %}
{% endcapture %}

<div>
  <section
    class="w-full h-[450px] bg-no-repeat bg-cover bg-center flex items-center px-[10%] bg-slate-300"
    style="background-image: url('https://cdn.shopify.com/s/files/1/0735/4204/1817/files/andrei-mike-N1ufEF8ukmI-unsplash.jpg?v=1748274093');"
  >
    <div class="flex flex-col gap-[10px] text-left">
      <h2 class="text-neutral font-bold text-[30px]">Global Komunika Blog & News</h2>
      <p class="text-neutral text-[18px]">Find your travel inspiration wherever you’re going.</p>
    </div>
  </section>

  {% if section.settings.view_type != 'all' %}
    <div class="wrapper md:wrapper-base mt-[10px]">
      <h1 class="text-primary font-bold text-center text-[30px]">Stay Connected, Travel Smarter</h1>
      <p class="text-primary text-[16px] md:text-[18px] text-center">
        Global Komunika shares essential travel tips, destination insights, and the latest updates on eSIM and SIM card
        solutions, helping travelers stay connected with ease wherever they go.
      </p>
    </div>
  {% endif %}

  <!-- Latest 3 (paling baru dari semua kategori) -->
  <div id="latest-articles">
    {% comment %}
      SKELETON LOADING FOR NEWS TYPE TOP
    {% endcomment %}
    {% if section.settings.view_type != 'all' %}
    <div class="space-y-[20px] pt-8">
      <section class="wrapper md:wrapper-base grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for i in (1..3) %}
          <div class="bg-neutral p-[15px] rounded-[15px] space-y-3">
            <ui-skeleton class="w-full h-[220px] rounded-[15px]"></ui-skeleton>

            <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
            <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
            <ui-skeleton class="h-[20px] w-[100px]"></ui-skeleton>
          </div>
        {% endfor %}
      </section>

      <section class="h-[250px] w-full bg-neutral flex items-center justify-center">
        <div class="space-y-3">
          <ui-skeleton class="w-[200px] h-[20px] rounded-[15px] mx-auto"></ui-skeleton>
          <ui-skeleton class="max-w-[700px] h-[20px] rounded-[15px] mx-auto"></ui-skeleton>
          <ui-skeleton class="w-[200px] h-[50px] rounded-[15px] mx-auto"></ui-skeleton>
        </div>
      </section>
      <section class="wrapper md:wrapper-base grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for i in (1..3) %}
          <div class="bg-neutral p-[15px] rounded-[15px] space-y-3">
            <ui-skeleton class="w-full h-[220px] rounded-[15px]"></ui-skeleton>

            <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
            <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
            <ui-skeleton class="h-[20px] w-[100px]"></ui-skeleton>
          </div>
        {% endfor %}
      </section>
    </div>
  </div>
  {% endif %}
</div>

<!-- Section per-category -->
<div id="category-sections">{% comment %}
      SKELETON LOADING FOR NEWS TYPE ALL
    {% endcomment %}
    {% if section.settings.view_type == 'all' %}
    <section class="wrapper md:wrapper-base grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {% for i in (1..9) %}
        <div class="bg-neutral p-[15px] rounded-[15px] space-y-3">
          <ui-skeleton class="w-full h-[220px] rounded-[15px]"></ui-skeleton>

          <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
          <ui-skeleton class="h-[20px] w-full"></ui-skeleton>
          <ui-skeleton class="h-[20px] w-[100px]"></ui-skeleton>
        </div>
      {% endfor %}
    </section>
    {% endif %}
</div>

<script type="module" defer>
  (async function () {
    const ICON_NEXT = {{ icon_arrow_right | strip_newlines | json }};
    const ICON_PREV = {{ icon_arrow_left  | strip_newlines | json }};

    const CATEGORIES = ['news', 'travel-guide', 'travel-tips', 'event', 'tech-guide'].map((s) => s.toLowerCase());
    let page = 1;
    let itemsByCategory = {};
    let maxItems = 3;

    // ambil dari setting section (Shopify schema)
    const SECTION_VIEW_TYPE = '{{ section.settings.view_type }}'; // 'top' | 'all'

    // Ambil parameter URL
    const urlParams = new URLSearchParams(window.location.search);
    const categoryQuery = urlParams.get('q')?.toLowerCase();
    const viewQuery = urlParams.get('view'); // optional: override via URL ?view=all

    // Tentukan view yang dipakai (URL override kalau ada, kalau tidak pakai setting section)
    const effectiveView = (viewQuery || SECTION_VIEW_TYPE || 'top').toLowerCase();

    // Hero banner ikut aturan setting section (biar tetap hilang kalau setting = all)
    const showHeroBanner = (SECTION_VIEW_TYPE || 'top').toLowerCase() !== 'all' && !categoryQuery;

    // If view = all -> tampilkan semua item, else top 3
    if (effectiveView === 'all') maxItems = 0;

    // =========================
    // PAGINATION SETTINGS (MODE ALL)
    // =========================
    const ITEMS_PER_PAGE = 9;

    const safeId = (s) =>
      String(s || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-');

    const isMobile = () => window.matchMedia('(max-width: 640px)').matches;

    const buildPageList = (current, total) => {
      // MOBILE: tampilkan 1 2 3 4 5 ... last
      if (isMobile()) {
        if (total <= 6) return Array.from({ length: total }, (_, i) => i + 1);
        return [1, 2, 3, 4, 5, '...', total];
      }

      // DESKTOP: logic lama (lebih lengkap)
      if (total <= 9) return Array.from({ length: total }, (_, i) => i + 1);

      if (current <= 5) return [1, 2, 3, 4, 5, 6, 7, '...', total];

      if (current >= total - 4)
        return [1, '...', total - 6, total - 5, total - 4, total - 3, total - 2, total - 1, total];

      return [1, '...', current - 2, current - 1, current, current + 1, current + 2, '...', total];
    };

    // =========================
    // PERFORMANCE: Lazy render section saat mendekati viewport
    // =========================
    const onVisible = (el, cb, options = {}) => {
      if (!('IntersectionObserver' in window)) {
        cb();
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              io.disconnect();
              cb();
            }
          });
        },
        { root: null, rootMargin: options.rootMargin || '350px 0px', threshold: 0.01 }
      );
      io.observe(el);
    };

    // Mapping deskripsi per category
    const CATEGORY_DESC = {
      news: 'Latest updates on travel, airlines, airport rules, and tourism trends.',
      'travel-tips': 'Smart tips for easier, cheaper, and more enjoyable travel.',
      'travel-guide': 'Explore top sights, local eats, and things to do at every destination.',
      'tech-guide':
        'Practical tech tips and gadget guides for smarter travel—apps, devices, connectivity, and digital safety.',
      event: 'Find festivals, local events, and seasonal highlights worth visiting.',
    };

    // Mapping khusus HERO banner (desc + image)
    const HERO_META = {
      news: {
        desc: `Stay up to date with the latest developments in travel, including <strong>airline updates</strong>, airport regulations,<strong>visa policies</strong>, and <strong>tourism trends</strong>. Perfect for keeping informed before and during your journey.`,
        image: `//gkomunika.com/cdn/shop/files/news_1.webp?v=1747649452`,
      },
      'travel-guide': {
        desc: `Plan your trip with in-depth guides featuring top <strong>attractions</strong>, local food spots, and <strong>fun activities</strong>. Whether you’re visiting a city for the first time or returning for more, our guides help you get the most out of every destination.`,
        image: `//gkomunika.com/cdn/shop/files/annika-k2dh4qZ2o_I-unsplash.jpg?v=1748331635`,
      },
      event: {
        desc: `Find out what’s happening around the world—from <strong>traditional festivals</strong> and <strong>cultural parades</strong> to seasonal highlights. These events can add a unique and memorable touch to your trip.`,
        image: `//gkomunika.com/cdn/shop/files/miguel-bernardo-lAT-Z6uLYew-unsplash.jpg?v=1748331635`,
      },
      'travel-tips': {
        desc: `Explore <strong>helpful tips and tricks</strong> to make your travel smoother, more affordable, and more enjoyable. From packing efficiently to saving money on transport and accommodations, we've got you covered.`,
        image: `//gkomunika.com/cdn/shop/files/kristina-zykova-5n-Os-7qitE-unsplash.jpg?v=1748331635`,
      },
      'tech-guide': {
        desc: `Break down complex tech topics into simple, traveler-friendly guides. Learn how to <strong>maximize your eSIM</strong>, <strong>optimize your device</strong>, and <strong>solve common connectivity issues</strong>, helping you stay online anywhere in the world.`,
        image: `//gkomunika.com/cdn/shop/files/WhatsApp_Image_2025-11-20_at_16.05.04_32a9aae1.jpg?v=1763630437`,
      },
    };

    const formatCategoryTitle = (cat) =>
      (cat || '')
        .split('-')
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
        .join(' ');

    // helper tanggal: pakai updated_at kalau ada, fallback published_at/created_at
    const getItemDate = (item) => {
      const raw = item.updated_at || item.published_at || item.created_at;
      const d = raw ? new Date(raw) : new Date(0);
      return isNaN(d.getTime()) ? new Date(0) : d;
    };

    const formatDate = (dateObj) =>
      dateObj.toLocaleDateString('en-GB', {
        day: '2-digit',
        month: 'long',
        year: 'numeric',
      });

    const renderCard = (item) => {
      const title = item.title || 'Untitled';
      const excerpt = item.excerpt || 'No description available.';
      const url = item.url || '#';
      const img = item.image || 'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/placeholder.jpg';
      const dateObj = getItemDate(item);

      return `
        <a
          class="bg-neutral p-[15px] rounded-[15px] space-y-3 hover:shadow-lg transition-all will-change-transform"
          href="${url}"
        >
          <div class="w-full h-[220px] rounded-[15px] overflow-hidden bg-slate-300">
            <img
              class="w-full h-full object-cover object-center block"
              loading="lazy"
              decoding="async"
              src="${img}"
              alt="${title}"
            >
          </div>

          <h2
            class="text-primary text-[20px] font-bold leading-normal line-clamp-2"
            title="${title}"
          >
            ${title}
          </h2>
          <p class="text-primary text-[14px] line-clamp-3 leading-relaxed">
            ${excerpt}
          </p>
          <p class="text-secondary text-[14px]">
            ${formatDate(dateObj)}
          </p>
        </a>
      `;
    };

    // Jika parameter 'q' ada, gunakan kategori tersebut, jika tidak, tampilkan semua kategori
    const categoriesToRender = categoryQuery && CATEGORIES.includes(categoryQuery) ? [categoryQuery] : CATEGORIES;

    // Kumpulkan semua item untuk kebutuhan "Latest 3"
    const allItems = [];

    await new Promise((r) => requestAnimationFrame(() => r()));

    // FETCH semua page
    while (true) {
      const url = `/search?view=news-api-json&type=page&q=%2A&page=${page}`;
      const res = await fetch(url, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('HTTP ' + res.status);

      const data = await res.json();

      const filtered = (data.items || []).filter((x) => {
        const cat = (x.category || '').toLowerCase().trim();
        return categoriesToRender.includes(cat);
      });

      // simpan untuk global latest
      allItems.push(...filtered);

      // simpan untuk render per-category
      filtered.forEach((item) => {
        const category = (item.category || '').toLowerCase().trim();
        if (!itemsByCategory[category]) itemsByCategory[category] = [];
        itemsByCategory[category].push(item);
      });

      if (page >= data.pages) break;
      page += 1;
    }

    // Dedup biar aman kalau ada item dobel
    const uniqueMap = new Map();
    allItems.forEach((it) => {
      const key = it.url || it.handle || it.title + '|' + (it.updated_at || it.published_at || it.created_at || '');
      if (!uniqueMap.has(key)) uniqueMap.set(key, it);
    });
    const uniqueItems = Array.from(uniqueMap.values());

    // Sort per-category biar newest dulu
    Object.keys(itemsByCategory).forEach((cat) => {
      itemsByCategory[cat].sort((a, b) => getItemDate(b).getTime() - getItemDate(a).getTime());
    });

    // =========================
    // MODE TOP (tanpa q):
    // - tampilkan Latest 3 di atas
    // =========================
    if (effectiveView !== 'all' && !categoryQuery) {
      const latest3 = uniqueItems.sort((a, b) => getItemDate(b).getTime() - getItemDate(a).getTime()).slice(0, 3);

      const latestContainer = document.querySelector('#latest-articles');
      if (latestContainer) {
        latestContainer.innerHTML = `
          <div class="wrapper md:wrapper-base grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            ${latest3.map(renderCard).join('')}
          </div>
        `;
      }
    }

    // =========================
    // Render per-category (LAZY + pagination saat view = all)
    // =========================
    const sectionContainer = document.querySelector('#category-sections');
    if (!sectionContainer) return;

    sectionContainer.innerHTML = '';

    categoriesToRender.forEach((category) => {
      const items = itemsByCategory[category] || [];
      if (items.length === 0) return;

      const categoryTitle = formatCategoryTitle(category);

      const categoryDesc = CATEGORY_DESC[category] || 'Discover the latest articles and updates in this category.';
      const heroDesc = HERO_META[category]?.desc || categoryDesc;

      const heroImage =
        HERO_META[category]?.image ||
        'https://cdn.shopify.com/s/files/1/0735/4204/1817/files/andrei-mike-N1ufEF8ukmI-unsplash.jpg?v=1748274093';

      const sid = safeId(category);
      const gridId = `grid-${sid}`;
      const pagerInfoId = `pager-info-${sid}`;
      const pagerControlsId = `pager-controls-${sid}`;

      const totalItems = items.length;
      const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);

      const section = document.createElement('section');

      // Untuk performance: mode ALL, grid awalnya kosong (diisi saat section visible)
      const initialCards =
        effectiveView === 'all'
          ? ''
          : items
              .slice(0, maxItems || undefined)
              .map(renderCard)
              .join('');


      section.innerHTML = `
        ${
          // HERO BANNER: hanya muncul saat view bukan "all"
          showHeroBanner
            ? `
              <div class=container>
                <div
                  class="wrapper-base flex flex-col items-center justify-center min-h-[310px]"
                  style="background-image: url('${heroImage}'); background-size: cover; background-position: center;">
                  <h2 class="text-primary text-[30px] font-bold">${categoryTitle}</h2>
                  <span class="text-primary text-[14px] leading-relaxed md:text-[18px] text-left md:text-center mt-2">${heroDesc}</span>
                  <a
                    href="/pages/news-category?q=${encodeURIComponent(category)}"
                    class="inline-flex items-center justify-center px-[50px] py-4 mt-16 rounded-[15px] text-[16px] bg-primary text-neutral hover:opacity-90 transition"
                  >
                    Read more
                  </a>
                </div>
              </div>
            `
            : ''
        }

        <div class="container">
          <div class="wrapper md:wrapper-base">

            ${
              // HEADER MODE ALL: hanya muncul saat view = "all"
              effectiveView === 'all'
                ? `
                  <div class="mb-12 mt-4">
                    <h2 class="text-primary font-bold text-[24px] text-center">${categoryTitle}</h2>
                    <p class="text-primary text-[18px] text-center">${categoryDesc}</p>
                  </div>
                `
                : ''
            }

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="${gridId}" aria-busy="true">
              ${initialCards}
            </div>

            ${
              // PAGINATION hanya untuk mode ALL & kalau pages > 1
              effectiveView === 'all' && totalPages > 1
                ? `
                  <div class="flex flex-col items-center gap-3 mt-8">
                    <div class="text-primary text-[14px]" id="${pagerInfoId}"></div>
                    <div class="flex items-center gap-2 justify-center flex-nowrap" id="${pagerControlsId}"></div>
                  </div>
                `
                : ''
            }

          </div>
        </div>
      `;

      sectionContainer.appendChild(section);

      // Kalau bukan mode ALL, ga perlu pagination+lazy
      if (effectiveView !== 'all') return;

      // ====== Setup pagination + lazy render ======
      const gridEl = section.querySelector(`#${CSS.escape(gridId)}`);
      const infoEl = section.querySelector(`#${CSS.escape(pagerInfoId)}`);
      const controlsEl = section.querySelector(`#${CSS.escape(pagerControlsId)}`);

      const state = { page: 1, hydrated: false };

      const renderControls = () => {
        if (!controlsEl) return;

        const pages = buildPageList(state.page, totalPages);

        const base =
          'shrink-0 rounded-[8px] border transition ' +
          'min-w-[32px] h-[32px] px-2 text-[13px] ' + // mobile
          'sm:min-w-[38px] sm:h-[38px] sm:px-3 sm:text-[14px]'; // desktop

        const active = 'bg-primary text-neutral border-primary';
        const normal = 'bg-white text-primary border-[#D9DEE3] hover:bg-[#F3F4F6]';
        const disabled = 'opacity-40 cursor-not-allowed';

        const prevDisabled = state.page === 1;
        const nextDisabled = state.page === totalPages;

        const prevBtn = `
  <button type="button" data-nav="prev"
    class="${base} ${normal} ${prevDisabled ? disabled : ''} flex items-center justify-center"
    ${prevDisabled ? 'disabled' : ''}
    aria-label="Previous page"
  >${ICON_PREV}</button>
`;

        const nextBtn = `
  <button type="button" data-nav="next"
    class="${base} ${normal} ${nextDisabled ? disabled : ''} flex items-center justify-center"
    ${nextDisabled ? 'disabled' : ''}
    aria-label="Next page"
  >${ICON_NEXT}</button>
`;

        const pageBtns = pages
          .map((p) => {
            if (p === '...') return `<span class="px-1 sm:px-2 text-primary select-none shrink-0">…</span>`;

            const isActive = p === state.page;
            return `
        <button type="button" data-page="${p}"
          class="${base} ${isActive ? active : normal}"
          aria-current="${isActive ? 'page' : 'false'}"
        >${p}</button>
      `;
          })
          .join('');

        controlsEl.innerHTML = `${prevBtn}${pageBtns}${nextBtn}`;
      };

      const renderInfo = () => {
        if (!infoEl) return;
        const start = (state.page - 1) * ITEMS_PER_PAGE + 1;
        const end = Math.min(state.page * ITEMS_PER_PAGE, totalItems);
        infoEl.textContent = `Showing ${start} – ${end} of ${totalItems} articles`;
      };

      const renderPage = (pageNum) => {
        const next = Math.max(1, Math.min(totalPages, pageNum));
        state.page = next;

        const startIdx = (state.page - 1) * ITEMS_PER_PAGE;
        const pageItems = items.slice(startIdx, startIdx + ITEMS_PER_PAGE);

        gridEl.innerHTML = pageItems.map(renderCard).join('');
        renderInfo();
        renderControls();
        gridEl.setAttribute('aria-busy', 'false');
      };

      if (controlsEl) {
        controlsEl.addEventListener('click', (e) => {
          const navBtn = e.target.closest('button[data-nav]');
          if (navBtn) {
            if (navBtn.dataset.nav === 'prev') renderPage(state.page - 1);
            if (navBtn.dataset.nav === 'next') renderPage(state.page + 1);
            window.scrollTo({ top: section.offsetTop - 80, behavior: 'smooth' });
            return;
          }

          const pageBtn = e.target.closest('button[data-page]');
          if (!pageBtn) return;
          renderPage(Number(pageBtn.dataset.page));
          window.scrollTo({ top: section.offsetTop - 80, behavior: 'smooth' });
        });
      }

      // Lazy hydrate: render halaman 1 hanya ketika section terlihat
      onVisible(section, () => {
        if (state.hydrated) return;
        state.hydrated = true;
        renderPage(1);
        window.addEventListener('resize', () => {
          if (!state.hydrated) return;
          renderControls();
        });
      });
    });
  })();
</script>


{% schema %}
{
  "name": "News Section",
  "settings": [
    {
      "type": "radio",
      "label": "View Type",
      "id": "view_type",
      "default": "top",
      "options": [
        { "value": "top", "label": "Top 3" },
        { "value": "all", "label": "All" }
      ]
    }
  ],
  "presets": [
    {
      "name": "News Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
