<section class="max-w-[1920px] mx-auto">
  <div class="pt-8 px-[24px] md:px-[10%] flex gap-[5px] md:gap-4 items-center justify-start">

    <a href="/pages/product-category?q=esim"
      class="category-nav-btn bg-primary text-neutral flex items-center justify-center gap-2
             rounded-[15px] h-[52px] w-[120px] md:w-auto md:px-5 px-4">
      {% render 'icon-qr-code', class: 'text-neutral w-[26px] h-[26px] md:h-[40px] md:w-[40px] flex-shrink-0' %}
      <span class="font-bold text-[14px] md:text-[16px] leading-tight text-center">eSIM</span>
    </a>

    <a href="/pages/product-category?q=sim-card"
      class="category-nav-btn bg-primary text-neutral flex items-center justify-center gap-2
             rounded-[15px] h-[52px] w-[120px] md:w-auto md:px-5 px-4">
      {% render 'icon-simcard', class: 'text-neutral w-[26px] h-[26px] md:h-[40px] md:w-[40px] flex-shrink-0' %}
      <span class="font-bold text-[14px] md:text-[16px] leading-tight text-center">SIM<br>Card</span>
    </a>

    <a href="/pages/product-category?q=insurance"
      class="category-nav-btn bg-primary text-neutral flex items-center justify-center gap-2
             rounded-[15px] h-[52px] w-[120px] md:w-auto md:px-5 px-4">
      {% render 'icon-insurance', class: 'text-neutral w-[26px] h-[26px] md:h-[40px] md:w-[40px] flex-shrink-0' %}
      <span class="font-bold text-[14px] md:text-[16px] leading-tight text-center">Insurance</span>
    </a>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('a.category-nav-btn').forEach((a) => {
      a.addEventListener('click', (e) => {
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.dataset.loading === '1') return;

        a.dataset.loading = '1';
        a.style.opacity = '0.6';
        a.style.pointerEvents = 'none';

        window.addEventListener('pageshow', () => {
          a.dataset.loading = '0';
          a.style.opacity = '';
          a.style.pointerEvents = '';
        }, { once: true });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Category Button",
  "settings": [],
  "presets": [
    {
      "name": "Product Category Button",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}