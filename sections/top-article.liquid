<section class="wrapper md:wrapper-base space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-primary text-[33px] font-bold">Blog Posts</h1>
        <a href="/pages/news" aria-label="See more news articles" class="rounded-full border border-primary px-[24px] py-2 text-primary font-semibold text-[15px] hover:bg-primary hover:text-neutral transition whitespace-nowrap">
            See More
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[15px] items-start">
        {% for block in section.blocks %}
            {% assign pages = block.settings.page %}

            {% if pages != blank %}
                {% assign first_img = '' %}
                {% assign parts = pages.content | split: 'src="' %}
                {% if parts.size > 1 %}
                    {% assign first_img = parts[1] | split: '"' | first %}
                {% endif %}

                <a href="{{ pages.url }}" class="rounded-[15px] bg-neutral overflow-hidden shadow-md hover:shadow-lg transition-all hover:-translate-y-[5px] flex flex-col">
                    <!-- 2/3 aspect ratio, capped at 280px height -->
                    <div class="w-full flex-shrink-0" style="aspect-ratio: 2/3; max-height: 150px; height: min(calc(100vw / 3 * 3 / 2), 280px); overflow: hidden;">
                        <img
                            class="w-full h-full object-cover bg-slate-300"
                            {% if first_img != blank %}src="{{ first_img }}"{% endif %}
                            alt="{{ pages.title | escape }}"
                            loading="lazy"
                            width="auto"
                            height="auto"
                        >
                    </div>

                    <!-- Card content -->
                    <div class="p-[15px] flex flex-col gap-2 flex-1">
                        <h2 class="text-primary text-[18px] line-clamp-2 font-semibold leading-tight">
                            {{ pages.title }}
                        </h2>
                        <p class="line-clamp-3 text-primary text-[14px] leading-snug flex-1">
                            {{ pages.content | strip_html | truncate: 160 }}
                        </p>
                        <span class="flex items-center gap-1 text-primary text-[14px] font-semibold mt-2">
                            Read article
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </span>
                    </div>
                </a>
            {% endif %}

        {% endfor %}
    </div>
</section>

{% schema %}
{
  "name": "Top Article",
  "settings": [],
  "blocks": [
    {
      "type": "post",
      "name": "Post Card",
      "settings": [
        {
          "type": "page",
          "id": "page",
          "label": "Select Page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Article",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}