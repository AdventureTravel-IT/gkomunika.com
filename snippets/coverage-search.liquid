<div class="search-container flex flex-col items-center w-full">
  <form action="{{ routes.search_url }}" method="get" class="search-form flex flex-col items-center w-full" onsubmit="return false;">
    <div class="search-box relative w-full h-[60px]">
      <input
        class="search-fields w-full placeholder:text-primary placeholder:focus:text-primary/60 h-full px-[10px] text-[16px] border border-primary rounded-[15px] outline-none text-primary"
        id="search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        oninput="filterCountries()"
        placeholder="{{ 'general.search.search' | t }}"
        aria-label="Search"
      >
    </div>
  </form>

  <div
    id="search-empty"
    class="search-empty w-full mt-2 p-[10px] border border-dashed border-primary rounded-[8px] text-primary"
    style="display:none;"
    role="status"
    aria-live="polite"
  >
    country not found
  </div>
</div>

<script>
const searchInput = document.getElementById('search-input');
const emptyMsg = document.getElementById('search-empty');

function matches(haystack, needle) {
  if (!needle) return true;
  haystack = (haystack || '').toLowerCase();
  needle = (needle || '').toLowerCase();
  return haystack.includes(needle);
}

function filterCountries() {
  const input = (searchInput.value || '').trim().toLowerCase();
  const items = document.querySelectorAll('#coverage-container .coverage-item');
  let found = 0;

  items.forEach(item => {
    const byAttr = (item.getAttribute('data-country') || '').toLowerCase();
    const byRaw  = (item.getAttribute('data-country-raw') || '').toLowerCase();
    const byText = (item.textContent || '').toLowerCase();
    const hay = `${byAttr} ${byRaw} ${byText}`.replace(/_/g, ' ');

    const show = matches(hay, input);
    item.style.display = show ? '' : 'none';
    if (show) found++;
  });

  if (input && found === 0) emptyMsg.style.display = 'block';
  else emptyMsg.style.display = 'none';
}

window.filterCountries = filterCountries;
</script>

<style>
  input[type="search"]::-webkit-search-cancel-button { display: none; }
</style>
