{%- comment -%}
  Coverage (Metaobject-based)
  - Source: product.metafields.search.key.value
  - Display name (single):
      * if language is id => country_id
      * else => country (country_en)
  - If name contains "_" => replace with space
  - Text size: 20px (text-xl)
  - Keep design same as previous (li: img + h3)
{%- endcomment -%}

{%- assign lang_code = localization.language.iso_code | downcase -%}
{%- assign is_id = false -%}
{%- if lang_code contains 'id' -%}{%- assign is_id = true -%}{%- endif -%}

<div id="coverage-container" class="flex flex-col gap-[5px]">
  {%- comment -%} initial render handled by JS {%- endcomment -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const coverageContainer = document.getElementById('coverage-container');
    if (!coverageContainer) return;

    const isID = {{ is_id | json }};
    const norm = (s) => String(s || '').trim().toLowerCase();
    const pretty = (s) => String(s || '').replace(/_/g, ' ').trim();

    // ✅ MASTER LIST — paginate by 250 agar semua entry terbaca (fix limit 50)
    const masterCoverage = [
      {%- paginate product.metafields.search.key.value by 250 -%}
        {%- for country in product.metafields.search.key.value -%}
          {
            country_en: {{ country.country.value | json }},
            country_id: {{ country.country_id.value | json }},
            country_alias: [
              {%- for alias in country.alias.value -%}
                {{ alias | json }}{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            ],
            flag: {% if country.flag.value %}{{ country.flag.value | image_url | json }}{% else %}null{% endif %}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      {%- endpaginate -%}
    ];

    // Build lookup index by EN/ID/alias
    const index = new Map();
    masterCoverage.forEach(obj => {
      const en = norm(obj.country_en);
      const id = norm(obj.country_id);
      if (en) index.set(en, obj);
      if (id) index.set(id, obj);

      (obj.country_alias || []).forEach(a => {
        const k = norm(a);
        if (k) index.set(k, obj);
      });
    });

    // Fallback flag if metaobject flag is empty
    function fallbackFlag(displayName) {
      const file = String(displayName || '').trim().replace(/\s+/g, '_');
      return `//gkomunika.com/cdn/shop/files/${file}.svg`;
    }

    // Normalize list coming from variant metafield:
    // - if it's object => use it
    // - if it's string => map to metaobject by index
    function normalizeCoverageList(list) {
      if (!Array.isArray(list)) return [];

      const out = [];
      list.forEach(item => {
        if (item && typeof item === 'object' && (item.country_en || item.country_id)) {
          out.push({
            country_en: item.country_en || '',
            country_id: item.country_id || '',
            country_alias: Array.isArray(item.country_alias) ? item.country_alias : [],
            flag: item.flag || null
          });
          return;
        }

        const mapped = index.get(norm(item));
        if (mapped) out.push(mapped);
      });

      // dedupe by displayed name (after pretty)
      const seen = new Set();
      return out.filter(o => {
        const raw = isID ? (o.country_id || '') : (o.country_en || '');
        const key = norm(pretty(raw));
        if (!key || seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function renderCoverage(list) {
      const countries = normalizeCoverageList(list);

      coverageContainer.innerHTML = '';

      countries.forEach(c => {
        const rawName = isID ? c.country_id : c.country_en;
        const displayName = pretty(rawName);
        if (!displayName) return;

        const imgUrl = c.flag || fallbackFlag(displayName);

        const aliases = Array.isArray(c.country_alias) ? c.country_alias.join(' ') : '';
        const searchable = `${displayName} ${aliases}`.trim().toLowerCase().replace(/_/g, ' ');

        const el = document.createElement('div');
        el.className = 'coverage-item pointer-events-none select-none cursor-default';
        el.setAttribute('data-country', searchable);
        el.setAttribute('data-country-raw', String(displayName || '').toLowerCase());

        el.innerHTML = `
          <li class="flex items-center gap-[10px] pointer-events-none select-none cursor-default">
            <img
              class="image-countries rounded-[15px] border border-border pointer-events-none"
              src="${imgUrl}"
              alt="${displayName}"
              width="50"
              height="50"
              loading="lazy"
              draggable="false"
            />
            <h3 class="text-left leading-tight text-lg text-primary m-0">${displayName}</h3>
          </li>
        `;

        coverageContainer.appendChild(el);
      });

      if (typeof window.filterCountries === 'function') window.filterCountries();
    }

    // === Variant switching (works for your Tailwind selects option0..)
    const variantDropdowns =
      document.querySelectorAll('.variant-dropdown, select[id^="option"]');

    const variantsData = [
      {% for variant in product.variants %}
        {
          id: {{ variant.id }},
          options: [{% for option in variant.options %}{{ option | escape | json }}{% unless forloop.last %}, {% endunless %}{% endfor %}],
          coverage: {{ variant.metafields.variant.coverage.value | default: "[]" | json }}
        }{% unless forloop.last %}, {% endunless %}
      {% endfor %}
    ];

    // default product coverage: show all from masterCoverage
    const productCoverage = masterCoverage;

    function getSelectedOptions() {
      const selects = Array.from(document.querySelectorAll('select[id^="option"]'));
      if (selects.length) return selects.map(s => s.value);
      return Array.from(document.querySelectorAll('.variant-dropdown')).map(s => s.value);
    }

    function updateCoverageByVariant() {
      const selectedOptions = getSelectedOptions();

      const matchedVariant = variantsData.find(v =>
        v.options.every((opt, idx) => opt === selectedOptions[idx])
      );

      if (matchedVariant && Array.isArray(matchedVariant.coverage) && matchedVariant.coverage.length) {
        renderCoverage(matchedVariant.coverage);
      } else {
        renderCoverage(productCoverage);
      }
    }

    variantDropdowns.forEach(el => el.addEventListener('change', updateCoverageByVariant));
    updateCoverageByVariant();
  });
</script>