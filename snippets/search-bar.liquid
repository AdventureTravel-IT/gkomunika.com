<section class="relative flex items-center" data-country-autocomplete>
  <input
    class="w-full rounded-[15px] py-[15px] pl-[15px] pr-[70px] text-primary placeholder:text-primary outline-none"
    data-country-input
    type="search"
    name="q"
    value="{{ search.terms | escape }}"
    placeholder="Search Your Destination"
    autocomplete="off"
  >

  <div
    data-country-suggestions
    class="max-h-[250px] overflow-auto bg-white rounded-[15px] p-[10px] shadow-lg"
    style="display:none;"
  >
    <ul data-country-list class="flex flex-col gap-1"></ul>
  </div>

  <button
    type="submit"
    class="absolute right-[5px] bg-primary rounded-[15px] p-[10px]"
    aria-label="{{ 'general.search.search' | t }}"
  >
    <span>{{- 'material-search.svg' | inline_asset_content -}}</span>
  </button>
</section>

<script>
  (() => {
    const ENDPOINT = '/collections/all?view=country-api-json';

    const normalize = (str = '') => String(str).toLowerCase().trim().replace(/_/g, ' ').replace(/\s+/g, ' ');

    const toImgSrc = (url) => {
      if (!url) return null;
      return url.startsWith('//') ? 'https:' + url : url;
    };

    const escapeHtml = (s) =>
      String(s)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    async function init(root) {
      const input = root.querySelector('[data-country-input]');
      const box = root.querySelector('[data-country-suggestions]');
      const list = root.querySelector('[data-country-list]');
      if (!input || !box || !list) return;

      // ✅ PINDAHKAN dropdown ke <body> biar gak ketutup overflow:hidden
      document.body.appendChild(box);
      box.style.position = 'fixed';
      box.style.zIndex = '999999';
      box.style.display = 'none';

      const updatePos = () => {
        const rect = input.getBoundingClientRect();
        box.style.left = rect.left + 'px';
        box.style.top = rect.bottom + 8 + 'px';
        box.style.width = rect.width + 'px';
      };

      const showBox = () => {
        updatePos();
        box.style.display = 'block';
      };

      const hideBox = () => {
        box.style.display = 'none';
        list.innerHTML = '';
      };

      // --- Fetch JSON ---
      let countries = [];
      try {
        const res = await fetch(ENDPOINT);
        const raw = await res.text();
        if (!raw.trim().startsWith('{')) {
          console.error('[autocomplete] endpoint bukan JSON:', raw.slice(0, 150));
          return;
        }
        const data = JSON.parse(raw);
        countries = Array.isArray(data.search_keys) ? data.search_keys : [];
      } catch (e) {
        console.error('[autocomplete] fetch gagal:', e);
        return;
      }

      const index = countries.map((c) => {
        const countryEn = (c.country_en || '').trim();
        const aliases = Array.isArray(c.country_alias) ? c.country_alias : [];
        const tokens = [countryEn, ...aliases].map((x) => normalize((x || '').trim())).filter(Boolean);

        return {
          id: c.id,
          country_en: countryEn,
          country_flag: toImgSrc(c.country_flag),
          tokens: Array.from(new Set(tokens)),
        };
      });

      console.log('[autocomplete] READY ✅', index.length, 'countries');

      const searchCountries = (q) => {
        const nq = normalize(q);
        if (nq.length < 2) return [];

        const MAX = 10;
        return index
          .map((it) => {
            let score = 999;
            for (const t of it.tokens) {
              if (t === nq) score = Math.min(score, 0);
              else if (t.startsWith(nq)) score = Math.min(score, 1);
              else if (t.includes(nq)) score = Math.min(score, 2);
            }
            return { it, score };
          })
          .filter((x) => x.score !== 999)
          .sort((a, b) => a.score - b.score || a.it.country_en.localeCompare(b.it.country_en))
          .slice(0, MAX)
          .map((x) => x.it);
      };

      // detect locale dari path: /id, /en, dll
      const currentLocale = (window.location.pathname.split('/')[1] || '').toLowerCase();
      const isID = currentLocale === 'id';

      // buat label country sesuai locale + rapihin "_" jadi spasi
      const getCountryLabel = (r) => {
        const raw = isID ? r.country_id || r.country_en || '' : r.country_en || '';
        return String(raw).trim().replace(/_/g, ' ');
      };

      const renderResults = (results) => {
        if (!results.length) return hideBox();

        list.innerHTML = results
          .map((r) => {
            const label = getCountryLabel(r);

            const flag = r.country_flag
              ? `<img src="${escapeHtml(r.country_flag)}"
        class="w-[40px] h-[40px] shrink-0 border border-slate-300 rounded-[10px] object-cover"
        alt="${escapeHtml(label)}">`
              : `<span
        class="w-[40px] h-[40px] shrink-0 border border-slate-300 rounded-[10px] bg-slate-400 inline-block"
      ></span>`;

            return `
    <li>
      <button type="button"
        class="w-full flex items-center gap-3 px-3 py-2 rounded-[12px] hover:bg-black/5 text-left"
        data-query="${escapeHtml(label)}">
        ${flag}
        <span class="text-primary text-[16px]">${escapeHtml(label)}</span>
      </button>
    </li>
  `;
          })
          .join('');

        showBox();
      };

      let timer = null;
      input.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(() => {
          renderResults(searchCountries(input.value));
        }, 120);
      });

      list.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-query]');
        if (!btn) return;

        const q = btn.dataset.query || '';
        input.value = q;
        hideBox();

        // redirect ke search
        window.location.href = `/search?q=${encodeURIComponent(q)}`;
      });

      document.addEventListener('click', (e) => {
        if (e.target.closest('[data-country-suggestions]') || e.target.closest('[data-country-input]')) return;
        hideBox();
      });

      window.addEventListener(
        'scroll',
        () => {
          if (box.style.display === 'block') updatePos();
        },
        true
      );

      window.addEventListener('resize', () => {
        if (box.style.display === 'block') updatePos();
      });
    }

    function boot() {
      document.querySelectorAll('[data-country-autocomplete]').forEach(init);
    }

    // ✅ Jalan walaupun DOMContentLoaded sudah lewat
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    // ✅ Support Shopify section reload
    document.addEventListener('shopify:section:load', boot);
  })();
</script>
