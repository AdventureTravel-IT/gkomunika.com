{%- layout none -%}

{
  "product": {
    "id": {{ product.id | json }},
    "handle": {{ product.handle | json }},
    "title": {{ product.title | json }},

    "description_html": {{ product.description | json }},
    "description_text": {{ product.description | strip_html | strip_newlines | json }},

    "vendor": {{ product.vendor | json }},
    "product_type": {{ product.type | json }},
    "tags": {{ product.tags | json }},

    "images": [
      {%- for img in product.images -%}
        {%- unless forloop.first -%},{%- endunless -%}
        {
          "id": {{ img.id | json }},
          "src": {
            "small": {{ img | image_url: width: 400 | json }},
            "medium": {{ img | image_url: width: 800 | json }},
            "large": {{ img | image_url: width: 1200 | json }}
          },
          "alt": {{ img.alt | default: "" | json }},
          "width": {{ img.width | json }},
          "height": {{ img.height | json }}
        }
      {%- endfor -%}
    ],

    "options": [
      {%- for opt in product.options -%}
        {%- unless forloop.first -%},{%- endunless -%}
        {
          "name": {{ opt | json }},
          "values": {{ product.options_by_name[opt].values | json }}
        }
      {%- endfor -%}
    ],

    "variants": [
      {% for v in product.variants %}
      {
        "id": {{ v.id | json }},
        "title": {{ v.title | json }},
        "available": {{ v.available | json }},
        "selected_options": [
          {% for opt in product.options_with_values %}
          { "name": {{ opt.name | json }}, "value": {{ v.options[forloop.index0] | json }} }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],

        "price_cents": {{ v.price | json }},
        "price_money_with_currency": {{ v.price | money_with_currency | json }},


        "price_money_with_currency": {{ v.price | money_with_currency | json }},

        "total_money_with_currency_by_qty": {
          {% for q in (1..20) %}
          "{{ q }}": {{ v.price | times: q | money_with_currency | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        }
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
}
